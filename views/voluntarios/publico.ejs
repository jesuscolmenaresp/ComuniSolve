<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="text-center mb-5">
    <div class="mx-auto d-flex align-items-center justify-content-center mb-3">
      <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
        <i class="bi bi-people-fill fs-1 text-white"></i>
      </div>
    </div>
    <h2 class="fw-bold" style="color: #fd6704bd;">Voluntarios de la Comunidad</h2>
    <p class="text-muted" style="color: #8B6B5A;">Conoce a los voluntarios que ayudan a transformar la comuna</p>
  </div>

  <!-- Mensajes flash -->
  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4 text-center" style="max-width: 600px; margin: 0 auto 20px auto;">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <!-- Lista de voluntarios -->
  <div class="row g-4">
    <% if (voluntarios && voluntarios.length > 0) { %>
      <% voluntarios.forEach(v => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card border-0 rounded-4 shadow-sm h-100 overflow-hidden">
            <div class="text-center pt-4 pb-2" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
              <div style="width: 70px; height: 70px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 35px; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                <i class="bi bi-person-fill fs-1 text-white"></i>
              </div>
            </div>
            <div class="card-body p-4">
              <h5 class="card-title fw-bold text-center mb-3" style="color: #5D4037;"><%= v.nombre %></h5>
              <div class="list-group list-group-flush">
                <div class="list-group-item px-0 d-flex align-items-center gap-3" style="background: transparent;">
                  <i class="bi bi-tools fs-5" style="color: #fd6704bd; width: 30px;"></i>
                  <div>
                    <small class="text-muted d-block">Habilidad</small>
                    <span class="fw-semibold" style="color: #5D4037;"><%= v.habilidad %></span>
                  </div>
                </div>
                <% if (v.telefono) { %>
                  <div class="list-group-item px-0 d-flex align-items-center gap-3" style="background: transparent;">
                    <i class="bi bi-telephone fs-5" style="color: #fd6704bd; width: 30px;"></i>
                    <div>
                      <small class="text-muted d-block">Contacto</small>
                      <span class="fw-semibold" style="color: #5D4037;"><%= v.telefono %></span>
                    </div>
                  </div>
                <% } %>
                <% if (v.calle_nombre) { %>
                  <div class="list-group-item px-0 d-flex align-items-center gap-3" style="background: transparent;">
                    <i class="bi bi-geo-alt fs-5" style="color: #fd6704bd; width: 30px;"></i>
                    <div>
                      <small class="text-muted d-block">Calle</small>
                      <span class="fw-semibold" style="color: #5D4037;"><%= v.calle_nombre %></span>
                    </div>
                  </div>
                <% } %>
                <% if (v.disponibilidad_horaria) { %>
                  <div class="list-group-item px-0 d-flex align-items-center gap-3" style="background: transparent;">
                    <i class="bi bi-clock fs-5" style="color: #fd6704bd; width: 30px;"></i>
                    <div>
                      <small class="text-muted d-block">Disponibilidad</small>
                      <span class="fw-semibold" style="color: #5D4037;"><%= v.disponibilidad_horaria %></span>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
          <div class="text-center py-5" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
            <i class="bi bi-people-fill fs-1 text-muted d-block mb-3" style="color: #fd6704bd;"></i>
            <h5 class="text-muted mb-3">No hay voluntarios registrados aún</h5>
            <% if (!usuario) { %>
              <a href="/login" class="btn px-4 py-2 fw-semibold rounded-3"
                 style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar sesión
              </a>
            <% } else if (usuario.rol_id === 4) { %>
              <a href="/voluntarios" class="btn px-4 py-2 fw-semibold rounded-3"
                 style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                <i class="bi bi-person-plus me-2"></i> ¡Únete como voluntario!
              </a>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-5">
    <small class="text-muted" style="color: #8B6B5A;">
      <i class="bi bi-heart-fill me-1" style="color: #fd6704bd;"></i> 
      Ser voluntario es una forma de transformar tu comunidad
    </small>
  </div>
</div>
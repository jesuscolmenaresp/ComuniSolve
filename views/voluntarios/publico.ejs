<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="text-center mb-5">
    <div class="mx-auto d-flex align-items-center justify-content-center mb-3">
      <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
        <i class="bi bi-people-fill fs-1 text-white"></i>
      </div>
    </div>
    <h2 class="fw-bold" style="color: #fd6704bd;">Voluntarios de la Comunidad</h2>
    <p class="text-muted" style="color: #8B6B5A;">Conoce a los voluntarios que ayudan a transformar la comuna</p>
  </div>

  <!-- Mensajes flash -->
  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4 text-center" style="max-width: 600px; margin: 0 auto 20px auto;">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <!-- Lista de voluntarios -->
  <div class="row g-4">
    <% if (voluntarios && voluntarios.length > 0) { %>
      <% voluntarios.forEach(v => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card border-0 rounded-4 shadow-sm h-100 overflow-hidden voluntario-card">
            <div class="text-center pt-4 pb-2 voluntario-card-header">
              <div class="voluntario-avatar">
                <i class="bi bi-person-fill fs-1 text-white"></i>
              </div>
            </div>
            <div class="card-body p-4 voluntario-card-body">
              <h5 class="card-title fw-bold text-center mb-3 voluntario-nombre"><%= v.nombre %></h5>
              <div class="list-group list-group-flush">
                <div class="list-group-item px-0 d-flex align-items-center gap-3 voluntario-item">
                  <i class="bi bi-tools fs-5 voluntario-icon-habilidad"></i>
                  <div>
                    <small class="text-muted d-block voluntario-label">Habilidad</small>
                    <span class="fw-semibold voluntario-valor"><%= v.habilidad %></span>
                  </div>
                </div>
                <% if (v.telefono) { %>
                  <div class="list-group-item px-0 d-flex align-items-center gap-3 voluntario-item">
                    <i class="bi bi-telephone fs-5 voluntario-icon-telefono"></i>
                    <div>
                      <small class="text-muted d-block voluntario-label">Contacto</small>
                      <span class="fw-semibold voluntario-valor"><%= v.telefono %></span>
                    </div>
                  </div>
                <% } %>
                <% if (v.calle_nombre) { %>
                  <div class="list-group-item px-0 d-flex align-items-center gap-3 voluntario-item">
                    <i class="bi bi-geo-alt fs-5 voluntario-icon-calle"></i>
                    <div>
                      <small class="text-muted d-block voluntario-label">Calle</small>
                      <span class="fw-semibold voluntario-valor"><%= v.calle_nombre %></span>
                    </div>
                  </div>
                <% } %>
                <% if (v.disponibilidad_horaria) { %>
                  <div class="list-group-item px-0 d-flex align-items-center gap-3 voluntario-item">
                    <i class="bi bi-clock fs-5 voluntario-icon-disponibilidad"></i>
                    <div>
                      <small class="text-muted d-block voluntario-label">Disponibilidad</small>
                      <span class="fw-semibold voluntario-valor"><%= v.disponibilidad_horaria %></span>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden voluntario-empty">
          <div class="text-center py-5 voluntario-empty-header">
            <i class="bi bi-people-fill fs-1 text-muted d-block mb-3 voluntario-empty-icon"></i>
            <h5 class="text-muted mb-3 voluntario-empty-title">No hay voluntarios registrados aún</h5>
            <% if (!usuario) { %>
              <a href="/login" class="btn px-4 py-2 fw-semibold rounded-3 btn-voluntario-login">
                <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar sesión
              </a>
            <% } else if (usuario.rol_id === 4) { %>
              <a href="/voluntarios" class="btn px-4 py-2 fw-semibold rounded-3 btn-voluntario-unirse">
                <i class="bi bi-person-plus me-2"></i> ¡Únete como voluntario!
              </a>
            <% } %>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-5">
    <small class="text-muted voluntario-footer">
      <i class="bi bi-heart-fill me-1 voluntario-footer-icon"></i> 
      Ser voluntario es una forma de transformar tu comunidad
    </small>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta de voluntario */
  .voluntario-card {
    background: white;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .voluntario-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.1);
  }
  
  .voluntario-card-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .voluntario-avatar {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border-radius: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }
  
  .voluntario-card-body {
    background: white;
  }
  
  .voluntario-nombre {
    color: #5D4037;
  }
  
  .voluntario-item {
    background: transparent;
    border-bottom: 1px solid #f0d5c0;
  }
  
  /* Iconos con colores diferenciados */
  .voluntario-icon-habilidad {
    color: #fd6704bd;
    width: 30px;
  }
  .voluntario-icon-telefono {
    color: #17a2b8;
    width: 30px;
  }
  .voluntario-icon-calle {
    color: #fd6704bd;
    width: 30px;
  }
  .voluntario-icon-disponibilidad {
    color: #17a2b8;
    width: 30px;
  }
  
  .voluntario-label {
    color: #8B6B5A;
  }
  
  .voluntario-valor {
    color: #5D4037;
  }
  
  /* Estado vacío */
  .voluntario-empty {
    background: white;
  }
  .voluntario-empty-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  .voluntario-empty-icon {
    color: #fd6704bd;
  }
  .voluntario-empty-title {
    color: #6c757d;
  }
  
  /* Botones */
  .btn-voluntario-login {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-voluntario-login:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  .btn-voluntario-unirse {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-voluntario-unirse:hover {
    transform: translateY(-2px);
  }
  
  /* Footer */
  .voluntario-footer {
    color: #8B6B5A;
  }
  .voluntario-footer-icon {
    color: #fd6704bd;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .voluntario-card {
    background: #27272a;
  }
  
  body.dark-mode .voluntario-card-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  
  body.dark-mode .voluntario-card-body {
    background: #27272a;
  }
  
  body.dark-mode .voluntario-nombre {
    color: #e4e4e7;
  }
  
  body.dark-mode .voluntario-item {
    border-bottom-color: #3f3f46;
  }
  
  body.dark-mode .voluntario-icon-habilidad,
  body.dark-mode .voluntario-icon-calle {
    color: #f7931e;
  }
  
  body.dark-mode .voluntario-icon-telefono,
  body.dark-mode .voluntario-icon-disponibilidad {
    color: #138496;
  }
  
  body.dark-mode .voluntario-label {
    color: #a1a1aa;
  }
  
  body.dark-mode .voluntario-valor {
    color: #e4e4e7;
  }
  
  body.dark-mode .voluntario-empty {
    background: #1a1a2e;
  }
  
  body.dark-mode .voluntario-empty-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  
  body.dark-mode .voluntario-empty-icon {
    color: #f7931e;
    opacity: 0.7;
  }
  
  body.dark-mode .voluntario-empty-title {
    color: #a1a1aa;
  }
  
  body.dark-mode .voluntario-footer {
    color: #a1a1aa;
  }
  
  body.dark-mode .voluntario-footer-icon {
    color: #f7931e;
  }
  
  body.dark-mode .alert-success {
    background: #0d3b1f;
    color: #a3e4b7;
  }
  
  /* Transiciones */
  .btn, .card {
    transition: all 0.2s ease;
  }
</style>
<div class="container mt-4">
  <h2 class="mb-4">📋 Gestionar Solicitudes de Voluntarios</h2>

  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= session.mensaje %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <%= session.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <ul class="nav nav-tabs mb-3" id="tabSolicitudes">
    <li class="nav-item">
      <a class="nav-link active" data-bs-toggle="tab" href="#pendientes">Pendientes</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#aprobados">Aprobados</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#rechazados">Rechazados</a>
    </li>
  </ul>

  <div class="tab-content">
    <!-- Pendientes -->
    <div class="tab-pane active" id="pendientes">
      <div class="table-responsive">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Nombre</th>
              <th>Email</th>
              <th>Teléfono</th>
              <th>Habilidad</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% const pendientes = solicitudes.filter(s => s.estado === 'pendiente') %>
            <% if (pendientes.length > 0) { %>
              <% pendientes.forEach(s => { %>
                <tr>
                  <td><%= new Date(s.fecha_solicitud).toLocaleDateString() %></td>
                  <td><%= s.nombre %></td>
                  <td><%= s.email %></td>
                  <td><%= s.telefono || s.usuario_telefono || '—' %></td>
                  <td><%= s.habilidad %></td>
                  <td>
                    <form action="/voluntarios/<%= s.id %>/aprobar" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-success">✅ Aprobar</button>
                    </form>
                    <form action="/voluntarios/<%= s.id %>/rechazar" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-danger" 
                              onclick="return confirm('¿Rechazar este voluntario?')">❌ Rechazar</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center">No hay solicitudes pendientes</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Aprobados -->
    <div class="tab-pane" id="aprobados">
      <div class="table-responsive">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Nombre</th>
              <th>Email</th>
              <th>Teléfono</th>
              <th>Habilidad</th>
              <th>Aprobado por</th>
            </tr>
          </thead>
          <tbody>
            <% const aprobados = solicitudes.filter(s => s.estado === 'aprobado') %>
            <% if (aprobados.length > 0) { %>
              <% aprobados.forEach(s => { %>
                <tr>
                  <td><%= new Date(s.fecha_solicitud).toLocaleDateString() %></td>
                  <td><%= s.nombre %></td>
                  <td><%= s.email %></td>
                  <td><%= s.telefono || s.usuario_telefono || '—' %></td>
                  <td><%= s.habilidad %></td>
                  <td><span class="badge bg-success">Aprobado</span></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center">No hay voluntarios aprobados</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Rechazados -->
    <div class="tab-pane" id="rechazados">
      <div class="table-responsive">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Nombre</th>
              <th>Email</th>
              <th>Habilidad</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <% const rechazados = solicitudes.filter(s => s.estado === 'rechazado') %>
            <% if (rechazados.length > 0) { %>
              <% rechazados.forEach(s => { %>
                <tr>
                  <td><%= new Date(s.fecha_solicitud).toLocaleDateString() %></td>
                  <td><%= s.nombre %></td>
                  <td><%= s.email %></td>
                  <td><%= s.habilidad %></td>
                  <td><span class="badge bg-danger">Rechazado</span></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center">No hay solicitudes rechazadas</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <a href="/voluntarios" class="btn btn-primary">➕ Nueva solicitud</a>
  </div>
</div>
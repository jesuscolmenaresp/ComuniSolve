  body.dark-mode .btn-outline-secondary:hover {
    background: #3f3f46;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .card {
    transition: transform 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
  }
</style>
  }
  .solicitudes-body {
    background: white;
  }
  .solicitud-item {
    border-bottom-color: #f0d5c0;
  }
  .solicitud-titulo {
    color: #5D4037;
  }
  .solicitud-descripcion {
    color: #6c757d;
  }
  .solicitud-calle {
    color: #6c757d;
  }
  .solicitud-estado-pendiente {
    background: #ffc107;
    color: #333;
  }
  .btn-aceptar-solicitud {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-aceptar-solicitud:hover {
    transform: translateY(-2px);
  }
  .btn-rechazar-solicitud {
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-rechazar-solicitud:hover {
    transform: translateY(-2px);
  }
  .solicitud-empty i {
    color: #6c757d;
    opacity: 0.5;
  }
  .solicitud-empty p {
    color: #6c757d;
  }
  
  /* Ayudas card */
  .ayudas-card {
    background: white;
  }
  .ayudas-header {

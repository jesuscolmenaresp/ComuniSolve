    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  .miperfil-avatar {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border-radius: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);
  }
  .miperfil-nombre {
    color: #5D4037;
  }
  .miperfil-estado {
    background: #28a745;
    color: white;
  }
  .estado-pendiente {
    background: #ffc107;
    color: #333;
  }
  .estado-rechazado {
    background: #dc3545;
    color: white;
  }
  .miperfil-card-body {
    background: white;
  }
  .miperfil-list-item {
    background: transparent;

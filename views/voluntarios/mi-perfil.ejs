<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">👤 Mi Perfil de Voluntario</h5>
                </div>
                <div class="card-body">
                    <% if (voluntario) { %>
                        <p><strong>Nombre:</strong> <%= voluntario.nombre %></p>
                        <p><strong>Teléfono:</strong> <%= voluntario.telefono || 'No especificado' %></p>
                        <p><strong>Habilidad:</strong> <%= voluntario.habilidad %></p>
                        <p><strong>Experiencia:</strong> <%= voluntario.experiencia || 'No especificada' %></p>
                        <p><strong>Disponibilidad:</strong> <%= voluntario.disponibilidad_horaria || 'No especificada' %></p>
                        <p><strong>Estado:</strong> 
                            <span class="badge <%= voluntario.estado === 'aprobado' ? 'bg-success' : voluntario.estado === 'pendiente' ? 'bg-warning' : 'bg-danger' %>">
                                <%= voluntario.estado === 'aprobado' ? 'Aprobado' : voluntario.estado === 'pendiente' ? 'Pendiente' : 'Rechazado' %>
                            </span>
                        </p>
                        <a href="/voluntarios/editar" class="btn btn-sm btn-warning mt-2">✏️ Editar perfil</a>
                    <% } else { %>
                        <p>No eres voluntario. <a href="/voluntarios">¡Postúlate ahora!</a></p>
                    <% } %>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <!-- Solicitudes pendientes -->
            <div class="card shadow mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">📋 Solicitudes de ayuda pendientes</h5>
                </div>
                <div class="card-body">
                    <% if (asignaciones && asignaciones.length > 0) { %>
                        <% asignaciones.forEach(a => { %>
                            <div class="border-bottom pb-3 mb-3">
                                <h6><%= a.titulo %></h6>
                                <p class="text-muted small"><%= a.descripcion.substring(0, 100) %>...</p>
                                <p><strong>📍 Calle:</strong> <%= a.calle %></p>
                                <div class="d-flex gap-2">
                                    <form action="/voluntarios/asignacion/<%= a.id %>/responder" method="POST">
                                        <input type="hidden" name="accion" value="aceptado">
                                        <button type="submit" class="btn btn-sm btn-success">✅ Aceptar</button>
                                    </form>
                                    <form action="/voluntarios/asignacion/<%= a.id %>/responder" method="POST">
                                        <input type="hidden" name="accion" value="rechazado">
                                        <button type="submit" class="btn btn-sm btn-danger">❌ Rechazar</button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-muted">No tienes solicitudes de ayuda pendientes.</p>
                    <% } %>
                </div>
            </div>

            <!-- Solicitudes aceptadas (en las que está ayudando) -->
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">✅ Reportes en los que estás ayudando</h5>
                </div>
                <div class="card-body">
                    <% if (asignacionesAceptadas && asignacionesAceptadas.length > 0) { %>
                        <% asignacionesAceptadas.forEach(a => { %>
                            <div class="border-bottom pb-3 mb-3">
                                <h6><%= a.titulo %></h6>
                                <p class="text-muted small"><%= a.descripcion.substring(0, 100) %>...</p>
                                <p><strong>📍 Calle:</strong> <%= a.calle %></p>
                                <p><strong>📌 Estado del reporte:</strong> 
                                    <span class="badge <%= a.reporte_estado === 'Pendiente' ? 'bg-warning' : a.reporte_estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>">
                                        <%= a.reporte_estado %>
                                    </span>
                                </p>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-muted">No estás ayudando en ningún reporte actualmente.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold miperfil-title"><i class="bi bi-person-badge me-2"></i> Mi Perfil de Voluntario</h2>
      <p class="text-muted mb-0 miperfil-subtitle">
        <i class="bi bi-info-circle me-1"></i> Gestiona tu información y revisa las solicitudes de ayuda
      </p>
    </div>
    <% if (voluntario) { %>
      <a href="/voluntarios/editar" class="btn px-4 py-2 fw-semibold rounded-3 btn-editar-miperfil">
        <i class="bi bi-pencil-square me-2"></i> Editar perfil
      </a>
    <% } else { %>
      <a href="/voluntarios" class="btn px-4 py-2 fw-semibold rounded-3 btn-postular-miperfil">
        <i class="bi bi-person-plus me-2"></i> Postularse como voluntario
      </a>
    <% } %>
  </div>

  <!-- Mensajes flash -->
  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <div class="row g-4">
    
    <!-- COLUMNA IZQUIERDA: Información del voluntario -->
    <div class="col-lg-4">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden miperfil-card">
        
        <!-- Header -->
        <div class="text-center py-4 miperfil-card-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="miperfil-avatar">
              <i class="bi bi-person-badge fs-1 text-white"></i>
            </div>
          </div>
          <% if (voluntario) { %>
            <h4 class="fw-bold mb-1 miperfil-nombre"><%= voluntario.nombre %></h4>
            <span class="badge px-3 py-2 rounded-pill miperfil-estado
                  <%= voluntario.estado === 'aprobado' ? 'estado-aprobado' : voluntario.estado === 'pendiente' ? 'estado-pendiente' : 'estado-rechazado' %>">
              <% if (voluntario.estado === 'aprobado') { %>
                <i class="bi bi-check-circle me-1"></i> Aprobado
              <% } else if (voluntario.estado === 'pendiente') { %>
                <i class="bi bi-clock-history me-1"></i> Pendiente
              <% } else { %>
                <i class="bi bi-x-circle me-1"></i> Rechazado
              <% } %>
            </span>
          <% } else { %>
            <h4 class="fw-bold mb-1 miperfil-nombre">No eres voluntario</h4>
          <% } %>
        </div>
        
        <div class="card-body p-4 miperfil-card-body">
          <% if (voluntario) { %>
            <div class="list-group list-group-flush">
              <div class="list-group-item px-0 d-flex align-items-center gap-3 miperfil-list-item">
                <i class="bi bi-telephone fs-5 miperfil-icon"></i>
                <div>
                  <small class="text-muted d-block miperfil-label">Teléfono</small>
                  <span class="fw-semibold miperfil-valor"><%= voluntario.telefono || 'No especificado' %></span>
                </div>
              </div>
              <div class="list-group-item px-0 d-flex align-items-center gap-3 miperfil-list-item">
                <i class="bi bi-tools fs-5 miperfil-icon"></i>
                <div>
                  <small class="text-muted d-block miperfil-label">Habilidad</small>
                  <span class="fw-semibold miperfil-valor"><%= voluntario.habilidad %></span>
                </div>
              </div>
              <div class="list-group-item px-0 d-flex align-items-center gap-3 miperfil-list-item">
                <i class="bi bi-journal-bookmark fs-5 miperfil-icon"></i>
                <div>
                  <small class="text-muted d-block miperfil-label">Experiencia</small>
                  <span class="fw-semibold miperfil-valor"><%= voluntario.experiencia || 'No especificada' %></span>
                </div>
              </div>
              <div class="list-group-item px-0 d-flex align-items-center gap-3 miperfil-list-item">
                <i class="bi bi-clock fs-5 miperfil-icon"></i>
                <div>
                  <small class="text-muted d-block miperfil-label">Disponibilidad</small>
                  <span class="fw-semibold miperfil-valor"><%= voluntario.disponibilidad_horaria || 'No especificada' %></span>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="text-center py-4">
              <i class="bi bi-person-x fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted mb-3">No eres voluntario aún</p>
              <a href="/voluntarios" class="btn px-4 py-2 fw-semibold rounded-3 btn-postular-miperfil">
                <i class="bi bi-person-plus me-2"></i> Postularse ahora
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
    
    <!-- COLUMNA DERECHA: Solicitudes -->
    <div class="col-lg-8">
      
      <!-- Solicitudes pendientes -->
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden mb-4 solicitudes-card">
        <div class="px-4 py-3 solicitudes-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-bell-fill me-2"></i> Solicitudes de ayuda pendientes</h5>
        </div>
        <div class="card-body p-0 solicitudes-body">
          <% if (asignaciones && asignaciones.length > 0) { %>
            <div class="list-group list-group-flush">
              <% asignaciones.forEach(a => { %>
                <div class="list-group-item px-4 py-3 solicitud-item" style="border-color: #f0d5c0;">
                  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                    <h6 class="mb-0 fw-semibold solicitud-titulo"><i class="bi bi-chat-square-text me-2"></i> <%= a.titulo %></h6>
                    <span class="badge px-3 py-1 rounded-pill solicitud-estado-pendiente">
                      <i class="bi bi-clock-history me-1"></i> Pendiente
                    </span>
                  </div>
                  <p class="text-muted small mb-2 solicitud-descripcion"><%= a.descripcion ? (a.descripcion.length > 100 ? a.descripcion.substring(0, 100) + '...' : a.descripcion) : 'Sin descripción' %></p>
                  <p class="mb-2 small solicitud-calle"><i class="bi bi-geo-alt me-1"></i> <strong>Calle:</strong> <%= a.calle %></p>
                  <div class="d-flex gap-2 mt-3">
                    <form action="/voluntarios/asignacion/<%= a.id %>/responder" method="POST" class="d-inline">
                      <input type="hidden" name="accion" value="aceptado">
                      <button type="submit" class="btn btn-sm px-3 py-1 fw-semibold rounded-3 btn-aceptar-solicitud" 
                              onclick="return confirm('¿Aceptar esta solicitud de ayuda?')">
                        <i class="bi bi-check-lg me-1"></i> Aceptar
                      </button>
                    </form>
                    <form action="/voluntarios/asignacion/<%= a.id %>/responder" method="POST" class="d-inline">
                      <input type="hidden" name="accion" value="rechazado">
                      <button type="submit" class="btn btn-sm px-3 py-1 fw-semibold rounded-3 btn-rechazar-solicitud" 
                              onclick="return confirm('¿Rechazar esta solicitud de ayuda?')">
                        <i class="bi bi-x-lg me-1"></i> Rechazar
                      </button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="text-center py-5 solicitud-empty">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
              <p class="text-muted mb-0">No tienes solicitudes de ayuda pendientes</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Reportes en los que está ayudando -->
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden ayudas-card">
        <div class="px-4 py-3 ayudas-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-heart-fill me-2"></i> Reportes en los que estás ayudando</h5>
        </div>
        <div class="card-body p-0 ayudas-body">
          <% if (asignacionesAceptadas && asignacionesAceptadas.length > 0) { %>
            <div class="list-group list-group-flush">
              <% asignacionesAceptadas.forEach(a => { %>
                <div class="list-group-item px-4 py-3 ayuda-item" style="border-color: #f0d5c0;">
                  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                    <h6 class="mb-0 fw-semibold ayuda-titulo"><i class="bi bi-chat-square-text me-2"></i> <%= a.titulo %></h6>
                    <span class="badge px-3 py-1 rounded-pill ayuda-estado
                          <%= a.reporte_estado === 'Pendiente' ? 'ayuda-estado-pendiente' : a.reporte_estado === 'En Progreso' ? 'ayuda-estado-progreso' : 'ayuda-estado-resuelto' %>">
                      <% if (a.reporte_estado === 'Pendiente') { %>
                        <i class="bi bi-clock-history me-1"></i> Pendiente
                      <% } else if (a.reporte_estado === 'En Progreso') { %>
                        <i class="bi bi-arrow-repeat me-1"></i> En Progreso
                      <% } else { %>
                        <i class="bi bi-check-circle me-1"></i> Resuelto
                      <% } %>
                    </span>
                  </div>
                  <p class="text-muted small mb-2 ayuda-descripcion"><%= a.descripcion ? (a.descripcion.length > 100 ? a.descripcion.substring(0, 100) + '...' : a.descripcion) : 'Sin descripción' %></p>
                  <p class="mb-0 small ayuda-calle"><i class="bi bi-geo-alt me-1"></i> <strong>Calle:</strong> <%= a.calle %></p>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="text-center py-5 ayuda-empty">
              <i class="bi bi-heart fs-1 text-muted d-block mb-2"></i>
              <p class="text-muted mb-0">No estás ayudando en ningún reporte actualmente</p>
              <a href="/voluntarios" class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-ver-oportunidades">Ver oportunidades</a>
            </div>
          <% } %>
        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .miperfil-title {
    color: #5D4037;
  }
  .miperfil-title i {
    color: #fd6704bd;
  }
  .miperfil-subtitle {
    color: #8B6B5A;
  }
  .miperfil-subtitle i {
    color: #fd6704bd;
  }
  
  /* Botones */
  .btn-editar-miperfil {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-editar-miperfil:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  .btn-postular-miperfil {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);

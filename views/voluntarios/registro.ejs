<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-person-badge fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;"><%= yaSolicito ? 'Editar Perfil' : 'Únete como Voluntario' %></h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">
            <% if (yaSolicito) { %>
              Actualiza tu información de voluntario
            <% } else { %>
              Completa el formulario para postularte
            <% } %>
          </p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Botón volver (arriba) -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/voluntarios/mi-perfil" class="btn btn-sm px-3 py-1 rounded-3"
               style="border: 1px solid #f0d5c0; color: #5D4037;">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de estado -->
          <% if (session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <% if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'aprobado') { %>
            <div class="alert alert-success border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-check-circle-fill me-2"></i>
              <small>✅ Ya eres voluntario aprobado. Puedes editar tu información.</small>
            </div>
          <% } else if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'pendiente') { %>
            <div class="alert alert-warning border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-clock-history me-2"></i>
              <small>⏳ Tu solicitud está pendiente de aprobación por un líder comunitario.</small>
            </div>
          <% } else if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'rechazado') { %>
            <div class="alert alert-danger border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-x-circle-fill me-2"></i>
              <small>❌ Tu solicitud fue rechazada. Puedes volver a postularte.</small>
            </div>
          <% } %>

          <!-- Formulario -->
          <form action="/voluntarios" method="POST">
            
            <!-- Nombre completo -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-person-fill me-1" style="color: #fd6704bd;"></i> Nombre completo *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3" 
                     value="<%= datosVoluntario ? datosVoluntario.nombre : usuario.nombre %>" 
                     placeholder="Ej: Juan Pérez" required
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
            </div>

            <!-- Teléfono -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-telephone-fill me-1" style="color: #fd6704bd;"></i> Teléfono de contacto *
              </label>
              <input type="text" name="telefono" class="form-control rounded-3" 
                     value="<%= datosVoluntario ? datosVoluntario.telefono : usuario.telefono %>" 
                     placeholder="0412-1234567" required
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              <small class="text-muted" style="color: #8B6B5A;">Número de contacto para coordinación de ayudas</small>
            </div>

            <!-- Habilidad -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-tools me-1" style="color: #fd6704bd;"></i> ¿Qué sabes hacer? *
              </label>
              <textarea name="habilidad" class="form-control rounded-3" rows="3" 
                        placeholder="Ej: fontanería, electricidad, enfermería, manejo de redes, construcción, etc." 
                        required
                        style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;"><%= datosVoluntario ? datosVoluntario.habilidad : '' %></textarea>
              <small class="text-muted" style="color: #8B6B5A;">Describe tus principales habilidades para ayudar a la comunidad</small>
            </div>

            <!-- Experiencia previa -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-journal-bookmark-fill me-1" style="color: #fd6704bd;"></i> Experiencia previa
              </label>
              <textarea name="experiencia" class="form-control rounded-3" rows="2" 
                        placeholder="Cuéntanos tu experiencia relacionada..."
                        style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;"><%= datosVoluntario ? datosVoluntario.experiencia : '' %></textarea>
              <small class="text-muted" style="color: #8B6B5A;">Opcional: experiencia previa como voluntario o en trabajos relacionados</small>
            </div>

            <!-- Disponibilidad horaria -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-clock-fill me-1" style="color: #fd6704bd;"></i> Disponibilidad horaria
              </label>
              <input type="text" name="disponibilidad_horaria" class="form-control rounded-3" 
                     value="<%= datosVoluntario ? datosVoluntario.disponibilidad_horaria : '' %>"
                     placeholder="Ej: Fines de semana, Lunes a Viernes de 2pm a 6pm, etc."
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              <small class="text-muted" style="color: #8B6B5A;">¿Cuándo puedes dedicar tiempo para ayudar?</small>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); 
                             border: none; color: white;">
                <i class="bi <%= yaSolicito ? 'bi-check-lg' : 'bi-send-fill' %> me-2"></i>
                <%= yaSolicito ? 'Actualizar perfil' : 'Enviar solicitud' %>
              </button>
              <a href="/voluntarios/mi-perfil" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                 style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>
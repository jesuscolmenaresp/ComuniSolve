<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden voluntario-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 voluntario-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="voluntario-icon-wrapper">
              <i class="bi bi-person-badge fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold voluntario-title"><%= yaSolicito ? 'Editar Perfil' : 'Únete como Voluntario' %></h3>
          <p class="small mb-0 mt-1 voluntario-subtitle">
            <% if (yaSolicito) { %>
              Actualiza tu información de voluntario
            <% } else { %>
              Completa el formulario para postularte
            <% } %>
          </p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 voluntario-body">
          
          <!-- Botón volver (arriba) -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/voluntarios/mi-perfil" class="btn btn-sm px-3 py-1 rounded-3 btn-volver-voluntario">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de estado -->
          <% if (session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4 alert-danger-voluntario" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <% if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'aprobado') { %>
            <div class="alert alert-success border-0 rounded-3 py-2 mb-4 alert-success-voluntario" role="alert">
              <i class="bi bi-check-circle-fill me-2"></i>
              <small>✅ Ya eres voluntario aprobado. Puedes editar tu información.</small>
            </div>
          <% } else if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'pendiente') { %>
            <div class="alert alert-warning border-0 rounded-3 py-2 mb-4 alert-warning-voluntario" role="alert">
              <i class="bi bi-clock-history me-2"></i>
              <small>⏳ Tu solicitud está pendiente de aprobación por un líder comunitario.</small>
            </div>
          <% } else if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'rechazado') { %>
            <div class="alert alert-danger border-0 rounded-3 py-2 mb-4 alert-danger-voluntario" role="alert">
              <i class="bi bi-x-circle-fill me-2"></i>
              <small>❌ Tu solicitud fue rechazada. Puedes volver a postularte.</small>
            </div>
          <% } %>

          <!-- Formulario -->
          <form action="/voluntarios" method="POST">
            
            <!-- Nombre completo -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 voluntario-label">
                <i class="bi bi-person-fill me-1"></i> Nombre completo *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3 voluntario-input" 
                     value="<%= datosVoluntario ? datosVoluntario.nombre : usuario.nombre %>" 
                     placeholder="Ej: Juan Pérez" required>
            </div>

            <!-- Teléfono -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 voluntario-label">
                <i class="bi bi-telephone-fill me-1"></i> Teléfono de contacto *
              </label>
              <input type="text" name="telefono" class="form-control rounded-3 voluntario-input" 
                     value="<%= datosVoluntario ? datosVoluntario.telefono : usuario.telefono %>" 
                     placeholder="0412-1234567" required>
              <small class="text-muted voluntario-help">Número de contacto para coordinación de ayudas</small>
            </div>

            <!-- Habilidad -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 voluntario-label">
                <i class="bi bi-tools me-1"></i> ¿Qué sabes hacer? *
              </label>
              <textarea name="habilidad" class="form-control rounded-3 voluntario-textarea" rows="3" 
                        placeholder="Ej: fontanería, electricidad, enfermería, manejo de redes, construcción, etc." 
                        required><%= datosVoluntario ? datosVoluntario.habilidad : '' %></textarea>
              <small class="text-muted voluntario-help">Describe tus principales habilidades para ayudar a la comunidad</small>
            </div>

            <!-- Experiencia previa -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 voluntario-label">
                <i class="bi bi-journal-bookmark-fill me-1"></i> Experiencia previa
              </label>
              <textarea name="experiencia" class="form-control rounded-3 voluntario-textarea" rows="2" 
                        placeholder="Cuéntanos tu experiencia relacionada..."><%= datosVoluntario ? datosVoluntario.experiencia : '' %></textarea>
              <small class="text-muted voluntario-help">Opcional: experiencia previa como voluntario o en trabajos relacionados</small>
            </div>

            <!-- Disponibilidad horaria -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 voluntario-label">
                <i class="bi bi-clock-fill me-1"></i> Disponibilidad horaria
              </label>
              <input type="text" name="disponibilidad_horaria" class="form-control rounded-3 voluntario-input" 
                     value="<%= datosVoluntario ? datosVoluntario.disponibilidad_horaria : '' %>"
                     placeholder="Ej: Fines de semana, Lunes a Viernes de 2pm a 6pm, etc.">
              <small class="text-muted voluntario-help">¿Cuándo puedes dedicar tiempo para ayudar?</small>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar-voluntario">
                <i class="bi <%= yaSolicito ? 'bi-check-lg' : 'bi-send-fill' %> me-2"></i>
                <%= yaSolicito ? 'Actualizar perfil' : 'Enviar solicitud' %>
              </button>
              <a href="/voluntarios/mi-perfil" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar-voluntario">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 voluntario-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 voluntario-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .voluntario-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .voluntario-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .voluntario-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .voluntario-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .voluntario-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .voluntario-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver-voluntario {
    border: 1px solid #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-voluntario:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Labels */
  .voluntario-label {
    color: #5D4037;
  }
  .voluntario-label i {
    color: #fd6704bd;
  }
  
  /* Inputs y textarea */
  .voluntario-input, .voluntario-textarea {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .voluntario-input:focus, .voluntario-textarea:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Ayuda */
  .voluntario-help {
    color: #8B6B5A;
  }
  
  /* Botón guardar */
  .btn-guardar-voluntario {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar-voluntario:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar-voluntario {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar-voluntario:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .voluntario-badge {
    color: #8B6B5A !important;
  }
  .voluntario-badge i {
    color: #17a2b8;
  }
  
  /* Alertas */
  .alert-success-voluntario {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    color: #155724;
  }
  .alert-warning-voluntario {
    background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
    color: #856404;
  }
  .alert-danger-voluntario {
    background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
    color: #721c24;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .voluntario-card {
    background: #27272a;
  }
  
  body.dark-mode .voluntario-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .voluntario-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .voluntario-body {
    background: #27272a;
  }
  
  body.dark-mode .btn-volver-voluntario {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-voluntario:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .voluntario-label {
    color: #e4e4e7;
  }
  body.dark-mode .voluntario-label i {
    color: #f7931e;
  }
  
  body.dark-mode .voluntario-input,
  body.dark-mode .voluntario-textarea {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .voluntario-input:focus,
  body.dark-mode .voluntario-textarea:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .voluntario-input::placeholder,
  body.dark-mode .voluntario-textarea::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .voluntario-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-cancelar-voluntario {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar-voluntario:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .voluntario-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .voluntario-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-success-voluntario {
    background: #0d3b1f;
    color: #a3e4b7;
  }
  body.dark-mode .alert-warning-voluntario {
    background: #3d2e1a;
    color: #f5dba3;
  }
  body.dark-mode .alert-danger-voluntario {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
</style>
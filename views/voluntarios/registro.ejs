<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">🤝 <%= yaSolicito ? 'Editar mi perfil' : 'Únete como Voluntario' %></h4>
                </div>
                <div class="card-body">
                    
                    <% if (session && session.error) { %>
                        <div class="alert alert-danger"><%= session.error %></div>
                        <% session.error = null; %>
                    <% } %>
                    
                    <% if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'aprobado') { %>
                        <div class="alert alert-success">
                            ✅ Ya eres voluntario aprobado. Puedes editar tu información.
                        </div>
                    <% } else if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'pendiente') { %>
                        <div class="alert alert-warning">
                            ⏳ Tu solicitud está pendiente de aprobación.
                        </div>
                    <% } else if (yaSolicito && datosVoluntario && datosVoluntario.estado === 'rechazado') { %>
                        <div class="alert alert-danger">
                            ❌ Tu solicitud fue rechazada. Puedes volver a postularte.
                        </div>
                    <% } %>

                    <form action="/voluntarios" method="POST">
                        <div class="mb-3">
                            <label class="form-label">Nombre completo *</label>
                            <input type="text" name="nombre" class="form-control" 
                                   value="<%= datosVoluntario ? datosVoluntario.nombre : usuario.nombre %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Teléfono de contacto *</label>
                            <input type="text" name="telefono" class="form-control" 
                                   value="<%= datosVoluntario ? datosVoluntario.telefono : usuario.telefono %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">¿Qué sabes hacer? *</label>
                            <textarea name="habilidad" class="form-control" rows="2" required><%= datosVoluntario ? datosVoluntario.habilidad : '' %></textarea>
                            <small class="text-muted">Ej: fontanería, electricidad, enfermería, manejo de redes, etc.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Experiencia previa</label>
                            <textarea name="experiencia" class="form-control" rows="2"><%= datosVoluntario ? datosVoluntario.experiencia : '' %></textarea>
                            <small class="text-muted">Cuéntanos tu experiencia relacionada</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Disponibilidad horaria</label>
                            <input type="text" name="disponibilidad_horaria" class="form-control" 
                                   value="<%= datosVoluntario ? datosVoluntario.disponibilidad_horaria : '' %>"
                                   placeholder="Ej: Fines de semana, Lunes a Viernes de 2pm a 6pm, etc.">
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <%= yaSolicito ? '✅ Actualizar perfil' : '✅ Enviar solicitud' %>
                            </button>
                            <a href="/voluntarios/mi-perfil" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow">
        <div class="card-header bg-success text-white">
          <h4 class="mb-0">🤝 Únete como Voluntario</h4>
        </div>
        <div class="card-body">
          
          <% if (session && session.error) { %>
            <div class="alert alert-danger">
              <%= session.error %>
            </div>
            <% session.error = null; %>
          <% } %>
          
          <% if (yaSolicito) { %>
            <div class="alert alert-info">
              <strong>Ya tienes una solicitud registrada.</strong><br>
              <% if (estadoSolicitud === 'pendiente') { %>
                Tu solicitud está <span class="badge bg-warning">pendiente de aprobación</span>.
              <% } else if (estadoSolicitud === 'aprobado') { %>
                ¡Felicidades! Ya eres <span class="badge bg-success">voluntario aprobado</span>.
              <% } else if (estalificado === 'rechazado') { %>
                Tu solicitud fue <span class="badge bg-danger">rechazada</span>.
              <% } %>
            </div>
            <a href="/" class="btn btn-primary">Volver al inicio</a>
          <% } else { %>
            <p class="text-muted mb-4">
              Completa este formulario para formar parte del equipo de voluntarios 
              de la Comuna Socialista Nuestra Señora de las Mercedes.
            </p>

            <form action="/voluntarios" method="POST">
              <div class="mb-3">
                <label class="form-label">Nombre completo *</label>
                <input type="text" name="nombre" class="form-control" 
                       value="<%= usuario.nombre %>" required>
              </div>

              <div class="mb-3">
                <label class="form-label">Teléfono de contacto</label>
                <input type="text" name="telefono" class="form-control" 
                       placeholder="0414-1234567"
                       value="<%= usuario.telefono || '' %>">
              </div>

              <div class="mb-3">
                <label class="form-label">¿Qué sabes hacer? *</label>
                <textarea name="habilidad" class="form-control" rows="3"
                          placeholder="Ej: fontanería, electricidad, enfermería, manejo de redes, cocina, etc."
                          required></textarea>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                  ✅ Enviar solicitud
                </button>
                <a href="/" class="btn btn-outline-secondary">
                  Cancelar
                </a>
              </div>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 auditoria-title">
        <i class="bi bi-clock-history me-2"></i> Registro de Auditoría
      </h2>
      <p class="text-muted small mb-0 auditoria-subtitle">Historial de acciones realizadas en el sistema</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/auditoria/exportar/excel" id="btnExportarExcel" class="btn btn-sm px-3 py-2 fw-semibold rounded-3 btn-excel">
        <i class="bi bi-file-excel me-1"></i> Excel
      </a>
      <a href="/auditoria/exportar/pdf" id="btnExportarPDF" class="btn btn-sm px-3 py-2 fw-semibold rounded-3 btn-pdf">
        <i class="bi bi-file-pdf me-1"></i> PDF
      </a>
      <button type="button" class="btn btn-sm px-3 py-2 fw-semibold rounded-3 btn-limpiar" data-bs-toggle="modal" data-bs-target="#modalLimpiar">
        <i class="bi bi-trash me-1"></i> Limpiar antiguos
      </button>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Filtros avanzados -->
  <div class="card border-0 rounded-4 shadow-sm mb-4 overflow-hidden filtros-card">
    <div class="px-4 py-3 filtros-header">
      <h5 class="mb-0 fw-semibold">
        <i class="bi bi-funnel me-2"></i> Filtros
      </h5>
    </div>
    <div class="card-body p-4 filtros-body">
      <form id="formFiltros" method="GET" action="/auditoria" class="row g-3">
        <div class="col-md-3">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-person me-1"></i> Usuario
          </label>
          <input type="text" name="usuario" id="filtroUsuario" class="form-control rounded-3 filtros-input" 
                 placeholder="Nombre del usuario" value="<%= filters && filters.usuario ? filters.usuario : '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-lightning-charge me-1"></i> Acción
          </label>
          <select name="accion" id="filtroAccion" class="form-select rounded-3 filtros-select">
            <option value="todos" <%= (!filters || filters.accion === 'todos' || !filters.accion) ? 'selected' : '' %>>Todos</option>
            <option value="CREAR" <%= filters && filters.accion === 'CREAR' ? 'selected' : '' %>>Crear</option>
            <option value="EDITAR" <%= filters && filters.accion === 'EDITAR' ? 'selected' : '' %>>Editar</option>
            <option value="ELIMINAR" <%= filters && filters.accion === 'ELIMINAR' ? 'selected' : '' %>>Eliminar</option>
            <option value="ELIMINAR_PERMANENTEMENTE" <%= filters && filters.accion === 'ELIMINAR_PERMANENTEMENTE' ? 'selected' : '' %>>Eliminar Permanentemente</option>
            <option value="ACTIVAR" <%= filters && filters.accion === 'ACTIVAR' ? 'selected' : '' %>>Activar</option>
            <option value="DESACTIVAR" <%= filters && filters.accion === 'DESACTIVAR' ? 'selected' : '' %>>Desactivar</option>
            <option value="ASIGNAR" <%= filters && filters.accion === 'ASIGNAR' ? 'selected' : '' %>>Asignar empresa</option>
            <option value="CAMBIAR_ESTADO" <%= filters && filters.accion === 'CAMBIAR_ESTADO' ? 'selected' : '' %>>Cambiar estado</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-table me-1"></i> Tabla
          </label>
          <select name="tabla" id="filtroTabla" class="form-select rounded-3 filtros-select">
            <option value="todos" <%= (!filters || filters.tabla === 'todos' || !filters.tabla) ? 'selected' : '' %>>Todos</option>
            <option value="usuarios" <%= filters && filters.tabla === 'usuarios' ? 'selected' : '' %>>Usuarios</option>
            <option value="reportes" <%= filters && filters.tabla === 'reportes' ? 'selected' : '' %>>Reportes</option>
            <option value="voluntarios" <%= filters && filters.tabla === 'voluntarios' ? 'selected' : '' %>>Voluntarios</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-calendar3 me-1"></i> Fecha desde
          </label>
          <input type="date" name="fecha_desde" id="filtroFechaDesde" class="form-control rounded-3 filtros-input" 
                 value="<%= filters && filters.fecha_desde ? filters.fecha_desde : '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-calendar3 me-1"></i> Fecha hasta
          </label>
          <input type="date" name="fecha_hasta" id="filtroFechaHasta" class="form-control rounded-3 filtros-input" 
                 value="<%= filters && filters.fecha_hasta ? filters.fecha_hasta : '' %>">
        </div>
        <div class="col-12 d-flex gap-2">
          <button type="submit" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-filtrar-auditoria">
            <i class="bi bi-search me-1"></i> Filtrar
          </button>
          <button type="button" id="btnLimpiarFiltros" class="btn btn-sm btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-limpiar-filtros">
            <i class="bi bi-x-circle me-1"></i> Limpiar
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Tabla de auditoría -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden tabla-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 tabla-auditoria" id="tablaAuditoria">
          <thead class="tabla-header-auditoria">
            <tr class="text-center">
              <th><i class="bi bi-calendar3"></i> Fecha</th>
              <th><i class="bi bi-person"></i> Usuario</th>
              <th><i class="bi bi-lightning-charge"></i> Acción</th>
              <th><i class="bi bi-table"></i> Tabla</th>
              <th><i class="bi bi-hash"></i> Registro ID</th>
              <th><i class="bi bi-info-circle"></i> Detalles</th>
            </tr>
          </thead>
          <tbody>
            <% if (registros && registros.length > 0) { %>
              <% registros.forEach(r => { 
                let datosAnterioresObj = null;
                let datosNuevosObj = null;
                
                try {
                  if (r.datos_anteriores) datosAnterioresObj = JSON.parse(r.datos_anteriores);
                  if (r.datos_nuevos) datosNuevosObj = JSON.parse(r.datos_nuevos);
                } catch(e) {
                  console.error('Error parsing JSON');
                }
              %>
                <tr class="align-middle text-center fila-auditoria">
                  <td class="small"><%= new Date(r.fecha).toLocaleString() %></td>
                  <td><%= r.usuario_nombre || 'Sistema' %></td>
                  <td>
                    <span class="badge rounded-pill px-3 py-1 
                      <%= r.accion === 'CREAR' ? 'bg-success' : 
                          r.accion === 'EDITAR' ? 'bg-warning text-dark' : 
                          r.accion === 'ELIMINAR' ? 'bg-danger' : 
                          r.accion === 'ELIMINAR_PERMANENTEMENTE' ? 'bg-dark' : 
                          r.accion === 'ACTIVAR' ? 'bg-success' :
                          r.accion === 'DESACTIVAR' ? 'bg-warning text-dark' :
                          r.accion === 'ASIGNAR' ? 'bg-info' : 
                          r.accion === 'CAMBIAR_ESTADO' ? 'bg-primary' : 'bg-secondary' %>">
                      <i class="bi 
                        <%= r.accion === 'CREAR' ? 'bi-plus-circle' : 
                            r.accion === 'EDITAR' ? 'bi-pencil' : 
                            r.accion === 'ELIMINAR' ? 'bi-trash' : 
                            r.accion === 'ELIMINAR_PERMANENTEMENTE' ? 'bi-trash3-fill' : 
                            r.accion === 'ACTIVAR' ? 'bi-check-circle' :
                            r.accion === 'DESACTIVAR' ? 'bi-person-x' :
                            r.accion === 'ASIGNAR' ? 'bi-building' : 
                            r.accion === 'CAMBIAR_ESTADO' ? 'bi-arrow-repeat' : 'bi-info-circle' %> me-1"></i>
                      <%= r.accion === 'ELIMINAR_PERMANENTEMENTE' ? 'ELIMINAR PERM.' : r.accion %>
                    </span>
                  </td>
                  <td><%= r.tabla %></td>
                  <td><%= r.registro_id || '—' %></td>
                  <td>
                    <button class="btn btn-sm px-3 py-1 rounded-3 btn-ver-detalle" 
                            data-id="<%= r.id %>"
                            data-accion="<%= r.accion %>"
                            data-tabla="<%= r.tabla %>"
                            data-registro-id="<%= r.registro_id %>"
                            data-fecha="<%= new Date(r.fecha).toLocaleString() %>"
                            data-usuario="<%= r.usuario_nombre || 'Sistema' %>"
                            data-ip="<%= r.ip_address || 'No registrada' %>"
                            data-user-agent="<%= r.user_agent || 'No registrado' %>"
                            data-datos-anteriores='<%- JSON.stringify(datosAnterioresObj) %>'
                            data-datos-nuevos='<%- JSON.stringify(datosNuevosObj) %>'>
                      <i class="bi bi-eye me-1"></i> Ver
                    </button>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center py-5 empty-state-auditoria">
                  <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay registros de auditoría</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted auditoria-info">
      <i class="bi bi-info-circle me-1"></i> 
      Los registros de auditoría se conservan automáticamente
    </small>
  </div>
</div>

<!-- Modal para ver detalles mejorado -->
<div class="modal fade" id="modalDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-detalle-auditoria">
      <div class="modal-header modal-detalle-header">
        <h5 class="modal-title text-white">
          <i class="bi bi-info-circle me-2"></i> Detalles del registro
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4 modal-detalle-body" id="detalleContent">
        <!-- Contenido dinámico -->
      </div>
      <div class="modal-footer modal-detalle-footer">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal para limpiar registros -->
<div class="modal fade" id="modalLimpiar" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-limpiar">
      <div class="modal-header modal-limpiar-header">
        <h5 class="modal-title text-white">
          <i class="bi bi-trash me-2"></i> Limpiar registros antiguos
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/auditoria/limpiar" method="POST">
        <div class="modal-body p-4 modal-limpiar-body">
          <label class="form-label fw-semibold modal-limpiar-label">Eliminar registros con más de:</label>
          <select name="dias" class="form-select rounded-3 mt-2 modal-limpiar-select">
            <option value="30">30 días</option>
            <option value="60">60 días</option>
            <option value="90" selected>90 días</option>
            <option value="180">180 días</option>
            <option value="365">1 año</option>
          </select>
          <small class="text-muted mt-2 d-block modal-limpiar-help">⚠️ Esta acción no se puede deshacer</small>
        </div>
        <div class="modal-footer modal-limpiar-footer">
          <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn rounded-3 px-4 btn-limpiar-confirmar">Limpiar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Actualizar enlaces de exportación con los filtros actuales
  function actualizarEnlacesExportacion() {
    const usuario = document.getElementById('filtroUsuario')?.value || '';
    const accion = document.getElementById('filtroAccion')?.value || 'todos';
    const tabla = document.getElementById('filtroTabla')?.value || 'todos';
    const fechaDesde = document.getElementById('filtroFechaDesde')?.value || '';
    const fechaHasta = document.getElementById('filtroFechaHasta')?.value || '';
    
    const params = new URLSearchParams();
    if (usuario) params.append('usuario', usuario);
    if (accion && accion !== 'todos') params.append('accion', accion);
    if (tabla && tabla !== 'todos') params.append('tabla', tabla);
    if (fechaDesde) params.append('fecha_desde', fechaDesde);
    if (fechaHasta) params.append('fecha_hasta', fechaHasta);
    
    const queryString = params.toString();
    const excelBtn = document.getElementById('btnExportarExcel');
    const pdfBtn = document.getElementById('btnExportarPDF');
    
    if (excelBtn) excelBtn.href = `/auditoria/exportar/excel${queryString ? '?' + queryString : ''}`;
    if (pdfBtn) pdfBtn.href = `/auditoria/exportar/pdf${queryString ? '?' + queryString : ''}`;
  }
  
  // Escuchar cambios en los filtros
  const filtros = ['filtroUsuario', 'filtroAccion', 'filtroTabla', 'filtroFechaDesde', 'filtroFechaHasta'];
  filtros.forEach(id => {
    const element = document.getElementById(id);
    if (element) {
      element.addEventListener('change', actualizarEnlacesExportacion);
      element.addEventListener('keyup', actualizarEnlacesExportacion);
    }
  });
  
  // Limpiar filtros
  document.getElementById('btnLimpiarFiltros')?.addEventListener('click', () => {
    window.location.href = '/auditoria';
  });
  
  // Inicializar enlaces
  actualizarEnlacesExportacion();

  // Función para formatear datos de forma legible
  function formatearDatos(datos, titulo, icono, bgColor = '#fff') {
    if (!datos || Object.keys(datos).length === 0) return '';
    
    let html = `<div class="mt-3 p-3 rounded-3 datos-card" style="background: ${bgColor};">
                  <div class="fw-bold mb-2 datos-titulo">${icono} ${titulo}:</div>
                  <div class="table-responsive">
                    <table class="table table-sm mb-0 datos-tabla">
                      <tbody>`;
    
    for (const [key, value] of Object.entries(datos)) {
      let campo = key;
      switch(key) {
        case 'nombre': campo = '👤 Nombre'; break;
        case 'email': campo = '📧 Email'; break;
        case 'telefono': campo = '📞 Teléfono'; break;
        case 'rol_id': campo = '🎭 Rol ID'; break;
        case 'calle_id': campo = '📍 Calle ID'; break;
        case 'estado': campo = '📌 Estado'; break;
        case 'empresa_id': campo = '🏢 Empresa ID'; break;
        case 'categoria': campo = '🏷️ Categoría'; break;
        case 'cedula': campo = '🆔 Cédula'; break;
        case 'password': campo = '🔑 Contraseña'; break;
        case 'motivo_eliminacion': campo = '⚠️ MOTIVO DE ELIMINACIÓN'; break;
        case 'eliminado_por': campo = '👑 Eliminado por'; break;
        case 'fecha_eliminacion': campo = '📅 Fecha de eliminación'; break;
        default: campo = key.charAt(0).toUpperCase() + key.slice(1);
      }
      
      let valor = value;
      if (value === null || value === '') valor = '<span class="text-muted">(vacío)</span>';
      if (key === 'password') valor = '••••••••';
      
      if (key === 'motivo_eliminacion') {
        html += `<tr class="motivo-row"><td class="fw-bold pe-3" style="width: 40%;">${campo}</td><td class="motivo-valor">${valor}</td></tr>`;
      } else {
        html += `<tr><td class="fw-bold pe-3" style="width: 40%;">${campo}</td><td>${valor}</td></tr>`;
      }
    }
    
    html += `</tbody> </table> </div> </div>`;
    return html;
  }
  
  // Ver detalles
  document.querySelectorAll('.btn-ver-detalle').forEach(btn => {
    btn.addEventListener('click', function() {
      const accion = this.dataset.accion;
      const tabla = this.dataset.tabla;
      const registroId = this.dataset.registroId;
      const fecha = this.dataset.fecha;
      const usuario = this.dataset.usuario;
      const ip = this.dataset.ip;
      const userAgent = this.dataset.userAgent;
      
      let datosAnteriores = null;
      let datosNuevos = null;
      
      try {
        if (this.dataset.datosAnteriores && this.dataset.datosAnteriores !== 'null' && this.dataset.datosAnteriores !== 'undefined') {
          datosAnteriores = JSON.parse(this.dataset.datosAnteriores);
        }
        if (this.dataset.datosNuevos && this.dataset.datosNuevos !== 'null' && this.dataset.datosNuevos !== 'undefined') {
          datosNuevos = JSON.parse(this.dataset.datosNuevos);
        }
      } catch(e) {
        console.error('Error al parsear datos:', e);
      }
      
      let html = `
        <div class="mb-4 pb-2 detalle-info">
          <div class="row mb-2">
            <div class="col-4 fw-bold detalle-label"><i class="bi bi-calendar3 me-1"></i> Fecha:</div>
            <div class="col-8 detalle-valor">${fecha}</div>
          </div>
          <div class="row mb-2">
            <div class="col-4 fw-bold detalle-label"><i class="bi bi-person me-1"></i> Usuario:</div>
            <div class="col-8 detalle-valor">${usuario}</div>
          </div>
          <div class="row mb-2">
            <div class="col-4 fw-bold detalle-label"><i class="bi bi-wifi me-1"></i> IP Address:</div>
            <div class="col-8 detalle-valor"><code>${ip}</code></div>
          </div>
          <div class="row mb-2">
            <div class="col-4 fw-bold detalle-label"><i class="bi bi-laptop me-1"></i> Navegador:</div>
            <div class="col-8 detalle-valor"><small>${userAgent}</small></div>
          </div>
          <div class="row mb-2">
            <div class="col-4 fw-bold detalle-label"><i class="bi bi-lightning-charge me-1"></i> Acción:</div>
            <div class="col-8 detalle-valor">
              <span class="badge rounded-pill px-3 py-1 ${accion === 'CREAR' ? 'bg-success' : accion === 'EDITAR' ? 'bg-warning' : accion === 'ELIMINAR' ? 'bg-danger' : accion === 'ELIMINAR_PERMANENTEMENTE' ? 'bg-dark' : accion === 'ACTIVAR' ? 'bg-success' : accion === 'DESACTIVAR' ? 'bg-warning' : 'bg-info'}" style="${accion === 'EDITAR' || accion === 'DESACTIVAR' ? 'color: #333;' : 'color: white;'}">
                ${accion === 'ELIMINAR_PERMANENTEMENTE' ? 'ELIMINAR PERMANENTEMENTE' : accion}
              </span>
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-4 fw-bold detalle-label"><i class="bi bi-table me-1"></i> Tabla:</div>
            <div class="col-8 detalle-valor">${tabla}</div>
          </div>
          <div class="row">
            <div class="col-4 fw-bold detalle-label"><i class="bi bi-hash me-1"></i> Registro ID:</div>
            <div class="col-8 detalle-valor">${registroId || '—'}</div>
          </div>
        </div>
      `;
      
      if (accion === 'CREAR' && datosNuevos) {
        html += formatearDatos(datosNuevos, 'DATOS CREADOS', '✅', '#f0fff4');
      } 
      else if (accion === 'EDITAR') {
        if (datosAnteriores && Object.keys(datosAnteriores).length > 0) {
          html += formatearDatos(datosAnteriores, 'DATOS ANTERIORES', '📄', '#fff8f0');
        } else {
          html += `<div class="alert alert-info mt-2 rounded-3">No se registraron datos anteriores</div>`;
        }
        if (datosNuevos && Object.keys(datosNuevos).length > 0) {
          html += formatearDatos(datosNuevos, 'DATOS NUEVOS', '🆕', '#f0fff4');
        }
      }
      else if (accion === 'ELIMINAR' && datosAnteriores) {
        html += formatearDatos(datosAnteriores, 'DATOS ELIMINADOS', '🗑️', '#fff0f0');
      }
      else if (accion === 'ELIMINAR_PERMANENTEMENTE' && datosAnteriores) {
        html += formatearDatos(datosAnteriores, 'USUARIO ELIMINADO PERMANENTEMENTE', '⚠️', '#fff0f0');
        if (datosAnteriores.motivo_eliminacion) {
          html += `
            <div class="mt-3 p-3 rounded-3 motivo-card">
              <div class="fw-bold mb-2 motivo-titulo"><i class="bi bi-chat-text me-1"></i> MOTIVO DE ELIMINACIÓN:</div>
              <div class="p-2 bg-white rounded-3 motivo-texto">${datosAnteriores.motivo_eliminacion}</div>
              <div class="mt-2 small text-muted">Eliminado por: ${datosAnteriores.eliminado_por || 'Desconocido'} | Fecha: ${datosAnteriores.fecha_eliminacion || ''}</div>
            </div>
          `;
        }
      }
      else if (accion === 'DESACTIVAR' && datosNuevos) {
        html += formatearDatos(datosNuevos, 'USUARIO DESACTIVADO', '🔴', '#fff0f0');
      }
      else if (accion === 'ACTIVAR' && datosNuevos) {
        html += formatearDatos(datosNuevos, 'USUARIO ACTIVADO', '🟢', '#f0fff4');
      }
      else if (accion === 'ASIGNAR' && datosNuevos) {
        html += formatearDatos(datosNuevos, 'ASIGNACIÓN REALIZADA', '🏢', '#f0f4ff');
      }
      else if (accion === 'CAMBIAR_ESTADO') {
        if (datosAnteriores && Object.keys(datosAnteriores).length > 0) {
          html += formatearDatos(datosAnteriores, 'ESTADO ANTERIOR', '📄', '#fff8f0');
        }
        if (datosNuevos && Object.keys(datosNuevos).length > 0) {
          html += formatearDatos(datosNuevos, 'ESTADO NUEVO', '🆕', '#f0fff4');
        }
      }
      
      if ((!datosAnteriores || Object.keys(datosAnteriores).length === 0) && (!datosNuevos || Object.keys(datosNuevos).length === 0) && accion !== 'ELIMINAR_PERMANENTEMENTE') {
        html += `<div class="alert alert-info mt-3 rounded-3">No hay datos detallados disponibles para este registro.</div>`;
      }
      
      document.getElementById('detalleContent').innerHTML = html;
      new bootstrap.Modal(document.getElementById('modalDetalle')).show();
    });
  });
</script>


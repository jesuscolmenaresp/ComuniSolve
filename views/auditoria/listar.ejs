<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📋 Registro de Auditoría</h2>
        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#modalLimpiar">
            🧹 Limpiar registros antiguos
        </button>
    </div>

    <% if (session && session.mensaje) { %>
        <div class="alert alert-success alert-dismissible fade show">
            <%= session.mensaje %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% session.mensaje = null; %>
    <% } %>

    <% if (session && session.error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <%= session.error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% session.error = null; %>
    <% } %>

    <!-- Filtros -->
    <div class="row mb-3 g-2">
        <div class="col-md-4">
            <select id="filtroAccion" class="form-select">
                <option value="0">📌 Todas las acciones</option>
                <option value="CREAR">➕ Crear</option>
                <option value="EDITAR">✏️ Editar</option>
                <option value="ELIMINAR">🗑️ Eliminar</option>
                <option value="ASIGNAR">🏢 Asignar empresa</option>
                <option value="CAMBIAR_ESTADO">🔄 Cambiar estado</option>
            </select>
        </div>
        <div class="col-md-4">
            <input type="text" id="buscarUsuario" class="form-control" placeholder="🔍 Buscar por usuario...">
        </div>
        <div class="col-md-4">
            <button id="limpiarFiltros" class="btn btn-outline-secondary w-100">
                🧹 Limpiar filtros
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-sm" id="tablaAuditoria">
            <thead class="table-light">
                <tr>
                    <th>Fecha</th>
                    <th>Usuario</th>
                    <th>Acción</th>
                    <th>Tabla</th>
                    <th>Registro ID</th>
                    <th>Detalles</th>
                </thead>
            <tbody>
                <% if (registros && registros.length > 0) { %>
                    <% registros.forEach(r => { 
                        // Preparar datos para el modal
                        let datosAnterioresObj = null;
                        let datosNuevosObj = null;
                        
                        try {
                            if (r.datos_anteriores) datosAnterioresObj = JSON.parse(r.datos_anteriores);
                            if (r.datos_nuevos) datosNuevosObj = JSON.parse(r.datos_nuevos);
                        } catch(e) {
                            console.error('Error parsing JSON');
                        }
                    %>
                        <tr data-accion="<%= r.accion %>" data-usuario="<%= r.usuario_nombre ? r.usuario_nombre.toLowerCase() : '' %>"
                            data-datos-anteriores='<%- JSON.stringify(datosAnterioresObj) %>'
                            data-datos-nuevos='<%- JSON.stringify(datosNuevosObj) %>'
                            data-tabla="<%= r.tabla %>"
                            data-accion-nombre="<%= r.accion %>">
                            <td class="small"><%= new Date(r.fecha).toLocaleString() %></td>
                            <td><%= r.usuario_nombre || 'Sistema' %></td>
                            <td>
                                <span class="badge <%= 
                                    r.accion === 'CREAR' ? 'bg-success' : 
                                    r.accion === 'EDITAR' ? 'bg-warning text-dark' : 
                                    r.accion === 'ELIMINAR' ? 'bg-danger' : 
                                    r.accion === 'ASIGNAR' ? 'bg-info' : 
                                    'bg-secondary' %>">
                                    <%= r.accion %>
                                </span>
                            </td>
                            <td><%= r.tabla %></td>
                            <td><%= r.registro_id || '—' %></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary ver-detalle" 
                                        data-id="<%= r.id %>"
                                        data-accion="<%= r.accion %>"
                                        data-tabla="<%= r.tabla %>"
                                        data-registro-id="<%= r.registro_id %>"
                                        data-fecha="<%= new Date(r.fecha).toLocaleString() %>"
                                        data-usuario="<%= r.usuario_nombre || 'Sistema' %>">
                                    🔍 Ver detalles
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                      <td colspan="6" class="text-center py-5 text-muted">
                            No hay registros de auditoría
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal para ver detalles mejorado -->
<div class="modal fade" id="modalDetalle" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-info-circle"></i> Detalles del registro
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detalleContent">
                <!-- Contenido dinámico -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal para limpiar registros -->
<div class="modal fade" id="modalLimpiar" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Limpiar registros antiguos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="/auditoria/limpiar" method="POST">
                <div class="modal-body">
                    <label class="form-label">Eliminar registros con más de:</label>
                    <select name="dias" class="form-select">
                        <option value="30">30 días</option>
                        <option value="60">60 días</option>
                        <option value="90" selected>90 días</option>
                        <option value="180">180 días</option>
                        <option value="365">1 año</option>
                    </select>
                    <small class="text-muted">Esta acción no se puede deshacer</small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Limpiar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Filtros
    const filtroAccion = document.getElementById('filtroAccion');
    const buscarUsuario = document.getElementById('buscarUsuario');
    const limpiarFiltros = document.getElementById('limpiarFiltros');
    
    function aplicarFiltros() {
        const accion = filtroAccion.value;
        const texto = buscarUsuario.value.toLowerCase();
        
        document.querySelectorAll('#tablaAuditoria tbody tr').forEach(fila => {
            const dataAccion = fila.dataset.accion;
            const dataUsuario = fila.dataset.usuario;
            
            let mostrar = true;
            if (accion != 0 && dataAccion !== accion) mostrar = false;
            if (texto && dataUsuario && !dataUsuario.includes(texto)) mostrar = false;
            fila.style.display = mostrar ? '' : 'none';
        });
    }
    
    filtroAccion.addEventListener('change', aplicarFiltros);
    buscarUsuario.addEventListener('keyup', aplicarFiltros);
    limpiarFiltros.addEventListener('click', () => {
        filtroAccion.value = '0';
        buscarUsuario.value = '';
        aplicarFiltros();
    });
    
    // Función para formatear datos de forma legible
    function formatearDatos(datos, titulo, icono) {
        if (!datos || Object.keys(datos).length === 0) return '';
        
        let html = `<h6 class="mt-3">${icono} ${titulo}:</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered">`;
        
        for (const [key, value] of Object.entries(datos)) {
            // Traducir nombres de campos
            let campo = key;
            switch(key) {
                case 'nombre': campo = 'Nombre'; break;
                case 'email': campo = 'Email'; break;
                case 'telefono': campo = 'Teléfono'; break;
                case 'rol_id': campo = 'Rol ID'; break;
                case 'calle_id': campo = 'Calle ID'; break;
                case 'estado': campo = 'Estado'; break;
                case 'empresa_id': campo = 'Empresa ID'; break;
                case 'categoria': campo = 'Categoría'; break;
                case 'descripcion': campo = 'Descripción'; break;
                default: campo = key.charAt(0).toUpperCase() + key.slice(1);
            }
            
            let valor = value;
            if (value === null) valor = '<span class="text-muted">(vacío)</span>';
            if (value === '') valor = '<span class="text-muted">(vacío)</span>';
            
            html += `<tr>
                        <td class="fw-bold" style="width: 40%">${campo}</td>
                        <td>${valor}</td>
                     </tr>`;
        }
        
        html += `</table></div>`;
        return html;
    }
    
    // Ver detalles
    document.querySelectorAll('.ver-detalle').forEach(btn => {
        btn.addEventListener('click', function() {
            const fila = this.closest('tr');
            const accion = this.dataset.accion;
            const tabla = this.dataset.tabla;
            const registroId = this.dataset.registroId;
            const fecha = this.dataset.fecha;
            const usuario = this.dataset.usuario;
            
            // Obtener datos de la fila
            let datosAnteriores = null;
            let datosNuevos = null;
            
            try {
                if (fila.dataset.datosAnteriores && fila.dataset.datosAnteriores !== 'null') {
                    datosAnteriores = JSON.parse(fila.dataset.datosAnteriores);
                }
                if (fila.dataset.datosNuevos && fila.dataset.datosNuevos !== 'null') {
                    datosNuevos = JSON.parse(fila.dataset.datosNuevos);
                }
            } catch(e) {
                console.error('Error al parsear datos:', e);
            }
            
            // Construir contenido
            let html = `
                <div class="mb-3">
                    <div class="row">
                        <div class="col-4 fw-bold">Fecha:</div>
                        <div class="col-8">${fecha}</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">Usuario:</div>
                        <div class="col-8">${usuario}</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">Acción:</div>
                        <div class="col-8">
                            <span class="badge ${accion === 'CREAR' ? 'bg-success' : accion === 'EDITAR' ? 'bg-warning' : accion === 'ELIMINAR' ? 'bg-danger' : 'bg-info'}">
                                ${accion}
                            </span>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">Tabla:</div>
                        <div class="col-8">${tabla}</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">Registro ID:</div>
                        <div class="col-8">${registroId || '—'}</div>
                    </div>
                </div>
            `;
            
            // Mostrar datos según la acción
            if (accion === 'CREAR' && datosNuevos) {
                html += formatearDatos(datosNuevos, 'Datos creados', '✅');
            } 
            else if (accion === 'EDITAR') {
                if (datosAnteriores) {
                    html += formatearDatos(datosAnteriores, 'Datos anteriores', '📄');
                }
                if (datosNuevos) {
                    html += formatearDatos(datosNuevos, 'Datos nuevos', '🆕');
                }
            }
            else if (accion === 'ELIMINAR' && datosAnteriores) {
                html += formatearDatos(datosAnteriores, 'Datos eliminados', '🗑️');
            }
            else if (accion === 'ASIGNAR' && datosNuevos) {
                html += formatearDatos(datosNuevos, 'Asignación realizada', '🏢');
            }
            else if (accion === 'CAMBIAR_ESTADO') {
                if (datosAnteriores) {
                    html += formatearDatos(datosAnteriores, 'Estado anterior', '📄');
                }
                if (datosNuevos) {
                    html += formatearDatos(datosNuevos, 'Estado nuevo', '🆕');
                }
            }
            
            if (!datosAnteriores && !datosNuevos) {
                html += `<div class="alert alert-info mt-3">No hay datos detallados disponibles para este registro.</div>`;
            }
            
            document.getElementById('detalleContent').innerHTML = html;
            new bootstrap.Modal(document.getElementById('modalDetalle')).show();
        });
    });
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
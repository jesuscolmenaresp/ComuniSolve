<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📋 Registro de Auditoría</h2>
        <div class="d-flex gap-2">
            <a href="/auditoria/exportar/excel" id="btnExportarExcel" class="btn btn-success">
                <i class="bi bi-file-excel"></i> Exportar a Excel
            </a>
            <a href="/auditoria/exportar/pdf" id="btnExportarPDF" class="btn btn-danger">
                <i class="bi bi-file-pdf"></i> Exportar a PDF
            </a>
            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#modalLimpiar">
                🧹 Limpiar registros antiguos
            </button>
        </div>
    </div>

    <% if (session && session.mensaje) { %>
        <div class="alert alert-success alert-dismissible fade show">
            <%= session.mensaje %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% session.mensaje = null; %>
    <% } %>

    <% if (session && session.error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            <%= session.error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% session.error = null; %>
    <% } %>

    <!-- Filtros avanzados -->
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-funnel"></i> Filtros</h5>
        </div>
        <div class="card-body">
            <form id="formFiltros" method="GET" action="/auditoria" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Usuario</label>
                    <input type="text" name="usuario" id="filtroUsuario" class="form-control" placeholder="Nombre del usuario" value="<%= filters && filters.usuario ? filters.usuario : '' %>">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Acción</label>
                    <select name="accion" id="filtroAccion" class="form-select">
                        <option value="todos" <%= (!filters || filters.accion === 'todos' || !filters.accion) ? 'selected' : '' %>>Todos</option>
                        <option value="CREAR" <%= filters && filters.accion === 'CREAR' ? 'selected' : '' %>>Crear</option>
                        <option value="EDITAR" <%= filters && filters.accion === 'EDITAR' ? 'selected' : '' %>>Editar</option>
                        <option value="ELIMINAR" <%= filters && filters.accion === 'ELIMINAR' ? 'selected' : '' %>>Eliminar</option>
                        <option value="ASIGNAR" <%= filters && filters.accion === 'ASIGNAR' ? 'selected' : '' %>>Asignar empresa</option>
                        <option value="CAMBIAR_ESTADO" <%= filters && filters.accion === 'CAMBIAR_ESTADO' ? 'selected' : '' %>>Cambiar estado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tabla</label>
                    <select name="tabla" id="filtroTabla" class="form-select">
                        <option value="todos" <%= (!filters || filters.tabla === 'todos' || !filters.tabla) ? 'selected' : '' %>>Todos</option>
                        <option value="usuarios" <%= filters && filters.tabla === 'usuarios' ? 'selected' : '' %>>Usuarios</option>
                        <option value="reportes" <%= filters && filters.tabla === 'reportes' ? 'selected' : '' %>>Reportes</option>
                        <option value="voluntarios" <%= filters && filters.tabla === 'voluntarios' ? 'selected' : '' %>>Voluntarios</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fecha desde</label>
                    <input type="date" name="fecha_desde" id="filtroFechaDesde" class="form-control" value="<%= filters && filters.fecha_desde ? filters.fecha_desde : '' %>">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha hasta</label>
                    <input type="date" name="fecha_hasta" id="filtroFechaHasta" class="form-control" value="<%= filters && filters.fecha_hasta ? filters.fecha_hasta : '' %>">
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Filtrar
                    </button>
                    <button type="button" id="btnLimpiarFiltros" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Limpiar filtros
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover table-sm" id="tablaAuditoria">
            <thead class="table-dark">
                <tr>
                    <th>Fecha</th>
                    <th>Usuario</th>
                    <th>Acción</th>
                    <th>Tabla</th>
                    <th>Registro ID</th>
                    <th>Detalles</th>
                 </thead>
            <tbody>
                <% if (registros && registros.length > 0) { %>
                    <% registros.forEach(r => { 
                        let datosAnterioresObj = null;
                        let datosNuevosObj = null;
                        
                        try {
                            if (r.datos_anteriores) datosAnterioresObj = JSON.parse(r.datos_anteriores);
                            if (r.datos_nuevos) datosNuevosObj = JSON.parse(r.datos_nuevos);
                        } catch(e) {
                            console.error('Error parsing JSON');
                        }
                    %>
                        <tr>
                            <td class="small"><%= new Date(r.fecha).toLocaleString() %></td>
                            <td><%= r.usuario_nombre || 'Sistema' %></td>
                            <td>
                                <span class="badge <%= 
                                    r.accion === 'CREAR' ? 'bg-success' : 
                                    r.accion === 'EDITAR' ? 'bg-warning text-dark' : 
                                    r.accion === 'ELIMINAR' ? 'bg-danger' : 
                                    r.accion === 'ASIGNAR' ? 'bg-info' : 
                                    r.accion === 'CAMBIAR_ESTADO' ? 'bg-primary' : 
                                    'bg-secondary' %>">
                                    <%= r.accion %>
                                </span>
                            </td>
                            <td><%= r.tabla %></td>
                            <td><%= r.registro_id || '—' %></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary ver-detalle" 
                                        data-id="<%= r.id %>"
                                        data-accion="<%= r.accion %>"
                                        data-tabla="<%= r.tabla %>"
                                        data-registro-id="<%= r.registro_id %>"
                                        data-fecha="<%= new Date(r.fecha).toLocaleString() %>"
                                        data-usuario="<%= r.usuario_nombre || 'Sistema' %>"
                                        data-datos-anteriores='<%- JSON.stringify(datosAnterioresObj) %>'
                                        data-datos-nuevos='<%- JSON.stringify(datosNuevosObj) %>'>
                                    🔍 Ver detalles
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            No hay registros de auditoría
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal para ver detalles mejorado -->
<div class="modal fade" id="modalDetalle" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-info-circle"></i> Detalles del registro
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detalleContent">
                <!-- Contenido dinámico -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal para limpiar registros -->
<div class="modal fade" id="modalLimpiar" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Limpiar registros antiguos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form action="/auditoria/limpiar" method="POST">
                <div class="modal-body">
                    <label class="form-label">Eliminar registros con más de:</label>
                    <select name="dias" class="form-select">
                        <option value="30">30 días</option>
                        <option value="60">60 días</option>
                        <option value="90" selected>90 días</option>
                        <option value="180">180 días</option>
                        <option value="365">1 año</option>
                    </select>
                    <small class="text-muted">Esta acción no se puede deshacer</small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Limpiar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Actualizar enlaces de exportación con los filtros actuales
    function actualizarEnlacesExportacion() {
        const usuario = document.getElementById('filtroUsuario')?.value || '';
        const accion = document.getElementById('filtroAccion')?.value || 'todos';
        const tabla = document.getElementById('filtroTabla')?.value || 'todos';
        const fechaDesde = document.getElementById('filtroFechaDesde')?.value || '';
        const fechaHasta = document.getElementById('filtroFechaHasta')?.value || '';
        
        const params = new URLSearchParams();
        if (usuario) params.append('usuario', usuario);
        if (accion && accion !== 'todos') params.append('accion', accion);
        if (tabla && tabla !== 'todos') params.append('tabla', tabla);
        if (fechaDesde) params.append('fecha_desde', fechaDesde);
        if (fechaHasta) params.append('fecha_hasta', fechaHasta);
        
        const queryString = params.toString();
        const excelBtn = document.getElementById('btnExportarExcel');
        const pdfBtn = document.getElementById('btnExportarPDF');
        
        if (excelBtn) excelBtn.href = `/auditoria/exportar/excel${queryString ? '?' + queryString : ''}`;
        if (pdfBtn) pdfBtn.href = `/auditoria/exportar/pdf${queryString ? '?' + queryString : ''}`;
    }
    
    // Escuchar cambios en los filtros
    const filtros = ['filtroUsuario', 'filtroAccion', 'filtroTabla', 'filtroFechaDesde', 'filtroFechaHasta'];
    filtros.forEach(id => {
        const element = document.getElementById(id);
        if (element) {
            element.addEventListener('change', actualizarEnlacesExportacion);
            element.addEventListener('keyup', actualizarEnlacesExportacion);
        }
    });
    
    // Limpiar filtros
    document.getElementById('btnLimpiarFiltros')?.addEventListener('click', () => {
        window.location.href = '/auditoria';
    });
    
    // Inicializar enlaces
    actualizarEnlacesExportacion();

    // Función para formatear datos de forma legible
    function formatearDatos(datos, titulo, icono) {
        if (!datos || Object.keys(datos).length === 0) return '';
        
        let html = `<div class="mt-3">
                        <div class="fw-bold mb-2">${icono} ${titulo}:</div>
                        <table class="table table-sm table-bordered bg-light">
                            <thead>
                                <tr><th>Campo</th><th>Valor</th></td>
                            </thead>
                            <tbody>`;
        
        for (const [key, value] of Object.entries(datos)) {
            let campo = key;
            switch(key) {
                case 'nombre': campo = '👤 Nombre'; break;
                case 'email': campo = '📧 Email'; break;
                case 'telefono': campo = '📞 Teléfono'; break;
                case 'rol_id': campo = '🎭 Rol ID'; break;
                case 'calle_id': campo = '📍 Calle ID'; break;
                case 'estado': campo = '📌 Estado'; break;
                case 'empresa_id': campo = '🏢 Empresa ID'; break;
                case 'categoria': campo = '🏷️ Categoría'; break;
                case 'cedula': campo = '🆔 Cédula'; break;
                case 'password': campo = '🔑 Contraseña'; break;
                default: campo = key.charAt(0).toUpperCase() + key.slice(1);
            }
            
            let valor = value;
            if (value === null || value === '') valor = '<span class="text-muted">(vacío)</span>';
            if (key === 'password') valor = '••••••••';
            
            html += `<tr><td class="fw-bold" style="width: 40%">${campo}</td><td>${valor}</td></tr>`;
        }
        
        html += `</tbody></table></div>`;
        return html;
    }
    
    // Ver detalles
    document.querySelectorAll('.ver-detalle').forEach(btn => {
        btn.addEventListener('click', function() {
            const accion = this.dataset.accion;
            const tabla = this.dataset.tabla;
            const registroId = this.dataset.registroId;
            const fecha = this.dataset.fecha;
            const usuario = this.dataset.usuario;
            
            let datosAnteriores = null;
            let datosNuevos = null;
            
            try {
                if (this.dataset.datosAnteriores && this.dataset.datosAnteriores !== 'null' && this.dataset.datosAnteriores !== 'undefined') {
                    datosAnteriores = JSON.parse(this.dataset.datosAnteriores);
                }
                if (this.dataset.datosNuevos && this.dataset.datosNuevos !== 'null' && this.dataset.datosNuevos !== 'undefined') {
                    datosNuevos = JSON.parse(this.dataset.datosNuevos);
                }
            } catch(e) {
                console.error('Error al parsear datos:', e);
            }
            
            let html = `
                <div class="mb-3">
                    <div class="row">
                        <div class="col-4 fw-bold">📅 Fecha:</div>
                        <div class="col-8">${fecha}</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">👤 Usuario:</div>
                        <div class="col-8">${usuario}</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">⚡ Acción:</div>
                        <div class="col-8">
                            <span class="badge ${accion === 'CREAR' ? 'bg-success' : accion === 'EDITAR' ? 'bg-warning' : accion === 'ELIMINAR' ? 'bg-danger' : 'bg-info'}">
                                ${accion}
                            </span>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">📋 Tabla:</div>
                        <div class="col-8">${tabla}</div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-4 fw-bold">🔢 Registro ID:</div>
                        <div class="col-8">${registroId || '—'}</div>
                    </div>
                </div>
            `;
            
            if (accion === 'CREAR' && datosNuevos) {
                html += formatearDatos(datosNuevos, 'DATOS CREADOS', '✅');
            } 
            else if (accion === 'EDITAR') {
                if (datosAnteriores && Object.keys(datosAnteriores).length > 0) {
                    html += formatearDatos(datosAnteriores, 'DATOS ANTERIORES', '📄');
                } else {
                    html += `<div class="alert alert-info mt-2">No se registraron datos anteriores</div>`;
                }
                if (datosNuevos && Object.keys(datosNuevos).length > 0) {
                    html += formatearDatos(datosNuevos, 'DATOS NUEVOS', '🆕');
                }
            }
            else if (accion === 'ELIMINAR' && datosAnteriores) {
                html += formatearDatos(datosAnteriores, 'DATOS ELIMINADOS', '🗑️');
            }
            else if (accion === 'ASIGNAR' && datosNuevos) {
                html += formatearDatos(datosNuevos, 'ASIGNACIÓN REALIZADA', '🏢');
            }
            else if (accion === 'CAMBIAR_ESTADO') {
                if (datosAnteriores && Object.keys(datosAnteriores).length > 0) {
                    html += formatearDatos(datosAnteriores, 'ESTADO ANTERIOR', '📄');
                }
                if (datosNuevos && Object.keys(datosNuevos).length > 0) {
                    html += formatearDatos(datosNuevos, 'ESTADO NUEVO', '🆕');
                }
            }
            
            if ((!datosAnteriores || Object.keys(datosAnteriores).length === 0) && (!datosNuevos || Object.keys(datosNuevos).length === 0)) {
                html += `<div class="alert alert-info mt-3">No hay datos detallados disponibles para este registro.</div>`;
            }
            
            document.getElementById('detalleContent').innerHTML = html;
            new bootstrap.Modal(document.getElementById('modalDetalle')).show();
        });
    });
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
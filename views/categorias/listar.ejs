<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 Gestión de Categorías</h2>
    <a href="/categorias/nueva" class="btn btn-primary">
      ➕ Nueva Categoría
    </a>
  </div>

  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= session.mensaje %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <%= session.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>Icono</th>
          <th>Nombre</th>
          <th>Descripción</th>
          <th>Color</th>
          <th>Reportes</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (categorias && categorias.length > 0) { %>
          <% categorias.forEach(c => { %>
            <tr>
              <td style="font-size: 1.5rem;"><%= c.icono || '📌' %></td>
              <td><strong><%= c.nombre %></strong></td>
              <td><%= c.descripcion || '—' %></td>
              <td>
                <span class="badge bg-<%= c.color || 'secondary' %>">
                  <%= c.color || 'secondary' %>
                </span>
              </td>
              <td><span class="badge bg-info"><%= c.total_reportes || 0 %></span></td>
              <td>
                <a href="/categorias/<%= c.id %>/editar" class="btn btn-sm btn-warning">
                  ✏️ Editar
                </a>
                <form action="/categorias/<%= c.id %>/eliminar" method="POST" class="d-inline"
                      onsubmit="return confirm('¿Eliminar esta categoría?')">
                  <button type="submit" class="btn btn-sm btn-danger"
                          <%= c.total_reportes > 0 ? 'disabled' : '' %>>
                    🗑️ Eliminar
                  </button>
                </form>
                <% if (c.total_reportes > 0) { %>
                  <small class="text-muted d-block mt-1">Tiene reportes asociados</small>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center">No hay categorías registradas</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
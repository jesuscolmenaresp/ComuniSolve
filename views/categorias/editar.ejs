<div class="container mt-4">
  <h2>✏️ Editar Categoría</h2>

  <% if (session && session.error) { %>
    <div class="alert alert-danger">
      <%= session.error %>
    </div>
    <% session.error = null; %>
  <% } %>

  <form action="/categorias/<%= categoria.id %>/editar" method="POST" class="card p-4 shadow-sm">
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label">Nombre de la categoría *</label>
        <input type="text" name="nombre" class="form-control" 
               value="<%= categoria.nombre %>" required>
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label">Icono</label>
        <input type="text" name="icono" class="form-control" 
               value="<%= categoria.icono || '' %>">
      </div>

      <div class="col-md-6 mb-3">
        <label class="form-label">Color</label>
        <select name="color" class="form-select">
          <option value="primary" <%= categoria.color === 'primary' ? 'selected' : '' %>>Azul (primary)</option>
          <option value="secondary" <%= categoria.color === 'secondary' ? 'selected' : '' %>>Gris (secondary)</option>
          <option value="success" <%= categoria.color === 'success' ? 'selected' : '' %>>Verde (success)</option>
          <option value="danger" <%= categoria.color === 'danger' ? 'selected' : '' %>>Rojo (danger)</option>
          <option value="warning" <%= categoria.color === 'warning' ? 'selected' : '' %>>Amarillo (warning)</option>
          <option value="info" <%= categoria.color === 'info' ? 'selected' : '' %>>Celeste (info)</option>
          <option value="dark" <%= categoria.color === 'dark' ? 'selected' : '' %>>Negro (dark)</option>
        </select>
      </div>

      <div class="col-md-12 mb-3">
        <label class="form-label">Descripción</label>
        <textarea name="descripcion" class="form-control" rows="2"><%= categoria.descripcion || '' %></textarea>
      </div>
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-success">Actualizar</button>
      <a href="/categorias" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>
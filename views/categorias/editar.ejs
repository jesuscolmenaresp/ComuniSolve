<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden categoria-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 categoria-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="categoria-icon-wrapper">
              <i class="bi bi-pencil-square fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold categoria-title">Editar Categoría</h3>
          <p class="small mb-0 mt-1 categoria-subtitle">Actualiza la información de la categoría</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 categoria-body">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/categorias" class="btn btn-sm px-3 py-1 rounded-3 btn-volver-categoria">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/categorias/<%= categoria.id %>/editar" method="POST">
            
            <!-- Nombre -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 categoria-label">
                <i class="bi bi-card-heading me-1"></i> Nombre de la categoría *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3 categoria-input" required 
                     value="<%= categoria.nombre %>"
                     placeholder="Ej: Agua, Electricidad, Vialidad, Salud">
            </div>

            <!-- Icono - Selector visual -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 categoria-label">
                <i class="bi bi-emoji-smile me-1"></i> Icono (opcional)
              </label>
              
              <!-- Selector de iconos -->
              <div class="row g-2 mb-2">
                <div class="col-12">
                  <div class="d-flex flex-wrap gap-2" id="iconSelector">
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="💧">💧 Agua</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="⚡">⚡ Electricidad</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🚧">🚧 Vialidad</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🏥">🏥 Salud</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🗑️">🗑️ Basura</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🌳">🌳 Áreas Verdes</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🐶">🐶 Animales</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🔊">🔊 Ruido</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="💡">💡 Alumbrado</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="📦">📦 Otro</button>
                  </div>
                </div>
              </div>
              
              <input type="text" name="icono" id="iconoInput" class="form-control rounded-3 categoria-input" 
                     value="<%= categoria.icono || '' %>"
                     placeholder="💧, ⚡, 🚧, 🏥 o ingresa tu propio emoji">
              <small class="text-muted categoria-help">Puedes seleccionar un icono de la lista o escribir tu propio emoji</small>
            </div>

            <!-- Color - Selector visual -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 categoria-label">
                <i class="bi bi-palette me-1"></i> Color
              </label>
              
              <!-- Selector de colores visual -->
              <div class="row g-2 mb-2">
                <div class="col-12">
                  <div class="d-flex flex-wrap gap-2" id="colorSelector">
                    <button type="button" class="btn color-option rounded-3" data-color="primary" style="background-color: #0d6efd; width: 50px; height: 50px; border-radius: 12px;" title="Azul"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="secondary" style="background-color: #6c757d; width: 50px; height: 50px; border-radius: 12px;" title="Gris"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="success" style="background-color: #28a745; width: 50px; height: 50px; border-radius: 12px;" title="Verde"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="danger" style="background-color: #dc3545; width: 50px; height: 50px; border-radius: 12px;" title="Rojo"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="warning" style="background-color: #ffc107; width: 50px; height: 50px; border-radius: 12px;" title="Amarillo"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="info" style="background-color: #17a2b8; width: 50px; height: 50px; border-radius: 12px;" title="Celeste"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="dark" style="background-color: #212529; width: 50px; height: 50px; border-radius: 12px;" title="Negro"></button>
                  </div>
                </div>
              </div>
              
              <select name="color" id="colorSelect" class="form-select rounded-3 categoria-select">
                <option value="primary" <%= categoria.color === 'primary' ? 'selected' : '' %>>🔵 Azul</option>
                <option value="secondary" <%= categoria.color === 'secondary' ? 'selected' : '' %>>⚪ Gris</option>
                <option value="success" <%= categoria.color === 'success' ? 'selected' : '' %>>🟢 Verde</option>
                <option value="danger" <%= categoria.color === 'danger' ? 'selected' : '' %>>🔴 Rojo</option>
                <option value="warning" <%= categoria.color === 'warning' ? 'selected' : '' %>>🟡 Amarillo</option>
                <option value="info" <%= categoria.color === 'info' ? 'selected' : '' %>>🔷 Celeste</option>
                <option value="dark" <%= categoria.color === 'dark' ? 'selected' : '' %>>⚫ Negro</option>
              </select>
              <small class="text-muted categoria-help">Selecciona un color para identificar la categoría</small>
            </div>

            <!-- Descripción -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 categoria-label">
                <i class="bi bi-file-text me-1"></i> Descripción (opcional)
              </label>
              <textarea name="descripcion" class="form-control rounded-3 categoria-textarea" rows="3"
                        placeholder="Breve descripción de la categoría..."><%= categoria.descripcion || '' %></textarea>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar-categoria">
                <i class="bi bi-save me-2"></i> Actualizar categoría
              </button>
              <a href="/categorias" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar-categoria">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 categoria-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 categoria-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Seleccionar el icono actual en la lista si existe
  const iconoActual = document.getElementById('iconoInput').value;
  if (iconoActual) {
    const btnExistente = document.querySelector(`.icon-option[data-icon="${iconoActual}"]`);
    if (btnExistente) {
      btnExistente.classList.remove('btn-outline-secondary');
      btnExistente.classList.add('btn-primary');
    }
  }

  // Selector de iconos
  document.querySelectorAll('.icon-option').forEach(btn => {
    btn.addEventListener('click', function() {
      const icon = this.dataset.icon;
      document.getElementById('iconoInput').value = icon;
      
      // Resaltar el seleccionado
      document.querySelectorAll('.icon-option').forEach(b => {
        b.classList.remove('btn-primary');
        b.classList.add('btn-outline-secondary');
      });
      this.classList.remove('btn-outline-secondary');
      this.classList.add('btn-primary');
    });
  });

  // Selector de colores visual
  const colorActual = document.getElementById('colorSelect').value;
  if (colorActual) {
    const btnColorExistente = document.querySelector(`.color-option[data-color="${colorActual}"]`);
    if (btnColorExistente) {
      btnColorExistente.style.border = '3px solid #fd6704bd';
      btnColorExistente.style.transform = 'scale(1.05)';
    }
  }

  document.querySelectorAll('.color-option').forEach(btn => {
    btn.addEventListener('click', function() {
      const color = this.dataset.color;
      document.getElementById('colorSelect').value = color;
      
      // Resaltar el seleccionado con borde
      document.querySelectorAll('.color-option').forEach(b => {
        b.style.border = '2px solid #f0d5c0';
        b.style.transform = 'scale(1)';
      });
      this.style.border = '3px solid #fd6704bd';
      this.style.transform = 'scale(1.05)';
    });
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .categoria-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .categoria-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .categoria-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .categoria-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .categoria-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .categoria-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver-categoria {
    border: 1px solid #f0d5c0;

    transition: all 0.3s ease;
  }
  .categoria-input:focus, .categoria-select:focus, .categoria-textarea:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Ayuda */
  .categoria-help {
    color: #8B6B5A;
  }
  
  /* Botón guardar */
  .btn-guardar-categoria {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar-categoria:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar-categoria {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar-categoria:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .categoria-badge {
    color: #8B6B5A !important;
  }
  .categoria-badge i {
    color: #17a2b8;
  }
  
  /* Selector de colores */
  .color-option {
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .color-option:hover {
    transform: scale(1.05);
    border: 3px solid #fd6704bd !important;
  }
  
  /* Selector de iconos */
  .icon-option {
    transition: all 0.2s ease;
  }
  .icon-option:hover {
    transform: translateY(-2px);
  }
  .btn-primary {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .categoria-card {
    background: #27272a;
  }
  
  body.dark-mode .categoria-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .categoria-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .categoria-body {
    background: #27272a;
  }
  
  body.dark-mode .btn-volver-categoria {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-categoria:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .categoria-label {
    color: #e4e4e7;
  }
  body.dark-mode .categoria-label i {
    color: #f7931e;
  }
  
  body.dark-mode .categoria-input,
  body.dark-mode .categoria-select,
  body.dark-mode .categoria-textarea {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .categoria-input:focus,
  body.dark-mode .categoria-select:focus,
  body.dark-mode .categoria-textarea:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .categoria-input::placeholder,
  body.dark-mode .categoria-textarea::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .categoria-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-cancelar-categoria {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar-categoria:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .categoria-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .categoria-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  body.dark-mode .color-option {
    border: 2px solid #3f3f46;
  }
  
  body.dark-mode .btn-outline-secondary {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-outline-secondary:hover {
    background: #3f3f46;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
</style>
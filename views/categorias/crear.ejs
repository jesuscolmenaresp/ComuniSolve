<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-tag fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;">Nueva Categoría</h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">Completa el formulario para crear una nueva categoría</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/categorias" class="btn btn-sm px-3 py-1 rounded-3" style="border: 1px solid #f0d5c0; color: #5D4037;">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/categorias" method="POST">
            
            <!-- Nombre -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-card-heading me-1" style="color: #fd6704bd;"></i> Nombre de la categoría *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3" required 
                     placeholder="Ej: Agua, Electricidad, Vialidad, Salud"
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
            </div>

            <!-- Icono - Selector visual -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-emoji-smile me-1" style="color: #fd6704bd;"></i> Icono (opcional)
              </label>
              
              <!-- Selector de iconos -->
              <div class="row g-2 mb-2">
                <div class="col-12">
                  <div class="d-flex flex-wrap gap-2" id="iconSelector">
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="💧">💧 Agua</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="⚡">⚡ Electricidad</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🚧">🚧 Vialidad</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🏥">🏥 Salud</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🗑️">🗑️ Basura</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🌳">🌳 Áreas Verdes</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🐶">🐶 Animales</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="🔊">🔊 Ruido</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="💡">💡 Alumbrado</button>
                    <button type="button" class="btn btn-outline-secondary rounded-3 icon-option" data-icon="📦">📦 Otro</button>
                  </div>
                </div>
              </div>
              
              <input type="text" name="icono" id="iconoInput" class="form-control rounded-3" 
                     placeholder="💧, ⚡, 🚧, 🏥 o ingresa tu propio emoji"
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              <small class="text-muted" style="color: #8B6B5A;">Puedes seleccionar un icono de la lista o escribir tu propio emoji</small>
            </div>

            <!-- Color - Selector visual -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-palette me-1" style="color: #fd6704bd;"></i> Color
              </label>
              
              <!-- Selector de colores visual -->
              <div class="row g-2 mb-2">
                <div class="col-12">
                  <div class="d-flex flex-wrap gap-2" id="colorSelector">
                    <button type="button" class="btn color-option rounded-3" data-color="primary" style="background-color: #0d6efd; width: 50px; height: 50px; border-radius: 12px;" title="Azul"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="secondary" style="background-color: #6c757d; width: 50px; height: 50px; border-radius: 12px;" title="Gris"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="success" style="background-color: #28a745; width: 50px; height: 50px; border-radius: 12px;" title="Verde"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="danger" style="background-color: #dc3545; width: 50px; height: 50px; border-radius: 12px;" title="Rojo"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="warning" style="background-color: #ffc107; width: 50px; height: 50px; border-radius: 12px;" title="Amarillo"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="info" style="background-color: #17a2b8; width: 50px; height: 50px; border-radius: 12px;" title="Celeste"></button>
                    <button type="button" class="btn color-option rounded-3" data-color="dark" style="background-color: #212529; width: 50px; height: 50px; border-radius: 12px;" title="Negro"></button>
                  </div>
                </div>
              </div>
              
              <select name="color" id="colorSelect" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                <option value="primary">🔵 Azul</option>
                <option value="secondary">⚪ Gris</option>
                <option value="success">🟢 Verde</option>
                <option value="danger">🔴 Rojo</option>
                <option value="warning">🟡 Amarillo</option>
                <option value="info">🔷 Celeste</option>
                <option value="dark">⚫ Negro</option>
              </select>
              <small class="text-muted" style="color: #8B6B5A;">Selecciona un color para identificar la categoría</small>
            </div>

            <!-- Descripción -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-file-text me-1" style="color: #fd6704bd;"></i> Descripción (opcional)
              </label>
              <textarea name="descripcion" class="form-control rounded-3" rows="3"
                        placeholder="Breve descripción de la categoría..."
                        style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;"></textarea>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;">
                <i class="bi bi-save me-2"></i> Guardar categoría
              </button>
              <a href="/categorias" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                 style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Selector de iconos
  document.querySelectorAll('.icon-option').forEach(btn => {
    btn.addEventListener('click', function() {
      const icon = this.dataset.icon;
      document.getElementById('iconoInput').value = icon;
      
      // Resaltar el seleccionado
      document.querySelectorAll('.icon-option').forEach(b => {
        b.classList.remove('btn-primary');
        b.classList.add('btn-outline-secondary');
      });
      this.classList.remove('btn-outline-secondary');
      this.classList.add('btn-primary');
    });
  });

  // Selector de colores visual
  document.querySelectorAll('.color-option').forEach(btn => {
    btn.addEventListener('click', function() {
      const color = this.dataset.color;
      document.getElementById('colorSelect').value = color;
      
      // Resaltar el seleccionado con borde
      document.querySelectorAll('.color-option').forEach(b => {
        b.style.border = '2px solid #f0d5c0';
        b.style.transform = 'scale(1)';
      });
      this.style.border = '3px solid #fd6704bd';
      this.style.transform = 'scale(1.05)';
    });
  });
</script>

<style>
  .color-option {
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .color-option:hover {
    transform: scale(1.05);
    border: 3px solid #fd6704bd !important;
  }
  .icon-option {
    transition: all 0.2s ease;
  }
  .icon-option:hover {
    transform: translateY(-2px);
  }
  .btn-primary {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
  }
</style>
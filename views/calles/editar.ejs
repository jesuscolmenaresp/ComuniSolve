<div class="container mt-4">
  <h2>✏️ Editar Calle</h2>

  <% if (session && session.error) { %>
    <div class="alert alert-danger">
      <%= session.error %>
    </div>
    <% session.error = null; %>
  <% } %>

  <form action="/calles/<%= calle.id %>/editar" method="POST">
    <div class="mb-3">
      <label for="nombre" class="form-label">Nombre de la calle</label>
      <input type="text" class="form-control" name="nombre" id="nombre" 
             value="<%= calle.nombre %>" required>
    </div>

    <div class="mb-3">
      <label for="comunidad_id" class="form-label">Comunidad a la que pertenece</label>
      <select name="comunidad_id" id="comunidad_id" class="form-select">
        <option value="">-- Seleccione una comunidad --</option>
        <% if (comunidades && comunidades.length > 0) { %>
          <% comunidades.forEach(c => { %>
            <option value="<%= c.id %>" <%= calle.comunidad_id == c.id ? 'selected' : '' %>>
              <%= c.nombre %>
            </option>
          <% }) %>
        <% } %>
      </select>
    </div>

    <div class="mb-3">
      <label for="lider_id" class="form-label">Asignar líder comunitario</label>
      <select name="lider_id" id="lider_id" class="form-select">
        <option value="">-- Ninguno --</option>
        <% if (lideres && lideres.length > 0) { %>
          <% lideres.forEach(l => { %>
            <option value="<%= l.id %>" <%= calle.lider_id == l.id ? 'selected' : '' %>>
              <%= l.nombre %>
            </option>
          <% }) %>
        <% } %>
      </select>
    </div>

    <div class="mb-3">
      <label for="jefe_id" class="form-label">Asignar jefe de calle</label>
      <select name="jefe_id" id="jefe_id" class="form-select">
        <option value="">-- Ninguno --</option>
        <% if (jefes && jefes.length > 0) { %>
          <% jefes.forEach(j => { %>
            <option value="<%= j.id %>" <%= calle.jefe_id == j.id ? 'selected' : '' %>>
              <%= j.nombre %>
            </option>
          <% }) %>
        <% } %>
      </select>
    </div>

    <button type="submit" class="btn btn-success">Actualizar</button>
    <a href="/calles" class="btn btn-secondary">Cancelar</a>
  </form>
</div>
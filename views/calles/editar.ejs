<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden calle-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 calle-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="calle-icon-wrapper">
              <i class="bi bi-pencil-square fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold calle-title">Editar Calle</h3>
          <p class="small mb-0 mt-1 calle-subtitle">Actualiza la información de la calle</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 calle-body">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/calles" class="btn btn-sm px-3 py-1 rounded-3 btn-volver-calle">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/calles/<%= calle.id %>/editar" method="POST">
            
            <!-- Nombre de la calle -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 calle-label">
                <i class="bi bi-signpost-2 me-1"></i> Nombre de la calle *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3 calle-input" required
                     value="<%= calle.nombre %>">
            </div>

            <!-- Comunidad -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 calle-label">
                <i class="bi bi-building me-1"></i> Comunidad a la que pertenece
              </label>
              <select name="comunidad_id" class="form-select rounded-3 calle-select">
                <option value="">-- Seleccione una comunidad --</option>
                <% if (comunidades && comunidades.length > 0) { %>
                  <% comunidades.forEach(c => { %>
                    <option value="<%= c.id %>" <%= calle.comunidad_id == c.id ? 'selected' : '' %>>
                      <%= c.nombre %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
              <small class="text-muted calle-help">Selecciona la comunidad a la que pertenece esta calle</small>
            </div>

            <!-- Líder comunitario -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 calle-label">
                <i class="bi bi-person-badge me-1"></i> Asignar líder comunitario
              </label>
              <select name="lider_id" class="form-select rounded-3 calle-select">
                <option value="">-- Ninguno --</option>
                <% if (lideres && lideres.length > 0) { %>
                  <% lideres.forEach(l => { %>
                    <option value="<%= l.id %>" <%= calle.lider_id == l.id ? 'selected' : '' %>>
                      <%= l.nombre %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
              <small class="text-muted calle-help">Persona encargada de supervisar la calle</small>
            </div>

            <!-- Jefe de calle -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 calle-label">
                <i class="bi bi-person-check me-1"></i> Asignar jefe de calle
              </label>
              <select name="jefe_id" class="form-select rounded-3 calle-select">
                <option value="">-- Ninguno --</option>
                <% if (jefes && jefes.length > 0) { %>
                  <% jefes.forEach(j => { %>
                    <option value="<%= j.id %>" <%= calle.jefe_id == j.id ? 'selected' : '' %>>
                      <%= j.nombre %>
                    </option>
                  <% }) %>
                <% } %>
              </select>
              <small class="text-muted calle-help">Persona encargada directamente de la calle</small>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar-calle">
                <i class="bi bi-save me-2"></i> Actualizar calle
              </button>
              <a href="/calles" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar-calle">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 calle-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 calle-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .calle-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .calle-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .calle-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .calle-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .calle-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .calle-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver-calle {
    border: 1px solid #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-calle:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Labels */
  .calle-label {
    color: #5D4037;
  }
  .calle-label i {
    color: #fd6704bd;
  }
  
  /* Inputs y selects */
  .calle-input, .calle-select {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .calle-input:focus, .calle-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Ayuda */
  .calle-help {
    color: #8B6B5A;
  }
  
  /* Botón guardar */
  .btn-guardar-calle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar-calle:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar-calle {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar-calle:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .calle-badge {
    color: #8B6B5A !important;
  }
  .calle-badge i {
    color: #17a2b8;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .calle-card {
    background: #27272a;
  }
  
  body.dark-mode .calle-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .calle-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .calle-body {
    background: #27272a;
  }
  
  body.dark-mode .btn-volver-calle {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-calle:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .calle-label {
    color: #e4e4e7;
  }
  body.dark-mode .calle-label i {
    color: #f7931e;
  }
  
  body.dark-mode .calle-input,
  body.dark-mode .calle-select {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .calle-input:focus,
  body.dark-mode .calle-select:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .calle-input::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .calle-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-cancelar-calle {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar-calle:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .calle-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .calle-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .form-control:focus, .form-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  body.dark-mode .form-control:focus, body.dark-mode .form-select:focus {
    border-color: #f7931e;
  }
</style>
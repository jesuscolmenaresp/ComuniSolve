<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-geo-alt fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;">Nueva Calle</h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">Registra una nueva calle en la comunidad</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/calles" class="btn btn-sm px-3 py-1 rounded-3" style="border: 1px solid #f0d5c0; color: #5D4037;">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/calles/nueva" method="POST">
            
            <!-- Nombre de la calle -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-signpost-2 me-1" style="color: #fd6704bd;"></i> Nombre de la calle *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3" required
                     placeholder="Ej: Brisas 2, Calle Principal, Av. Libertador"
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              <small class="text-muted" style="color: #8B6B5A;">Nombre oficial o conocido de la calle</small>
            </div>

            <!-- Comunidad -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-building me-1" style="color: #fd6704bd;"></i> Comunidad a la que pertenece
              </label>
              <select name="comunidad_id" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                <option value="">-- Seleccione una comunidad --</option>
                <% if (comunidades && comunidades.length > 0) { %>
                  <% comunidades.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nombre %></option>
                  <% }) %>
                <% } else { %>
                  <option value="" disabled>No hay comunidades registradas</option>
                <% } %>
              </select>
              <small class="text-muted" style="color: #8B6B5A;">Selecciona la comunidad a la que pertenece esta calle</small>
            </div>

            <!-- Líder comunitario -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-person-badge me-1" style="color: #fd6704bd;"></i> Asignar líder comunitario
              </label>
              <select name="lider_id" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                <option value="">-- Ninguno --</option>
                <% if (lideres && lideres.length > 0) { %>
                  <% lideres.forEach(l => { %>
                    <option value="<%= l.id %>"><%= l.nombre %></option>
                  <% }) %>
                <% } else { %>
                  <option value="" disabled>No hay líderes disponibles</option>
                <% } %>
              </select>
              <small class="text-muted" style="color: #8B6B5A;">Persona encargada de supervisar la calle</small>
            </div>

            <!-- Jefe de calle -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-person-check me-1" style="color: #fd6704bd;"></i> Asignar jefe de calle
              </label>
              <select name="jefe_id" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                <option value="">-- Ninguno --</option>
                <% if (jefes && jefes.length > 0) { %>
                  <% jefes.forEach(j => { %>
                    <option value="<%= j.id %>"><%= j.nombre %></option>
                  <% }) %>
                <% } else { %>
                  <option value="" disabled>No hay jefes disponibles</option>
                <% } %>
              </select>
              <small class="text-muted" style="color: #8B6B5A;">Persona encargada directamente de la calle</small>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;">
                <i class="bi bi-save me-2"></i> Guardar calle
              </button>
              <a href="/calles" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                 style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  .form-control:focus, .form-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
</style>
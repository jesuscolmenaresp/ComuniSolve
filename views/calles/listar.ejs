<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 calles-title">
        <i class="bi bi-geo-alt me-2"></i> Gestión de Calles
      </h2>
      <p class="text-muted small mb-0 calles-subtitle">Administra las calles y su asignación a líderes y jefes</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/calles/inactivos" class="btn btn-sm btn-outline-danger px-3 py-2 fw-semibold rounded-3">
        <i class="bi bi-eye-slash me-1"></i> Ver inactivas
      </a>
      <a href="/calles/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-nueva-calle">
        <i class="bi bi-plus-circle me-1"></i> Nueva Calle
      </a>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- ========== FILTROS Y CONTADOR ========== -->
  <div class="row g-3 mb-4">
    <!-- Filtros -->
    <div class="col-12 col-md-9">
      <div class="card border-0 rounded-4 shadow-sm p-3 filtros-card">
        <div class="row g-2 align-items-end">
          <!-- Filtro por Comunidad -->
          <div class="col-12 col-sm-6 col-md-4">
            <label class="form-label fw-semibold small mb-1 filtro-label">
              <i class="bi bi-building me-1"></i> Comunidad
            </label>
            <select id="filtroComunidad" class="form-select form-select-sm rounded-3 filtro-select">
              <option value="">Todas las comunidades</option>
              <% if (comunidades && comunidades.length > 0) { %>
                <% comunidades.forEach(com => { %>
                  <option value="<%= com.id %>"><%= com.nombre %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <!-- Filtro por Líder -->
          <div class="col-12 col-sm-6 col-md-3">
            <label class="form-label fw-semibold small mb-1 filtro-label">
              <i class="bi bi-person-badge me-1"></i> Líder
            </label>
            <select id="filtroLider" class="form-select form-select-sm rounded-3 filtro-select">
              <option value="">Todos los líderes</option>
              <% if (lideres && lideres.length > 0) { %>
                <% lideres.forEach(l => { %>
                  <option value="<%= l.id %>"><%= l.nombre %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <!-- Filtro por Jefe -->
          <div class="col-12 col-sm-6 col-md-3">
            <label class="form-label fw-semibold small mb-1 filtro-label">
              <i class="bi bi-person-check me-1"></i> Jefe de Calle
            </label>
            <select id="filtroJefe" class="form-select form-select-sm rounded-3 filtro-select">
              <option value="">Todos los jefes</option>
              <% if (jefes && jefes.length > 0) { %>
                <% jefes.forEach(j => { %>
                  <option value="<%= j.id %>"><%= j.nombre %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <!-- Botón Limpiar Filtros -->
          <div class="col-12 col-sm-6 col-md-2">
            <button id="btnLimpiarFiltros" class="btn btn-sm w-100 rounded-3 btn-limpiar-filtros">
              <i class="bi bi-arrow-counterclockwise me-1"></i> Limpiar
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Contador de Calles -->
    <div class="col-12 col-md-3">
      <div class="card border-0 rounded-4 shadow-sm h-100 contador-card">
        <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="contador-icon">
              <i class="bi bi-signpost-2-fill"></i>
            </div>
            <div class="text-center">
              <span class="contador-numero" id="totalCalles"><%= calles ? calles.length : 0 %></span>
              <span class="contador-texto d-block">Calles registradas</span>
            </div>
          </div>
          <small class="text-muted mt-1" id="callesFiltradasInfo">
            Mostrando <span id="callesMostradas"><%= calles ? calles.length : 0 %></span> calles
          </small>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabla de calles -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden calles-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 calles-tabla" id="tablaCalles">
          <thead class="calles-tabla-header">
            <tr class="text-center">
              <th><i class="bi bi-signpost-2"></i> Nombre</th>
              <th><i class="bi bi-building"></i> Comunidad</th>
              <th><i class="bi bi-person-badge"></i> Líder asignado</th>
              <th><i class="bi bi-person-check"></i> Jefe de calle</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody id="tablaCallesBody">
            <% if (calles && calles.length > 0) { %>
              <% calles.forEach(c => { %>
                <tr class="align-middle text-center calle-fila" 
                    data-comunidad="<%= c.comunidad_id || '' %>"
                    data-lider="<%= c.lider_id || '' %>"
                    data-jefe="<%= c.jefe_id || '' %>">
                  <td class="fw-semibold text-start calle-nombre"><%= c.nombre %></td>
                  <td>
                    <% if (c.comunidad_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill badge-comunidad">
                        <i class="bi bi-building me-1"></i> <%= c.comunidad_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignada —</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.lider_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill badge-lider">
                        <i class="bi bi-person-badge me-1"></i> <%= c.lider_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignado —</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.jefe_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill badge-jefe">
                        <i class="bi bi-person-check me-1"></i> <%= c.jefe_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignado —</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/calles/<%= c.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3 btn-editar-calle">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/calles/<%= c.id %>/desactivar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Desactivar esta calle? Puede afectar algun reporte asociado.')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3 btn-desactivar-calle">
                          <i class="bi bi-person-x me-1"></i> Desactivar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr id="filaVacia">
                <td colspan="5" class="text-center py-5 empty-state-calles">
                  <i class="bi bi-geo-alt fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay calles registradas</p>
                  <a href="/calles/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-crear-calle">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera calle
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted calles-info">
      <i class="bi bi-info-circle me-1"></i> 
      Las calles pueden ser asignadas a líderes comunitarios y jefes de calle
    </small>
  </div>
</div>

<!-- ========== SCRIPTS PARA FILTROS ========== -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filtroComunidad = document.getElementById('filtroComunidad');
    const filtroLider = document.getElementById('filtroLider');
    const filtroJefe = document.getElementById('filtroJefe');
    const btnLimpiar = document.getElementById('btnLimpiarFiltros');
    const tablaBody = document.getElementById('tablaCallesBody');
    const totalCallesSpan = document.getElementById('totalCalles');
    const callesMostradasSpan = document.getElementById('callesMostradas');

    function aplicarFiltros() {
      const comunidadId = filtroComunidad.value;
      const liderId = filtroLider.value;
      const jefeId = filtroJefe.value;

      const filas = tablaBody.querySelectorAll('.calle-fila');
      let visibles = 0;

      filas.forEach(fila => {
        const dataComunidad = fila.dataset.comunidad || '';
        const dataLider = fila.dataset.lider || '';
        const dataJefe = fila.dataset.jefe || '';

        let mostrar = true;

        if (comunidadId && dataComunidad !== comunidadId) {
          mostrar = false;
        }

        if (liderId && dataLider !== liderId) {
          mostrar = false;
        }

        if (jefeId && dataJefe !== jefeId) {
          mostrar = false;
        }

        if (mostrar) {
          fila.style.display = '';
          visibles++;
        } else {
          fila.style.display = 'none';
        }
      });

      // Mostrar/ocultar fila vacía
      const filaVacia = document.getElementById('filaVacia');
      if (filaVacia) {
        if (visibles === 0 && filas.length > 0) {
          filaVacia.style.display = '';
          filaVacia.querySelector('td').innerHTML = `
            <i class="bi bi-search fs-1 d-block mb-2"></i>
            <p class="mb-0">No hay calles que coincidan con los filtros</p>
            <button class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-limpiar-filtros" onclick="document.getElementById('btnLimpiarFiltros').click()">
              <i class="bi bi-arrow-counterclockwise me-1"></i> Limpiar filtros
            </button>
          `;
        } else if (visibles === 0 && filas.length === 0) {
          // Ya hay mensaje de "No hay calles registradas"
        } else {
          filaVacia.style.display = 'none';
        }
      }

      // Actualizar contadores
      const total = filas.length;
      totalCallesSpan.textContent = total;
      callesMostradasSpan.textContent = visibles;

      // Actualizar texto informativo
      const info = document.getElementById('callesFiltradasInfo');
      if (comunidadId || liderId || jefeId) {
        info.innerHTML = `Mostrando <span id="callesMostradas">${visibles}</span> de <span id="totalCalles">${total}</span> calles <span class="badge bg-primary rounded-pill ms-1">Filtrado</span>`;
      } else {
        info.innerHTML = `Mostrando <span id="callesMostradas">${visibles}</span> calles`;
      }
    }

    // Event listeners
    filtroComunidad.addEventListener('change', aplicarFiltros);
    filtroLider.addEventListener('change', aplicarFiltros);
    filtroJefe.addEventListener('change', aplicarFiltros);

    btnLimpiar.addEventListener('click', function() {
      filtroComunidad.value = '';
      filtroLider.value = '';
      filtroJefe.value = '';
      aplicarFiltros();
    });

    // Inicializar
    aplicarFiltros();
  });
</script>


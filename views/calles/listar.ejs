<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1" style="color: #5D4037;">
        <i class="bi bi-geo-alt me-2" style="color: #fd6704bd;"></i> Gestión de Calles
      </h2>
      <p class="text-muted small mb-0" style="color: #8B6B5A;">Administra las calles y su asignación a líderes y jefes</p>
    </div>
    <a href="/calles/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
      <i class="bi bi-plus-circle me-1"></i> Nueva Calle
    </a>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Tabla de calles -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr class="text-center">
              <th><i class="bi bi-signpost-2"></i> Nombre</th>
              <th><i class="bi bi-building"></i> Comunidad</th>
              <th><i class="bi bi-person-badge"></i> Líder asignado</th>
              <th><i class="bi bi-person-check"></i> Jefe de calle</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (calles && calles.length > 0) { %>
              <% calles.forEach(c => { %>
                <tr class="align-middle text-center">
                  <td class="fw-semibold text-start" style="color: #5D4037;"><%= c.nombre %></td>
                  <td>
                    <% if (c.comunidad_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                        <i class="bi bi-building me-1"></i> <%= c.comunidad_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignada —</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.lider_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white;">
                        <i class="bi bi-person-badge me-1"></i> <%= c.lider_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignado —</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.jefe_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill" style="background: linear-gradient(135deg, #17a2b8 0%, #0dcaf0 100%); color: white;">
                        <i class="bi bi-person-check me-1"></i> <%= c.jefe_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignado —</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/calles/<%= c.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); color: #333; border: none;">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/calles/<%= c.id %>/eliminar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Eliminar esta calle? Esto afectará los reportes asociados.')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3" 
                                style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none;">
                          <i class="bi bi-trash me-1"></i> Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center py-5">
                  <i class="bi bi-geo-alt fs-1 text-muted d-block mb-2"></i>
                  <p class="text-muted mb-0">No hay calles registradas</p>
                  <a href="/calles/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera calle
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted" style="color: #8B6B5A;">
      <i class="bi bi-info-circle me-1" style="color: #fd6704bd;"></i> 
      Las calles pueden ser asignadas a líderes comunitarios y jefes de calle
    </small>
  </div>
</div>

<style>
  .table-hover tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  .btn-sm {
    transition: all 0.2s ease;
  }
  .btn-sm:hover {
    transform: translateY(-2px);
  }
  .badge {
    font-weight: normal;
  }
</style>
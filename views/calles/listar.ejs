<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 calles-title">
        <i class="bi bi-geo-alt me-2"></i> Gestión de Calles
      </h2>
      <p class="text-muted small mb-0 calles-subtitle">Administra las calles y su asignación a líderes y jefes</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/calles/inactivos" class="btn btn-sm btn-outline-danger px-3 py-2 fw-semibold rounded-3">
        <i class="bi bi-eye-slash me-1"></i> Ver inactivas
      </a>
      <a href="/calles/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-nueva-calle">
        <i class="bi bi-plus-circle me-1"></i> Nueva Calle
      </a>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Tabla de calles -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden calles-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 calles-tabla">
          <thead class="calles-tabla-header">
            <tr class="text-center">
              <th><i class="bi bi-signpost-2"></i> Nombre</th>
              <th><i class="bi bi-building"></i> Comunidad</th>
              <th><i class="bi bi-person-badge"></i> Líder asignado</th>
              <th><i class="bi bi-person-check"></i> Jefe de calle</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (calles && calles.length > 0) { %>
              <% calles.forEach(c => { %>
                <tr class="align-middle text-center calle-fila">
                  <td class="fw-semibold text-start calle-nombre"><%= c.nombre %></td>
                  <td>
                    <% if (c.comunidad_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill badge-comunidad">
                        <i class="bi bi-building me-1"></i> <%= c.comunidad_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignada —</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.lider_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill badge-lider">
                        <i class="bi bi-person-badge me-1"></i> <%= c.lider_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignado —</span>
                    <% } %>
                  </td>
                  <td>
                    <% if (c.jefe_nombre) { %>
                      <span class="badge px-3 py-1 rounded-pill badge-jefe">
                        <i class="bi bi-person-check me-1"></i> <%= c.jefe_nombre %>
                      </span>
                    <% } else { %>
                      <span class="text-muted">— No asignado —</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/calles/<%= c.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3 btn-editar-calle">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/calles/<%= c.id %>/desactivar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Desactivar esta calle? Puede afectar algun reporte asociado.')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3 btn-desactivar-calle">
                          <i class="bi bi-person-x me-1"></i> Desactivar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center py-5 empty-state-calles">
                  <i class="bi bi-geo-alt fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay calles registradas</p>
                  <a href="/calles/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-crear-calle">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera calle
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted calles-info">
      <i class="bi bi-info-circle me-1"></i> 
      Las calles pueden ser asignadas a líderes comunitarios y jefes de calle
    </small>
  </div>
</div>

<style>
  .calles-title {
    color: #5D4037;
  }
  .calles-title i {
    color: #fd6704bd;
  }
  .calles-subtitle {
    color: #8B6B5A;
  }
  
  .btn-nueva-calle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-nueva-calle:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  .calles-card {
    background: white;
  }
  
  .calles-tabla {
    background: white;
  }
  
  .calles-tabla-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .calles-tabla-header th {
    color: #5D4037;
    font-weight: 600;
    border-bottom: 2px solid #fd6704bd;
  }
  
  .calle-fila {
    border-bottom-color: #f0d5c0;
  }
  
  .calle-fila:hover {
    background-color: #fff8f0 !important;
  }
  
  .calle-nombre {
    color: #5D4037;
  }
  
  .badge-comunidad {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  .badge-lider {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
  }
  
  .badge-jefe {
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    color: white;
  }
  
  .btn-editar-calle {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    color: #333;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-editar-calle:hover {
    transform: translateY(-2px);
  }
  
  .btn-desactivar-calle {
    background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-desactivar-calle:hover {
    transform: translateY(-2px);
  }
  
  .empty-state-calles i {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-state-calles p {
    color: #6c757d;
  }
  
  .btn-crear-calle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-crear-calle:hover {
    transform: translateY(-2px);
  }
  
  .calles-info {
    color: #8B6B5A;
  }
  .calles-info i {
    color: #fd6704bd;
  }
  
  body.dark-mode .calles-title {
    color: #e4e4e7;
  }
  body.dark-mode .calles-subtitle {
    color: #a1a1aa;
  }
  
  body.dark-mode .calles-card {
    background: #1a1a2e !important;
  }
  
  body.dark-mode .calles-tabla {
    background-color: #1a1a2e !important;
  }
  
  body.dark-mode .calles-tabla tbody tr {
    background-color: #1a1a2e !important;
  }
  
  body.dark-mode .calles-tabla tbody tr:hover {
    background-color: #2d2d44 !important;
  }
  
  body.dark-mode .calles-tabla td {
    color: #e4e4e7 !important;
    background-color: transparent !important;
  }
  
  body.dark-mode .calles-tabla .calle-nombre {
    color: #e4e4e7 !important;
  }
  
  body.dark-mode .calles-tabla .text-muted {
    color: #a1a1aa !important;
  }
  
  body.dark-mode .calles-tabla-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  
  body.dark-mode .calles-tabla-header th {
    color: #e4e4e7;
    border-bottom-color: #f7931e;
    background: transparent !important;
  }
  
  body.dark-mode .badge-comunidad {
    background: linear-gradient(135deg, #f7931e 0%, #e08515 100%);
  }
  
  body.dark-mode .badge-lider {
    background: linear-gradient(135deg, #0d6e2e 0%, #0a5a25 100%);
  }
  
  body.dark-mode .badge-jefe {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
  }
  
  body.dark-mode .empty-state-calles i {
    color: #a1a1aa;
  }
  body.dark-mode .empty-state-calles p {
    color: #a1a1aa;
  }
  
  body.dark-mode .calles-info {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-editar-calle {
    background: linear-gradient(135deg, #e0a800 0%, #c69500 100%);
    color: #333;
  }
  
  body.dark-mode .btn-desactivar-calle {
    background: linear-gradient(135deg, #e8590c 0%, #c94a0a 100%);
    color: white;
  }
  
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .badge {
    font-weight: normal;
  }
</style>
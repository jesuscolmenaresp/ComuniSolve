  .backups-title {
    color: #5D4037;
  }
  .backups-title i {
    color: #fd6704bd;
  }
  .backups-subtitle {
    color: #8B6B5A;
  }
  
  /* Botones */
  .btn-volver-backups {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-backups:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  .btn-nuevo-backup {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;

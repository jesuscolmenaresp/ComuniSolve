<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 backups-title">
        <i class="bi bi-database me-2"></i> Respaldos de Base de Datos
      </h2>
      <p class="text-muted small mb-0 backups-subtitle">Gestión de copias de seguridad del sistema</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/dashboard/superadmin" class="btn btn-sm btn-outline-secondary px-3 py-2 rounded-3 btn-volver-backups">
        <i class="bi bi-arrow-left me-1"></i> Volver al Dashboard
      </a>
      <div class="dropdown">
        <button class="btn btn-sm px-3 py-2 rounded-3 dropdown-toggle btn-nuevo-backup" 
                type="button" id="backupDropdown" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-plus-circle me-1"></i> Nuevo Respaldo
        </button>
        <ul class="dropdown-menu dropdown-menu-backups" aria-labelledby="backupDropdown">
          <li>
            <a class="dropdown-item" href="/superadmin/backup/completo">
              <i class="bi bi-database-fill me-2 text-success"></i> Respaldo Completo
            </a>
          </li>
          <li>
            <a class="dropdown-item" href="/superadmin/backup/estructura">
              <i class="bi bi-table me-2 text-primary"></i> Solo Estructura
            </a>
          </li>
          <li>
            <a class="dropdown-item" href="/superadmin/backup/datos">
              <i class="bi bi-file-text me-2 text-warning"></i> Solo Datos
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Mensajes flash mejorados -->
  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-3 mb-4 shadow-sm alert-success-custom">
      <div class="d-flex align-items-center">
        <i class="bi bi-check-circle-fill me-2 fs-5"></i>
        <div>
          <strong>¡Éxito!</strong><br>
          <small><%= session.mensaje %></small>
        </div>
      </div>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-3 mb-4 shadow-sm alert-danger-custom">
      <div class="d-flex align-items-center">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div>
          <strong>Error</strong><br>
          <small><%= session.error %></small>
        </div>
      </div>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Estadísticas rápidas -->
  <% if (backups && backups.length > 0) { %>
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card border-0 rounded-3 shadow-sm stat-card-backup stat-card-total-backup">
          <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <small class="text-white-50">Total Respaldos</small>
                <h3 class="text-white mb-0"><%= backups.length %></h3>
              </div>
              <i class="bi bi-archive fs-1 text-white-50"></i>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 rounded-3 shadow-sm stat-card-backup stat-card-ultimo-backup">
          <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <small class="text-white-50">Último Respaldo</small>
                <h6 class="text-white mb-0"><%= new Date(backups[0].fecha).toLocaleDateString() %></h6>
                <small class="text-white-50"><%= new Date(backups[0].fecha).toLocaleTimeString() %></small>
              </div>
              <i class="bi bi-clock-history fs-1 text-white-50"></i>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card border-0 rounded-3 shadow-sm stat-card-backup stat-card-espacio-backup">
          <div class="card-body py-2">
            <div class="d-flex justify-content-between align-items-center">
              <div>
                <small class="text-white-50">Espacio Total</small>
                <h3 class="text-white mb-0">
                  <% 
                    let totalSize = 0;
                    backups.forEach(b => {
                      totalSize += parseFloat(b.tamaño);
                    });
                  %>
                  <%= totalSize.toFixed(2) %> KB
                </h3>
              </div>
              <i class="bi bi-hdd-stack fs-1 text-white-50"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Tabla de respaldos mejorada -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden backups-card">
    <div class="card-header bg-white py-3 border-0 backups-card-header">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold backups-card-title">
          <i class="bi bi-files me-2"></i> Lista de Respaldos
        </h5>
        <% if (backups && backups.length > 0) { %>
          <button class="btn btn-sm btn-outline-danger btn-eliminar-todos" onclick="eliminarTodos()">
            <i class="bi bi-trash3 me-1"></i> Eliminar todos
          </button>
        <% } %>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle backups-tabla">
          <thead class="backups-tabla-header">
            <tr class="text-center">
              <th style="width: 5%">#</th>
              <th style="width: 45%"><i class="bi bi-file-earmark"></i> Nombre del archivo</th>
              <th style="width: 10%"><i class="bi bi-hdd-stack"></i> Tamaño</th>
              <th style="width: 25%"><i class="bi bi-calendar3"></i> Fecha de creación</th>
              <th style="width: 15%"><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (backups && backups.length > 0) { %>
              <% backups.forEach((b, index) => { %>
                <tr class="text-center align-middle backup-fila">
                  <td class="text-muted"><%= index + 1 %>.</td>
                  <td class="text-start">
                    <i class="bi bi-filetype-sql me-2 fs-5 backup-icon"></i>
                    <strong class="backup-nombre"><%= b.nombre %></strong>
                    <br>
                    <small class="text-muted">
                      <%
                        const tipo = b.nombre.includes('completo') ? 'Completo' : 
                                    (b.nombre.includes('estructura') ? 'Solo Estructura' : 'Solo Datos');
                      %>
                      <span class="badge badge-tipo-backup"><%= tipo %></span>
                    </small>
                  </td>
                  <td>
                    <span class="badge bg-light text-dark p-2 badge-tamano-backup">
                      <i class="bi bi-hdd-stack me-1"></i> <%= b.tamaño %>
                    </span>
                  </td>
                  <td>
                    <div class="backup-fecha"><%= new Date(b.fecha).toLocaleDateString() %></div>
                    <small class="text-muted backup-hora"><%= new Date(b.fecha).toLocaleTimeString() %></small>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/superadmin/backup/descargar/<%= b.nombre %>" 
                         class="btn btn-sm btn-success px-3 py-1 rounded-3 btn-descargar-backup"
                         title="Descargar respaldo">
                        <i class="bi bi-download me-1"></i> 
                        <span class="d-none d-md-inline">Descargar</span>
                      </a>
                      <form action="/superadmin/backup/eliminar/<%= b.nombre %>" 
                            method="POST" 
                            class="d-inline eliminar-form"
                            data-nombre="<%= b.nombre %>">
                        <button type="submit" class="btn btn-sm btn-danger px-3 py-1 rounded-3 btn-eliminar-backup" title="Eliminar respaldo">
                          <i class="bi bi-trash me-1"></i>
                          <span class="d-none d-md-inline">Eliminar</span>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center py-5 empty-state-backups">
                  <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                  <h5>No hay respaldos generados</h5>
                  <p class="mb-3">Crea tu primer respaldo de seguridad</p>
                  <div class="dropdown d-inline-block">
                    <button class="btn btn-sm px-4 py-2 rounded-3 dropdown-toggle btn-crear-backup"
                            type="button" data-bs-toggle="dropdown">
                      <i class="bi bi-plus-circle me-1"></i> Crear primer respaldo
                    </button>
                    <ul class="dropdown-menu dropdown-menu-backups">
                      <li><a class="dropdown-item" href="/superadmin/backup/completo">Completo</a></li>
                      <li><a class="dropdown-item" href="/superadmin/backup/estructura">Solo Estructura</a></li>
                      <li><a class="dropdown-item" href="/superadmin/backup/datos">Solo Datos</a></li>
                    </ul>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Información adicional mejorada -->
  <div class="row mt-4 g-3">
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm h-100 info-card-backup">
        <div class="card-body p-3">
          <div class="d-flex align-items-start gap-3">
            <i class="bi bi-info-circle-fill fs-3 info-icon-backup"></i>
            <div>
              <strong class="small">¿Cómo restaurar un respaldo?</strong>
              <p class="small mb-1">Método 1: Usando MySQL Workbench</p>
              <p class="small mb-0">Método 2: Línea de comandos: <code class="restore-code">mysql -u root -p comunisolve_db < archivo.sql</code></p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm h-100 info-card-backup">
        <div class="card-body p-3">
          <div class="d-flex align-items-start gap-3">
            <i class="bi bi-shield-lock-fill fs-3 security-icon-backup"></i>
            <div>
              <strong class="small">Consejos de seguridad</strong>
              <p class="small mb-0">✓ Descarga respaldos importantes a tu PC<br>✓ Los respaldos se eliminan al redeployar<br>✓ Programa respaldos periódicos</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Confirmación mejorada para eliminar
  document.querySelectorAll('.eliminar-form').forEach(form => {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const nombre = this.dataset.nombre;
      
      if (confirm(`¿Estás seguro de que deseas eliminar el respaldo "${nombre}"?\n\nEsta acción no se puede deshacer.`)) {
        this.submit();
      }
    });
  });
  
  // Función para eliminar todos los respaldos
  function eliminarTodos() {
    if (confirm('⚠️ ADVERTENCIA: Vas a eliminar TODOS los respaldos.\n\n¿Estás completamente seguro?')) {
      document.querySelectorAll('.eliminar-form').forEach(form => {
        form.submit();
      });
    }
  }
  
  // Auto-cerrar alertas después de 5 segundos
  setTimeout(() => {
    document.querySelectorAll('.alert').forEach(alert => {
      const bsAlert = new bootstrap.Alert(alert);
      setTimeout(() => bsAlert.close(), 5000);
    });
  }, 100);
</script>


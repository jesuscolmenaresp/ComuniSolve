    transition: all 0.2s ease;
  }
  .dropdown-item:hover {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  /* Tarjetas de estadísticas */
  .stat-card-backup {
    transition: all 0.2s ease;
  }
  .stat-card-backup:hover {
    transform: translateY(-4px);
  }
  .stat-card-total-backup {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }
  .stat-card-ultimo-backup {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  }
  .stat-card-espacio-backup {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  }
  
  /* Tabla */
  .backups-card {
    background: white;
  }
  .backups-card-header {
    background: white;
  }
  .backups-card-title {
    color: #5D4037;
  }
  .backups-card-title i {
    color: #fd6704bd;
  }
  
  .backups-tabla {
    background: white;
  }
  .backups-tabla-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  .backups-tabla-header th {
    color: #5D4037;
    font-weight: 600;
    border-bottom: 2px solid #fd6704bd;
  }
  
  .backup-fila {
    border-bottom-color: #f0d5c0;
  }
  .backup-fila:hover {
    background-color: #fff8f0 !important;
  }
  
  .backup-icon {
    color: #fd6704bd;
  }
  .backup-nombre {

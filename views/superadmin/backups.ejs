  }
  
  .badge-tipo-backup {
    background: #6c757d;
    color: white;
  }
  .badge-tamano-backup {
    background: #f8f9fa;
    color: #212529;
  }
  
  .backup-fecha {
    color: #5D4037;
  }
  .backup-hora {
    color: #8B6B5A;
  }
  
  /* Botones de acción */
  .btn-descargar-backup {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-descargar-backup:hover {
    transform: translateY(-2px);
  }
  .btn-eliminar-backup {
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-eliminar-backup:hover {
    transform: translateY(-2px);
  }
  .btn-eliminar-todos {
    transition: all 0.2s ease;
  }
  .btn-eliminar-todos:hover {
    transform: translateY(-2px);
  }
  
  /* Estado vacío */

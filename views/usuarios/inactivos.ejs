<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1" style="color: #5D4037;">
        <i class="bi bi-person-x-fill me-2" style="color: #dc3545;"></i> Usuarios Inactivos
      </h2>
      <p class="text-muted small mb-0" style="color: #8B6B5A;">Usuarios desactivados del sistema</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/usuarios" class="btn btn-sm btn-outline-secondary px-3 py-2 rounded-3">
        <i class="bi bi-arrow-left me-1"></i> Volver a usuarios activos
      </a>
      <button onclick="window.location.reload()" class="btn btn-sm px-3 py-2 rounded-3"
              style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
        <i class="bi bi-arrow-repeat me-1"></i> Actualizar
      </button>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Tabla de usuarios inactivos -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
    <div class="card-header bg-white py-3 border-0">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold" style="color: #5D4037;">
          <i class="bi bi-person-x me-2" style="color: #dc3545;"></i> Lista de Usuarios Inactivos
        </h5>
        <span class="badge bg-danger rounded-pill px-3 py-2">
          <i class="bi bi-people me-1"></i> Total: <%= usuarios ? usuarios.length : 0 %>
        </span>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr class="text-center">
              <th style="width: 25%"><i class="bi bi-person"></i> Nombre</th>
              <th style="width: 30%"><i class="bi bi-envelope"></i> Email</th>
              <th style="width: 15%"><i class="bi bi-tag"></i> Rol</th>
              <th style="width: 20%"><i class="bi bi-calendar3"></i> Registro</th>
              <th style="width: 10%"><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (usuarios && usuarios.length > 0) { %>
              <% usuarios.forEach(u => { %>
                <tr class="text-center align-middle">
                  <td class="text-start">
                    <strong><%= u.nombre %></strong>
                    <% if (u.cedula) { %>
                      <br><small class="text-muted">C.I: <%= u.cedula %></small>
                    <% } %>
                  </td>
                  <td><small><%= u.email %></small></td>
                  <td>
                    <span class="badge bg-secondary rounded-pill px-2 py-1">
                      <%= u.rol_nombre || u.rol_id %>
                    </span>
                  </td>
                  <td><small><%= new Date(u.fecha_registro).toLocaleDateString() %></small></td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                      
                      <!-- Botón ACTIVAR -->
                      <form action="/usuarios/<%= u.id %>/activar" method="POST" class="d-inline">
                        <input type="hidden" name="motivo" value="Reactivado por <%= session.usuario.nombre %>">
                        <button type="submit" class="btn btn-sm btn-success px-3 py-1 rounded-3" 
                                title="Activar usuario" onclick="return confirm('¿Activar este usuario?')">
                          <i class="bi bi-check-circle me-1"></i> Activar
                        </button>
                      </form>
                      
                      <!-- Botón ELIMINAR PERMANENTEMENTE (solo SuperAdmin) -->
                      <% if (session.usuario && session.usuario.rol_id === 5) { %>
                        <button type="button" class="btn btn-sm btn-danger px-3 py-1 rounded-3" 
                                title="Eliminar permanentemente"
                                onclick="abrirModalEliminar('<%= u.id %>', '<%= u.nombre.replace(/'/g, "\\'") %>', '<%= u.email %>')">
                          <i class="bi bi-trash3 me-1"></i> Eliminar
                        </button>
                      <% } %>
                      
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center py-5">
                  <i class="bi bi-check-circle-fill fs-1 text-success d-block mb-3"></i>
                  <h5 class="text-muted">No hay usuarios inactivos</h5>
                  <p class="text-muted small mb-0">Todos los usuarios están activos en el sistema</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card-footer bg-transparent text-center py-3">
      <small class="text-muted">
        <i class="bi bi-info-circle me-1"></i> 
        Los usuarios inactivos no pueden iniciar sesión. Los SuperAdministradores pueden eliminar usuarios permanentemente (requiere motivo).
      </small>
    </div>
  </div>
</div>

<!-- MODAL ÚNICO para eliminar -->
<div class="modal fade" id="modalEliminarGlobal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg">
      <div class="modal-header" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);">
        <h5 class="modal-title text-white">
          <i class="bi bi-exclamation-triangle-fill me-2"></i> Eliminar Permanentemente
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formEliminarGlobal" method="POST">
        <div class="modal-body p-4">
          <div class="alert alert-warning mb-3">
            <i class="bi bi-info-circle me-1"></i>
            <strong>¡Cuidado!</strong> Esta acción NO se puede deshacer.
          </div>
          <p class="mb-2">Estás a punto de eliminar permanentemente a:</p>
          <div class="bg-light p-2 rounded-3 mb-3 text-center" id="usuarioAEliminarInfo">
            <!-- Se llena con JavaScript -->
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">
              <i class="bi bi-chat-text me-1"></i> Motivo de eliminación:
            </label>
            <textarea name="motivo" id="motivoEliminacion" class="form-control rounded-3" rows="3" 
                      placeholder="Ej: Usuario duplicado, solicitud del usuario, información falsa..."
                      required></textarea>
            <small class="text-muted">Este motivo quedará registrado en la auditoría.</small>
          </div>
        </div>
        <div class="modal-footer bg-light">
          <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-danger rounded-3 px-4">
            <i class="bi bi-trash3 me-1"></i> Eliminar permanentemente
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function abrirModalEliminar(usuarioId, usuarioNombre, usuarioEmail) {
    document.getElementById('formEliminarGlobal').action = '/usuarios/' + usuarioId + '/destruir';
    document.getElementById('usuarioAEliminarInfo').innerHTML = 
      '<strong>' + usuarioNombre.replace(/\\'/g, "'") + '</strong><br><small class="text-muted">' + usuarioEmail + '</small>';
    document.getElementById('motivoEliminacion').value = '';
    var modal = new bootstrap.Modal(document.getElementById('modalEliminarGlobal'));
    modal.show();
  }
</script>


<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden crear-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 crear-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="crear-icon-wrapper">
              <i class="bi bi-person-plus-fill fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold crear-title">Nuevo Usuario</h3>
          <p class="small mb-0 mt-1 crear-subtitle">Registra un nuevo ciudadano en la comunidad</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 crear-body">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/usuarios" class="btn btn-sm px-3 py-1 rounded-3 btn-volver-crear">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/usuarios" method="POST">
            
            <div class="row g-3">
              <!-- Cédula -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-card-text me-1"></i> Cédula de identidad
                </label>
                <input type="text" name="cedula" class="form-control rounded-3 crear-input" 
                       placeholder="12345678">
                <small class="text-muted crear-help">Solo números</small>
              </div>

              <!-- Nombre -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-person-fill me-1"></i> Nombre completo *
                </label>
                <input type="text" name="nombre" class="form-control rounded-3 crear-input" required
                       placeholder="Ej: Juan Pérez">
              </div>

              <!-- Email -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-envelope-fill me-1"></i> Email *
                </label>
                <input type="email" name="email" class="form-control rounded-3 crear-input" required
                       placeholder="ejemplo@correo.com">
              </div>

              <!-- Contraseña -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-lock-fill me-1"></i> Contraseña *
                </label>
                <input type="password" name="password" class="form-control rounded-3 crear-input" required 
                       minlength="6" placeholder="Mínimo 6 caracteres">
              </div>

              <!-- Teléfono -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-telephone-fill me-1"></i> Teléfono
                </label>
                <input type="text" name="telefono" class="form-control rounded-3 crear-input" 
                       placeholder="0414-1234567">
              </div>

              <!-- Rol (con permisos según usuario logueado) -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-tag me-1"></i> Rol *
                </label>
                <select name="rol_id" id="rolSelect" class="form-select rounded-3 crear-select" required>
                  <option value="">Seleccione...</option>
                  <% roles.forEach(r => { 
                    if (r.id === 5 && session.usuario.rol_id !== 5) return;
                  %>
                    <option value="<%= r.id %>"><%= r.nombre %></option>
                  <% }) %>
                </select>
              </div>

              <!-- Campo para JEFE (una sola calle) -->
              <div class="col-md-12" id="campoJefe" style="display:none;">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-geo-alt me-1"></i> Calle asignada (para Jefes)
                </label>
                <select name="calle_id" class="form-select rounded-3 crear-select">
                  <option value="">-- Sin calle asignada --</option>
                  <% calles.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nombre_completo || c.nombre %></option>
                  <% }) %>
                </select>
                <small class="text-muted crear-help">Calle que este jefe supervisa</small>
              </div>

              <!-- Campo para LÍDER (múltiples calles con checkboxes) -->
              <div class="col-md-12" id="campoLider" style="display:none;">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-geo-alt me-1"></i> Calles que lidera
                </label>
                <div class="border rounded-3 p-3 crear-checkbox-container">
                  <div class="d-flex flex-wrap gap-2">
                    <% calles.forEach(c => { %>
                      <div class="form-check">
                        <input class="form-check-input crear-checkbox" type="checkbox" name="calles_lider" value="<%= c.id %>" id="calle_<%= c.id %>">
                        <label class="form-check-label crear-checkbox-label" for="calle_<%= c.id %>">
                          <%= c.nombre %>
                        </label>
                      </div>
                    <% }) %>
                  </div>
                </div>
                <small class="text-muted crear-help">Seleccione todas las calles que lidera</small>
              </div>

              <!-- Campo para CIUDADANO (una sola calle) -->
              <div class="col-md-12" id="campoCiudadano" style="display:none;">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-house-heart me-1"></i> Calle donde vive (para Ciudadanos)
                </label>
                <select name="calle_id" class="form-select rounded-3 crear-select">
                  <option value="">-- Seleccione una calle --</option>
                  <% calles.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nombre_completo || c.nombre %></option>
                  <% }) %>
                </select>
                <small class="text-muted crear-help">Seleccione la calle donde reside</small>
              </div>

              <!-- Campo para UBCH (múltiples comunidades con checkboxes) -->
              <div class="col-md-12" id="campoUbch" style="display:none;">
                <label class="form-label fw-semibold small mb-2 crear-label">
                  <i class="bi bi-building me-1"></i> Comunidades que atiende
                </label>
                <div class="border rounded-3 p-3 crear-checkbox-container">
                  <div class="d-flex flex-wrap gap-2">
                    <% if (typeof comunidades !== 'undefined' && comunidades.length > 0) { %>
                      <% comunidades.forEach(c => { %>
                        <div class="form-check">
                          <input class="form-check-input crear-checkbox" type="checkbox" name="comunidades" value="<%= c.id %>" id="comunidad_<%= c.id %>">
                          <label class="form-check-label crear-checkbox-label" for="comunidad_<%= c.id %>">
                            <%= c.nombre %>
                          </label>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <p class="text-muted small mb-0">No hay comunidades registradas. <a href="/comunidades/nueva">Crear una</a></p>
                    <% } %>
                  </div>
                </div>
                <small class="text-muted crear-help">Seleccione todas las comunidades que supervisa</small>
              </div>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar-crear">
                <i class="bi bi-save me-2"></i> Guardar usuario
              </button>
              <a href="/usuarios" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar-crear">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 crear-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 crear-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  document.getElementById('rolSelect').addEventListener('change', function() {
    const rol = this.value;
    document.getElementById('campoJefe').style.display = rol == '3' ? 'block' : 'none';
    document.getElementById('campoLider').style.display = rol == '2' ? 'block' : 'none';
    document.getElementById('campoCiudadano').style.display = rol == '4' ? 'block' : 'none';
    document.getElementById('campoUbch').style.display = rol == '1' ? 'block' : 'none';
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .crear-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .crear-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .crear-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .crear-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .crear-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .crear-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver-crear {
    border: 1px solid #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-crear:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Labels */
  .crear-label {
    color: #5D4037;
  }
  .crear-label i {
    color: #fd6704bd;
  }
  
  /* Inputs y selects */
  .crear-input, .crear-select {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .crear-input:focus, .crear-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Checkbox container */
  .crear-checkbox-container {
    border-color: #f0d5c0;
    background-color: #fefaf7;
  }
  
  /* Checkbox */
  .crear-checkbox {
    border-color: #fd6704bd;
  }
  .crear-checkbox:checked {
    background-color: #fd6704bd;
    border-color: #fd6704bd;
  }
  .crear-checkbox-label {
    color: #5D4037;
  }
  
  /* Ayuda */
  .crear-help {
    color: #8B6B5A;
  }
  
  /* Botón guardar */
  .btn-guardar-crear {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar-crear:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar-crear {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar-crear:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .crear-badge {
    color: #8B6B5A !important;
  }
  .crear-badge i {
    color: #17a2b8;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .crear-card {
    background: #27272a;
  }
  
  body.dark-mode .crear-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .crear-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .crear-body {
    background: #27272a;
  }
  
  body.dark-mode .btn-volver-crear {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-crear:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .crear-label {
    color: #e4e4e7;
  }
  body.dark-mode .crear-label i {
    color: #f7931e;
  }
  
  body.dark-mode .crear-input,
  body.dark-mode .crear-select {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .crear-input:focus,
  body.dark-mode .crear-select:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .crear-input::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .crear-checkbox-container {
    border-color: #3f3f46;
    background-color: #3f3f46;
  }
  
  body.dark-mode .crear-checkbox-label {
    color: #e4e4e7;
  }
  
  body.dark-mode .crear-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-cancelar-crear {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar-crear:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .crear-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .crear-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .form-control:focus, .form-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  body.dark-mode .form-control:focus, body.dark-mode .form-select:focus {
    border-color: #f7931e;
  }
  
  .form-check-input:checked {
    background-color: #fd6704bd;
    border-color: #fd6704bd;
  }
  body.dark-mode .form-check-input:checked {
    background-color: #f7931e;
    border-color: #f7931e;
  }
</style>
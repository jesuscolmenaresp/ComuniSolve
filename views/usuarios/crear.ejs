<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-person-plus-fill fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;">Nuevo Usuario</h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">Registra un nuevo ciudadano en la comunidad</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/usuarios" class="btn btn-sm px-3 py-1 rounded-3" style="border: 1px solid #f0d5c0; color: #5D4037;">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/usuarios" method="POST">
            
            <div class="row g-3">
              <!-- Cédula -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-card-text me-1" style="color: #fd6704bd;"></i> Cédula de identidad
                </label>
                <input type="text" name="cedula" class="form-control rounded-3" 
                       placeholder="12345678"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                <small class="text-muted" style="color: #8B6B5A;">Solo números</small>
              </div>

              <!-- Nombre -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-person-fill me-1" style="color: #fd6704bd;"></i> Nombre completo *
                </label>
                <input type="text" name="nombre" class="form-control rounded-3" required
                       placeholder="Ej: Juan Pérez"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Email -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-envelope-fill me-1" style="color: #fd6704bd;"></i> Email *
                </label>
                <input type="email" name="email" class="form-control rounded-3" required
                       placeholder="ejemplo@correo.com"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Contraseña -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-lock-fill me-1" style="color: #fd6704bd;"></i> Contraseña *
                </label>
                <input type="password" name="password" class="form-control rounded-3" required 
                       minlength="6" placeholder="Mínimo 6 caracteres"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Teléfono -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-telephone-fill me-1" style="color: #fd6704bd;"></i> Teléfono
                </label>
                <input type="text" name="telefono" class="form-control rounded-3" 
                       placeholder="0414-1234567"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Rol -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-tag me-1" style="color: #fd6704bd;"></i> Rol *
                </label>
                <select name="rol_id" id="rolSelect" class="form-select rounded-3" required style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                  <option value="">Seleccione...</option>
                  <% roles.forEach(r => { %>
                    <option value="<%= r.id %>"><%= r.nombre %></option>
                  <% }) %>
                </select>
              </div>

              <!-- Campo para JEFE (una sola calle) -->
              <div class="col-md-12" id="campoJefe" style="display:none;">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-geo-alt me-1" style="color: #fd6704bd;"></i> Calle asignada (para Jefes)
                </label>
                <select name="calle_id" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                  <option value="">-- Sin calle asignada --</option>
                  <% calles.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nombre_completo || c.nombre %></option>
                  <% }) %>
                </select>
                <small class="text-muted" style="color: #8B6B5A;">Calle que este jefe supervisa</small>
              </div>

              <!-- Campo para LÍDER (múltiples calles con checkboxes) -->
              <div class="col-md-12" id="campoLider" style="display:none;">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-geo-alt me-1" style="color: #fd6704bd;"></i> Calles que lidera
                </label>
                <div class="border rounded-3 p-3" style="border-color: #f0d5c0; background-color: #fefaf7; max-height: 200px; overflow-y: auto;">
                  <div class="d-flex flex-wrap gap-2">
                    <% calles.forEach(c => { %>
                      <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="calles_lider" value="<%= c.id %>" id="calle_<%= c.id %>"
                               style="border-color: #fd6704bd;">
                        <label class="form-check-label" for="calle_<%= c.id %>" style="color: #5D4037;">
                          <%= c.nombre %>
                        </label>
                      </div>
                    <% }) %>
                  </div>
                </div>
                <small class="text-muted" style="color: #8B6B5A;">Seleccione todas las calles que lidera</small>
              </div>

              <!-- Campo para CIUDADANO (una sola calle) -->
              <div class="col-md-12" id="campoCiudadano" style="display:none;">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-house-heart me-1" style="color: #fd6704bd;"></i> Calle donde vive (para Ciudadanos)
                </label>
                <select name="calle_id" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                  <option value="">-- Seleccione una calle --</option>
                  <% calles.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nombre_completo || c.nombre %></option>
                  <% }) %>
                </select>
                <small class="text-muted" style="color: #8B6B5A;">Seleccione la calle donde reside</small>
              </div>

              <!-- Campo para UBCH (múltiples comunidades con checkboxes) -->
              <div class="col-md-12" id="campoUbch" style="display:none;">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-building me-1" style="color: #fd6704bd;"></i> Comunidades que atiende
                </label>
                <div class="border rounded-3 p-3" style="border-color: #f0d5c0; background-color: #fefaf7; max-height: 200px; overflow-y: auto;">
                  <div class="d-flex flex-wrap gap-2">
                    <% if (typeof comunidades !== 'undefined' && comunidades.length > 0) { %>
                      <% comunidades.forEach(c => { %>
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="comunidades" value="<%= c.id %>" id="comunidad_<%= c.id %>"
                                 style="border-color: #fd6704bd;">
                          <label class="form-check-label" for="comunidad_<%= c.id %>" style="color: #5D4037;">
                            <%= c.nombre %>
                          </label>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <p class="text-muted small mb-0">No hay comunidades registradas. <a href="/comunidades/nueva">Crear una</a></p>
                    <% } %>
                  </div>
                </div>
                <small class="text-muted" style="color: #8B6B5A;">Seleccione todas las comunidades que supervisa</small>
              </div>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;">
                <i class="bi bi-save me-2"></i> Guardar usuario
              </button>
              <a href="/usuarios" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                 style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  document.getElementById('rolSelect').addEventListener('change', function() {
    const rol = this.value;
    document.getElementById('campoJefe').style.display = rol == '3' ? 'block' : 'none';
    document.getElementById('campoLider').style.display = rol == '2' ? 'block' : 'none';
    document.getElementById('campoCiudadano').style.display = rol == '4' ? 'block' : 'none';
    document.getElementById('campoUbch').style.display = rol == '1' ? 'block' : 'none';
  });
</script>

<style>
  .form-control:focus, .form-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  .form-check-input:checked {
    background-color: #fd6704bd;
    border-color: #fd6704bd;
  }
</style>
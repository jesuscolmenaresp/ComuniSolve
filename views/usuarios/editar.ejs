  }
  body.dark-mode .editar-input::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .editar-checkbox-container {
    border-color: #3f3f46;
    background-color: #3f3f46;
  }
  
  body.dark-mode .editar-checkbox-label {
    color: #e4e4e7;
  }
  
  body.dark-mode .editar-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-cancelar-editar {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar-editar:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .editar-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .editar-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .form-control:focus, .form-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  body.dark-mode .form-control:focus, body.dark-mode .form-select:focus {
    border-color: #f7931e;
  }
  
  .form-check-input:checked {
    background-color: #fd6704bd;
    border-color: #fd6704bd;
  }
  body.dark-mode .form-check-input:checked {
    background-color: #f7931e;
    border-color: #f7931e;
  }
</style>
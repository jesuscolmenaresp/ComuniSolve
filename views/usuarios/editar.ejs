  }
  
  body.dark-mode .editar-body {
    background: #27272a;
  }
  
  body.dark-mode .btn-volver-editar {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-editar:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .editar-label {
    color: #e4e4e7;
  }
  body.dark-mode .editar-label i {
    color: #f7931e;
  }
  
  body.dark-mode .editar-input,
  body.dark-mode .editar-select {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;

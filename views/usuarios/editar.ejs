<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden editar-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 editar-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="editar-icon-wrapper">
              <i class="bi bi-pencil-square fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold editar-title">Editar Usuario</h3>
          <p class="small mb-0 mt-1 editar-subtitle">Actualiza la información del usuario</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 editar-body">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/usuarios" class="btn btn-sm px-3 py-1 rounded-3 btn-volver-editar">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/usuarios/<%= usuario.id %>/editar" method="POST">
            
            <div class="row g-3">
              <!-- Cédula -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-card-text me-1"></i> Cédula de identidad
                </label>
                <input type="text" name="cedula" class="form-control rounded-3 editar-input" 
                       value="<%= usuario.cedula || '' %>" placeholder="12345678">
                <small class="text-muted editar-help">Solo números</small>
              </div>

              <!-- Nombre -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-person-fill me-1"></i> Nombre completo *
                </label>
                <input type="text" name="nombre" class="form-control rounded-3 editar-input" required
                       value="<%= usuario.nombre %>">
              </div>

              <!-- Email -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-envelope-fill me-1"></i> Email *
                </label>
                <input type="email" name="email" class="form-control rounded-3 editar-input" required
                       value="<%= usuario.email %>">
              </div>

              <!-- Nueva contraseña -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-key-fill me-1"></i> Nueva contraseña
                </label>
                <input type="password" name="password" class="form-control rounded-3 editar-input" 
                       placeholder="Dejar vacío para no cambiar">
                <small class="text-muted editar-help">Mínimo 6 caracteres si desea cambiarla</small>
              </div>

              <!-- Teléfono -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-telephone-fill me-1"></i> Teléfono
                </label>
                <input type="text" name="telefono" class="form-control rounded-3 editar-input" 
                       value="<%= usuario.telefono || '' %>" placeholder="0414-1234567">
              </div>

              <!-- Rol -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-tag me-1"></i> Rol *
                </label>
                <select name="rol_id" id="rolSelectEdit" class="form-select rounded-3 editar-select" required>
                  <% roles.forEach(r => { 
                    if (r.id === 5 && session.usuario.rol_id !== 5) return;
                  %>
                    <option value="<%= r.id %>" <%= usuario.rol_id == r.id ? 'selected' : '' %>>
                      <%= r.nombre %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <!-- Campo para JEFE -->
              <div class="col-md-12 campo-jefe <%= usuario.rol_id === 3 ? '' : 'd-none' %>">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-geo-alt me-1"></i> Calle asignada (para Jefes)
                </label>
                <select name="calle_jefe_id" class="form-select rounded-3 editar-select">
                  <option value="">-- Sin calle asignada --</option>
                  <% calles.forEach(c => { %>
                    <option value="<%= c.id %>" <%= usuario.calle_id == c.id ? 'selected' : '' %>>
                      <%= c.nombre_completo || c.nombre %>
                    </option>
                  <% }) %>
                </select>
                <small class="text-muted editar-help">Calle que este jefe supervisa</small>
              </div>

              <!-- Campo para LÍDER -->
              <div class="col-md-12 campo-lider <%= usuario.rol_id === 2 ? '' : 'd-none' %>">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-geo-alt me-1"></i> Calles que lidera
                </label>
                <div class="border rounded-3 p-3 editar-checkbox-container">
                  <div class="d-flex flex-wrap gap-2">
                    <% calles.forEach(c => { %>
                      <div class="form-check">
                        <input class="form-check-input editar-checkbox" type="checkbox" name="calles_lider" value="<%= c.id %>" id="calle_<%= c.id %>"
                               <%= (typeof callesLideradas !== 'undefined' && callesLideradas.includes(c.id)) ? 'checked' : '' %>>
                        <label class="form-check-label editar-checkbox-label" for="calle_<%= c.id %>">
                          <%= c.nombre %>
                        </label>
                      </div>
                    <% }) %>
                  </div>
                </div>
                <small class="text-muted editar-help">Seleccione todas las calles que lidera</small>
              </div>

              <!-- Campo para CIUDADANO -->
              <div class="col-md-12 campo-ciudadano <%= usuario.rol_id === 4 ? '' : 'd-none' %>">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-house-heart me-1"></i> Calle donde vive (para Ciudadanos)
                </label>
                <select name="calle_ciudadano_id" class="form-select rounded-3 editar-select">
                  <option value="">-- Seleccione una calle --</option>
                  <% calles.forEach(c => { %>
                    <option value="<%= c.id %>" <%= usuario.calle_id == c.id ? 'selected' : '' %>>
                      <%= c.nombre_completo || c.nombre %>
                    </option>
                  <% }) %>
                </select>
                <small class="text-muted editar-help">Seleccione la calle donde reside</small>
              </div>

              <!-- Campo para UBCH -->
              <div class="col-md-12 campo-comunidades <%= usuario.rol_id === 1 ? '' : 'd-none' %>">
                <label class="form-label fw-semibold small mb-2 editar-label">
                  <i class="bi bi-building me-1"></i> Comunidades que atiende
                </label>
                <div class="border rounded-3 p-3 editar-checkbox-container">
                  <div class="d-flex flex-wrap gap-2">
                    <% if (typeof comunidades !== 'undefined' && comunidades.length > 0) { %>
                      <% comunidades.forEach(c => { %>
                        <div class="form-check">
                          <input class="form-check-input editar-checkbox" type="checkbox" name="comunidades" value="<%= c.id %>" id="comunidad_<%= c.id %>"
                                 <%= (typeof comunidadesAsignadas !== 'undefined' && comunidadesAsignadas.includes(c.id)) ? 'checked' : '' %>>
                          <label class="form-check-label editar-checkbox-label" for="comunidad_<%= c.id %>">
                            <%= c.nombre %>
                          </label>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <p class="text-muted small mb-0">No hay comunidades registradas. <a href="/comunidades/nueva">Crear una</a></p>
                    <% } %>
                  </div>
                </div>
                <small class="text-muted editar-help">Seleccione todas las comunidades que supervisa</small>
              </div>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar-editar">
                <i class="bi bi-save me-2"></i> Actualizar usuario
              </button>
              <a href="/usuarios" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar-editar">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 editar-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 editar-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  document.getElementById('rolSelectEdit').addEventListener('change', function() {
    const rol = this.value;
    
    const campoJefe = document.querySelector('.campo-jefe');
    const campoLider = document.querySelector('.campo-lider');
    const campoCiudadano = document.querySelector('.campo-ciudadano');
    const campoComunidades = document.querySelector('.campo-comunidades');
    
    if (rol === '3') {
      campoJefe.classList.remove('d-none');
      campoLider.classList.add('d-none');
      campoCiudadano.classList.add('d-none');
      campoComunidades.classList.add('d-none');
    } else if (rol === '2') {
      campoJefe.classList.add('d-none');
      campoLider.classList.remove('d-none');
      campoCiudadano.classList.add('d-none');
      campoComunidades.classList.add('d-none');
    } else if (rol === '4') {
      campoJefe.classList.add('d-none');
      campoLider.classList.add('d-none');
      campoCiudadano.classList.remove('d-none');
      campoComunidades.classList.add('d-none');
    } else if (rol === '1') {
      campoJefe.classList.add('d-none');
      campoLider.classList.add('d-none');
      campoCiudadano.classList.add('d-none');
      campoComunidades.classList.remove('d-none');
    } else {
      campoJefe.classList.add('d-none');
      campoLider.classList.add('d-none');
      campoCiudadano.classList.add('d-none');
      campoComunidades.classList.add('d-none');
    }
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .editar-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .editar-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .editar-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);

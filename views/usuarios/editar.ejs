    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .editar-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .editar-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .editar-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver-editar {
    border: 1px solid #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-editar:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Labels */
  .editar-label {
    color: #5D4037;
  }
  .editar-label i {
    color: #fd6704bd;
  }
  
  /* Inputs y selects */
  .editar-input, .editar-select {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .editar-input:focus, .editar-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Checkbox container */
  .editar-checkbox-container {
    border-color: #f0d5c0;
    background-color: #fefaf7;
  }
  
  /* Checkbox */
  .editar-checkbox {
    border-color: #fd6704bd;
  }
  .editar-checkbox:checked {
    background-color: #fd6704bd;
    border-color: #fd6704bd;
  }
  .editar-checkbox-label {
    color: #5D4037;
  }
  
  /* Ayuda */
  .editar-help {
    color: #8B6B5A;
  }
  
  /* Botón guardar */
  .btn-guardar-editar {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar-editar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar-editar {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar-editar:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .editar-badge {
    color: #8B6B5A !important;
  }
  .editar-badge i {
    color: #17a2b8;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .editar-card {
    background: #27272a;
  }
  
  body.dark-mode .editar-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);

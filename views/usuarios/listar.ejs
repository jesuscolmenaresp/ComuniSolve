<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>👥 Gestión de Usuarios</h2>
    <a href="/usuarios/nuevo" class="btn btn-primary">
      ➕ Nuevo Usuario
    </a>
  </div>

  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= session.mensaje %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <%= session.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Filtros -->
  <div class="row mb-3">
    <div class="col-md-4">
      <select id="filtroRol" class="form-select">
        <option value="0">Todos los roles</option>
        <option value="1">UBCH</option>
        <option value="2">Líder</option>
        <option value="3">Jefe de Calle</option>
        <option value="4">Ciudadano</option>
      </select>
    </div>
    <div class="col-md-4">
      <input type="text" id="buscarUsuario" class="form-control" placeholder="🔍 Buscar por nombre o email...">
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-striped table-hover" id="tablaUsuarios">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Nombre</th>
          <th>Email</th>
          <th>Teléfono</th>
          <th>Rol</th>
          <th>Calles asignadas</th>
          <th>Comunidades</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (usuarios && usuarios.length > 0) { %>
          <% usuarios.forEach(u => { %>
            <tr data-rol="<%= u.rol_id %>">
              <td><%= u.id %></td>
              <td><%= u.nombre %></td>
              <td><%= u.email %></td>
              <td><%= u.telefono || '—' %></td>
              <td>
                <span class="badge <%= 
                  u.rol_id === 1 ? 'bg-danger' : 
                  u.rol_id === 2 ? 'bg-info' : 
                  u.rol_id === 3 ? 'bg-success' : 
                  'bg-secondary' %>">
                  <%= u.rol_nombre %>
                </span>
              </td>
              <td>
                <% if (u.rol_id === 2 && u.calles_lideradas && u.calles_lideradas.length > 0) { %>
                  <% u.calles_lideradas.forEach(calle => { %>
                    <span class="badge bg-primary me-1"><%= calle %></span>
                  <% }) %>
                <% } else if (u.rol_id === 2) { %>
                  <span class="text-muted">— Sin calles asignadas —</span>
                <% } else if (u.rol_id === 3 && u.calle_nombre) { %>
                  <span class="badge bg-success"><%= u.calle_nombre %></span>
                <% } else if (u.rol_id === 3) { %>
                  <span class="text-muted">— Sin calle asignada —</span>
                <% } else if (u.rol_id === 1) { %>
                  <span class="text-muted">— Admin —</span>
                <% } else { %>
                  <span class="text-muted">— No aplica —</span>
                <% } %>
              </td>
              <td>
                <% if (u.rol_id === 1 && u.comunidades_atiende && u.comunidades_atiende.length > 0) { %>
                  <% u.comunidades_atiende.forEach(com => { %>
                    <span class="badge bg-warning text-dark me-1"><%= com %></span>
                  <% }) %>
                <% } else if (u.rol_id === 1) { %>
                  <span class="text-muted">— Sin comunidades —</span>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
              <td>
                <a href="/usuarios/<%= u.id %>/editar" class="btn btn-sm btn-warning">
                  ✏️ Editar
                </a>
                <% if (u.id !== usuario.id) { %>
                  <form action="/usuarios/<%= u.id %>/eliminar" method="POST" class="d-inline" 
                        onsubmit="return confirm('¿Eliminar este usuario?')">
                    <button type="submit" class="btn btn-sm btn-danger">
                      🗑️ Eliminar
                    </button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="8" class="text-center">No hay usuarios registrados</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  // Filtro por rol
  document.getElementById('filtroRol').addEventListener('change', function() {
    const rol = this.value;
    const filas = document.querySelectorAll('#tablaUsuarios tbody tr');
    
    filas.forEach(fila => {
      if (rol == 0 || fila.dataset.rol == rol) {
        fila.style.display = '';
      } else {
        fila.style.display = 'none';
      }
    });
  });

  // Búsqueda por texto
  document.getElementById('buscarUsuario').addEventListener('keyup', function() {
    const texto = this.value.toLowerCase();
    const filas = document.querySelectorAll('#tablaUsuarios tbody tr');
    
    filas.forEach(fila => {
      if (fila.style.display !== 'none') {
        const nombre = fila.cells[1].textContent.toLowerCase();
        const email = fila.cells[2].textContent.toLowerCase();
        
        if (nombre.includes(texto) || email.includes(texto)) {
          fila.style.display = '';
        } else {
          fila.style.display = 'none';
        }
      }
    });
  });
</script>
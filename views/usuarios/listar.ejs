<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>👥 Gestión de Usuarios</h2>
    <a href="/usuarios/nuevo" class="btn btn-primary">
      ➕ Nuevo Usuario
    </a>
  </div>

  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= session.mensaje %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <%= session.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Filtros mejorados -->
  <div class="row mb-3 g-2">
    <div class="col-md-3">
      <select id="filtroRol" class="form-select">
        <option value="0">📌 Todos los roles</option>
        <option value="1">🏛️ UBCH</option>
        <option value="2">👨‍💼 Líder</option>
        <option value="3">👤 Jefe de Calle</option>
        <option value="4">🧑‍🤝‍🧑 Ciudadano</option>
      </select>
    </div>
    <div class="col-md-3">
      <select id="filtroEstado" class="form-select">
        <option value="todos">📌 Todos los estados</option>
        <option value="pendiente">⏳ Pendientes</option>
        <option value="aprobado">✅ Aprobados</option>
        <option value="rechazado">❌ Rechazados</option>
      </select>
    </div>
    <div class="col-md-4">
      <input type="text" id="buscarUsuario" class="form-control" placeholder="🔍 Buscar por nombre o email...">
    </div>
    <div class="col-md-2">
      <button id="limpiarFiltros" class="btn btn-outline-secondary w-100">
        🧹 Limpiar filtros
      </button>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover table-sm align-middle" id="tablaUsuarios">
      <thead class="table-light">
        <tr>
          <th>Cédula</th>
          <th>Nombre</th>
          <th>Email</th>
          <th>Teléfono</th>
          <th>Rol</th>
          <th>Asignación</th>
          <th>Estado</th>
          <th>Acciones</th>
         </thead>
      <tbody>
        <% if (usuarios && usuarios.length > 0) { %>
          <% usuarios.forEach(u => { %>
            <tr data-rol="<%= u.rol_id %>" data-estado="<%= u.estado %>"
                data-id="<%= u.id %>"
                data-cedula="<%= u.cedula || '' %>"
                data-nombre="<%= u.nombre %>"
                data-email="<%= u.email %>"
                data-telefono="<%= u.telefono || 'No registrado' %>"
                data-rol-nombre="<%= u.rol_nombre %>"
                data-calles-lideradas="<%= JSON.stringify(u.calles_lideradas || []) %>"
                data-calle-nombre="<%= u.calle_nombre || '' %>"
                data-comunidades="<%= JSON.stringify(u.comunidades_atiende || []) %>"
                style="cursor: pointer;">
              <td class="small"><%= u.cedula || '—' %></td>
              <td class="fw-semibold"><%= u.nombre %></td>
              <td><%= u.email %></td>
              <td><%= u.telefono || '—' %></td>
              <td>
                <span class="badge <%= 
                  u.rol_id === 1 ? 'bg-danger' : 
                  u.rol_id === 2 ? 'bg-info text-dark' : 
                  u.rol_id === 3 ? 'bg-success' : 
                  'bg-secondary' %>">
                  <%= u.rol_nombre %>
                </span>
              </td>
              <td>
                <% if (u.rol_id === 2 && u.calles_lideradas && u.calles_lideradas.length > 0) { %>
                  <span class="badge bg-primary" title="Calles que lidera">
                    📍 <%= u.calles_lideradas.length %> calles
                  </span>
                  <span class="text-muted small d-block"><%= u.calles_lideradas.join(', ').substring(0, 40) %><%= u.calles_lideradas.join(', ').length > 40 ? '...' : '' %></span>
                <% } else if (u.rol_id === 3 && u.calle_nombre) { %>
                  <span class="badge bg-success">🏘️ <%= u.calle_nombre %></span>
                <% } else if (u.rol_id === 4 && u.calle_nombre) { %>
                  <span class="badge bg-secondary">📍 <%= u.calle_nombre %></span>
                <% } else if (u.rol_id === 4) { %>
                  <span class="text-muted small">— Sin calle asignada —</span>
                <% } else if (u.rol_id === 1 && u.comunidades_atiende && u.comunidades_atiende.length > 0) { %>
                  <span class="badge bg-warning text-dark" title="Comunidades que atiende">
                    🏘️ <%= u.comunidades_atiende.length %> comunidades
                  </span>
                <% } else if (u.rol_id === 1) { %>
                  <span class="text-muted small">— Sin asignaciones —</span>
                <% } else if (u.rol_id === 2) { %>
                  <span class="text-muted small">— Sin calles asignadas —</span>
                <% } else if (u.rol_id === 3) { %>
                  <span class="text-muted small">— Sin calle asignada —</span>
                <% } else { %>
                  <span class="text-muted small">— Sin asignación —</span>
                <% } %>
              </td>
              <!-- Columna Estado con botones de acción -->
              <td class="text-center">
                <span class="badge <%= 
                  u.estado === 'aprobado' ? 'bg-success' : 
                  u.estado === 'pendiente' ? 'bg-warning' : 
                  'bg-danger' %>">
                  <%= u.estado === 'aprobado' ? '✅ Aprobado' : u.estado === 'pendiente' ? '⏳ Pendiente' : '❌ Rechazado' %>
                </span>
                <% if (u.estado === 'pendiente') { %>
                  <div class="mt-1">
                    <form action="/usuarios/<%= u.id %>/aprobar" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-success" title="Aprobar">
                        ✅
                      </button>
                    </form>
                    <button type="button" class="btn btn-sm btn-danger" title="Rechazar"
                            data-bs-toggle="modal" data-bs-target="#modalRechazar<%= u.id %>">
                      ❌
                    </button>
                  </div>
                  <!-- Modal para motivo de rechazo -->
                  <div class="modal fade" id="modalRechazar<%= u.id %>" tabindex="-1">
                    <div class="modal-dialog modal-sm">
                      <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                          <h6 class="modal-title">Rechazar usuario</h6>
                          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form action="/usuarios/<%= u.id %>/rechazar" method="POST">
                          <div class="modal-body">
                            <label class="form-label">Motivo (opcional):</label>
                            <textarea name="motivo" class="form-control" rows="2" placeholder="Ej: No vive en la calle indicada"></textarea>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-sm btn-danger">Rechazar</button>
                          </div>
                        </form>
                      </div>
                    </div>
                  </div>
                <% } %>
              </td>
              <td>
                <div class="btn-group btn-group-sm" role="group">
                  <a href="/usuarios/<%= u.id %>/editar" class="btn btn-warning" title="Editar">
                    ✏️
                  </a>
                  <% if (u.id !== usuario.id) { %>
                    <form action="/usuarios/<%= u.id %>/eliminar" method="POST" class="d-inline" 
                          onsubmit="return confirm('¿Eliminar este usuario?')">
                      <button type="submit" class="btn btn-danger" title="Eliminar">
                        🗑️
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="8" class="text-center py-5 text-muted">
              <i class="bi bi-people"></i> No hay usuarios registrados
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Resumen de usuarios -->
  <div class="card mt-3 bg-light">
    <div class="card-body py-2">
      <div class="row text-center">
        <div class="col-3">
          <small class="text-muted">Total usuarios</small>
          <h5 class="mb-0"><%= usuarios.length %></h5>
        </div>
        <div class="col-3">
          <small class="text-muted">UBCH</small>
          <h5 class="mb-0"><%= usuarios.filter(u => u.rol_id === 1).length %></h5>
        </div>
        <div class="col-3">
          <small class="text-muted">Líderes</small>
          <h5 class="mb-0"><%= usuarios.filter(u => u.rol_id === 2).length %></h5>
        </div>
        <div class="col-3">
          <small class="text-muted">Ciudadanos</small>
          <h5 class="mb-0"><%= usuarios.filter(u => u.rol_id === 4).length %></h5>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Detalles del Usuario -->
<div class="modal fade" id="modalUsuarioDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">
          <i class="bi bi-person-circle"></i> Detalles del Usuario
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="detalleUsuarioContent">
          <!-- Contenido cargado dinámicamente -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
        <a href="#" id="btnEditarUsuario" class="btn btn-warning">✏️ Editar usuario</a>
      </div>
    </div>
  </div>
</div>

<script>
  // Filtros
  const filtroRol = document.getElementById('filtroRol');
  const filtroEstado = document.getElementById('filtroEstado');
  const buscarUsuario = document.getElementById('buscarUsuario');
  const limpiarFiltros = document.getElementById('limpiarFiltros');
  const filas = () => document.querySelectorAll('#tablaUsuarios tbody tr');

  function aplicarFiltros() {
    const rol = filtroRol.value;
    const estado = filtroEstado.value;
    const texto = buscarUsuario.value.toLowerCase();
    
    filas().forEach(fila => {
      const dataRol = fila.dataset.rol;
      const dataEstado = fila.dataset.estado;
      const dataNombre = fila.dataset.nombre?.toLowerCase() || '';
      const dataEmail = fila.dataset.email?.toLowerCase() || '';
      
      let mostrar = true;
      
      if (rol != 0 && dataRol != rol) mostrar = false;
      if (estado !== 'todos' && dataEstado !== estado) mostrar = false;
      if (texto && !dataNombre.includes(texto) && !dataEmail.includes(texto)) mostrar = false;
      
      fila.style.display = mostrar ? '' : 'none';
    });
  }

  filtroRol.addEventListener('change', aplicarFiltros);
  filtroEstado.addEventListener('change', aplicarFiltros);
  buscarUsuario.addEventListener('keyup', aplicarFiltros);
  limpiarFiltros.addEventListener('click', () => {
    filtroRol.value = '0';
    filtroEstado.value = 'todos';
    buscarUsuario.value = '';
    aplicarFiltros();
  });

  // Doble clic para mostrar detalles
  document.querySelectorAll('#tablaUsuarios tbody tr').forEach(fila => {
    fila.addEventListener('dblclick', function(e) {
      if (e.target.tagName === 'BUTTON' || e.target.tagName === 'A') return;
      
      const id = this.dataset.id;
      const cedula = this.dataset.cedula;
      const nombre = this.dataset.nombre;
      const email = this.dataset.email;
      const telefono = this.dataset.telefono;
      const rolNombre = this.dataset.rolNombre;
      const rolId = this.dataset.rol;
      const callesLideradas = JSON.parse(this.dataset.callesLideradas || '[]');
      const calleNombre = this.dataset.calleNombre;
      const comunidades = JSON.parse(this.dataset.comunidades || '[]');
      
      let contenido = `
        <div class="mb-3">
          <div class="row">
            <div class="col-4 fw-bold">Cédula:</div>
            <div class="col-8">${cedula || '—'}</div>
          </div>
          <div class="row mt-2">
            <div class="col-4 fw-bold">Nombre:</div>
            <div class="col-8">${nombre}</div>
          </div>
          <div class="row mt-2">
            <div class="col-4 fw-bold">Email:</div>
            <div class="col-8">${email}</div>
          </div>
          <div class="row mt-2">
            <div class="col-4 fw-bold">Teléfono:</div>
            <div class="col-8">${telefono}</div>
          </div>
          <div class="row mt-2">
            <div class="col-4 fw-bold">Rol:</div>
            <div class="col-8">
              <span class="badge ${rolId == 1 ? 'bg-danger' : rolId == 2 ? 'bg-info text-dark' : rolId == 3 ? 'bg-success' : 'bg-secondary'}">
                ${rolNombre}
              </span>
            </div>
          </div>
        </div>
      `;
      
      if (rolId == 1 && comunidades.length > 0) {
        contenido += `
          <div class="card mt-3">
            <div class="card-header bg-info text-white">
              <i class="bi bi-building"></i> Comunidades que atiende
            </div>
            <div class="card-body">
              <div class="d-flex flex-wrap gap-2">
                ${comunidades.map(com => `<span class="badge bg-warning text-dark">🏘️ ${com}</span>`).join('')}
              </div>
            </div>
          </div>
        `;
      } else if (rolId == 2 && callesLideradas.length > 0) {
        contenido += `
          <div class="card mt-3">
            <div class="card-header bg-primary text-white">
              <i class="bi bi-geo-alt"></i> Calles que lidera
            </div>
            <div class="card-body">
              <div class="list-group">
                ${callesLideradas.map(calle => `<div class="list-group-item list-group-item-action">📍 ${calle}</div>`).join('')}
              </div>
            </div>
          </div>
        `;
      } else if (rolId == 3 && calleNombre) {
        contenido += `
          <div class="card mt-3">
            <div class="card-header bg-success text-white">
              <i class="bi bi-house-door"></i> Calle asignada
            </div>
            <div class="card-body">
              <h5 class="mb-0">📍 ${calleNombre}</h5>
            </div>
          </div>
        `;
      } else if (rolId == 4 && calleNombre) {
        contenido += `
          <div class="card mt-3">
            <div class="card-header bg-secondary text-white">
              <i class="bi bi-house-heart"></i> Calle donde vive
            </div>
            <div class="card-body">
              <h5 class="mb-0">📍 ${calleNombre}</h5>
            </div>
          </div>
        `;
      } else {
        contenido += `
          <div class="alert alert-warning mt-3 mb-0">
            <i class="bi bi-info-circle"></i> Este usuario no tiene asignaciones específicas.
          </div>
        `;
      }
      
      document.getElementById('detalleUsuarioContent').innerHTML = contenido;
      document.getElementById('btnEditarUsuario').href = `/usuarios/${id}/editar`;
      
      new bootstrap.Modal(document.getElementById('modalUsuarioDetalle')).show();
    });
  });
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
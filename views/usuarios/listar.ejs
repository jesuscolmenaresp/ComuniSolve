<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1" style="color: #5D4037;">
        <i class="bi bi-people me-2" style="color: #fd6704bd;"></i> Gestión de Usuarios
      </h2>
      <p class="text-muted small mb-0" style="color: #8B6B5A;">Administra los ciudadanos y líderes de la comunidad</p>
    </div>
    <a href="/usuarios/nuevo" class="btn btn-sm px-4 py-2 fw-semibold rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
      <i class="bi bi-plus-circle me-1"></i> Nuevo Usuario
    </a>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Filtros -->
  <div class="card border-0 rounded-4 shadow-sm mb-4 overflow-hidden">
    <div class="px-4 py-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
      <h5 class="mb-0 fw-semibold" style="color: #5D4037;">
        <i class="bi bi-funnel me-2" style="color: #fd6704bd;"></i> Filtros
      </h5>
    </div>
    <div class="card-body p-4">
      <div class="row g-3">
        <div class="col-md-3">
          <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
            <i class="bi bi-tag me-1" style="color: #fd6704bd;"></i> Rol
          </label>
          <select id="filtroRol" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
            <option value="0">📌 Todos los roles</option>
            <option value="1">🏛️ UBCH</option>
            <option value="2">👨‍💼 Líder</option>
            <option value="3">👤 Jefe de Calle</option>
            <option value="4">🧑‍🤝‍🧑 Ciudadano</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
            <i class="bi bi-info-circle me-1" style="color: #fd6704bd;"></i> Estado
          </label>
          <select id="filtroEstado" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
            <option value="todos">📌 Todos los estados</option>
            <option value="pendiente">⏳ Pendientes</option>
            <option value="aprobado">✅ Aprobados</option>
            <option value="rechazado">❌ Rechazados</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
            <i class="bi bi-search me-1" style="color: #fd6704bd;"></i> Buscar
          </label>
          <input type="text" id="buscarUsuario" class="form-control rounded-3" placeholder="Buscar por nombre o email..."
                 style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button id="limpiarFiltros" class="btn btn-sm btn-outline-secondary w-100 py-2 fw-semibold rounded-3" style="border-color: #f0d5c0; color: #5D4037;">
            <i class="bi bi-x-circle me-1"></i> Limpiar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabla de usuarios -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="tablaUsuarios">
          <thead class="table-light">
            <tr class="text-center">
              <th><i class="bi bi-card-text"></i> Cédula</th>
              <th><i class="bi bi-person"></i> Nombre</th>
              <th><i class="bi bi-envelope"></i> Email</th>
              <th><i class="bi bi-telephone"></i> Teléfono</th>
              <th><i class="bi bi-tag"></i> Rol</th>
              <th><i class="bi bi-geo-alt"></i> Asignación</th>
              <th><i class="bi bi-info-circle"></i> Estado</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (usuarios && usuarios.length > 0) { %>
              <% usuarios.forEach(u => { %>
                <tr class="align-middle text-center" 
                    data-rol="<%= u.rol_id %>" 
                    data-estado="<%= u.estado %>"
                    data-id="<%= u.id %>"
                    data-cedula="<%= u.cedula || '' %>"
                    data-nombre="<%= u.nombre %>"
                    data-email="<%= u.email %>"
                    data-telefono="<%= u.telefono || 'No registrado' %>"
                    data-rol-nombre="<%= u.rol_nombre %>"
                    data-calles-lideradas="<%= JSON.stringify(u.calles_lideradas || []) %>"
                    data-calle-nombre="<%= u.calle_nombre || '' %>"
                    data-comunidades="<%= JSON.stringify(u.comunidades_atiende || []) %>"
                    style="cursor: pointer;">
                  <td class="small"><%= u.cedula || '—' %></td>
                  <td class="fw-semibold text-start" style="color: #5D4037;"><%= u.nombre %></td>
                  <td><%= u.email %></td>
                  <td><%= u.telefono || '—' %></td>
                  <td>
                    <span class="badge rounded-pill px-3 py-1 
                      <%= u.rol_id === 1 ? 'bg-danger' : 
                          u.rol_id === 2 ? 'bg-info' : 
                          u.rol_id === 3 ? 'bg-success' : 'bg-secondary' %>" 
                      style="<%= u.rol_id === 2 ? 'color: #333;' : 'color: white;' %>">
                      <%= u.rol_nombre %>
                    </span>
                  </td>
                  <td>
                    <% if (u.rol_id === 2 && u.calles_lideradas && u.calles_lideradas.length > 0) { %>
                      <span class="badge rounded-pill px-2 py-1" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                        <i class="bi bi-geo-alt me-1"></i> <%= u.calles_lideradas.length %> calles
                      </span>
                    <% } else if (u.rol_id === 3 && u.calle_nombre) { %>
                      <span class="badge rounded-pill px-2 py-1" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white;">
                        <i class="bi bi-pin-map-fill me-1"></i> <%= u.calle_nombre %>
                      </span>
                    <% } else if (u.rol_id === 4 && u.calle_nombre) { %>
                      <span class="badge rounded-pill px-2 py-1" style="background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%); color: white;">
                        <i class="bi bi-house-heart me-1"></i> <%= u.calle_nombre %>
                      </span>
                    <% } else if (u.rol_id === 1 && u.comunidades_atiende && u.comunidades_atiende.length > 0) { %>
                      <span class="badge rounded-pill px-2 py-1" style="background: linear-gradient(135deg, #17a2b8 0%, #0dcaf0 100%); color: white;">
                        <i class="bi bi-building me-1"></i> <%= u.comunidades_atiende.length %> comunidades
                      </span>
                    <% } else { %>
                      <span class="text-muted small">— Sin asignación —</span>
                    <% } %>
                  </td>
                  <!-- Estado -->
                  <td class="text-center">
                    <span class="badge rounded-pill px-3 py-1 
                      <%= u.estado === 'aprobado' ? 'bg-success' : 
                          u.estado === 'pendiente' ? 'bg-warning' : 'bg-danger' %>" 
                      style="<%= u.estado === 'pendiente' ? 'color: #333;' : 'color: white;' %>">
                      <%= u.estado === 'aprobado' ? '✅ Aprobado' : u.estado === 'pendiente' ? '⏳ Pendiente' : '❌ Rechazado' %>
                    </span>
                    <% if (u.estado === 'pendiente') { %>
                      <div class="mt-1 d-flex gap-1 justify-content-center">
                        <form action="/usuarios/<%= u.id %>/aprobar" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm px-2 py-1 rounded-3" title="Aprobar" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white; border: none;">
                            <i class="bi bi-check-lg"></i>
                          </button>
                        </form>
                        <button type="button" class="btn btn-sm px-2 py-1 rounded-3" title="Rechazar" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none;"
                                data-bs-toggle="modal" data-bs-target="#modalRechazar<%= u.id %>">
                          <i class="bi bi-x-lg"></i>
                        </button>
                      </div>
                      <!-- Modal para motivo de rechazo -->
                      <div class="modal fade" id="modalRechazar<%= u.id %>" tabindex="-1">
                        <div class="modal-dialog modal-sm">
                          <div class="modal-content border-0 rounded-4 shadow-lg">
                            <div class="modal-header" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);">
                              <h6 class="modal-title text-white">Rechazar usuario</h6>
                              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <form action="/usuarios/<%= u.id %>/rechazar" method="POST">
                              <div class="modal-body p-4" style="background: #fefaf7;">
                                <label class="form-label fw-semibold small" style="color: #5D4037;">Motivo (opcional):</label>
                                <textarea name="motivo" class="form-control rounded-3 mt-2" rows="2" placeholder="Ej: No vive en la calle indicada"
                                          style="border: 1px solid #f0d5c0; background-color: #fefaf7;"></textarea>
                              </div>
                              <div class="modal-footer bg-light">
                                <button type="button" class="btn btn-sm btn-secondary rounded-3" data-bs-dismiss="modal">Cancelar</button>
                                <button type="submit" class="btn btn-sm rounded-3" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none;">Rechazar</button>
                              </div>
                            </form>
                          </div>
                        </div>
                      </div>
                    <% } %>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/usuarios/<%= u.id %>/editar" class="btn btn-sm px-2 py-1 rounded-3" title="Editar" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); color: #333; border: none;">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <% if (u.id !== usuario.id) { %>
                        <form action="/usuarios/<%= u.id %>/eliminar" method="POST" class="d-inline" 
                              onsubmit="return confirm('¿Eliminar este usuario?')">
                          <button type="submit" class="btn btn-sm px-2 py-1 rounded-3" title="Eliminar" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none;">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="8" class="text-center py-5">
                  <i class="bi bi-people fs-1 text-muted d-block mb-2"></i>
                  <p class="text-muted mb-0">No hay usuarios registrados</p>
                  <a href="/usuarios/nuevo" class="btn btn-sm mt-3 px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                    <i class="bi bi-plus-circle me-1"></i> Crear primer usuario
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Resumen de usuarios -->
  <div class="card border-0 rounded-4 shadow-sm mt-4 overflow-hidden">
    <div class="card-body p-3">
      <div class="row text-center">
        <div class="col-3">
          <i class="bi bi-people fs-4" style="color: #fd6704bd;"></i>
          <h5 class="fw-bold mb-0" style="color: #5D4037;"><%= usuarios.length %></h5>
          <small class="text-muted" style="color: #8B6B5A;">Total</small>
        </div>
        <div class="col-3">
          <i class="bi bi-bank fs-4" style="color: #dc3545;"></i>
          <h5 class="fw-bold mb-0" style="color: #5D4037;"><%= usuarios.filter(u => u.rol_id === 1).length %></h5>
          <small class="text-muted" style="color: #8B6B5A;">UBCH</small>
        </div>
        <div class="col-3">
          <i class="bi bi-person-badge fs-4" style="color: #17a2b8;"></i>
          <h5 class="fw-bold mb-0" style="color: #5D4037;"><%= usuarios.filter(u => u.rol_id === 2).length %></h5>
          <small class="text-muted" style="color: #8B6B5A;">Líderes</small>
        </div>
        <div class="col-3">
          <i class="bi bi-person fs-4" style="color: #28a745;"></i>
          <h5 class="fw-bold mb-0" style="color: #5D4037;"><%= usuarios.filter(u => u.rol_id === 4).length %></h5>
          <small class="text-muted" style="color: #8B6B5A;">Ciudadanos</small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal de Detalles del Usuario -->
<div class="modal fade" id="modalUsuarioDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg">
      <div class="modal-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
        <h5 class="modal-title text-white">
          <i class="bi bi-person-circle me-2"></i> Detalles del Usuario
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4" id="detalleUsuarioContent" style="background: #fefaf7;">
        <!-- Contenido cargado dinámicamente -->
      </div>
      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
        <a href="#" id="btnEditarUsuario" class="btn rounded-3 px-4" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); color: #333; border: none;">✏️ Editar usuario</a>
      </div>
    </div>
  </div>
</div>

<script>
  // Filtros
  const filtroRol = document.getElementById('filtroRol');
  const filtroEstado = document.getElementById('filtroEstado');
  const buscarUsuario = document.getElementById('buscarUsuario');
  const limpiarFiltros = document.getElementById('limpiarFiltros');
  const filas = () => document.querySelectorAll('#tablaUsuarios tbody tr');

  function aplicarFiltros() {
    const rol = filtroRol.value;
    const estado = filtroEstado.value;
    const texto = buscarUsuario.value.toLowerCase();
    
    filas().forEach(fila => {
      const dataRol = fila.dataset.rol;
      const dataEstado = fila.dataset.estado;
      const dataNombre = fila.dataset.nombre?.toLowerCase() || '';
      const dataEmail = fila.dataset.email?.toLowerCase() || '';
      
      let mostrar = true;
      
      if (rol != 0 && dataRol != rol) mostrar = false;
      if (estado !== 'todos' && dataEstado !== estado) mostrar = false;
      if (texto && !dataNombre.includes(texto) && !dataEmail.includes(texto)) mostrar = false;
      
      fila.style.display = mostrar ? '' : 'none';
    });
  }

  filtroRol.addEventListener('change', aplicarFiltros);
  filtroEstado.addEventListener('change', aplicarFiltros);
  buscarUsuario.addEventListener('keyup', aplicarFiltros);
  limpiarFiltros.addEventListener('click', () => {
    filtroRol.value = '0';
    filtroEstado.value = 'todos';
    buscarUsuario.value = '';
    aplicarFiltros();
  });

  // Doble clic para mostrar detalles
  document.querySelectorAll('#tablaUsuarios tbody tr').forEach(fila => {
    fila.addEventListener('dblclick', function(e) {
      if (e.target.tagName === 'BUTTON' || e.target.tagName === 'A') return;
      
      const id = this.dataset.id;
      const cedula = this.dataset.cedula;
      const nombre = this.dataset.nombre;
      const email = this.dataset.email;
      const telefono = this.dataset.telefono;
      const rolNombre = this.dataset.rolNombre;
      const rolId = this.dataset.rol;
      const callesLideradas = JSON.parse(this.dataset.callesLideradas || '[]');
      const calleNombre = this.dataset.calleNombre;
      const comunidades = JSON.parse(this.dataset.comunidades || '[]');
      
      let contenido = `
        <div class="mb-3">
          <div class="row mb-2">
            <div class="col-5 fw-bold" style="color: #5D4037;">Cédula:</div>
            <div class="col-7">${cedula || '—'}</div>
          </div>
          <div class="row mb-2">
            <div class="col-5 fw-bold" style="color: #5D4037;">Nombre:</div>
            <div class="col-7">${nombre}</div>
          </div>
          <div class="row mb-2">
            <div class="col-5 fw-bold" style="color: #5D4037;">Email:</div>
            <div class="col-7">${email}</div>
          </div>
          <div class="row mb-2">
            <div class="col-5 fw-bold" style="color: #5D4037;">Teléfono:</div>
            <div class="col-7">${telefono}</div>
          </div>
          <div class="row">
            <div class="col-5 fw-bold" style="color: #5D4037;">Rol:</div>
            <div class="col-7">
              <span class="badge rounded-pill px-3 py-1 ${rolId == 1 ? 'bg-danger' : rolId == 2 ? 'bg-info' : rolId == 3 ? 'bg-success' : 'bg-secondary'}" style="${rolId == 2 ? 'color: #333;' : 'color: white;'}">
                ${rolNombre}
              </span>
            </div>
          </div>
        </div>
      `;
      
      if (rolId == 1 && comunidades.length > 0) {
        contenido += `
          <div class="card border-0 rounded-3 shadow-sm mt-3">
            <div class="card-header" style="background: linear-gradient(135deg, #17a2b8 0%, #0dcaf0 100%);">
              <small class="fw-bold text-white"><i class="bi bi-building me-1"></i> Comunidades que atiende</small>
            </div>
            <div class="card-body p-3">
              <div class="d-flex flex-wrap gap-2">
                ${comunidades.map(com => `<span class="badge rounded-pill px-3 py-1" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">🏘️ ${com}</span>`).join('')}
              </div>
            </div>
          </div>
        `;
      } else if (rolId == 2 && callesLideradas.length > 0) {
        contenido += `
          <div class="card border-0 rounded-3 shadow-sm mt-3">
            <div class="card-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
              <small class="fw-bold text-white"><i class="bi bi-geo-alt me-1"></i> Calles que lidera</small>
            </div>
            <div class="card-body p-3">
              <div class="d-flex flex-wrap gap-2">
                ${callesLideradas.map(calle => `<span class="badge rounded-pill px-3 py-1" style="background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%); color: white;">📍 ${calle}</span>`).join('')}
              </div>
            </div>
          </div>
        `;
      } else if (rolId == 3 && calleNombre) {
        contenido += `
          <div class="card border-0 rounded-3 shadow-sm mt-3">
            <div class="card-header" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
              <small class="fw-bold text-white"><i class="bi bi-house-door me-1"></i> Calle asignada</small>
            </div>
            <div class="card-body p-3">
              <h6 class="mb-0" style="color: #5D4037;">📍 ${calleNombre}</h6>
            </div>
          </div>
        `;
      } else if (rolId == 4 && calleNombre) {
        contenido += `
          <div class="card border-0 rounded-3 shadow-sm mt-3">
            <div class="card-header" style="background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);">
              <small class="fw-bold text-white"><i class="bi bi-house-heart me-1"></i> Calle donde vive</small>
            </div>
            <div class="card-body p-3">
              <h6 class="mb-0" style="color: #5D4037;">📍 ${calleNombre}</h6>
            </div>
          </div>
        `;
      } else if (rolId != 1 && rolId != 2 && rolId != 3 && rolId != 4) {
        contenido += `
          <div class="alert alert-warning mt-3 mb-0 rounded-3" style="background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%); border: none;">
            <i class="bi bi-info-circle me-1"></i> Este usuario no tiene asignaciones específicas.
          </div>
        `;
      }
      
      document.getElementById('detalleUsuarioContent').innerHTML = contenido;
      document.getElementById('btnEditarUsuario').href = `/usuarios/${id}/editar`;
      
      new bootstrap.Modal(document.getElementById('modalUsuarioDetalle')).show();
    });
  });
</script>

<style>
  .table-hover tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  .btn-sm {
    transition: all 0.2s ease;
  }
  .btn-sm:hover {
    transform: translateY(-2px);
  }
  .badge {
    font-weight: normal;
  }
  .form-control:focus, .form-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
</style>
<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 listar-title">
        <i class="bi bi-people me-2"></i> Gestión de Usuarios
      </h2>
      <p class="text-muted small mb-0 listar-subtitle">Administra los ciudadanos y líderes de la comunidad</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/usuarios/inactivos" class="btn btn-sm btn-outline-danger px-3 py-2 fw-semibold rounded-3 btn-ver-inactivos">
        <i class="bi bi-person-x me-1"></i> Ver inactivos
      </a>
      <a href="/usuarios/nuevo" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-nuevo-usuario">
        <i class="bi bi-plus-circle me-1"></i> Nuevo Usuario
      </a>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Filtros -->
  <div class="card border-0 rounded-4 shadow-sm mb-4 overflow-hidden filtros-card">
    <div class="px-4 py-3 filtros-header">
      <h5 class="mb-0 fw-semibold">
        <i class="bi bi-funnel me-2"></i> Filtros
      </h5>
    </div>
    <div class="card-body p-4 filtros-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-tag me-1"></i> Rol
          </label>
          <select id="filtroRol" class="form-select rounded-3 filtros-select">
            <option value="0">📌 Todos los roles</option>
            <option value="1">🏛️ UBCH</option>
            <option value="2">👨‍💼 Líder</option>
            <option value="3">👤 Jefe de Calle</option>
            <option value="4">🧑‍🤝‍🧑 Ciudadano</option>
            <% if (session.usuario && session.usuario.rol_id === 5) { %>
              <option value="5">👑 SuperAdministrador</option>
            <% } %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-info-circle me-1"></i> Estado
          </label>
          <select id="filtroEstado" class="form-select rounded-3 filtros-select">
            <option value="todos">📌 Todos los estados</option>
            <option value="pendiente">⏳ Pendientes</option>
            <option value="aprobado">✅ Aprobados</option>
            <option value="rechazado">❌ Rechazados</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold small mb-2 filtros-label">
            <i class="bi bi-search me-1"></i> Buscar
          </label>
          <input type="text" id="buscarUsuario" class="form-control rounded-3 filtros-input" placeholder="Buscar por nombre o email...">
        </div>
      </div>
      <div class="row mt-3">
        <div class="col-12 d-flex justify-content-end">
          <button id="limpiarFiltros" class="btn btn-sm btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-limpiar-filtros">
            <i class="bi bi-x-circle me-1"></i> Limpiar filtros
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabla de usuarios -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden listar-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 listar-tabla" id="tablaUsuarios">
          <thead class="listar-tabla-header">
            <tr class="text-center">
              <th style="width: 10%"><i class="bi bi-card-text"></i> Cédula</th>
              <th style="width: 25%"><i class="bi bi-person"></i> Nombre</th>
              <th style="width: 25%"><i class="bi bi-envelope"></i> Email</th>
              <th style="width: 10%"><i class="bi bi-tag"></i> Rol</th>
              <th style="width: 15%"><i class="bi bi-geo-alt"></i> Asignación</th>
              <th style="width: 15%"><i class="bi bi-info-circle"></i> Estado</th>
              <th style="width: 10%"><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (usuarios && usuarios.length > 0) { %>
              <% usuarios.forEach(u => { 
                const esSuperAdminLogueado = session.usuario && session.usuario.rol_id === 5;
                const esUBCHLogueado = session.usuario && session.usuario.rol_id === 1;
                
                if (esUBCHLogueado && u.rol_id === 5) return;
              %>
                <tr class="align-middle text-center listar-fila" 
                    data-rol="<%= u.rol_id %>" 
                    data-estado="<%= u.estado %>"
                    data-id="<%= u.id %>"
                    data-cedula="<%= u.cedula || '' %>"
                    data-nombre="<%= u.nombre %>"
                    data-email="<%= u.email %>"
                    data-telefono="<%= u.telefono || 'No registrado' %>"
                    data-rol-nombre="<%= u.rol_nombre %>"
                    data-calles-lideradas="<%= JSON.stringify(u.calles_lideradas || []) %>"
                    data-calle-nombre="<%= u.calle_nombre || '' %>"
                    data-comunidades="<%= JSON.stringify(u.comunidades_atiende || []) %>"
                    data-foto-perfil="<%= u.foto_perfil || '' %>"
                    style="cursor: pointer;">
                  <td class="small listar-cedula"><%= u.cedula || '—' %></td>
                  <td class="fw-semibold text-start listar-nombre"><%= u.nombre %></td>
                  <td><small class="listar-email"><%= u.email %></small></td>
                  <td>
                    <% if (u.rol_id === 5) { %>
                      <span class="badge rounded-pill px-3 py-1 badge-superadmin">SuperAdmin</span>
                    <% } else { %>
                      <span class="badge rounded-pill px-3 py-1 badge-rol 
                        <%= u.rol_id === 1 ? 'badge-ubch' : 
                            u.rol_id === 2 ? 'badge-lider' : 
                            u.rol_id === 3 ? 'badge-jefe' : 'badge-ciudadano' %>">
                        <%= u.rol_nombre %>
                      </span>
                    <% } %>
                  </td>
                  <td>
                    <% if (u.rol_id === 2 && u.calles_lideradas && u.calles_lideradas.length > 0) { %>
                      <span class="badge rounded-pill px-2 py-1 badge-asignacion-calles">
                        <i class="bi bi-geo-alt me-1"></i> <%= u.calles_lideradas.length %> calles
                      </span>
                    <% } else if (u.rol_id === 3 && u.calle_nombre) { %>
                      <span class="badge rounded-pill px-2 py-1 badge-asignacion-jefe">
                        <i class="bi bi-pin-map-fill me-1"></i> <%= u.calle_nombre %>
                      </span>
                    <% } else if (u.rol_id === 4 && u.calle_nombre) { %>
                      <span class="badge rounded-pill px-2 py-1 badge-asignacion-ciudadano">
                        <i class="bi bi-house-heart me-1"></i> <%= u.calle_nombre %>
                      </span>
                    <% } else if (u.rol_id === 1 && u.comunidades_atiende && u.comunidades_atiende.length > 0) { %>
                      <span class="badge rounded-pill px-2 py-1 badge-asignacion-ubch">
                        <i class="bi bi-building me-1"></i> <%= u.comunidades_atiende.length %> comunidades
                      </span>
                    <% } else { %>
                      <span class="text-muted small">— Sin asignación —</span>
                    <% } %>
                  </td>
                  <td class="text-center">
                    <span class="badge rounded-pill px-3 py-1 estado-badge 
                      <%= u.estado === 'aprobado' ? 'estado-aprobado' : 
                          u.estado === 'pendiente' ? 'estado-pendiente' : 'estado-rechazado' %>">
                      <%= u.estado === 'aprobado' ? '✅ Aprobado' : u.estado === 'pendiente' ? '⏳ Pendiente' : '❌ Rechazado' %>
                    </span>
                    
                    <% if (u.estado === 'rechazado') { %>
                      <div class="mt-1">
                        <form action="/usuarios/<%= u.id %>/reaprobar" method="POST" class="d-inline"
                              onsubmit="return confirm('¿Reaprobar este usuario? Volverá a estar activo en el sistema.')">
                          <button type="submit" class="btn btn-sm px-2 py-1 rounded-3 btn-reaprobar">
                            <i class="bi bi-arrow-repeat me-1"></i> Reaprobar
                          </button>
                        </form>
                      </div>
                    <% } %>
                    
                    <% if (u.estado === 'pendiente') { %>
                      <div class="mt-1 d-flex gap-1 justify-content-center">
                        <form action="/usuarios/<%= u.id %>/aprobar" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm px-2 py-1 rounded-3 btn-aprobar">
                            <i class="bi bi-check-lg"></i>
                          </button>
                        </form>
                        <button type="button" class="btn btn-sm px-2 py-1 rounded-3 btnRechazar btn-rechazar" 
                                data-id="<%= u.id %>"
                                data-nombre="<%= u.nombre %>">
                          <i class="bi bi-x-lg"></i>
                        </button>
                      </div>
                    <% } %>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <% const puedeEditar = (session.usuario.rol_id === 5) || (session.usuario.rol_id === 1 && u.rol_id !== 5); %>
                      <% if (puedeEditar && u.id !== session.usuario.id) { %>
                        <a href="/usuarios/<%= u.id %>/editar" class="btn btn-sm px-2 py-1 rounded-3 btn-editar" title="Editar">
                          <i class="bi bi-pencil"></i>
                        </a>
                      <% } %>
                      
                      <% 
                        const puedeDesactivar = 
                          (session.usuario.rol_id === 5 && u.id !== session.usuario.id && u.rol_id !== 5) ||
                          (session.usuario.rol_id === 1 && u.rol_id !== 1 && u.rol_id !== 5 && u.id !== session.usuario.id && u.estado === 'aprobado');
                      %>
                      <% if (puedeDesactivar) { %>
                        <form action="/usuarios/<%= u.id %>/eliminar" method="POST" class="d-inline" 
                              onsubmit="return confirm('¿Desactivar este usuario? Podrá ser reactivado después.')">
                          <button type="submit" class="btn btn-sm px-2 py-1 rounded-3 btn-desactivar" title="Desactivar">
                            <i class="bi bi-person-x"></i>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center py-5 empty-state-listar">
                  <i class="bi bi-people fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay usuarios registrados</p>
                  <a href="/usuarios/nuevo" class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-crear-primero">
                    <i class="bi bi-plus-circle me-1"></i> Crear primer usuario
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

<!-- ========== MENSAJE INFORMATIVO FUERA DE LA TABLA ========== -->
<div class="text-center mt-3">
  <span class="badge bg-light text-muted px-3 py-2 rounded-pill" style="font-weight: normal; font-size: 0.75rem; border: 1px solid #e0e0e0;">
    <i class="bi bi-hand-index-thumb me-1"></i> 
    Doble clic en cualquier fila para ver detalles
  </span>
</div>

  <!-- Resumen de usuarios -->
  <div class="card border-0 rounded-4 shadow-sm mt-4 overflow-hidden resumen-card">
    <div class="card-body p-3 resumen-body">
      <div class="row text-center">
        <div class="col-3">
          <i class="bi bi-people fs-4 resumen-icon-total"></i>
          <h5 class="fw-bold mb-0 resumen-total"><%= usuarios.filter(u => !(session.usuario.rol_id === 1 && u.rol_id === 5)).length %></h5>
          <small class="text-muted resumen-label">Total</small>
        </div>
        <div class="col-3">
          <i class="bi bi-bank fs-4 resumen-icon-ubch"></i>
          <h5 class="fw-bold mb-0 resumen-ubch"><%= usuarios.filter(u => u.rol_id === 1).length %></h5>
          <small class="text-muted resumen-label">UBCH</small>
        </div>
        <div class="col-3">
          <i class="bi bi-person-badge fs-4 resumen-icon-lider"></i>
          <h5 class="fw-bold mb-0 resumen-lider"><%= usuarios.filter(u => u.rol_id === 2).length %></h5>
          <small class="text-muted resumen-label">Líderes</small>
        </div>
        <div class="col-3">
          <i class="bi bi-person fs-4 resumen-icon-ciudadano"></i>
          <h5 class="fw-bold mb-0 resumen-ciudadano"><%= usuarios.filter(u => u.rol_id === 4).length %></h5>
          <small class="text-muted resumen-label">Ciudadanos</small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL ÚNICO PARA RECHAZAR USUARIO -->
<div class="modal fade" id="modalRechazarGlobal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-rechazar">
      <div class="modal-header modal-rechazar-header">
        <h6 class="modal-title text-white">
          <i class="bi bi-x-circle-fill me-2"></i> Rechazar usuario
        </h6>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="formRechazarGlobal" method="POST">
        <div class="modal-body p-4 modal-rechazar-body">
          <p class="mb-2">Estás a punto de rechazar a:</p>
          <div class="bg-light p-2 rounded-3 mb-3 text-center usuario-info" id="usuarioARechazarInfo"></div>
          <label class="form-label fw-semibold small modal-rechazar-label">Motivo (opcional):</label>
          <textarea name="motivo" id="motivoRechazo" class="form-control rounded-3 mt-2 modal-rechazar-textarea" rows="2" 
                    placeholder="Ej: No vive en la calle indicada"></textarea>
        </div>
        <div class="modal-footer modal-rechazar-footer">
          <button type="button" class="btn btn-sm btn-secondary rounded-3" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-sm rounded-3 btn-rechazar-confirmar">Rechazar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal de Detalles del Usuario -->
<div class="modal fade" id="modalUsuarioDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-detalle-usuario">
      <div class="modal-header modal-detalle-header">
        <h5 class="modal-title text-white">
          <i class="bi bi-person-circle me-2"></i> Detalles del Usuario
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4 modal-detalle-body" id="detalleUsuarioContent"></div>
      <div class="modal-footer modal-detalle-footer">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
        <a href="#" id="btnEditarUsuario" class="btn rounded-3 px-4 btn-editar-detalle">✏️ Editar usuario</a>
      </div>
    </div>
  </div>
</div>

<script>
  function abrirModalRechazar(usuarioId, usuarioNombre) {
    document.getElementById('formRechazarGlobal').action = '/usuarios/' + usuarioId + '/rechazar';
    document.getElementById('usuarioARechazarInfo').innerHTML = '<strong>' + usuarioNombre + '</strong>';
    document.getElementById('motivoRechazo').value = '';
    var modal = new bootstrap.Modal(document.getElementById('modalRechazarGlobal'));
    modal.show();
  }

  document.querySelectorAll('.btnRechazar').forEach(btn => {
    btn.addEventListener('click', function() {
      const id = this.dataset.id;
      const nombre = this.dataset.nombre;
      abrirModalRechazar(id, nombre);
    });
  });

  const filtroRol = document.getElementById('filtroRol');
  const filtroEstado = document.getElementById('filtroEstado');
  const buscarUsuario = document.getElementById('buscarUsuario');
  const limpiarFiltros = document.getElementById('limpiarFiltros');
  const filas = () => document.querySelectorAll('#tablaUsuarios tbody tr');

  function aplicarFiltros() {
    const rol = filtroRol.value;
    const estado = filtroEstado.value;
    const texto = buscarUsuario.value.toLowerCase();
    
    filas().forEach(fila => {
      const dataRol = fila.dataset.rol;
      const dataEstado = fila.dataset.estado;
      const dataNombre = fila.dataset.nombre?.toLowerCase() || '';
      const dataEmail = fila.dataset.email?.toLowerCase() || '';
      
      let mostrar = true;
      if (rol != 0 && dataRol != rol) mostrar = false;
      if (estado !== 'todos' && dataEstado !== estado) mostrar = false;
      if (texto && !dataNombre.includes(texto) && !dataEmail.includes(texto)) mostrar = false;
      fila.style.display = mostrar ? '' : 'none';
    });
  }

  filtroRol.addEventListener('change', aplicarFiltros);
  filtroEstado.addEventListener('change', aplicarFiltros);
  buscarUsuario.addEventListener('keyup', aplicarFiltros);
  limpiarFiltros.addEventListener('click', () => {
    filtroRol.value = '0';
    filtroEstado.value = 'todos';
    buscarUsuario.value = '';
    aplicarFiltros();
  });

  // ========== DOBLE CLICK PARA VER DETALLES CON FOTO ==========
  document.querySelectorAll('#tablaUsuarios tbody tr').forEach(fila => {
    fila.addEventListener('dblclick', function(e) {
      if (e.target.tagName === 'BUTTON' || e.target.tagName === 'A') return;
      
      const id = this.dataset.id;
      const cedula = this.dataset.cedula;
      const nombre = this.dataset.nombre;
      const email = this.dataset.email;
      const telefono = this.dataset.telefono;
      const rolNombre = this.dataset.rolNombre;
      const rolId = this.dataset.rol;
      const callesLideradas = JSON.parse(this.dataset.callesLideradas || '[]');
      const calleNombre = this.dataset.calleNombre;
      const comunidades = JSON.parse(this.dataset.comunidades || '[]');
      const fotoPerfil = this.dataset.fotoPerfil || null;
      
      let contenido = `
        <div class="row mb-3">
          <div class="col-12 text-center">
            <div class="detalle-avatar" style="width: 100px; height: 100px; border-radius: 50%; overflow: hidden; margin: 0 auto; border: 4px solid #fd6704bd; box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3); background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); display: flex; align-items: center; justify-content: center;">
              ${fotoPerfil && fotoPerfil !== 'null' && fotoPerfil !== '' ? 
                `<img src="${fotoPerfil}" alt="Foto de perfil" style="width: 100%; height: 100%; object-fit: cover;">` : 
                `<i class="bi bi-person-fill" style="font-size: 3rem; color: white;"></i>`
              }
            </div>
            <h5 class="fw-bold mt-2 mb-0" style="color: #5D4037;">${nombre}</h5>
            <span class="badge rounded-pill px-3 py-1 ${rolId == 1 ? 'bg-danger' : rolId == 2 ? 'bg-info' : rolId == 3 ? 'bg-success' : rolId == 5 ? 'bg-dark' : 'bg-secondary'}" style="color: white;">${rolNombre}</span>
          </div>
        </div>
        <hr>
        <div class="row">
          <div class="col-12">
            <div class="row mb-2"><div class="col-4 fw-bold text-muted">Cédula:</div><div class="col-8">${cedula || '—'}</div></div>
            <div class="row mb-2"><div class="col-4 fw-bold text-muted">Email:</div><div class="col-8">${email}</div></div>
            <div class="row mb-2"><div class="col-4 fw-bold text-muted">Teléfono:</div><div class="col-8">${telefono}</div></div>
          </div>
        </div>`;
      
      if (rolId == 1 && comunidades.length > 0) {
        contenido += `<div class="card border-0 rounded-3 shadow-sm mt-3"><div class="card-header" style="background: linear-gradient(135deg, #17a2b8 0%, #0dcaf0 100%);"><small class="fw-bold text-white"><i class="bi bi-building me-1"></i> Comunidades que atiende</small></div><div class="card-body p-3"><div class="d-flex flex-wrap gap-2">${comunidades.map(com => `<span class="badge rounded-pill px-3 py-1" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">🏘️ ${com}</span>`).join('')}</div></div></div>`;
      } else if (rolId == 2 && callesLideradas.length > 0) {
        contenido += `<div class="card border-0 rounded-3 shadow-sm mt-3"><div class="card-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);"><small class="fw-bold text-white"><i class="bi bi-geo-alt me-1"></i> Calles que lidera</small></div><div class="card-body p-3"><div class="d-flex flex-wrap gap-2">${callesLideradas.map(calle => `<span class="badge rounded-pill px-3 py-1" style="background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%); color: white;">📍 ${calle}</span>`).join('')}</div></div></div>`;
      } else if (rolId == 3 && calleNombre) {
        contenido += `<div class="card border-0 rounded-3 shadow-sm mt-3"><div class="card-header" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);"><small class="fw-bold text-white"><i class="bi bi-house-door me-1"></i> Calle asignada</small></div><div class="card-body p-3"><h6 class="mb-0">📍 ${calleNombre}</h6></div></div>`;
      } else if (rolId == 4 && calleNombre) {
        contenido += `<div class="card border-0 rounded-3 shadow-sm mt-3"><div class="card-header" style="background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);"><small class="fw-bold text-white"><i class="bi bi-house-heart me-1"></i> Calle donde vive</small></div><div class="card-body p-3"><h6 class="mb-0">📍 ${calleNombre}</h6></div></div>`;
      }
      
      document.getElementById('detalleUsuarioContent').innerHTML = contenido;
      document.getElementById('btnEditarUsuario').href = `/usuarios/${id}/editar`;
      new bootstrap.Modal(document.getElementById('modalUsuarioDetalle')).show();
    });
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  .listar-title { color: #5D4037; }
  .listar-title i { color: #fd6704bd; }

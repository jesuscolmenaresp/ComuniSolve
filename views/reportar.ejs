<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden reportar-card">
        
        <!-- Header con gradiente dual (naranja + azul) -->
        <div class="text-center py-4 px-3 reportar-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="reportar-icon-wrapper">
              <i class="bi bi-megaphone-fill fs-2 text-white"></i>
            </div>
          </div>
          <h2 class="mb-0 fw-bold reportar-title">Reportar Problema</h2>
          <p class="small mb-0 mt-1 reportar-subtitle">Completa el formulario para reportar una incidencia en tu comunidad</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 reportar-body">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/reportes" class="btn btn-sm px-3 py-1 rounded-3 btn-volver">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/reportar" method="POST" enctype="multipart/form-data" id="formReportar">
            
            <!-- Título -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 reportar-label">
                <i class="bi bi-card-heading me-1"></i> Título del problema *
              </label>
              <input type="text" name="titulo" id="tituloInput" class="form-control rounded-3 reportar-input" 
                     placeholder="Ej: Bote de agua en la esquina" required>
            </div>

            <!-- Descripción -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 reportar-label">
                <i class="bi bi-file-text me-1"></i> Descripción *
              </label>
              <textarea name="descripcion" id="descripcionInput" class="form-control rounded-3 reportar-input" rows="3" 
                        placeholder="Describe detalladamente el problema que deseas reportar..." required></textarea>
            </div>

            <!-- Categoría - SIN ICONOS -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 reportar-label">
                <i class="bi bi-tag me-1"></i> Categoría del problema *
              </label>
              <select name="categoria_id" id="categoriaSelect" class="form-select rounded-3 reportar-select" required>
                <option value="">-- Seleccione una categoría --</option>
                <% if (categorias && categorias.length > 0) { %>
                  <% categorias.forEach(cat => { %>
                    <option value="<%= cat.id %>">
                      <%= cat.nombre %>
                    </option>
                  <% }) %>
                <% } else { %>
                  <option value="" disabled>No hay categorías disponibles</option>
                <% } %>
              </select>
            </div>

            <!-- Calle -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 reportar-label">
                <i class="bi bi-geo-alt me-1"></i> ¿A qué calle pertenece el problema? *
              </label>
              
              <% if (usuario.rol_id === 4 && usuario.calle_id && calles && calles.length > 0) { %>
                <div class="alert alert-success-custom py-2 mb-0">
                  <i class="bi bi-check-circle-fill me-1"></i>
                  Reportando desde tu calle: <strong><%= calles[0].nombre %></strong>
                </div>
                <input type="hidden" name="calle_id" value="<%= usuario.calle_id %>">
              
              <% } else if (usuario.rol_id === 3 && usuario.calle_id && calles && calles.length > 0) { %>
                <div class="alert alert-info-custom py-2 mb-0">
                  <i class="bi bi-info-circle-fill me-1"></i>
                  Reportando desde tu calle asignada: <strong><%= calles[0].nombre %></strong>
                </div>
                <input type="hidden" name="calle_id" value="<%= usuario.calle_id %>">
              
              <% } else if ((usuario.rol_id === 2 || usuario.rol_id === 1) && calles && calles.length > 0) { %>
                <select name="calle_id" id="calleSelect" class="form-select rounded-3 reportar-select" required>
                  <option value="">-- Seleccione una calle --</option>
                  <% calles.forEach(c => { %>
                    <option value="<%= c.id %>"><%= c.nombre %></option>
                  <% }) %>
                </select>
                <small class="text-muted reportar-help">Selecciona la calle donde ocurre el problema</small>
              
              <% } else { %>
                <div class="alert alert-warning-custom py-2 mb-0">
                  <i class="bi bi-exclamation-triangle-fill me-1"></i>
                  No tienes una calle asignada. Contacta al administrador.
                </div>
                <input type="hidden" name="calle_id" value="">
              <% } %>
            </div>

            <!-- Mostrar nombre -->
            <div class="mb-4">
              <div class="form-check">
                <input class="form-check-input reportar-checkbox" type="checkbox" name="mostrar_nombre" value="1" id="mostrarNombre" checked>
                <label class="form-check-label reportar-label-check" for="mostrarNombre">
                  <i class="bi bi-person-badge me-1"></i> Mostrar mi nombre en el reporte
                </label>
              </div>
              <small class="text-muted reportar-help">Si no marcas esta opción, tu reporte aparecerá como anónimo</small>
            </div>

            <!-- Subir imagen -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 reportar-label">
                <i class="bi bi-image me-1"></i> Adjuntar imagen (opcional)
              </label>
              <input type="file" name="imagen" id="imagenInput" class="form-control rounded-3 reportar-file" accept="image/*">
              <small class="text-muted reportar-help" id="infoImagen">Puedes subir una imagen del problema (JPG, PNG, GIF, WEBP - Máximo 10 MB)</small>
              <div id="previewImagen" class="mt-2" style="display: none;">
                <img id="previewImg" src="#" alt="Vista previa" style="max-height: 150px; border-radius: 8px; border: 1px solid #f0d5c0; padding: 4px;">
                <button type="button" id="btnQuitarImagen" class="btn btn-sm btn-outline-danger mt-1">
                  <i class="bi bi-x-circle me-1"></i> Quitar imagen
                </button>
              </div>
              <!-- Barra de progreso de compresión -->
              <div id="compressionProgress" style="display: none; margin-top: 8px;">
                <div class="progress" style="height: 8px;">
                  <div id="compressionBar" class="progress-bar progress-bar-striped" role="progressbar" style="width: 0%; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);"></div>
                </div>
                <small class="text-muted" id="compressionText">Comprimiendo imagen...</small>
              </div>
            </div>

            <!-- Mapa de ubicación -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 reportar-label">
                <i class="bi bi-map me-1"></i> Ubicación del problema *
              </label>
              
              <div class="mb-2">
                <button type="button" id="btnUbicacion" class="btn btn-sm px-3 py-1 rounded-3 btn-ubicacion">
                  <i class="bi bi-geo-alt-fill me-1"></i> Usar mi ubicación actual
                </button>
                <small class="text-muted ms-2" id="estadoUbicacion"></small>
              </div>
              
              <div id="map" style="height: 350px; border-radius: 12px;"></div>
              <input type="hidden" name="ubicacion_lat" id="ubicacion_lat">
              <input type="hidden" name="ubicacion_lng" id="ubicacion_lng">
              <small class="text-muted reportar-help">Haz clic en el mapa para marcar la ubicación exacta</small>
            </div>

            <!-- Barra de progreso de envío -->
            <div id="submitProgress" style="display: none; margin-top: 15px;">
              <div class="progress" style="height: 25px;">
                <div id="submitProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
                     role="progressbar" style="width: 0%; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
                  0%
                </div>
              </div>
              <small class="text-muted" id="submitProgressText">Enviando reporte...</small>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-enviar" id="btnEnviar">
                <i class="bi bi-send-fill me-2"></i> Enviar Reporte
              </button>
              <a href="/reportes" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 reportar-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 reportar-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<!-- Leaflet CSS y JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  // ==========================================
  // 1. FUNCIÓN PARA COMPRIMIR IMAGEN
  // ==========================================
  async function comprimirImagen(file, maxWidth = 1200, maxHeight = 1200, quality = 0.7) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = function(event) {
        const img = new Image();
        img.src = event.target.result;
        img.onload = function() {
          // Actualizar barra de progreso
          document.getElementById('compressionBar').style.width = '30%';
          document.getElementById('compressionText').textContent = 'Procesando imagen...';
          
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;
          
          // Redimensionar si es necesario
          if (width > maxWidth) {
            height = (height * maxWidth) / width;
            width = maxWidth;
          }
          if (height > maxHeight) {
            width = (width * maxHeight) / height;
            height = maxHeight;
          }
          
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          
          // Actualizar barra de progreso
          document.getElementById('compressionBar').style.width = '70%';
          document.getElementById('compressionText').textContent = 'Comprimiendo imagen...';
          
          // Convertir a JPEG con calidad reducida
          canvas.toBlob(function(blob) {
            const compressedFile = new File([blob], file.name.replace(/\.[^.]+$/, '.jpg'), {
              type: 'image/jpeg',
              lastModified: Date.now()
            });
            
            // Completar barra de progreso
            document.getElementById('compressionBar').style.width = '100%';
            document.getElementById('compressionText').textContent = '✅ Imagen comprimida!';
            
            setTimeout(() => {
              document.getElementById('compressionProgress').style.display = 'none';
            }, 1000);
            
            resolve(compressedFile);
          }, 'image/jpeg', quality);
        };
        img.onerror = reject;
      };
      reader.onerror = reject;
    });
  }

  // ==========================================
  // 2. PREVISUALIZACIÓN DE IMAGEN CON COMPRESIÓN
  // ==========================================
  document.getElementById('imagenInput').addEventListener('change', async function(e) {
    const previewDiv = document.getElementById('previewImagen');
    const previewImg = document.getElementById('previewImg');
    const file = this.files[0];
    
    if (file) {
      // Mostrar barra de compresión
      const compressionProgress = document.getElementById('compressionProgress');
      compressionProgress.style.display = 'block';
      document.getElementById('compressionBar').style.width = '0%';
      document.getElementById('compressionText').textContent = 'Cargando imagen...';
      
      try {
        // Comprimir la imagen para la vista previa
        const compressedFile = await comprimirImagen(file, 800, 800, 0.7);
        
        // Mostrar vista previa con la imagen comprimida
        const reader = new FileReader();
        reader.onload = function(event) {
          previewImg.src = event.target.result;
          previewDiv.style.display = 'block';
        };
        reader.readAsDataURL(compressedFile);
        
        // Guardar el archivo comprimido para el envío
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(compressedFile);
        document.getElementById('imagenInput').files = dataTransfer.files;
        
        // Mostrar información del archivo comprimido
        const sizeMB = (compressedFile.size / 1024 / 1024).toFixed(1);
        document.getElementById('infoImagen').textContent = `✅ Imagen comprimida: ${compressedFile.name} (${sizeMB} MB)`;
        
      } catch (error) {
        console.error('Error comprimiendo imagen:', error);
        // Si falla la compresión, usar la imagen original
        const reader = new FileReader();
        reader.onload = function(event) {
          previewImg.src = event.target.result;
          previewDiv.style.display = 'block';
        };
        reader.readAsDataURL(file);
        document.getElementById('infoImagen').textContent = `⚠️ Sin compresión: ${file.name}`;
      }
    }
  });

  // Quitar imagen
  document.getElementById('btnQuitarImagen').addEventListener('click', function() {
    document.getElementById('imagenInput').value = '';
    document.getElementById('previewImagen').style.display = 'none';
    document.getElementById('infoImagen').textContent = 'Puedes subir una imagen del problema (JPG, PNG, GIF, WEBP - Máximo 10 MB)';
    document.getElementById('compressionProgress').style.display = 'none';
  });

  // ==========================================
  // 3. INICIALIZAR MAPA
  // ==========================================
  window.map = L.map('map').setView([10.0389, -67.4931], 14);
  
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
  }).addTo(window.map);

  let marker = null;

  window.map.on('click', function(e) {
    const { lat, lng } = e.latlng;

    if (marker) {
      marker.setLatLng([lat, lng]);
    } else {
      marker = L.marker([lat, lng]).addTo(window.map);
    }

    document.getElementById('ubicacion_lat').value = lat;
    document.getElementById('ubicacion_lng').value = lng;
  });

  // Botón de geolocalización
  document.getElementById('btnUbicacion').addEventListener('click', function() {
    const estado = document.getElementById('estadoUbicacion');
    estado.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> Obteniendo ubicación...';
    estado.style.color = '#fd6704bd';
    
    if (!navigator.geolocation) {
      estado.innerHTML = '❌ Tu navegador no soporta geolocalización';
      estado.style.color = '#dc3545';
      return;
    }
    
    navigator.geolocation.getCurrentPosition(
      function(position) {
        const lat = position.coords.latitude;
        const lng = position.coords.longitude;
        
        document.getElementById('ubicacion_lat').value = lat;
        document.getElementById('ubicacion_lng').value = lng;
        
        window.map.setView([lat, lng], 16);
        if (marker) {
          marker.setLatLng([lat, lng]);
        } else {
          marker = L.marker([lat, lng]).addTo(window.map);
        }
        
        estado.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Ubicación obtenida correctamente';
        estado.style.color = '#28a745';
        setTimeout(() => { estado.innerHTML = ''; }, 3000);
      },
      function(error) {
        let mensaje = '❌ Error: ';
        switch(error.code) {
          case error.PERMISSION_DENIED:
            mensaje += 'Permiso denegado';
            break;
          case error.POSITION_UNAVAILABLE:
            mensaje += 'Ubicación no disponible';
            break;
          case error.TIMEOUT:
            mensaje += 'Tiempo de espera agotado';
            break;
          default:
            mensaje += 'No se pudo obtener tu ubicación';
        }
        estado.innerHTML = mensaje;
        estado.style.color = '#dc3545';
      }
    );
  });

  // ==========================================
  // 4. VALIDACIONES Y ENVÍO DEL FORMULARIO
  // ==========================================
  document.getElementById('formReportar').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const btnEnviar = document.getElementById('btnEnviar');
    const submitProgress = document.getElementById('submitProgress');
    const submitProgressBar = document.getElementById('submitProgressBar');
    const submitProgressText = document.getElementById('submitProgressText');
    const fileInput = document.getElementById('imagenInput');
    
    // 1. Validar título
    const titulo = document.getElementById('tituloInput').value.trim();
    if (titulo.length < 3) {
      alert('⚠️ El título debe tener al menos 3 caracteres.');
      document.getElementById('tituloInput').focus();
      return;
    }
    
    // 2. Validar descripción
    const descripcion = document.getElementById('descripcionInput').value.trim();
    if (descripcion.length < 10) {
      alert('⚠️ La descripción debe tener al menos 10 caracteres.');
      document.getElementById('descripcionInput').focus();
      return;
    }
    
    // 3. Validar categoría
    const categoria = document.getElementById('categoriaSelect').value;
    if (!categoria) {
      alert('⚠️ Por favor, selecciona una categoría.');
      document.getElementById('categoriaSelect').focus();
      return;
    }
    
    // 4. Validar calle (si aplica)
    const calleSelect = document.getElementById('calleSelect');
    if (calleSelect && calleSelect.value === '') {
      alert('⚠️ Por favor, selecciona una calle.');
      calleSelect.focus();
      return;
    }
    
    // 5. Validar imagen (si hay)
    if (fileInput.files.length > 0) {
      const file = fileInput.files[0];
      if (file.size > 10 * 1024 * 1024) {
        alert(`⚠️ La imagen es demasiado grande (${(file.size / 1024 / 1024).toFixed(1)} MB).\nMáximo permitido: 10 MB.`);
        return;
      }
    }
    
    // 6. Validar ubicación
    const lat = document.getElementById('ubicacion_lat').value;
    const lng = document.getElementById('ubicacion_lng').value;
    if (!lat || !lng) {
      alert('⚠️ Por favor, selecciona una ubicación en el mapa o usa el botón "Usar mi ubicación actual"');
      return;
    }
    
    // 7. Mostrar barra de progreso
    submitProgress.style.display = 'block';
    submitProgressBar.style.width = '0%';
    submitProgressText.textContent = 'Preparando envío...';
    
    // Deshabilitar botón
    btnEnviar.disabled = true;
    btnEnviar.innerHTML = '<i class="bi bi-hourglass-split me-2"></i> Enviando...';
    
    // Crear FormData
    const formData = new FormData(this);
    
    // Si hay imagen comprimida, ya está en el input
    // Si no, seguir normal
    
    // Simular progreso (ya que fetch no da progreso de subida fácilmente)
    let progress = 0;
    const interval = setInterval(() => {
      progress += Math.random() * 10;
      if (progress > 90) progress = 90;
      submitProgressBar.style.width = progress + '%';
      submitProgressBar.textContent = Math.round(progress) + '%';
      if (progress > 30) {
        submitProgressText.textContent = 'Subiendo reporte...';
      }
      if (progress > 60) {
        submitProgressText.textContent = 'Procesando en el servidor...';
      }
    }, 300);
    
    try {
      const response = await fetch('/reportar', {
        method: 'POST',
        body: formData
      });
      
      clearInterval(interval);
      
      if (response.redirected) {
        // Éxito - redirigir
        submitProgressBar.style.width = '100%';
        submitProgressBar.textContent = '100%';
        submitProgressText.textContent = '✅ ¡Reporte enviado! Redirigiendo...';
        window.location.href = response.url;
      } else {
        // Error
        const result = await response.text();
        submitProgressBar.style.width = '100%';
        submitProgressBar.className = 'progress-bar bg-danger';
        submitProgressText.textContent = '❌ Error al enviar el reporte';
        btnEnviar.disabled = false;
        btnEnviar.innerHTML = '<i class="bi bi-send-fill me-2"></i> Enviar Reporte';
        alert('Error al enviar el reporte. Por favor, intenta de nuevo.');
      }
    } catch (error) {
      console.error('Error:', error);
      clearInterval(interval);
      submitProgressBar.className = 'progress-bar bg-danger';
      submitProgressText.textContent = '❌ Error de conexión';
      btnEnviar.disabled = false;
      btnEnviar.innerHTML = '<i class="bi bi-send-fill me-2"></i> Enviar Reporte';
      alert('Error de conexión. Verifica tu internet e intenta de nuevo.');
    }
  });

  // ==========================================
  // 5. RECUPERAR UBICACIÓN SI YA EXISTE
  // ==========================================
  const latActual = document.getElementById('ubicacion_lat').value;
  const lngActual = document.getElementById('ubicacion_lng').value;
  
  if (latActual && lngActual) {
    const lat = parseFloat(latActual);
    const lng = parseFloat(lngActual);
    
    window.map.setView([lat, lng], 16);
    if (marker) {
      marker.setLatLng([lat, lng]);
    } else {
      marker = L.marker([lat, lng]).addTo(window.map);
    }
  }
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .reportar-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .reportar-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 50%, #17a2b8 100%);
  }
  
  .reportar-icon-wrapper {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .reportar-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .reportar-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .reportar-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver {
    border: 1px solid #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Labels */
  .reportar-label {
    color: #5D4037;
  }
  .reportar-label i {
    color: #fd6704bd;
  }
  
  /* Inputs, selects, textarea */
  .reportar-input, .reportar-select, .reportar-file {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .reportar-input:focus, .reportar-select:focus, .reportar-file:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Alertas personalizadas */
  .alert-success-custom {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    border: none;
    border-radius: 10px;
    color: #155724;
  }
  .alert-info-custom {
    background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
    border: none;

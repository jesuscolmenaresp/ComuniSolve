<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 empresas-title">
        <i class="bi bi-building me-2"></i> Gestión de Empresas
      </h2>
      <p class="text-muted small mb-0 empresas-subtitle">Administra las empresas y entes responsables de la comunidad</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/empresas/inactivos" class="btn btn-sm btn-outline-danger px-3 py-2 fw-semibold rounded-3">
        <i class="bi bi-eye-slash me-1"></i> Ver inactivas
      </a>
      <a href="/empresas/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-nueva-empresa">
        <i class="bi bi-plus-circle me-1"></i> Nueva Empresa
      </a>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Tabla de empresas -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden empresas-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 empresas-tabla">
          <thead class="empresas-tabla-header">
            <tr class="text-center">
              <th><i class="bi bi-building"></i> Nombre</th>
              <th><i class="bi bi-card-list"></i> RIF</th>
              <th><i class="bi bi-person"></i> Contacto</th>
              <th><i class="bi bi-telephone"></i> Teléfono</th>
              <th><i class="bi bi-tags"></i> Categorías</th>
              <th><i class="bi bi-tag"></i> Tipo</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (empresas && empresas.length > 0) { %>
              <% empresas.forEach(e => { %>
                <tr class="align-middle text-center empresa-fila" 
                    data-id="<%= e.id %>"
                    data-nombre="<%= e.nombre %>"
                    data-rif="<%= e.rif || '—' %>"
                    data-contacto="<%= e.contacto || '—' %>"
                    data-telefono="<%= e.telefono || '—' %>"
                    data-email="<%= e.email || '—' %>"
                    data-tipo="<%= e.tipo || '—' %>"
                    data-direccion="<%= e.direccion || '—' %>"
                    data-categorias="<%= e.categorias_nombres || '' %>"
                    style="cursor: pointer;">
                  <td class="fw-semibold text-start empresa-nombre"><%= e.nombre %></td>
                  <td><%= e.rif || '—' %></td>
                  <td><%= e.contacto || '—' %></td>
                  <td><%= e.telefono || '—' %></td>
                  <td class="text-start">
                    <% if (e.categorias_nombres) { %>
                      <% e.categorias_nombres.split(',').forEach(cat => { %>
                        <span class="badge px-2 py-1 rounded-pill me-1 badge-categoria-empresa"><%= cat %></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <span class="badge px-3 py-1 rounded-pill 
                      <%= e.tipo === 'pública' ? 'badge-tipo-publica' : 
                          e.tipo === 'privada' ? 'badge-tipo-privada' : 
                          e.tipo === 'mixta' ? 'badge-tipo-mixta' : 'badge-tipo-otro' %>">
                      <i class="bi bi-<%= e.tipo === 'pública' ? 'bank' : (e.tipo === 'privada' ? 'briefcase' : 'people') %> me-1"></i>
                      <%= e.tipo %>
                    </span>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/empresas/<%= e.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3 btn-editar-empresa">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/empresas/<%= e.id %>/desactivar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Desactivar esta empresa? Podrá ser reactivada después.')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3 btn-desactivar-empresa">
                          <i class="bi bi-person-x me-1"></i> Desactivar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center py-5 empty-state-empresas">
                  <i class="bi bi-building fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay empresas registradas</p>
                  <a href="/empresas/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-crear-empresa">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera empresa
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Mensaje de doble clic -->
  <div class="text-center mt-3">
    <span class="badge bg-light text-muted px-3 py-2 rounded-pill" style="font-weight: normal; font-size: 0.75rem; border: 1px solid #e0e0e0;">
      <i class="bi bi-hand-index-thumb me-1"></i> 
      Doble clic en cualquier fila para ver más detalles
    </span>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted empresas-info">
      <i class="bi bi-info-circle me-1"></i> 
      Las empresas pueden ser asignadas a reportes para gestionar su solución
    </small>
  </div>
</div>

<!-- Modal de Detalles de Empresa -->
<div class="modal fade" id="modalEmpresaDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-empresa-detalle">
      <div class="modal-header modal-empresa-header">
        <h5 class="modal-title text-white">
          <i class="bi bi-building me-2"></i> Detalles de la Empresa
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4 modal-empresa-body" id="detalleEmpresaContent">
        <div class="text-center py-5">
          <div class="spinner-border text-primary" role="status"></div>
          <p class="mt-2 text-muted">Cargando información...</p>
        </div>
      </div>
      <div class="modal-footer modal-empresa-footer">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
        <a href="#" id="btnEditarEmpresa" class="btn rounded-3 px-4 btn-editar-detalle-empresa">
          ✏️ Editar empresa
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // ========================================
  // DOBLE CLIC PARA VER DETALLES DE EMPRESA
  // ========================================
  document.querySelectorAll('.empresa-fila').forEach(fila => {
    fila.addEventListener('dblclick', function(e) {
      if (e.target.tagName === 'BUTTON' || e.target.tagName === 'A' || e.target.tagName === 'FORM') return;
      
      const id = this.dataset.id;
      const nombre = this.dataset.nombre;
      const rif = this.dataset.rif;
      const contacto = this.dataset.contacto;
      const telefono = this.dataset.telefono;
      const email = this.dataset.email;
      const tipo = this.dataset.tipo;
      const direccion = this.dataset.direccion;
      const categorias = this.dataset.categorias || 'Sin categorías asignadas';
      
      // Mapeo de tipos a iconos y colores
      const tipoMap = {
        'pública': { icon: '🏛️', color: '#28a745' },
        'privada': { icon: '💼', color: '#ffc107' },
        'mixta': { icon: '🤝', color: '#17a2b8' },
        'comunitaria': { icon: '🌱', color: '#fd7e14' }
      };
      
      const tipoInfo = tipoMap[tipo] || { icon: '📌', color: '#6c757d' };
      
      let contenido = `
        <div class="row">
          <div class="col-12 text-center mb-4">
            <div class="empresa-detalle-icon">
              <i class="bi bi-building-fill fs-1" style="color: #fd6704bd;"></i>
            </div>
            <h4 class="fw-bold mt-2" style="color: #5D4037;">${nombre}</h4>
            <span class="badge rounded-pill px-3 py-1" style="background: ${tipoInfo.color}; color: white; font-size: 0.85rem;">
              ${tipoInfo.icon} ${tipo}
            </span>
          </div>
        </div>
        <hr>
        <div class="row g-3">
          <div class="col-md-6">
            <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3">
              <i class="bi bi-card-list fs-4" style="color: #fd6704bd;"></i>
              <div>
                <strong class="small text-muted d-block">RIF</strong>
                <span class="fw-semibold">${rif}</span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3">
              <i class="bi bi-envelope fs-4" style="color: #17a2b8;"></i>
              <div>
                <strong class="small text-muted d-block">Email</strong>
                <span class="fw-semibold">${email}</span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3">
              <i class="bi bi-person fs-4" style="color: #28a745;"></i>
              <div>
                <strong class="small text-muted d-block">Persona de contacto</strong>
                <span class="fw-semibold">${contacto}</span>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3">
              <i class="bi bi-telephone fs-4" style="color: #6f42c1;"></i>
              <div>
                <strong class="small text-muted d-block">Teléfono</strong>
                <span class="fw-semibold">${telefono}</span>
              </div>
            </div>
          </div>
          <div class="col-12">
            <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3">
              <i class="bi bi-geo-alt fs-4" style="color: #dc3545;"></i>
              <div>
                <strong class="small text-muted d-block">Dirección</strong>
                <span class="fw-semibold">${direccion}</span>
              </div>
            </div>
          </div>
          <div class="col-12">
            <div class="d-flex align-items-center gap-3 p-2 bg-light rounded-3">
              <i class="bi bi-tags fs-4" style="color: #ffc107;"></i>
              <div>
                <strong class="small text-muted d-block">Categorías que atiende</strong>
                <div class="mt-1">
                  ${categorias !== 'Sin categorías asignadas' ? 
                    categorias.split(',').map(cat => 
                      `<span class="badge rounded-pill px-2 py-1 me-1" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">${cat.trim()}</span>`
                    ).join('') : 
                    `<span class="text-muted">${categorias}</span>`
                  }
                </div>
              </div>
            </div>
          </div>
        </div>
      `;
      
      document.getElementById('detalleEmpresaContent').innerHTML = contenido;
      document.getElementById('btnEditarEmpresa').href = `/empresas/${id}/editar`;
      new bootstrap.Modal(document.getElementById('modalEmpresaDetalle')).show();
    });
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .empresas-title {
    color: #5D4037;
  }
  .empresas-title i {
    color: #fd6704bd;
  }
  .empresas-subtitle {
    color: #8B6B5A;
  }
  
  /* Botones */
  .btn-nueva-empresa {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-nueva-empresa:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Tarjeta de tabla */
  .empresas-card {
    background: white;
  }
  
  /* Tabla */
  .empresas-tabla {
    background: white;
  }
  
  .empresas-tabla-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .empresas-tabla-header th {
    color: #5D4037;
    font-weight: 600;
    border-bottom: 2px solid #fd6704bd;
  }
  
  .empresa-fila {
    border-bottom-color: #f0d5c0;
    transition: all 0.2s ease;
  }
  
  .empresa-fila:hover {
    background-color: #fff8f0 !important;
  }
  
  .empresa-nombre {
    color: #5D4037;
  }
  
  /* Badges de categorías */
  .badge-categoria-empresa {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  /* Badges de tipo */
  .badge-tipo-publica {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
  }
  .badge-tipo-privada {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    color: #333;
  }
  .badge-tipo-mixta {
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    color: white;
  }
  .badge-tipo-otro {
    background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);
    color: white;
  }
  
  /* Botones de acción */
  .btn-editar-empresa {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    color: #333;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-editar-empresa:hover {
    transform: translateY(-2px);
  }
  
  .btn-desactivar-empresa {
    background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-desactivar-empresa:hover {
    transform: translateY(-2px);
  }
  
  /* Estado vacío */
  .empty-state-empresas i {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-state-empresas p {
    color: #6c757d;
  }
  
  .btn-crear-empresa {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-crear-empresa:hover {
    transform: translateY(-2px);
  }
  
  /* Información */
  .empresas-info {
    color: #8B6B5A;
  }
  .empresas-info i {
    color: #fd6704bd;
  }
  
  /* ========== MODAL DE DETALLES ========== */
  .modal-empresa-detalle {
    background: white;
  }
  
  .modal-empresa-header {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
  }
  
  .modal-empresa-body {
    background: #fefaf7;
  }
  
  .modal-empresa-footer {
    background: #f8f9fa;
  }
  
  .btn-editar-detalle-empresa {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    color: #333;
    border: none;
    transition: all 0.2s ease;
  }
  
  .btn-editar-detalle-empresa:hover {
    transform: translateY(-2px);
  }
  
  .empresa-detalle-icon {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: #fefaf7;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    border: 2px solid #f0d5c0;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .empresas-title {
    color: #e4e4e7;
  }
  body.dark-mode .empresas-subtitle {
    color: #a1a1aa;
  }
  
  body.dark-mode .empresas-card {
    background: #1a1a2e !important;
  }
  
  body.dark-mode .empresas-tabla {
    background-color: #1a1a2e !important;
  }
  
  body.dark-mode .empresas-tabla tbody tr {
    background-color: #1a1a2e !important;
  }
  
  body.dark-mode .empresas-tabla tbody tr:hover {
    background-color: #2d2d44 !important;
  }
  
  body.dark-mode .empresas-tabla td {
    color: #e4e4e7 !important;
    background-color: transparent !important;
  }
  
  body.dark-mode .empresas-tabla .empresa-nombre {
    color: #e4e4e7 !important;
  }
  
  body.dark-mode .empresas-tabla-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%) !important;
  }
  
  body.dark-mode .empresas-tabla-header th {
    color: #e4e4e7 !important;
    border-bottom-color: #f7931e !important;
    background: transparent !important;
  }
  
  body.dark-mode .badge-categoria-empresa {
    background: linear-gradient(135deg, #f7931e 0%, #e08515 100%);
  }
  
  body.dark-mode .badge-tipo-publica {
    background: linear-gradient(135deg, #0d6e2e 0%, #0a5a25 100%);
  }
  
  body.dark-mode .badge-tipo-privada {
    background: linear-gradient(135deg, #e0a800 0%, #c69500 100%);
    color: #333;
  }
  
  body.dark-mode .badge-tipo-mixta {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
  }
  
  body.dark-mode .badge-tipo-otro {
    background: linear-gradient(135deg, #5a6268 0%, #4a5258 100%);
  }
  
  body.dark-mode .btn-editar-empresa {
    background: linear-gradient(135deg, #e0a800 0%, #c69500 100%);
    color: #333;
  }
  
  body.dark-mode .btn-desactivar-empresa {
    background: linear-gradient(135deg, #e8590c 0%, #c94a0a 100%);
    color: white;
  }
  
  body.dark-mode .empty-state-empresas i {
    color: #a1a1aa;
  }
  body.dark-mode .empty-state-empresas p {
    color: #a1a1aa;
  }
  
  body.dark-mode .empresas-info {
    color: #a1a1aa;
  }
  
  body.dark-mode .text-muted {
    color: #a1a1aa !important;
  }
  
  /* Modal en modo nocturno */
  body.dark-mode .modal-empresa-detalle {
    background: #1a1a2e;
  }
  
  body.dark-mode .modal-empresa-body {
    background: #1a1a2e;
  }
  
  body.dark-mode .modal-empresa-footer {
    background: #1a1a2e;
  }
  
  body.dark-mode .modal-empresa-body h4 {
    color: #e4e4e7 !important;
  }
  
  body.dark-mode .modal-empresa-body .text-muted {
    color: #a1a1aa !important;
  }
  
  body.dark-mode .modal-empresa-body .bg-light {
    background: #27272a !important;
  }
  
  body.dark-mode .modal-empresa-body .fw-semibold {
    color: #e4e4e7 !important;
  }
  
  body.dark-mode .empresa-detalle-icon {
    background: #1f1f2e;
    border-color: #3f3f46;
  }
  
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .badge {
    font-weight: normal;
  }
</style>
<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1" style="color: #5D4037;">
        <i class="bi bi-building me-2" style="color: #fd6704bd;"></i> Gestión de Empresas
      </h2>
      <p class="text-muted small mb-0" style="color: #8B6B5A;">Administra las empresas y entes responsables de la comunidad</p>
    </div>
    <a href="/empresas/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
      <i class="bi bi-plus-circle me-1"></i> Nueva Empresa
    </a>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Tabla de empresas -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr class="text-center">
              <th><i class="bi bi-building"></i> Nombre</th>
              <th><i class="bi bi-card-list"></i> RIF</th>
              <th><i class="bi bi-person"></i> Contacto</th>
              <th><i class="bi bi-telephone"></i> Teléfono</th>
              <th><i class="bi bi-tags"></i> Categorías</th>
              <th><i class="bi bi-tag"></i> Tipo</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (empresas && empresas.length > 0) { %>
              <% empresas.forEach(e => { %>
                <tr class="align-middle text-center">
                  <td class="fw-semibold text-start" style="color: #5D4037;"><%= e.nombre %></td>
                  <td><%= e.rif || '—' %></td>
                  <td><%= e.contacto || '—' %></td>
                  <td><%= e.telefono || '—' %></td>
                  <td class="text-start">
                    <% if (e.categorias_nombres) { %>
                      <% e.categorias_nombres.split(',').forEach(cat => { %>
                        <span class="badge px-2 py-1 rounded-pill me-1" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;"><%= cat %></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <span class="badge px-3 py-1 rounded-pill 
                      <%= e.tipo === 'pública' ? 'bg-success' : 
                          e.tipo === 'privada' ? 'bg-warning' : 
                          e.tipo === 'mixta' ? 'bg-info' : 'bg-secondary' %>" 
                      style="color: <%= e.tipo === 'privada' ? '#333' : 'white' %>;">
                      <i class="bi bi-<%= e.tipo === 'pública' ? 'bank' : (e.tipo === 'privada' ? 'briefcase' : 'people') %> me-1"></i>
                      <%= e.tipo %>
                    </span>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/empresas/<%= e.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); color: #333; border: none;">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/empresas/<%= e.id %>/eliminar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Eliminar esta empresa?')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3" 
                                style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none;">
                          <i class="bi bi-trash me-1"></i> Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center py-5">
                  <i class="bi bi-building fs-1 text-muted d-block mb-2"></i>
                  <p class="text-muted mb-0">No hay empresas registradas</p>
                  <a href="/empresas/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera empresa
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted" style="color: #8B6B5A;">
      <i class="bi bi-info-circle me-1" style="color: #fd6704bd;"></i> 
      Las empresas pueden ser asignadas a reportes para gestionar su solución
    </small>
  </div>
</div>

<style>
  .table-hover tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  .btn-sm {
    transition: all 0.2s ease;
  }
  .btn-sm:hover {
    transform: translateY(-2px);
  }
  .badge {
    font-weight: normal;
  }
</style>
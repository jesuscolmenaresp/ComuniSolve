<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🏢 Gestión de Empresas</h2>
    <a href="/empresas/nueva" class="btn btn-primary">
      ➕ Nueva Empresa
    </a>
  </div>

  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= session.mensaje %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <%= session.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>Nombre</th>
          <th>RIF</th>
          <th>Contacto</th>
          <th>Teléfono</th>
          <th>Categorías</th>
          <th>Tipo</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (empresas && empresas.length > 0) { %>
          <% empresas.forEach(e => { %>
            <tr>
              <td><strong><%= e.nombre %></strong></td>
              <td><%= e.rif || '—' %></td>
              <td><%= e.contacto || '—' %></td>
              <td><%= e.telefono || '—' %></td>
              <td>
                <% if (e.categorias_nombres) { %>
                  <% e.categorias_nombres.split(',').forEach(cat => { %>
                    <span class="badge bg-info me-1"><%= cat %></span>
                  <% }) %>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
              <td>
                <span class="badge <%= e.tipo === 'pública' ? 'bg-success' : 
                                          e.tipo === 'privada' ? 'bg-warning' : 
                                          'bg-secondary' %>">
                  <%= e.tipo %>
                </span>
              </td>
              <td>
                <a href="/empresas/<%= e.id %>/editar" class="btn btn-sm btn-warning">
                  ✏️ Editar
                </a>
                <form action="/empresas/<%= e.id %>/eliminar" method="POST" class="d-inline"
                      onsubmit="return confirm('¿Eliminar esta empresa?')">
                  <button type="submit" class="btn btn-sm btn-danger">
                    🗑️ Eliminar
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="7" class="text-center">No hay empresas registradas</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
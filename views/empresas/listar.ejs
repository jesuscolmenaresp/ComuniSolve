<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 empresas-title">
        <i class="bi bi-building me-2"></i> Gestión de Empresas
      </h2>
      <p class="text-muted small mb-0 empresas-subtitle">Administra las empresas y entes responsables de la comunidad</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/empresas/inactivos" class="btn btn-sm btn-outline-danger px-3 py-2 fw-semibold rounded-3">
        <i class="bi bi-eye-slash me-1"></i> Ver inactivas
      </a>
      <a href="/empresas/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-nueva-empresa">
        <i class="bi bi-plus-circle me-1"></i> Nueva Empresa
      </a>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- ========== FILTROS Y CONTADOR ========== -->
  <div class="row g-3 mb-4">
    <!-- Filtros -->
    <div class="col-12 col-md-9">
      <div class="card border-0 rounded-4 shadow-sm p-3 filtros-card">
        <div class="row g-2 align-items-end">
          <!-- Filtro por Tipo -->
          <div class="col-12 col-sm-6 col-md-3">
            <label class="form-label fw-semibold small mb-1 filtro-label">
              <i class="bi bi-tag me-1"></i> Tipo
            </label>
            <select id="filtroTipo" class="form-select form-select-sm rounded-3 filtro-select">
              <option value="">Todos los tipos</option>
              <option value="pública">🏛️ Pública</option>
              <option value="privada">💼 Privada</option>
              <option value="mixta">🤝 Mixta</option>
              <option value="comunitaria">🌱 Comunitaria</option>
            </select>
          </div>

          <!-- Filtro por Categoría -->
          <div class="col-12 col-sm-6 col-md-3">
            <label class="form-label fw-semibold small mb-1 filtro-label">
              <i class="bi bi-tags me-1"></i> Categoría
            </label>
            <select id="filtroCategoria" class="form-select form-select-sm rounded-3 filtro-select">
              <option value="">Todas las categorías</option>
              <% if (categorias && categorias.length > 0) { %>
                <% categorias.forEach(cat => { %>
                  <option value="<%= cat.id %>"><%= cat.nombre %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <!-- Buscador -->
          <div class="col-12 col-sm-6 col-md-4">
            <label class="form-label fw-semibold small mb-1 filtro-label">
              <i class="bi bi-search me-1"></i> Buscar
            </label>
            <input type="text" id="buscarEmpresa" class="form-control form-control-sm rounded-3 filtro-input" placeholder="Buscar por nombre o RIF...">
          </div>

          <!-- Botón Limpiar Filtros -->
          <div class="col-12 col-sm-6 col-md-2">
            <button id="btnLimpiarFiltros" class="btn btn-sm w-100 rounded-3 btn-limpiar-filtros">
              <i class="bi bi-arrow-counterclockwise me-1"></i> Limpiar
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Contador de Empresas -->
    <div class="col-12 col-md-3">
      <div class="card border-0 rounded-4 shadow-sm h-100 contador-card">
        <div class="card-body d-flex flex-column justify-content-center align-items-center p-3">
          <div class="d-flex align-items-center gap-3">
            <div class="contador-icon">
              <i class="bi bi-building-fill"></i>
            </div>
            <div class="text-center">
              <span class="contador-numero" id="totalEmpresas"><%= empresas ? empresas.length : 0 %></span>
              <span class="contador-texto d-block">Empresas registradas</span>
            </div>
          </div>
          <small class="text-muted mt-1" id="empresasFiltradasInfo">
            Mostrando <span id="empresasMostradas"><%= empresas ? empresas.length : 0 %></span> empresas
          </small>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabla de empresas -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden empresas-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 empresas-tabla" id="tablaEmpresas">
          <thead class="empresas-tabla-header">
            <tr class="text-center">
              <th><i class="bi bi-building"></i> Nombre</th>
              <th><i class="bi bi-card-list"></i> RIF</th>
              <th><i class="bi bi-person"></i> Contacto</th>
              <th><i class="bi bi-telephone"></i> Teléfono</th>
              <th><i class="bi bi-tags"></i> Categorías</th>
              <th><i class="bi bi-tag"></i> Tipo</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody id="tablaEmpresasBody">
            <% if (empresas && empresas.length > 0) { %>
              <% empresas.forEach(e => { %>
                <tr class="align-middle text-center empresa-fila" 
                    data-id="<%= e.id %>"
                    data-nombre="<%= e.nombre %>"
                    data-rif="<%= e.rif || '—' %>"
                    data-contacto="<%= e.contacto || '—' %>"
                    data-telefono="<%= e.telefono || '—' %>"
                    data-email="<%= e.email || '—' %>"
                    data-tipo="<%= e.tipo || '—' %>"
                    data-direccion="<%= e.direccion || '—' %>"
                    data-categorias="<%= e.categorias_nombres || '' %>"
                    style="cursor: pointer;">
                  <td class="fw-semibold text-start empresa-nombre"><%= e.nombre %></td>
                  <td><%= e.rif || '—' %></td>
                  <td><%= e.contacto || '—' %></td>
                  <td><%= e.telefono || '—' %></td>
                  <td class="text-start">
                    <% if (e.categorias_nombres) { %>
                      <% e.categorias_nombres.split(',').forEach(cat => { %>
                        <span class="badge px-2 py-1 rounded-pill me-1 badge-categoria-empresa"><%= cat %></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-muted">—</span>
                    <% } %>
                  </td>
                  <td>
                    <span class="badge px-3 py-1 rounded-pill 
                      <%= e.tipo === 'pública' ? 'badge-tipo-publica' : 
                          e.tipo === 'privada' ? 'badge-tipo-privada' : 
                          e.tipo === 'mixta' ? 'badge-tipo-mixta' : 'badge-tipo-otro' %>">
                      <i class="bi bi-<%= e.tipo === 'pública' ? 'bank' : (e.tipo === 'privada' ? 'briefcase' : 'people') %> me-1"></i>
                      <%= e.tipo %>
                    </span>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/empresas/<%= e.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3 btn-editar-empresa">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/empresas/<%= e.id %>/desactivar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Desactivar esta empresa? Podrá ser reactivada después.')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3 btn-desactivar-empresa">
                          <i class="bi bi-person-x me-1"></i> Desactivar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr id="filaVacia">
                <td colspan="7" class="text-center py-5 empty-state-empresas">
                  <i class="bi bi-building fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay empresas registradas</p>
                  <a href="/empresas/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-crear-empresa">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera empresa
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Mensaje de doble clic -->
  <div class="text-center mt-3">
    <span class="badge bg-light text-muted px-3 py-2 rounded-pill" style="font-weight: normal; font-size: 0.75rem; border: 1px solid #e0e0e0;">
      <i class="bi bi-hand-index-thumb me-1"></i> 
      Doble clic en cualquier fila para ver más detalles
    </span>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted empresas-info">
      <i class="bi bi-info-circle me-1"></i> 
      Las empresas pueden ser asignadas a reportes para gestionar su solución
    </small>
  </div>
</div>

<!-- Modal de Detalles de Empresa -->
<div class="modal fade" id="modalEmpresaDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-empresa-detalle">
      <div class="modal-header modal-empresa-header">
        <h5 class="modal-title text-white">
          <i class="bi bi-building me-2"></i> Detalles de la Empresa
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4 modal-empresa-body" id="detalleEmpresaContent">
        <div class="text-center py-5">
          <div class="spinner-border text-primary" role="status"></div>
          <p class="mt-2 text-muted">Cargando información...</p>
        </div>
      </div>
      <div class="modal-footer modal-empresa-footer">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
        <a href="#" id="btnEditarEmpresa" class="btn rounded-3 px-4 btn-editar-detalle-empresa">
          ✏️ Editar empresa
        </a>
      </div>
    </div>
  </div>
</div>

<!-- ========== SCRIPTS PARA FILTROS ========== -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filtroTipo = document.getElementById('filtroTipo');
    const filtroCategoria = document.getElementById('filtroCategoria');
    const buscarEmpresa = document.getElementById('buscarEmpresa');
    const btnLimpiar = document.getElementById('btnLimpiarFiltros');
    const tablaBody = document.getElementById('tablaEmpresasBody');
    const totalEmpresasSpan = document.getElementById('totalEmpresas');
    const empresasMostradasSpan = document.getElementById('empresasMostradas');

    function aplicarFiltros() {
      const tipo = filtroTipo.value;
      const categoriaId = filtroCategoria.value;
      const texto = buscarEmpresa.value.toLowerCase().trim();

      const filas = tablaBody.querySelectorAll('.empresa-fila');
      let visibles = 0;

      filas.forEach(fila => {
        const dataTipo = fila.dataset.tipo || '';
        const dataCategorias = fila.dataset.categorias || '';
        const dataNombre = fila.dataset.nombre?.toLowerCase() || '';
        const dataRif = fila.dataset.rif?.toLowerCase() || '';

        let mostrar = true;

        // Filtro por tipo
        if (tipo && dataTipo !== tipo) {
          mostrar = false;
        }

        // Filtro por categoría
        if (categoriaId) {
          // Buscar si la categoría está en la lista de categorías de la empresa
          const categorias = dataCategorias ? dataCategorias.toLowerCase().split(',') : [];
          const categoriaNombre = document.querySelector(`#filtroCategoria option[value="${categoriaId}"]`)?.textContent?.toLowerCase() || '';
          
          // Si no hay categorías o no coincide, ocultar
          if (categorias.length === 0 || !categorias.some(cat => cat.trim() === categoriaNombre.trim())) {
            mostrar = false;
          }
        }

        // Buscador por nombre o RIF
        if (texto && !dataNombre.includes(texto) && !dataRif.includes(texto)) {
          mostrar = false;
        }

        if (mostrar) {
          fila.style.display = '';
          visibles++;
        } else {
          fila.style.display = 'none';
        }
      });

      // Mostrar/ocultar fila vacía
      const filaVacia = document.getElementById('filaVacia');
      if (filaVacia) {
        if (visibles === 0 && filas.length > 0) {
          filaVacia.style.display = '';
          filaVacia.querySelector('td').innerHTML = `
            <i class="bi bi-search fs-1 d-block mb-2"></i>
            <p class="mb-0">No hay empresas que coincidan con los filtros</p>
            <button class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-limpiar-filtros" onclick="document.getElementById('btnLimpiarFiltros').click()">
              <i class="bi bi-arrow-counterclockwise me-1"></i> Limpiar filtros
            </button>
          `;
        } else if (visibles === 0 && filas.length === 0) {
          // Ya hay mensaje de "No hay empresas registradas"
        } else {
          filaVacia.style.display = 'none';
        }
      }

      // Actualizar contadores
      const total = filas.length;
      totalEmpresasSpan.textContent = total;
      empresasMostradasSpan.textContent = visibles;

      // Actualizar texto informativo
      const info = document.getElementById('empresasFiltradasInfo');
      if (tipo || categoriaId || texto) {
        info.innerHTML = `Mostrando <span id="empresasMostradas">${visibles}</span> de <span id="totalEmpresas">${total}</span> empresas <span class="badge bg-primary rounded-pill ms-1">Filtrado</span>`;
      } else {
        info.innerHTML = `Mostrando <span id="empresasMostradas">${visibles}</span> empresas`;
      }
    }

    // Event listeners
    filtroTipo.addEventListener('change', aplicarFiltros);
    filtroCategoria.addEventListener('change', aplicarFiltros);
    buscarEmpresa.addEventListener('keyup', aplicarFiltros);

    btnLimpiar.addEventListener('click', function() {
      filtroTipo.value = '';
      filtroCategoria.value = '';
      buscarEmpresa.value = '';
      aplicarFiltros();
    });

    // Inicializar
    aplicarFiltros();
  });
</script>


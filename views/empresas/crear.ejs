<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-building fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;">Nueva Empresa</h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">Registra un nuevo ente responsable para la comunidad</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/empresas" class="btn btn-sm px-3 py-1 rounded-3" style="border: 1px solid #f0d5c0; color: #5D4037;">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/empresas" method="POST">
            
            <div class="row g-3">
              <!-- Nombre -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-building me-1" style="color: #fd6704bd;"></i> Nombre de la empresa *
                </label>
                <input type="text" name="nombre" class="form-control rounded-3" required
                       placeholder="Ej: Hidrolago, Corpoelec, etc."
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- RIF -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-card-list me-1" style="color: #fd6704bd;"></i> RIF
                </label>
                <input type="text" name="rif" class="form-control rounded-3"
                       placeholder="J-12345678-9"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Contacto -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-person me-1" style="color: #fd6704bd;"></i> Persona de contacto
                </label>
                <input type="text" name="contacto" class="form-control rounded-3"
                       placeholder="Nombre de contacto"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Teléfono -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-telephone me-1" style="color: #fd6704bd;"></i> Teléfono
                </label>
                <input type="text" name="telefono" class="form-control rounded-3"
                       placeholder="0414-1234567"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Email -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-envelope me-1" style="color: #fd6704bd;"></i> Email
                </label>
                <input type="email" name="email" class="form-control rounded-3"
                       placeholder="contacto@empresa.com"
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Tipo de ente -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-tag me-1" style="color: #fd6704bd;"></i> Tipo de ente
                </label>
                <select name="tipo" class="form-select rounded-3" style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                  <option value="pública">🏛️ Pública</option>
                  <option value="privada">💼 Privada</option>
                  <option value="mixta">🤝 Mixta</option>
                  <option value="comunitaria">🌱 Comunitaria</option>
                </select>
              </div>

              <!-- Dirección -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-geo-alt me-1" style="color: #fd6704bd;"></i> Dirección
                </label>
                <textarea name="direccion" class="form-control rounded-3" rows="2"
                          placeholder="Dirección completa de la empresa"
                          style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;"></textarea>
              </div>

              <!-- Categorías -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-tags me-1" style="color: #fd6704bd;"></i> Categorías que atiende
                </label>
                <div class="border rounded-3 p-3" style="border-color: #f0d5c0; background-color: #fefaf7;">
                  <div class="d-flex flex-wrap gap-2">
                    <% if (categorias && categorias.length > 0) { %>
                      <% categorias.forEach(cat => { %>
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="categorias" value="<%= cat.id %>" id="cat_<%= cat.id %>"
                                 style="border-color: #fd6704bd;">
                          <label class="form-check-label" for="cat_<%= cat.id %>" style="color: #5D4037;">
                            <%= cat.icono ? cat.icono + ' ' : '' %><%= cat.nombre %>
                          </label>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <p class="text-muted small mb-0">No hay categorías disponibles. Crea categorías primero.</p>
                    <% } %>
                  </div>
                </div>
                <small class="text-muted" style="color: #8B6B5A;">Selecciona las categorías que esta empresa puede atender</small>
              </div>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;">
                <i class="bi bi-save me-2"></i> Guardar empresa
              </button>
              <a href="/empresas" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                 style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  .form-check {
    margin-right: 1rem;
  }
  .form-check-input:checked {
    background-color: #fd6704bd;
    border-color: #fd6704bd;
  }
</style>
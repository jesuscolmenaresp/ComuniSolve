<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden empresa-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 empresa-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="empresa-icon-wrapper">
              <i class="bi bi-building fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold empresa-title">Nueva Empresa</h3>
          <p class="small mb-0 mt-1 empresa-subtitle">Registra un nuevo ente responsable para la comunidad</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 empresa-body">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/empresas" class="btn btn-sm px-3 py-1 rounded-3 btn-volver-empresa">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/empresas" method="POST">
            
            <div class="row g-3">
              <!-- Nombre -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-building me-1"></i> Nombre de la empresa *
                </label>
                <input type="text" name="nombre" class="form-control rounded-3 empresa-input" required
                       placeholder="Ej: Hidrolago, Corpoelec, etc.">
              </div>

              <!-- RIF -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-card-list me-1"></i> RIF
                </label>
                <input type="text" name="rif" class="form-control rounded-3 empresa-input"
                       placeholder="J-12345678-9">
              </div>

              <!-- Contacto -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-person me-1"></i> Persona de contacto
                </label>
                <input type="text" name="contacto" class="form-control rounded-3 empresa-input"
                       placeholder="Nombre de contacto">
              </div>

              <!-- Teléfono -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-telephone me-1"></i> Teléfono
                </label>
                <input type="text" name="telefono" class="form-control rounded-3 empresa-input"
                       placeholder="0414-1234567">
              </div>

              <!-- Email -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-envelope me-1"></i> Email
                </label>
                <input type="email" name="email" class="form-control rounded-3 empresa-input"
                       placeholder="contacto@empresa.com">
              </div>

              <!-- Tipo de ente -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-tag me-1"></i> Tipo de ente
                </label>
                <select name="tipo" class="form-select rounded-3 empresa-select">
                  <option value="pública">🏛️ Pública</option>
                  <option value="privada">💼 Privada</option>
                  <option value="mixta">🤝 Mixta</option>
                  <option value="comunitaria">🌱 Comunitaria</option>
                </select>
              </div>

              <!-- Dirección -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-geo-alt me-1"></i> Dirección
                </label>
                <textarea name="direccion" class="form-control rounded-3 empresa-textarea" rows="2"
                          placeholder="Dirección completa de la empresa"></textarea>
              </div>

              <!-- Categorías -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2 empresa-label">
                  <i class="bi bi-tags me-1"></i> Categorías que atiende
                </label>
                <div class="border rounded-3 p-3 empresa-categorias-container">
                  <div class="d-flex flex-wrap gap-2">
                    <% if (categorias && categorias.length > 0) { %>
                      <% categorias.forEach(cat => { %>
                        <div class="form-check">
                          <input class="form-check-input empresa-checkbox" type="checkbox" name="categorias" value="<%= cat.id %>" id="cat_<%= cat.id %>">
                          <label class="form-check-label empresa-checkbox-label" for="cat_<%= cat.id %>">
                            <%= cat.icono ? cat.icono + ' ' : '' %><%= cat.nombre %>
                          </label>
                        </div>
                      <% }) %>
                    <% } else { %>
                      <p class="text-muted small mb-0">No hay categorías disponibles. Crea categorías primero.</p>
                    <% } %>
                  </div>
                </div>
                <small class="text-muted empresa-help">Selecciona las categorías que esta empresa puede atender</small>
              </div>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar-empresa">
                <i class="bi bi-save me-2"></i> Guardar empresa
              </button>
              <a href="/empresas" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar-empresa">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 empresa-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 empresa-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .empresa-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .empresa-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .empresa-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .empresa-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .empresa-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .empresa-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver-empresa {
    border: 1px solid #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-empresa:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Labels */
  .empresa-label {
    color: #5D4037;
  }
  .empresa-label i {
    color: #fd6704bd;
  }
  
  /* Inputs, selects, textarea */
  .empresa-input, .empresa-select, .empresa-textarea {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .empresa-input:focus, .empresa-select:focus, .empresa-textarea:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Categorías container */
  .empresa-categorias-container {
    border-color: #f0d5c0;
    background-color: #fefaf7;
  }
  
  /* Checkbox */
  .empresa-checkbox {
    border-color: #fd6704bd;
  }
  .empresa-checkbox:checked {
    background-color: #fd6704bd;
    border-color: #fd6704bd;
  }
  .empresa-checkbox-label {
    color: #5D4037;
  }
  
  /* Ayuda */
  .empresa-help {
    color: #8B6B5A;
  }
  
  /* Botón guardar */
  .btn-guardar-empresa {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar-empresa:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar-empresa {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar-empresa:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .empresa-badge {
    color: #8B6B5A !important;
  }
  .empresa-badge i {
    color: #17a2b8;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .empresa-card {
    background: #27272a;
  }
  
  body.dark-mode .empresa-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .empresa-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .empresa-body {
    background: #27272a;
  }
  
  body.dark-mode .btn-volver-empresa {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-empresa:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .empresa-label {
    color: #e4e4e7;
  }
  body.dark-mode .empresa-label i {
    color: #f7931e;
  }
  
  body.dark-mode .empresa-input,
  body.dark-mode .empresa-select,
  body.dark-mode .empresa-textarea {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .empresa-input:focus,
  body.dark-mode .empresa-select:focus,
  body.dark-mode .empresa-textarea:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .empresa-input::placeholder,
  body.dark-mode .empresa-textarea::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .empresa-categorias-container {
    border-color: #3f3f46;
    background-color: #3f3f46;
  }
  
  body.dark-mode .empresa-checkbox-label {
    color: #e4e4e7;
  }
  
  body.dark-mode .empresa-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-cancelar-empresa {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar-empresa:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .empresa-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .empresa-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  body.dark-mode .form-check {
    margin-right: 1rem;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .form-control:focus, .form-select:focus, .form-textarea:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  body.dark-mode .form-control:focus, 
  body.dark-mode .form-select:focus, 
  body.dark-mode .form-textarea:focus {
    border-color: #f7931e;
  }
</style>
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-pencil-square fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;">Editar Perfil</h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">Actualiza tu información personal</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Mensaje de error -->
          <% if (session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><strong>Error:</strong> <%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/perfil/actualizar" method="POST">
            
            <!-- Cédula -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-card-text me-1" style="color: #fd6704bd;"></i> Cédula de identidad
              </label>
              <input type="text" name="cedula" class="form-control rounded-3" 
                     value="<%= user.cedula || '' %>" placeholder="12345678"
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              <small class="text-muted" style="color: #8B6B5A;">Solo números</small>
            </div>

            <!-- Nombre completo -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-person-fill me-1" style="color: #fd6704bd;"></i> Nombre completo *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3" 
                     value="<%= user.nombre %>" required
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
            </div>

            <!-- Teléfono -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-telephone-fill me-1" style="color: #fd6704bd;"></i> Teléfono
              </label>
              <input type="text" name="telefono" class="form-control rounded-3" 
                     value="<%= user.telefono || '' %>" placeholder="0414-1234567"
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
            </div>

            <!-- Calle (solo para ciudadanos y jefes) -->
            <% if (user.rol_id === 4 || user.rol_id === 3) { %>
              <div class="mb-4">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-geo-alt-fill me-1" style="color: #fd6704bd;"></i> Calle donde resides
                </label>
                <select name="calle_id" class="form-select rounded-3" disabled
                        style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                  <option value="<%= user.calle_id %>" selected>
                    <%= user.calle_nombre || 'No asignada' %>
                  </option>
                </select>
                <input type="hidden" name="calle_id" value="<%= user.calle_id %>">
                <div class="alert alert-warning mt-3 py-2 small rounded-3" style="background: #fff3cd; border-left: 3px solid #ffc107;">
                  <i class="bi bi-info-circle me-1"></i> 
                  <strong>No puedes cambiar tu calle automáticamente.</strong><br>
                  Si necesitas cambiar tu calle de residencia, contacta a un líder comunitario o al administrador.
                </div>
              </div>
            <% } %>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); 
                             border: none; color: white;">
                <i class="bi bi-save me-2"></i> Guardar cambios
              </button>
              <a href="/perfil" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                 style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-arrow-left me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Validar cédula solo números
  document.querySelector('input[name="cedula"]').addEventListener('input', function(e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });
</script>
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden perfil-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 perfil-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="perfil-icon-wrapper">
              <i class="bi bi-pencil-square fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold perfil-title">Editar Perfil</h3>
          <p class="small mb-0 mt-1 perfil-subtitle">Actualiza tu información personal</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 perfil-body">
          
          <!-- Mensajes de sesión -->
          <% if (session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><strong>Error:</strong> <%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario con enctype="multipart/form-data" -->
          <form action="/perfil/actualizar" method="POST" enctype="multipart/form-data" id="perfilForm">
            
            <!-- Foto de perfil -->
            <div class="mb-4 text-center">
              <label class="form-label fw-semibold small mb-2 perfil-label d-block">
                <i class="bi bi-image me-1"></i> Foto de perfil
              </label>
              
              <!-- Previsualización -->
              <div class="foto-perfil-container mb-3">
                <div class="foto-perfil-preview" id="fotoPreviewContainer">
                  <img id="fotoPreview" 
                       src="<%= user.foto_perfil || '/images/default-avatar.png' %>" 
                       alt="Foto de perfil" 
                       class="foto-perfil-img">
                </div>
              </div>
              
              <!-- Input de archivo -->
              <input type="file" name="foto_perfil" id="fotoPerfilInput" 
                     class="form-control rounded-3 perfil-input" 
                     accept="image/jpeg,image/png,image/gif,image/webp">
              <small class="text-muted perfil-help" id="fotoHelp">Formatos: JPG, PNG, GIF, WEBP | Máx: 5MB (se comprimirá automáticamente)</small>
              <div id="compressionProgress" style="display: none; margin-top: 8px;">
                <div class="progress" style="height: 6px;">
                  <div id="compressionBar" class="progress-bar progress-bar-striped" role="progressbar" style="width: 0%; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);"></div>
                </div>
                <small class="text-muted" id="compressionText">Comprimiendo imagen...</small>
              </div>
              
              <!-- Botón para eliminar foto (si existe) -->
              <% if (user.foto_perfil) { %>
                <div class="mt-2">
                  <a href="/perfil/eliminar-foto" class="btn btn-sm btn-outline-danger rounded-3" 
                     onclick="return confirm('¿Eliminar tu foto de perfil?')">
                    <i class="bi bi-trash me-1"></i> Eliminar foto
                  </a>
                </div>
              <% } %>
            </div>

            <!-- Cédula -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 perfil-label">
                <i class="bi bi-card-text me-1"></i> Cédula de identidad
              </label>
              <input type="text" name="cedula" id="cedulaInput" class="form-control rounded-3 perfil-input" 
                     value="<%= user.cedula || '' %>" placeholder="12345678">
              <small class="text-muted perfil-help">Solo números</small>
            </div>

            <!-- Nombre completo -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 perfil-label">
                <i class="bi bi-person-fill me-1"></i> Nombre completo *
              </label>
              <input type="text" name="nombre" id="nombreInput" class="form-control rounded-3 perfil-input" 
                     value="<%= user.nombre %>" required>
            </div>

            <!-- Teléfono -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 perfil-label">
                <i class="bi bi-telephone-fill me-1"></i> Teléfono
              </label>
              <input type="text" name="telefono" id="telefonoInput" class="form-control rounded-3 perfil-input" 
                     value="<%= user.telefono || '' %>" placeholder="0414-1234567">
            </div>

            <!-- Calle (solo para ciudadanos y jefes) -->
            <% if (user.rol_id === 4 || user.rol_id === 3) { %>
              <div class="mb-4">
                <label class="form-label fw-semibold small mb-2 perfil-label">
                  <i class="bi bi-geo-alt-fill me-1"></i> Calle donde resides
                </label>
                <select name="calle_id" class="form-select rounded-3 perfil-select" disabled>
                  <option value="<%= user.calle_id %>" selected>
                    <%= user.calle_nombre || 'No asignada' %>
                  </option>
                </select>
                <input type="hidden" name="calle_id" value="<%= user.calle_id %>">
                <div class="alert perfil-alert-warning mt-3 py-2 small rounded-3">
                  <i class="bi bi-info-circle me-1"></i> 
                  <strong>No puedes cambiar tu calle automáticamente.</strong><br>
                  Si necesitas cambiar tu calle de residencia, contacta a tu UBCH.
                </div>
              </div>
            <% } %>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar" id="btnGuardar">
                <i class="bi bi-save me-2"></i> Guardar cambios
              </button>
              <a href="/perfil" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar">
                <i class="bi bi-arrow-left me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 perfil-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 perfil-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // ========================================
  // FUNCIÓN PARA COMPRIMIR IMAGEN
  // ========================================
  async function comprimirImagen(file, maxWidth = 400, maxHeight = 400, quality = 0.7) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = function(event) {
        const img = new Image();
        img.src = event.target.result;
        img.onload = function() {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;
          
          if (width > maxWidth) {
            height = (height * maxWidth) / width;
            width = maxWidth;
          }
          if (height > maxHeight) {
            width = (width * maxHeight) / height;
            height = maxHeight;
          }
          
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          
          canvas.toBlob(function(blob) {
            const compressedFile = new File([blob], file.name.replace(/\.[^.]+$/, '.jpg'), {
              type: 'image/jpeg',
              lastModified: Date.now()
            });
            resolve(compressedFile);
          }, 'image/jpeg', quality);
        };
        img.onerror = reject;
      };
      reader.onerror = reject;
    });
  }

  // ========================================
  // PREVISUALIZACIÓN DE FOTO DE PERFIL
  // ========================================
  const fotoInput = document.getElementById('fotoPerfilInput');
  const fotoPreview = document.getElementById('fotoPreview');
  
  if (fotoInput) {
    fotoInput.addEventListener('change', function(e) {
      const file = this.files[0];
      if (file) {
        // Verificar tipo de archivo
        const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/webp'];
        if (!allowedTypes.includes(file.type)) {
          alert('❌ Solo se permiten imágenes (JPEG, PNG, GIF, WEBP)');
          this.value = '';
          return;
        }
        
        const reader = new FileReader();
        reader.onload = function(e) {
          fotoPreview.src = e.target.result;
          fotoPreview.classList.add('foto-cargada');
        };
        reader.readAsDataURL(file);
      } else {
        // Si no hay archivo, restaurar la imagen original
        const originalSrc = fotoPreview.dataset.original || '/images/default-avatar.png';
        fotoPreview.src = originalSrc;
        fotoPreview.classList.remove('foto-cargada');
      }
    });
    
    // Guardar imagen original para restaurar
    if (fotoPreview) {
      fotoPreview.dataset.original = fotoPreview.src;
    }
  }

  // ========================================
  // VALIDACIONES
  // ========================================
  // Cédula solo números
  document.getElementById('cedulaInput').addEventListener('input', function(e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });

  // Teléfono solo números y guiones
  document.getElementById('telefonoInput').addEventListener('input', function(e) {
    this.value = this.value.replace(/[^0-9\-]/g, '');
  });

  // ========================================
  // VALIDACIÓN Y ENVÍO CON COMPRESIÓN
  // ========================================
  const form = document.getElementById('perfilForm');
  const btnGuardar = document.getElementById('btnGuardar');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    // Validar nombre
    const nombre = document.getElementById('nombreInput').value.trim();
    if (nombre.length < 3) {
      alert('❌ El nombre debe tener al menos 3 caracteres.');
      document.getElementById('nombreInput').focus();
      return;
    }
    
    // ========================================
    // COMPRIMIR FOTO DE PERFIL SI EXISTE
    // ========================================
    const fotoInput = document.getElementById('fotoPerfilInput');
    const MAX_SIZE = 2 * 1024 * 1024; // 2 MB (límite después de comprimir)
    const compressionProgress = document.getElementById('compressionProgress');
    const compressionBar = document.getElementById('compressionBar');
    const compressionText = document.getElementById('compressionText');
    
    if (fotoInput.files.length > 0) {
      const file = fotoInput.files[0];
      
      // Si la imagen es grande, comprimirla
      if (file.size > MAX_SIZE) {
        try {
          compressionProgress.style.display = 'block';
          compressionBar.style.width = '20%';
          compressionText.textContent = 'Cargando imagen...';
          
          btnGuardar.disabled = true;
          btnGuardar.innerHTML = '<i class="bi bi-hourglass-split me-2"></i> Comprimiendo...';
          
          compressionBar.style.width = '50%';
          compressionText.textContent = 'Comprimiendo imagen...';
          
          const compressedFile = await comprimirImagen(file, 400, 400, 0.7);
          
          compressionBar.style.width = '80%';
          compressionText.textContent = 'Procesando...';
          
          // Reemplazar el archivo original con el comprimido
          const dataTransfer = new DataTransfer();
          dataTransfer.items.add(compressedFile);
          fotoInput.files = dataTransfer.files;
          
          // Actualizar preview
          const reader = new FileReader();
          reader.onload = function(e) {
            document.getElementById('fotoPreview').src = e.target.result;
          };
          reader.readAsDataURL(compressedFile);
          
          compressionBar.style.width = '100%';
          compressionText.textContent = `✅ Comprimido: ${(compressedFile.size / 1024 / 1024).toFixed(2)} MB`;
          
          setTimeout(() => {
            compressionProgress.style.display = 'none';
          }, 1500);
          
          console.log(`✅ Imagen comprimida: ${(file.size / 1024 / 1024).toFixed(2)}MB → ${(compressedFile.size / 1024 / 1024).toFixed(2)}MB`);
        } catch (error) {
          console.error('Error comprimiendo imagen:', error);
          compressionText.textContent = '⚠️ Usando imagen original';
          setTimeout(() => {
            compressionProgress.style.display = 'none';
          }, 1000);
        }
      }
    }
    
    // Enviar formulario
    btnGuardar.disabled = true;
    btnGuardar.innerHTML = '<i class="bi bi-hourglass-split me-2"></i> Guardando...';
    
    try {
      const formData = new FormData(this);
      const response = await fetch('/perfil/actualizar', {
        method: 'POST',
        body: formData
      });
      
      if (response.redirected) {
        window.location.href = response.url;
      } else {
        const result = await response.text();
        btnGuardar.disabled = false;
        btnGuardar.innerHTML = '<i class="bi bi-save me-2"></i> Guardar cambios';
        alert('Error al guardar cambios. Por favor, intenta de nuevo.');
      }
    } catch (error) {
      console.error('Error:', error);
      btnGuardar.disabled = false;
      btnGuardar.innerHTML = '<i class="bi bi-save me-2"></i> Guardar cambios';
      alert('Error de conexión. Verifica tu internet e intenta de nuevo.');
    }
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .perfil-card {
    background: #ffffff;
  }
  
  /* Header */
  .perfil-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .perfil-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .perfil-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .perfil-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .perfil-body {
    background: #ffffff;
  }
  
  /* Foto de perfil */
  .foto-perfil-container {
    display: flex;
    justify-content: center;
  }
  
  .foto-perfil-preview {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid #fd6704bd;
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.2);
    background: #f8f9fa;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .foto-perfil-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .foto-perfil-img.foto-cargada {
    border: 3px solid #28a745;
  }
  
  /* Labels */
  .perfil-label {
    color: #5D4037;
  }
  .perfil-label i {
    color: #fd6704bd;
  }
  
  /* Inputs */
  .perfil-input, .perfil-select {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .perfil-input:focus, .perfil-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  .perfil-select:disabled {
    background-color: #f5f0eb;
    cursor: not-allowed;
  }
  
  /* Input file personalizado */
  input[type="file"] {
    padding: 0.5rem;
  }
  input[type="file"]::file-selector-button {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
    font-weight: 500;
  }
  input[type="file"]::file-selector-button:hover {
    transform: translateY(-2px);
  }
  
  /* Ayuda */
  .perfil-help {
    color: #8B6B5A;
  }
  
  /* Alerta */
  .perfil-alert-warning {
    background: #fff3cd;
    border-left: 3px solid #ffc107;
    color: #856404;
  }
  
  /* Botones */
  .btn-guardar {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  .btn-cancelar {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .perfil-badge {
    color: #8B6B5A !important;
  }
  .perfil-badge i {
    color: #17a2b8;
  }
  
  /* Progress bar */
  .progress {
    border-radius: 10px;
    overflow: hidden;
    background-color: #f0d5c0;
  }
  .progress-bar {
    transition: width 0.3s ease;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .perfil-card {
    background: #27272a;
  }
  
  body.dark-mode .perfil-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .perfil-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
  }
  
  body.dark-mode .perfil-body {
    background: #27272a;
  }
  
  body.dark-mode .perfil-label {
    color: #e4e4e7;
  }
  body.dark-mode .perfil-label i {
    color: #f7931e;
  }
  
  body.dark-mode .perfil-input,
  body.dark-mode .perfil-select {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .perfil-input:focus,
  body.dark-mode .perfil-select:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .perfil-input::placeholder {
    color: #a1a1aa;
  }
  body.dark-mode .perfil-select:disabled {
    background-color: #2d2d44;
    color: #a1a1aa;
  }
  
  body.dark-mode .perfil-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .perfil-alert-warning {
    background: #3d2e1a;
    border-left-color: #f5dba3;
    color: #f5dba3;
  }
  
  body.dark-mode .foto-perfil-preview {
    border-color: #f7931e;
  }
  
  body.dark-mode input[type="file"]::file-selector-button {
    background: linear-gradient(135deg, #f7931e 0%, #e08515 100%);
  }
  
  body.dark-mode .btn-cancelar {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .perfil-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .perfil-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  body.dark-mode .progress {
    background-color: #3f3f46;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
</style>
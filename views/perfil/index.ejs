<div class="container py-4">
  
  <!-- ========== MENSAJES FLASH ========== -->
  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-3 mb-4 shadow-sm" role="alert" style="border-left: 4px solid #28a745;">
      <div class="d-flex align-items-center gap-3">
        <i class="bi bi-check-circle-fill fs-3 text-success"></i>
        <div>
          <strong class="d-block">¡Éxito!</strong>
          <span><%= session.mensaje %></span>
        </div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
      </div>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-3 mb-4 shadow-sm" role="alert" style="border-left: 4px solid #dc3545;">
      <div class="d-flex align-items-center gap-3">
        <i class="bi bi-exclamation-triangle-fill fs-3 text-danger"></i>
        <div>
          <strong class="d-block">Error</strong>
          <span><%= session.error %></span>
        </div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
      </div>
    </div>
    <% session.error = null; %>
  <% } %>

  <div class="row g-4">
    
    <!-- COLUMNA IZQUIERDA: Información personal -->
    <div class="col-lg-4">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden perfil-card">
        <div class="text-center py-4 perfil-header-card">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="perfil-avatar">
              <% if (user.foto_perfil) { %>
                <img src="<%= user.foto_perfil %>" alt="Foto de perfil" style="width: 100%; height: 100%; object-fit: cover; border-radius: 50%;">
              <% } else { %>
                <i class="bi bi-person-fill fs-1 text-white"></i>
              <% } %>
            </div>
          </div>
          <h4 class="fw-bold mb-1 perfil-nombre"><%= user.nombre %></h4>
          <span class="badge px-3 py-2 rounded-pill perfil-rol-badge">
            <%= user.rol_nombre %>
          </span>
        </div>
        
        <div class="card-body p-4 perfil-body">
          <div class="list-group list-group-flush">
            <div class="list-group-item px-0 d-flex align-items-center gap-3 perfil-list-item">
              <i class="bi bi-card-text fs-5 perfil-icon-cedula"></i>
              <div>
                <small class="text-muted d-block perfil-label">Cédula</small>
                <span class="fw-semibold perfil-valor"><%= user.cedula || 'No registrada' %></span>
              </div>
            </div>
            <div class="list-group-item px-0 d-flex align-items-center gap-3 perfil-list-item">
              <i class="bi bi-envelope fs-5 perfil-icon-email"></i>
              <div>
                <small class="text-muted d-block perfil-label">Correo electrónico</small>
                <span class="fw-semibold perfil-valor"><%= user.email %></span>
              </div>
            </div>
            <div class="list-group-item px-0 d-flex align-items-center gap-3 perfil-list-item">
              <i class="bi bi-telephone fs-5 perfil-icon-telefono"></i>
              <div>
                <small class="text-muted d-block perfil-label">Teléfono</small>
                <span class="fw-semibold perfil-valor"><%= user.telefono || 'No registrado' %></span>
              </div>
            </div>
            <% if (user.calle_nombre) { %>
              <div class="list-group-item px-0 d-flex align-items-center gap-3 perfil-list-item">
                <i class="bi bi-geo-alt fs-5 perfil-icon-calle"></i>
                <div>
                  <small class="text-muted d-block perfil-label">Calle</small>
                  <span class="fw-semibold perfil-valor"><%= user.calle_nombre %></span>
                </div>
              </div>
            <% } %>
            <div class="list-group-item px-0 d-flex align-items-center gap-3 perfil-list-item">
              <i class="bi bi-calendar fs-5 perfil-icon-fecha"></i>
              <div>
                <small class="text-muted d-block perfil-label">Registrado</small>
                <span class="fw-semibold perfil-valor"><%= new Date(user.fecha_registro).toLocaleDateString() %></span>
              </div>
            </div>
          </div>
          
          <div class="d-grid gap-2 mt-4">
            <a href="/perfil/editar" class="btn py-2 fw-semibold rounded-3 btn-editar-perfil">
              <i class="bi bi-pencil me-2"></i> Editar perfil
            </a>
            <a href="/perfil/cambiar-password" class="btn py-2 fw-semibold rounded-3 btn-cambiar-password">
              <i class="bi bi-key me-2"></i> Cambiar contraseña
            </a>
          </div>
        </div>
      </div>
    </div>
    
    <!-- COLUMNA DERECHA: Estadísticas y actividad -->
    <div class="col-lg-8">
      
      <!-- Tarjetas de estadísticas -->
      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="card border-0 rounded-3 shadow-sm text-center p-3 stat-card stat-card-reportes">
            <i class="bi bi-file-text fs-1 stat-icon-reportes"></i>
            <h2 class="fw-bold mb-0 stat-number"><%= stats.mis_reportes || 0 %></h2>
            <small class="text-muted stat-label">Reportes creados</small>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 rounded-3 shadow-sm text-center p-3 stat-card stat-card-votos">
            <i class="bi bi-hand-thumbs-up fs-1 stat-icon-votos"></i>
            <h2 class="fw-bold mb-0 stat-number"><%= stats.mis_votos || 0 %></h2>
            <small class="text-muted stat-label">Votos emitidos</small>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 rounded-3 shadow-sm text-center p-3 stat-card stat-card-voluntario">
            <i class="bi bi-people fs-1 stat-icon-voluntario"></i>
            <h2 class="fw-bold mb-0 stat-number"><%= stats.soy_voluntario ? 'Sí' : 'No' %></h2>
            <small class="text-muted stat-label">Voluntario</small>
          </div>
        </div>
      </div>
      
      <!-- Calles que lidero (solo líder) -->
      <% if (user.rol_id === 2 && callesLideradas && callesLideradas.length > 0) { %>
        <div class="card border-0 rounded-4 shadow-sm mb-4 overflow-hidden info-card">
          <div class="px-4 py-3 info-card-header-lider">
            <h5 class="mb-0 fw-semibold text-white"><i class="bi bi-geo-alt me-2"></i> Calles que lidero</h5>
          </div>
          <div class="card-body p-3 info-card-body">
            <div class="d-flex flex-wrap gap-2">
              <% callesLideradas.forEach(calle => { %>
                <span class="badge px-3 py-2 rounded-pill badge-calle">📍 <%= calle %></span>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
      
      <!-- Comunidades que atiendo (solo UBCH) -->
      <% if (user.rol_id === 1 && comunidadesAtiende && comunidadesAtiende.length > 0) { %>
        <div class="card border-0 rounded-4 shadow-sm mb-4 overflow-hidden info-card">
          <div class="px-4 py-3 info-card-header-ubch">
            <h5 class="mb-0 fw-semibold text-white"><i class="bi bi-building me-2"></i> Comunidades que atiendo</h5>
          </div>
          <div class="card-body p-3 info-card-body">
            <div class="d-flex flex-wrap gap-2">
              <% comunidadesAtiende.forEach(com => { %>
                <span class="badge px-3 py-2 rounded-pill badge-comunidad">🏘️ <%= com %></span>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
      
      <!-- Últimos reportes -->
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden reportes-card">
        <div class="px-4 py-3 reportes-card-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-file-text me-2"></i> Mis últimos reportes</h5>
        </div>
        <div class="card-body p-0 reportes-card-body">
          <% if (ultimosReportes && ultimosReportes.length > 0) { %>
            <div class="list-group list-group-flush">
              <% ultimosReportes.forEach(r => { %>
                <a href="/reportes" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-4 py-3 reporte-item">
                  <div>
                    <i class="bi bi-chat-square-text me-2 reporte-icon"></i>
                    <strong class="reporte-titulo"><%= r.titulo %></strong>
                    <span class="badge ms-2 px-2 py-1 rounded-pill reporte-estado" 
                          style="background: <%= r.estado === 'Pendiente' ? '#ffc107' : (r.estado === 'En Progreso' ? '#17a2b8' : '#28a745') %>; color: <%= r.estado === 'Pendiente' ? '#333' : '#fff' %>;">
                      <%= r.estado === 'Pendiente' ? '⏳ Pendiente' : (r.estado === 'En Progreso' ? '🔄 En Progreso' : '✅ Resuelto') %>
                    </span>
                  </div>
                  <small class="text-muted reporte-fecha"><i class="bi bi-calendar3 me-1"></i> <%= new Date(r.fecha).toLocaleDateString() %></small>
                </a>
              <% }) %>
            </div>
          <% } else { %>
            <div class="text-center py-4 empty-state">
              <i class="bi bi-inbox fs-1 d-block mb-2"></i>
              <p class="mb-0">No has creado reportes aún</p>
              <a href="/reportar" class="btn btn-sm mt-2 btn-crear-reporte">Crear mi primer reporte</a>
            </div>
          <% } %>
        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta de perfil */
  .perfil-card {
    background: #ffffff;
  }
  
  .perfil-header-card {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .perfil-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: 3px solid white;
  }
  
  .perfil-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .perfil-avatar i {
    font-size: 2.5rem;
    color: white;
  }
  
  .perfil-nombre {
    color: #5D4037;
  }
  
  .perfil-rol-badge {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  .perfil-body {
    background: #ffffff;
  }
  
  .perfil-list-item {
    background: transparent;
    border-bottom-color: #f0d5c0;
  }
  
  .perfil-icon-cedula {
    color: #fd6704bd;
  }
  
  .perfil-icon-email, .perfil-icon-telefono, .perfil-icon-fecha {
    color: #17a2b8;
  }
  
  .perfil-icon-calle {
    color: #fd6704bd;
  }
  
  .perfil-label {
    color: #8B6B5A;
  }
  
  .perfil-valor {
    color: #5D4037;
  }
  
  /* Botones de perfil */
  .btn-editar-perfil {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-editar-perfil:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  .btn-cambiar-password {
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-cambiar-password:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(23, 162, 184, 0.3);
  }
  
  /* Alertas */
  .alert-success {
    background: #d4edda;
    color: #155724;
    border-left: 4px solid #28a745;
  }
  
  .alert-danger {
    background: #f8d7da;
    color: #721c24;
    border-left: 4px solid #dc3545;
  }
  
  /* Tarjetas de estadísticas */
  .stat-card {
    transition: all 0.2s ease;
  }
  .stat-card:hover {
    transform: translateY(-4px);
  }
  
  .stat-card-reportes {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  .stat-card-votos {
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdef5 100%);
  }
  .stat-card-voluntario {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .stat-icon-reportes {
    color: #fd6704bd;
  }
  .stat-icon-votos {
    color: #17a2b8;
  }
  .stat-icon-voluntario {
    color: #fd6704bd;
  }
  
  .stat-number {
    color: #5D4037;
  }
  .stat-card-votos .stat-number {
    color: #0c5460;
  }
  
  .stat-label {
    color: #8B6B5A;
  }
  .stat-card-votos .stat-label {
    color: #0c5460;
  }
  
  /* Tarjetas de información (calles/comunidades) */
  .info-card {
    background: #ffffff;
  }
  
  .info-card-header-lider {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
  }
  
  .info-card-header-ubch {
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
  }
  
  .info-card-body {
    background: #ffffff;
  }
  
  .badge-calle {
    background: #fce5d4;
    color: #5D4037;
  }
  
  .badge-comunidad {
    background: #e3f2fd;
    color: #0c5460;
  }
  
  /* Tarjeta de reportes */
  .reportes-card {
    background: #ffffff;
  }
  
  .reportes-card-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
  }
  
  .reportes-card-header i {
    color: #fd6704bd;
  }
  
  .reportes-card-body {
    background: #ffffff;
  }
  
  .reporte-item {
    border-color: #f0d5c0;
    background: #ffffff;
    transition: all 0.2s ease;
  }
  .reporte-item:hover {
    background-color: #fff8f0 !important;
  }
  
  .reporte-icon {
    color: #fd6704bd;
  }
  
  .reporte-titulo {
    color: #5D4037;
  }
  
  .reporte-fecha {
    color: #8B6B5A;
  }
  
  /* Estado vacío */
  .empty-state i {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-state p {
    color: #6c757d;
  }
  
  .btn-crear-reporte {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-crear-reporte:hover {
    transform: translateY(-2px);
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .perfil-card {
    background: #27272a;
  }
  
  body.dark-mode .perfil-header-card {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  
  body.dark-mode .perfil-nombre {
    color: #e4e4e7;
  }
  
  body.dark-mode .perfil-body {
    background: #27272a;
  }
  
  body.dark-mode .perfil-list-item {
    border-bottom-color: #3f3f46;
  }
  
  body.dark-mode .perfil-label {
    color: #a1a1aa;
  }
  
  body.dark-mode .perfil-valor {
    color: #e4e4e7;
  }
  
  body.dark-mode .perfil-avatar {
    border-color: #3f3f46;
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.15);
  }
  
  body.dark-mode .alert-success {
    background: #0d3b1f;
    color: #a3e4b7;
    border-left-color: #28a745;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
    border-left-color: #dc3545;
  }
  
  body.dark-mode .stat-card-reportes {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  body.dark-mode .stat-card-voluntario {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  body.dark-mode .stat-card-votos {
    background: linear-gradient(135deg, #1a3d4d 0%, #0f2a3a 100%);
  }
  
  body.dark-mode .stat-number {
    color: #e4e4e7;
  }
  body.dark-mode .stat-card-votos .stat-number {
    color: #a3e4e4;
  }
  
  body.dark-mode .stat-label {
    color: #a1a1aa;
  }
  body.dark-mode .stat-card-votos .stat-label {
    color: #a3e4e4;
  }
  
  body.dark-mode .info-card {
    background: #27272a;
  }
  
  body.dark-mode .info-card-body {
    background: #27272a;
  }
  
  body.dark-mode .badge-calle {
    background: #3d3d5c;
    color: #e4e4e7;
  }
  
  body.dark-mode .badge-comunidad {
    background: #1a3d4d;
    color: #a3e4e4;
  }
  
  body.dark-mode .reportes-card {
    background: #27272a;
  }
  
  body.dark-mode .reportes-card-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
    color: #e4e4e7;
  }
  
  body.dark-mode .reportes-card-body {
    background: #27272a;
  }
  
  body.dark-mode .reporte-item {
    border-color: #3f3f46;
    background: #27272a;
  }
  body.dark-mode .reporte-item:hover {
    background-color: #3d3d5c !important;
  }
  
  body.dark-mode .reporte-titulo {
    color: #e4e4e7;
  }
  
  body.dark-mode .reporte-fecha {
    color: #a1a1aa;
  }
  
  body.dark-mode .empty-state i {
    color: #a1a1aa;
  }
  body.dark-mode .empty-state p {
    color: #a1a1aa;
  }
  
  /* Transiciones generales */
  .btn, .stat-card, .reporte-item {
    transition: all 0.2s ease;
  }
</style>
<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden password-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 password-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="password-icon-wrapper">
              <i class="bi bi-key fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold password-title">Cambiar Contraseña</h3>
          <p class="small mb-0 mt-1 password-subtitle">Actualiza tu contraseña de acceso</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 password-body">
          
          <!-- ========== MENSAJE DE ÉXITO ========== -->
          <% if (session && session.mensaje) { %>
            <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-3 mb-4" role="alert">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>
                  <strong>¡Éxito!</strong>
                  <small class="d-block"><%= session.mensaje %></small>
                </div>
              </div>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.mensaje = null; %>
          <% } %>

          <!-- ========== MENSAJE DE ERROR ========== -->
          <% if (session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-3 mb-4" role="alert">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <div>
                  <strong>Error:</strong>
                  <small class="d-block"><%= session.error %></small>
                </div>
              </div>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/perfil/cambiar-password" method="POST">
            
            <!-- Contraseña actual -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 password-label">
                <i class="bi bi-lock-fill me-1"></i> Contraseña actual *
              </label>
              <input type="password" name="password_actual" class="form-control rounded-3 password-input" required>
            </div>

            <!-- Nueva contraseña -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 password-label">
                <i class="bi bi-key-fill me-1"></i> Nueva contraseña *
              </label>
              <input type="password" name="password_nueva" id="password_nueva" class="form-control rounded-3 password-input" 
                     minlength="6" required>
              <small class="text-muted password-help">Mínimo 6 caracteres</small>
            </div>

            <!-- Confirmar nueva contraseña -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 password-label">
                <i class="bi bi-check-circle-fill me-1"></i> Confirmar nueva contraseña *
              </label>
              <input type="password" name="password_confirm" id="password_confirm" class="form-control rounded-3 password-input" required>
              <small class="text-muted password-help" id="passwordHelp"></small>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-cambiar">
                <i class="bi bi-check-circle me-2"></i> Cambiar contraseña
              </button>
              <a href="/perfil" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar">
                <i class="bi bi-arrow-left me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 password-badge">
              <i class="bi bi-shield-check"></i> Contraseña segura
            </small>
            <small class="text-muted d-flex align-items-center gap-1 password-badge">
              <i class="bi bi-lock-fill"></i> Encriptación SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Validar que las contraseñas coincidan antes de enviar
  document.querySelector('form').addEventListener('submit', function(e) {
    const nueva = document.getElementById('password_nueva').value;
    const confirm = document.getElementById('password_confirm').value;
    const help = document.getElementById('passwordHelp');
    
    if (nueva !== confirm) {
      e.preventDefault();
      help.innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    } else if (nueva.length > 0 && nueva.length < 6) {
      e.preventDefault();
      help.innerHTML = '<span class="text-danger">❌ La contraseña debe tener al menos 6 caracteres</span>';
    } else {
      help.innerHTML = '';
    }
  });
  
  // Validar en tiempo real
  document.getElementById('password_confirm').addEventListener('keyup', function() {
    const nueva = document.getElementById('password_nueva').value;
    const confirm = this.value;
    const help = document.getElementById('passwordHelp');
    
    if (nueva === confirm && nueva !== '') {
      help.innerHTML = '<span class="text-success">✅ Las contraseñas coinciden</span>';
    } else if (nueva !== confirm && confirm !== '') {
      help.innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    } else {
      help.innerHTML = '';
    }
  });

  // Validar longitud mínima de la nueva contraseña
  document.getElementById('password_nueva').addEventListener('keyup', function() {
    if (this.value.length > 0 && this.value.length < 6) {
      this.style.borderColor = '#dc3545';
    } else {
      this.style.borderColor = '';
    }
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .password-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .password-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .password-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .password-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .password-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .password-body {
    background: #ffffff;
  }
  
  /* Labels */
  .password-label {
    color: #5D4037;
  }
  .password-label i {
    color: #fd6704bd;
  }
  
  /* Inputs */
  .password-input {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .password-input:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Ayuda */
  .password-help {
    color: #8B6B5A;
  }
  
  /* Alertas */
  .alert-success {
    background: #d4edda;
    color: #155724;
    border-left: 4px solid #28a745;
  }
  
  .alert-danger {
    background: #f8d7da;
    color: #721c24;
    border-left: 4px solid #dc3545;
  }
  
  /* Botón cambiar contraseña */
  .btn-cambiar {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-cambiar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .password-badge {
    color: #8B6B5A !important;
  }
  .password-badge i {
    color: #17a2b8;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .password-card {
    background: #27272a;
  }
  
  body.dark-mode .password-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .password-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .password-body {
    background: #27272a;
  }
  
  body.dark-mode .password-label {
    color: #e4e4e7;
  }
  body.dark-mode .password-label i {
    color: #f7931e;
  }
  
  body.dark-mode .password-input {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .password-input:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .password-input::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .password-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .alert-success {
    background: #0d3b1f;
    color: #a3e4b7;
    border-left-color: #28a745;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
    border-left-color: #dc3545;
  }
  
  body.dark-mode .btn-cancelar {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .password-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .password-badge i {
    color: #138496;
  }
  
  /* Transiciones */
  .btn, .password-input {
    transition: all 0.2s ease;
  }
</style>
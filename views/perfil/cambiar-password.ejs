<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-key fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;">Cambiar Contraseña</h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">Actualiza tu contraseña de acceso</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Mensaje de error -->
          <% if (session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><strong>Error:</strong> <%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/perfil/cambiar-password" method="POST">
            
            <!-- Contraseña actual -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-lock-fill me-1" style="color: #fd6704bd;"></i> Contraseña actual *
              </label>
              <input type="password" name="password_actual" class="form-control rounded-3" required
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
            </div>

            <!-- Nueva contraseña -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-key-fill me-1" style="color: #fd6704bd;"></i> Nueva contraseña *
              </label>
              <input type="password" name="password_nueva" id="password_nueva" class="form-control rounded-3" 
                     minlength="6" required
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              <small class="text-muted" style="color: #8B6B5A;">Mínimo 6 caracteres</small>
            </div>

            <!-- Confirmar nueva contraseña -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                <i class="bi bi-check-circle-fill me-1" style="color: #fd6704bd;"></i> Confirmar nueva contraseña *
              </label>
              <input type="password" name="password_confirm" id="password_confirm" class="form-control rounded-3" required
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              <small class="text-muted" id="passwordHelp" style="color: #8B6B5A;"></small>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); 
                             border: none; color: white;">
                <i class="bi bi-check-circle me-2"></i> Cambiar contraseña
              </button>
              <a href="/perfil" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                 style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-arrow-left me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Contraseña segura
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Encriptación SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Validar que las contraseñas coincidan antes de enviar
  document.querySelector('form').addEventListener('submit', function(e) {
    const nueva = document.getElementById('password_nueva').value;
    const confirm = document.getElementById('password_confirm').value;
    
    if (nueva !== confirm) {
      e.preventDefault();
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    } else if (nueva.length > 0 && nueva.length < 6) {
      e.preventDefault();
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ La contraseña debe tener al menos 6 caracteres</span>';
    }
  });
  
  // Validar en tiempo real
  document.getElementById('password_confirm').addEventListener('keyup', function() {
    const nueva = document.getElementById('password_nueva').value;
    const confirm = this.value;
    
    if (nueva === confirm && nueva !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-success">✅ Las contraseñas coinciden</span>';
    } else if (nueva !== confirm && confirm !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    } else {
      document.getElementById('passwordHelp').innerHTML = '';
    }
  });

  // Validar longitud mínima de la nueva contraseña
  document.getElementById('password_nueva').addEventListener('keyup', function() {
    if (this.value.length > 0 && this.value.length < 6) {
      this.style.borderColor = '#dc3545';
    } else {
      this.style.borderColor = '#f0d5c0';
    }
  });
</script>
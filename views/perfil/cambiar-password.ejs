<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-key"></i> Cambiar Contraseña</h4>
                </div>
                <div class="card-body">
                    
                    <% if (session && session.error) { %>
                        <div class="alert alert-danger">
                            <%= session.error %>
                        </div>
                        <% session.error = null; %>
                    <% } %>

                    <form action="/perfil/cambiar-password" method="POST">
                        <!-- Contraseña actual -->
                        <div class="mb-3">
                            <label class="form-label">Contraseña actual *</label>
                            <input type="password" name="password_actual" class="form-control" required>
                        </div>

                        <!-- Nueva contraseña -->
                        <div class="mb-3">
                            <label class="form-label">Nueva contraseña *</label>
                            <input type="password" name="password_nueva" id="password_nueva" class="form-control" 
                                   minlength="6" required>
                            <small class="text-muted">Mínimo 6 caracteres</small>
                        </div>

                        <!-- Confirmar nueva contraseña -->
                        <div class="mb-3">
                            <label class="form-label">Confirmar nueva contraseña *</label>
                            <input type="password" name="password_confirm" id="password_confirm" class="form-control" required>
                            <small class="text-muted" id="passwordHelp"></small>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Cambiar contraseña
                            </button>
                            <a href="/perfil" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Validar que las contraseñas coincidan antes de enviar
    document.querySelector('form').addEventListener('submit', function(e) {
        const nueva = document.getElementById('password_nueva').value;
        const confirm = document.getElementById('password_confirm').value;
        
        if (nueva !== confirm) {
            e.preventDefault();
            document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
        }
    });
    
    // Validar en tiempo real
    document.getElementById('password_confirm').addEventListener('keyup', function() {
        const nueva = document.getElementById('password_nueva').value;
        const confirm = this.value;
        
        if (nueva === confirm && nueva !== '') {
            document.getElementById('passwordHelp').innerHTML = '<span class="text-success">✅ Las contraseñas coinciden</span>';
        } else if (nueva !== confirm && confirm !== '') {
            document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
        } else {
            document.getElementById('passwordHelp').innerHTML = '';
        }
    });
</script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
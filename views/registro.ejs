<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
              <i class="bi bi-person-plus-fill fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold" style="color: #fd6704bd;">Registro de Ciudadano</h3>
          <p class="small mb-0 mt-1" style="color: #8B6B5A;">Completa el formulario para crear tu cuenta</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5">
          
          <!-- Mensaje de error -->
          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><strong>Error:</strong> <%= error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
          <% } %>

          <!-- Formulario en grid de 2 columnas -->
          <form method="POST" action="/registro">
            <div class="row g-4">
              
              <!-- Cédula -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-card-text me-1" style="color: #fd6704bd;"></i> Cédula de identidad *
                </label>
                <input type="text" name="cedula" class="form-control rounded-3" 
                       placeholder="Ej: 12345678" required
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                <small class="text-muted" style="color: #8B6B5A;">Solo números</small>
              </div>

              <!-- Teléfono -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-telephone-fill me-1" style="color: #fd6704bd;"></i> Teléfono *
                </label>
                <input type="text" name="telefono" class="form-control rounded-3" 
                       placeholder="0414-1234567" required
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Nombre completo -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-person-fill me-1" style="color: #fd6704bd;"></i> Nombre completo *
                </label>
                <input type="text" name="nombre" class="form-control rounded-3" 
                       placeholder="Ej: Juan Pérez" required
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Correo electrónico -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-envelope-fill me-1" style="color: #fd6704bd;"></i> Correo electrónico *
                </label>
                <input type="email" name="email" class="form-control rounded-3" 
                       placeholder="ejemplo@correo.com" required
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Contraseña -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-lock-fill me-1" style="color: #fd6704bd;"></i> Contraseña *
                </label>
                <input type="password" name="password" id="password" class="form-control rounded-3" 
                       placeholder="Mínimo 6 caracteres" required
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
              </div>

              <!-- Confirmar contraseña -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-lock-fill me-1" style="color: #fd6704bd;"></i> Confirmar contraseña *
                </label>
                <input type="password" name="confirm_password" id="confirm_password" class="form-control rounded-3" 
                       placeholder="Repite tu contraseña" required
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                <small class="text-muted" id="passwordHelp" style="color: #8B6B5A;"></small>
              </div>

              <!-- Calle -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-geo-alt-fill me-1" style="color: #fd6704bd;"></i> ¿A qué calle perteneces? *
                </label>
                <select name="calle_id" class="form-select rounded-3" required
                        style="border: 1px solid #f0d5c0; background-color: #fefaf7; padding: 0.6rem 1rem;">
                  <option value="">Seleccione una calle...</option>
                  <% if (calles && calles.length > 0) { %>
                    <% calles.forEach(c => { %>
                      <option value="<%= c.id %>"><%= c.nombre %></option>
                    <% }) %>
                  <% } else { %>
                    <option value="" disabled>No hay calles registradas</option>
                  <% } %>
                </select>
                <small class="text-muted" style="color: #8B6B5A;">Tu solicitud será revisada por un líder comunitario</small>
              </div>

            </div>

            <!-- Botones -->
            <div class="d-flex justify-content-center gap-3 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3" id="btnRegistro"
                      style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); 
                            border: none; color: white;">
                <i class="bi bi-check-lg me-2"></i> Registrarse
              </button>
              <a href="/login" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3" 
                style="border-color: #f0d5c0; color: #5D4037;">
                <i class="bi bi-arrow-left me-2"></i> Volver
              </a>
            </div>

            <!-- Enlace a login -->
            <div class="text-center mt-4">
              <p class="mb-0 small" style="color: #8B6B5A;">
                ¿Ya tienes cuenta? 
                <a href="/login" class="fw-bold text-decoration-none" style="color: #fd6704bd;">
                  Inicia sesión aquí <i class="bi bi-arrow-right"></i>
                </a>
              </p>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
              <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Validar que las contraseñas coincidan antes de enviar
  document.querySelector('form').addEventListener('submit', function(e) {
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirm_password').value;
    
    if (password !== confirmPassword) {
      e.preventDefault();
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    }
  });
  
  // Validar en tiempo real
  document.getElementById('confirm_password').addEventListener('keyup', function() {
    const password = document.getElementById('password').value;
    const confirmPassword = this.value;
    
    if (password === confirmPassword && password !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-success">✅ Las contraseñas coinciden</span>';
    } else if (password !== confirmPassword && confirmPassword !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    } else {
      document.getElementById('passwordHelp').innerHTML = '';
    }
  });

  // Validar cédula solo números
  document.querySelector('input[name="cedula"]').addEventListener('input', function(e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });
</script>
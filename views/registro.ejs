<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden registro-card">
        
        <!-- Header con gradiente dual (naranja + azul) -->
        <div class="text-center py-4 px-3 registro-card-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="registro-icon-wrapper">
              <i class="bi bi-person-plus-fill fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold registro-card-title">Registro de Ciudadano</h3>
          <p class="small mb-0 mt-1 registro-card-subtitle">Completa el formulario para crear tu cuenta</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 registro-card-body">
          
          <!-- Mensaje de error -->
          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><strong>Error:</strong> <%= error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
          <% } %>

          <!-- Formulario en grid de 2 columnas -->
          <form method="POST" action="/registro">
            <div class="row g-4">
              
              <!-- Cédula -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 registro-label">
                  <i class="bi bi-card-text me-1"></i> Cédula de identidad *
                </label>
                <input type="text" name="cedula" class="form-control rounded-3 registro-input" 
                       placeholder="Ej: 12345678" required>
                <small class="text-muted registro-help">Solo números</small>
              </div>

              <!-- Teléfono -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 registro-label">
                  <i class="bi bi-telephone-fill me-1"></i> Teléfono *
                </label>
                <input type="text" name="telefono" class="form-control rounded-3 registro-input" 
                       placeholder="0414-1234567" required>
              </div>

              <!-- Nombre completo -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2 registro-label">
                  <i class="bi bi-person-fill me-1"></i> Nombre completo *
                </label>
                <input type="text" name="nombre" class="form-control rounded-3 registro-input" 
                       placeholder="Ej: Juan Pérez" required>
              </div>

              <!-- Correo electrónico -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2 registro-label">
                  <i class="bi bi-envelope-fill me-1"></i> Correo electrónico *
                </label>
                <input type="email" name="email" class="form-control rounded-3 registro-input" 
                       placeholder="ejemplo@correo.com" required>
              </div>

              <!-- Contraseña -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 registro-label">
                  <i class="bi bi-lock-fill me-1"></i> Contraseña *
                </label>
                <input type="password" name="password" id="password" class="form-control rounded-3 registro-input" 
                       placeholder="Mínimo 6 caracteres" required>
              </div>

              <!-- Confirmar contraseña -->
              <div class="col-md-6">
                <label class="form-label fw-semibold small mb-2 registro-label">
                  <i class="bi bi-lock-fill me-1"></i> Confirmar contraseña *
                </label>
                <input type="password" name="confirm_password" id="confirm_password" class="form-control rounded-3 registro-input" 
                       placeholder="Repite tu contraseña" required>
                <small class="text-muted registro-help" id="passwordHelp"></small>
              </div>

              <!-- Calle -->
              <div class="col-12">
                <label class="form-label fw-semibold small mb-2 registro-label">
                  <i class="bi bi-geo-alt-fill me-1"></i> ¿A qué calle perteneces? *
                </label>
                <select name="calle_id" class="form-select rounded-3 registro-select" required>
                  <option value="">Seleccione una calle...</option>
                  <% if (calles && calles.length > 0) { %>
                    <% calles.forEach(c => { %>
                      <option value="<%= c.id %>"><%= c.nombre %></option>
                    <% }) %>
                  <% } else { %>
                    <option value="" disabled>No hay calles registradas</option>
                  <% } %>
                </select>
                <small class="text-muted registro-help">Tu solicitud será revisada por un líder comunitario</small>
              </div>

            </div>

            <!-- Botones -->
            <div class="d-flex justify-content-center gap-3 mt-4">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 registro-btn" id="btnRegistro">
                <i class="bi bi-check-lg me-2"></i> Registrarse
              </button>
              <a href="/login" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 registro-cancel-btn">
                <i class="bi bi-arrow-left me-2"></i> Volver
              </a>
            </div>

            <!-- Enlace a login -->
            <div class="text-center mt-4">
              <p class="mb-0 small registro-footer-text">
                ¿Ya tienes cuenta? 
                <a href="/login" class="fw-bold text-decoration-none registro-login-link">
                  Inicia sesión aquí <i class="bi bi-arrow-right"></i>
                </a>
              </p>
            </div>

          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 registro-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 registro-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Validar que las contraseñas coincidan antes de enviar
  document.querySelector('form').addEventListener('submit', function(e) {
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirm_password').value;
    
    if (password !== confirmPassword) {
      e.preventDefault();
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    }
  });
  
  // Validar en tiempo real
  document.getElementById('confirm_password').addEventListener('keyup', function() {
    const password = document.getElementById('password').value;
    const confirmPassword = this.value;
    
    if (password === confirmPassword && password !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-success">✅ Las contraseñas coinciden</span>';
    } else if (password !== confirmPassword && confirmPassword !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    } else {
      document.getElementById('passwordHelp').innerHTML = '';
    }
  });

  // Validar cédula solo números
  document.querySelector('input[name="cedula"]').addEventListener('input', function(e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .registro-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual (naranja + azul) */
  .registro-card-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .registro-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .registro-card-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .registro-card-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .registro-card-body {
    background: #ffffff;
  }
  
  /* Labels */
  .registro-label {
    color: #5D4037;
  }
  .registro-label i {
    color: #fd6704bd;
  }
  
  /* Inputs y selects */
  .registro-input, .registro-select {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .registro-input:focus, .registro-select:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
  }
  
  /* Ayuda */
  .registro-help {
    color: #8B6B5A;
  }
  
  /* Botón registrarse */
  .registro-btn {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .registro-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(253, 103, 4, 0.4);
  }
  
  /* Botón cancelar */
  .registro-cancel-btn {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .registro-cancel-btn:hover {
    background: #f0d5c0;
    border-color: #e0c5b0;
  }
  
  /* Footer */
  .registro-footer-text {
    color: #8B6B5A;
  }
  
  .registro-login-link {
    color: #fd6704bd;
  }
  .registro-login-link:hover {
    color: #e85d2c;
  }
  
  /* Badges */
  .registro-badge {
    color: #8B6B5A !important;
  }
  .registro-badge i {
    color: #17a2b8;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .registro-card {
    background: #27272a;
  }
  
  body.dark-mode .registro-card-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .registro-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .registro-card-title {
    color: white;
  }
  
  body.dark-mode .registro-card-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  body.dark-mode .registro-card-body {
    background: #27272a;
  }
  
  body.dark-mode .registro-label {
    color: #e4e4e7;
  }
  body.dark-mode .registro-label i {
    color: #f7931e;
  }
  
  body.dark-mode .registro-input, 
  body.dark-mode .registro-select {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .registro-input:focus, 
  body.dark-mode .registro-select:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .registro-input::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .registro-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .registro-cancel-btn {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .registro-cancel-btn:hover {
    background: #3f3f46;
    border-color: #52525b;
  }
  
  body.dark-mode .registro-footer-text {
    color: #a1a1aa;
  }
  
  body.dark-mode .registro-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .registro-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  /* Estilos para selects en modo nocturno */
  body.dark-mode .registro-select option {
    background-color: #27272a;
    color: #e4e4e7;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
</style>
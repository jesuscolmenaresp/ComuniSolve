<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow">
        <div class="card-header bg-success text-white text-center">
          <h4 class="mb-0">🧑‍🤝‍🧑 Registro de Ciudadano</h4>
        </div>
        <div class="card-body">
          
          <% if (error) { %>
            <div class="alert alert-danger">
              <%= error %>
            </div>
          <% } %>

          <form method="POST" action="/registro">
            <!-- Cédula -->
            <div class="mb-3">
              <label class="form-label">Cédula de identidad *</label>
              <div class="input-group">
                <span class="input-group-text">🆔</span>
                <input type="text" name="cedula" class="form-control" 
                       placeholder="Ej: 12345678" required>
              </div>
              <small class="text-muted">Solo números, sin puntos ni letras</small>
            </div>

            <!-- Nombre -->
            <div class="mb-3">
              <label class="form-label">Nombre completo *</label>
              <div class="input-group">
                <span class="input-group-text">👤</span>
                <input type="text" name="nombre" class="form-control" 
                       placeholder="Ej: Juan Pérez" required>
              </div>
            </div>

            <!-- Correo -->
            <div class="mb-3">
              <label class="form-label">Correo electrónico *</label>
              <div class="input-group">
                <span class="input-group-text">📧</span>
                <input type="email" name="email" class="form-control" 
                       placeholder="ejemplo@correo.com" required>
              </div>
            </div>

            <!-- Contraseña -->
            <div class="mb-3">
              <label class="form-label">Contraseña *</label>
              <div class="input-group">
                <span class="input-group-text">🔑</span>
                <input type="password" name="password" id="password" class="form-control" 
                       placeholder="Mínimo 6 caracteres" required>
              </div>
            </div>

            <!-- Confirmar contraseña -->
            <div class="mb-3">
              <label class="form-label">Confirmar contraseña *</label>
              <div class="input-group">
                <span class="input-group-text">🔑</span>
                <input type="password" name="confirm_password" id="confirm_password" class="form-control" 
                       placeholder="Repite tu contraseña" required>
              </div>
              <small class="text-muted" id="passwordHelp"></small>
            </div>

            <!-- Teléfono -->
            <div class="mb-3">
              <label class="form-label">Teléfono *</label>
              <div class="input-group">
                <span class="input-group-text">📱</span>
                <input type="text" name="telefono" class="form-control" 
                       placeholder="0414-1234567" required>
              </div>
            </div>

            <!-- Calle -->
            <div class="mb-4">
              <label class="form-label">¿A qué calle perteneces? *</label>
              <div class="input-group">
                <span class="input-group-text">📍</span>
                <select name="calle_id" class="form-select" required>
                  <option value="">Seleccione una calle...</option>
                  <% if (calles && calles.length > 0) { %>
                    <% calles.forEach(c => { %>
                      <option value="<%= c.id %>"><%= c.nombre %></option>
                    <% }) %>
                  <% } else { %>
                    <option value="" disabled>No hay calles registradas</option>
                  <% } %>
                </select>
              </div>
              <small class="text-muted">Tu solicitud será revisada por un líder comunitario</small>
            </div>

            <!-- Botón -->
            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-success" id="btnRegistro">
                ✅ Registrarse
              </button>
            </div>

            <!-- Enlace a login -->
            <div class="text-center mt-3">
              <p class="mb-0">¿Ya tienes cuenta? 
                <a href="/login" class="text-primary fw-bold">Inicia sesión aquí</a>
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Validar que las contraseñas coincidan antes de enviar
  document.querySelector('form').addEventListener('submit', function(e) {
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirm_password').value;
    
    if (password !== confirmPassword) {
      e.preventDefault();
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    }
  });
  
  // Validar en tiempo real
  document.getElementById('confirm_password').addEventListener('keyup', function() {
    const password = document.getElementById('password').value;
    const confirmPassword = this.value;
    
    if (password === confirmPassword && password !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-success">✅ Las contraseñas coinciden</span>';
    } else if (password !== confirmPassword && confirmPassword !== '') {
      document.getElementById('passwordHelp').innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
    } else {
      document.getElementById('passwordHelp').innerHTML = '';
    }
  });

  // Validar cédula solo números
  document.querySelector('input[name="cedula"]').addEventListener('input', function(e) {
    this.value = this.value.replace(/[^0-9]/g, '');
  });
</script>
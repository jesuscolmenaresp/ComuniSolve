  }
  body.dark-mode .stat-label-lider-pendiente {
    color: #f5dba3;
  }
  body.dark-mode .stat-label-lider-progreso {
    color: #a3e4e4;
  }
  body.dark-mode .stat-label-lider-resuelto {
    color: #a3e4b7;
  }
  body.dark-mode .stat-icon-lider {
    color: #f7931e;
  }
  body.dark-mode .stat-card-pendiente-lider .stat-icon-lider {
    color: #f5dba3;
  }
  body.dark-mode .stat-card-progreso-lider .stat-icon-lider {

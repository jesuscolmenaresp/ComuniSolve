<%
// Preparar datos para Chart.js
let categoriasLabels = [];
let categoriasDatos = [];
let estadosLabels = [];
let estadosDatos = [];
let callesLabels = [];
let callesDatos = [];

if (porCategoria && porCategoria.length > 0) {
  categoriasLabels = porCategoria.map(item => item.nombre);
  categoriasDatos = porCategoria.map(item => item.total);
}

if (porEstado && porEstado.length > 0) {
  estadosLabels = porEstado.map(item => item.estado);
  estadosDatos = porEstado.map(item => item.total);
}

if (topCalles && topCalles.length > 0) {
  callesLabels = topCalles.map(item => item.nombre);
  callesDatos = topCalles.map(item => item.total);
}
%>

<div class="container py-4">
  
  <!-- ========== ENCABEZADO MEJORADO ========== -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h2 class="fw-bold mb-1 lider-title">
            <i class="bi bi-person-badge me-2" style="color: #fd6704;"></i> 
            Panel de Líder Comunitario
          </h2>
          <p class="text-muted small mb-0 lider-subtitle">
            <i class="bi bi-people me-1"></i> Gestiona las calles a tu cargo y da seguimiento a los reportes
          </p>
        </div>
        <div class="d-flex gap-2">
          <button onclick="window.location.reload()" class="btn btn-actualizar-lider px-4 py-2 rounded-3">
            <i class="bi bi-arrow-repeat me-2"></i> Actualizar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== MENSAJES FLASH ========== -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- ========== INFO CALLES A CARGO ========== -->
  <div class="alert info-calles-lider border-0 rounded-3 py-3 mb-4">
    <div class="d-flex align-items-center gap-3 flex-wrap">
      <i class="bi bi-geo-alt-fill fs-3 info-calles-icon"></i>
      <div>
        <strong class="info-calles-title">📍 Calles a tu cargo:</strong>
        <% if (misCalles && misCalles.length > 0) { %>
          <span class="fw-semibold info-calles-nombre"><%= misCalles.map(c => c.nombre).join(', ') %></span>
        <% } else { %>
          <span class="text-muted info-calles-empty">No tienes calles asignadas</span>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ========== TARJETAS DE RESUMEN (4) ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-lider stat-card-total-lider">
        <div class="card-body p-3 text-center">
          <div class="stat-icon-wrapper-lider">
            <i class="bi bi-file-text-fill fs-3 text-white"></i>
          </div>
          <h3 class="fw-bold mb-0 stat-number-lider mt-2"><%= totales.total_reportes || 0 %></h3>
          <small class="stat-label-lider">Total reportes</small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-lider stat-card-pendiente-lider">
        <div class="card-body p-3 text-center">
          <div class="stat-icon-wrapper-lider">
            <i class="bi bi-clock-history fs-3 text-white"></i>
          </div>
          <h3 class="fw-bold mb-0 stat-number-lider-pendiente mt-2"><%= totales.pendientes || 0 %></h3>
          <small class="stat-label-lider-pendiente">Pendientes</small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-lider stat-card-progreso-lider">
        <div class="card-body p-3 text-center">
          <div class="stat-icon-wrapper-lider">
            <i class="bi bi-arrow-repeat fs-3 text-white"></i>
          </div>
          <h3 class="fw-bold mb-0 stat-number-lider-progreso mt-2"><%= totales.en_progreso || 0 %></h3>
          <small class="stat-label-lider-progreso">En Progreso</small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-lider stat-card-resuelto-lider">
        <div class="card-body p-3 text-center">
          <div class="stat-icon-wrapper-lider">
            <i class="bi bi-check-circle-fill fs-3 text-white"></i>
          </div>
          <h3 class="fw-bold mb-0 stat-number-lider-resuelto mt-2"><%= totales.resueltos || 0 %></h3>
          <small class="stat-label-lider-resuelto">Resueltos</small>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== GRÁFICOS (2 columnas) ========== -->
  <div class="row g-4 mb-5">
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-lider h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-pie-chart-fill me-2" style="color: #fd7e14;"></i> 
            Reportes por Categoría
          </h5>
        </div>
        <div class="card-body p-4 pt-0 chart-body-lider">
          <canvas id="chartCategoria" style="max-height: 260px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-lider h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-donut-fill me-2" style="color: #28a745;"></i> 
            Reportes por Estado
          </h5>
        </div>
        <div class="card-body p-4 pt-0 chart-body-lider">
          <canvas id="chartEstado" style="max-height: 260px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== TOP CALLES + REPORTES RECIENTES (2 columnas) ========== -->
  <div class="row g-4 mb-5">
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-lider h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-bar-chart-steps me-2" style="color: #17a2b8;"></i> 
            Top Calles con más Reportes
          </h5>
        </div>
        <div class="card-body p-4 pt-0 chart-body-lider">
          <canvas id="chartCalles" style="max-height: 260px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden table-card-lider h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-clock-history me-2" style="color: #ffc107;"></i> 
            Reportes Recientes
          </h5>
          <span class="badge bg-info rounded-pill px-3 py-2">
            <i class="bi bi-file-text me-1"></i> últimos 5
          </span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 tabla-lider tabla-reportes-recientes">
              <thead>
                <tr>
                  <th><i class="bi bi-card-heading me-1"></i> Título</th>
                  <th><i class="bi bi-geo-alt me-1"></i> Calle</th>
                  <th><i class="bi bi-info-circle me-1"></i> Estado</th>
                  <th class="text-center"><i class="bi bi-eye me-1"></i> Ver</th>
                </tr>
              </thead>
              <tbody>
                <% if (reportesRecientes && reportesRecientes.length > 0) { %>
                  <% reportesRecientes.slice(0, 5).forEach(r => { %>
                    <tr>
                      <td><strong><%= r.titulo %></strong></td>
                      <td><i class="bi bi-pin-map-fill me-1 location-icon"></i> <%= r.calle %></td>
                      <td>
                        <span class="badge rounded-pill px-2 py-1 estado-badge-lider 
                          <%= r.estado === 'Pendiente' ? 'bg-warning text-dark' : 
                              r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>">
                          <%= r.estado === 'Pendiente' ? '⏳' : 
                              r.estado === 'En Progreso' ? '🔄' : '✅' %>
                          <%= r.estado %>
                        </span>
                      </td>
                      <td class="text-center">
                        <a href="/reportes" class="btn btn-sm btn-ver-lider px-3">
                          <i class="bi bi-eye me-1"></i> Ver
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-4 empty-state-lider">
                      <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                      <p class="mb-0 small">No hay reportes recientes</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent border-0 text-center pt-3 pb-4">
          <a href="/reportes" class="btn btn-sm btn-outline-primary rounded-3 px-4">
            Ver todos los reportes <i class="bi bi-arrow-right ms-1"></i>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== VOLUNTARIOS APROBADOS ========== -->
  <div class="row g-4">
    <div class="col-12">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden table-card-lider">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-person-badge me-2" style="color: #28a745;"></i> 
            Voluntarios Aprobados en tus Calles
          </h5>
          <span class="badge bg-success rounded-pill px-3 py-2">
            <i class="bi bi-people me-1"></i> <%= voluntarios ? voluntarios.length : 0 %> voluntarios
          </span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 tabla-lider tabla-voluntarios">
              <thead>
                <tr>
                  <th><i class="bi bi-person me-1"></i> Nombre</th>
                  <th><i class="bi bi-tools me-1"></i> Habilidad</th>
                  <th><i class="bi bi-telephone me-1"></i> Teléfono</th>
                </tr>
              </thead>
              <tbody>
                <% if (voluntarios && voluntarios.length > 0) { %>
                  <% voluntarios.forEach(v => { %>
                    <tr>
                      <td><strong><%= v.nombre %></strong></td>
                      <td><span class="badge rounded-pill px-2 py-1 habilidad-badge-lider"><%= v.habilidad || 'Sin habilidad' %></span></td>
                      <td><%= v.telefono || '—' %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="3" class="text-center py-4 empty-state-lider">
                      <i class="bi bi-person-x fs-3 d-block mb-2"></i>
                      <p class="mb-0 small">No hay voluntarios aprobados en tus calles</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent border-0 text-center pt-3 pb-4">
          <a href="/voluntarios/gestionar" class="btn btn-sm btn-outline-primary rounded-3 px-4">
            Gestionar voluntarios <i class="bi bi-arrow-right ms-1"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== CHART.JS ========== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Datos desde el servidor
  const categoriasLabels = <%- JSON.stringify(porCategoria.map(item => item.nombre)) %>;
  const categoriasDatos = <%- JSON.stringify(porCategoria.map(item => item.total)) %>;
  const estadosLabels = <%- JSON.stringify(porEstado.map(item => item.estado)) %>;
  const estadosDatos = <%- JSON.stringify(porEstado.map(item => item.total)) %>;
  const callesLabels = <%- JSON.stringify(topCalles.map(item => item.nombre)) %>;
  const callesDatos = <%- JSON.stringify(topCalles.map(item => item.total)) %>;

  // Gráfico de Categorías
  if (categoriasLabels.length > 0) {
    new Chart(document.getElementById('chartCategoria'), {
      type: 'pie',
      data: {
        labels: categoriasLabels,
        datasets: [{
          data: categoriasDatos,
          backgroundColor: [
            '#0d6efd', '#ffc107', '#dc3545', '#3bba89', '#6c757d', '#17a2b8', '#fd7e14'
          ],
          borderWidth: 0,
          hoverOffset: 10
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { 
            position: 'bottom', 
            labels: { 
              font: { size: 11 },
              padding: 15,
              usePointStyle: true,
              pointStyle: 'circle'
            }
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                const label = context.label || '';
                const value = context.raw || 0;
                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                return `${label}: ${value} (${percentage}%)`;
              }
            }
          }
        }
      }
    });
  } else {
    document.getElementById('chartCategoria').innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-pie-chart fs-1 d-block mb-2"></i><p>No hay datos para mostrar</p></div>';
  }

  // Gráfico de Estados
  if (estadosLabels.length > 0) {
    new Chart(document.getElementById('chartEstado'), {
      type: 'doughnut',
      data: {
        labels: estadosLabels,
        datasets: [{
          data: estadosDatos,
          backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
          borderWidth: 0,
          hoverOffset: 10
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '60%',
        plugins: {
          legend: { 
            position: 'bottom', 
            labels: { 
              font: { size: 11 },
              padding: 15,
              usePointStyle: true,
              pointStyle: 'circle'
            }
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                const label = context.label || '';
                const value = context.raw || 0;
                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                return `${label}: ${value} (${percentage}%)`;
              }
            }
          }
        }
      }
    });
  } else {
    document.getElementById('chartEstado').innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-donut fs-1 d-block mb-2"></i><p>No hay datos para mostrar</p></div>';
  }

  // Gráfico de Calles - TOP 5
  if (callesLabels.length > 0) {
    new Chart(document.getElementById('chartCalles'), {
      type: 'bar',
      data: {
        labels: callesLabels,
        datasets: [{
          label: 'Reportes',
          data: callesDatos,
          backgroundColor: [
            'rgba(253, 103, 4, 0.8)',
            'rgba(13, 110, 253, 0.8)',
            'rgba(40, 167, 69, 0.8)',
            'rgba(255, 193, 7, 0.8)',
            'rgba(23, 162, 184, 0.8)'
          ],
          borderRadius: 8,
          barPercentage: 0.7,
          hoverBackgroundColor: [
            'rgba(253, 103, 4, 1)',
            'rgba(13, 110, 253, 1)',
            'rgba(40, 167, 69, 1)',
            'rgba(255, 193, 7, 1)',
            'rgba(23, 162, 184, 1)'
          ]
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          y: {
            beginAtZero: true,
            stepSize: 1,
            grid: { color: 'rgba(0,0,0,0.05)' },
            ticks: { font: { size: 11 } }
          },
          x: {
            ticks: { font: { size: 11, weight: 'bold' } },
            grid: { display: false }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(0,0,0,0.8)',
            titleColor: 'white',
            bodyColor: 'white',
            cornerRadius: 8,
            padding: 10
          }
        }
      }
    });
  } else {
    document.getElementById('chartCalles').innerHTML = '<div class="text-center text-muted py-5"><i class="bi bi-bar-chart fs-1 d-block mb-2"></i><p>No hay datos para mostrar</p></div>';
  }
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .lider-title {
    color: #5D4037;
  }
  .lider-title i {
    color: #fd6704bd;
  }
  .lider-subtitle {
    color: #8B6B5A;
  }
  
  /* Botón actualizar */
  .btn-actualizar-lider {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-actualizar-lider:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Info calles */
  .info-calles-lider {
    background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
  }
  .info-calles-icon {
    color: #0c5460;
  }
  .info-calles-title {
    color: #0c5460;
  }
  .info-calles-nombre {
    color: #0c5460;
  }
  .info-calles-empty {
    color: #0c5460;
  }
  
  /* Tarjetas de estadísticas */
  .stat-card-lider {
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .stat-card-lider:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  }
  
  .stat-icon-wrapper-lider {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }
  
  .stat-card-total-lider {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  .stat-card-pendiente-lider {
    background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
  }
  .stat-card-progreso-lider {
    background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
  }
  .stat-card-resuelto-lider {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
  }
  
  .stat-number-lider {
    color: #5D4037;
  }
  .stat-number-lider-pendiente {
    color: #856404;
  }
  .stat-number-lider-progreso {
    color: #0c5460;
  }
  .stat-number-lider-resuelto {
    color: #155724;
  }
  
  .stat-label-lider {
    color: #8B6B5A;
  }
  .stat-label-lider-pendiente {
    color: #856404;
  }
  .stat-label-lider-progreso {
    color: #0c5460;
  }
  .stat-label-lider-resuelto {
    color: #155724;
  }
  
  /* Gráficos */
  .chart-card-lider {
    transition: all 0.2s ease;
  }
  .chart-card-lider .card-header h5 {
    color: #5D4037;
  }
  .chart-body-lider {
    background: white;
  }
  
  /* Tablas */
  .table-card-lider {
    transition: all 0.2s ease;
  }
  
  .tabla-lider {
    font-size: 14px;
  }
  .tabla-lider thead th {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
    font-weight: 600;
    padding: 12px;
    border-bottom: 2px solid #fd6704bd;
  }
  .tabla-lider tbody td {
    padding: 10px 12px;
    vertical-align: middle;
  }
  .tabla-lider tbody tr {
    border-bottom: 1px solid #f0d5c0;
  }
  .tabla-lider tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  
  .estado-badge-lider {
    font-size: 11px;
    padding: 4px 10px;
  }
  
  .btn-ver-lider {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-ver-lider:hover {
    transform: translateY(-2px);
  }
  
  .habilidad-badge-lider {
    background: linear-gradient(135deg, #6f42c1 0%, #8b5cf6 100%);
    color: white;
    font-size: 11px;
  }
  
  .location-icon {
    color: #6c757d;
  }
  
  .empty-state-lider i {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-state-lider p {
    color: #6c757d;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .lider-title {
    color: #e4e4e7;
  }
  body.dark-mode .lider-subtitle {
    color: #a1a1aa;
  }
  
  body.dark-mode .info-calles-lider {
    background: linear-gradient(135deg, #1a3d3d 0%, #0f2a2a 100%);
  }
  body.dark-mode .info-calles-title,
  body.dark-mode .info-calles-nombre,
  body.dark-mode .info-calles-icon {
    color: #a3e4e4;
  }
  body.dark-mode .info-calles-empty {
    color: #a3e4e4;
  }
  
  body.dark-mode .stat-card-total-lider {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  body.dark-mode .stat-card-pendiente-lider {

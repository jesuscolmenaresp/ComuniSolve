<%
// Preparar datos para Chart.js
let categoriasLabels = [];
let categoriasDatos = [];
let estadosLabels = [];
let estadosDatos = [];
let callesLabels = [];
let callesDatos = [];

if (porCategoria && porCategoria.length > 0) {
  categoriasLabels = porCategoria.map(item => item.nombre);
  categoriasDatos = porCategoria.map(item => item.total);
}

if (porEstado && porEstado.length > 0) {
  estadosLabels = porEstado.map(item => item.estado);
  estadosDatos = porEstado.map(item => item.total);
}

if (topCalles && topCalles.length > 0) {
  callesLabels = topCalles.map(item => item.nombre);
  callesDatos = topCalles.map(item => item.total);
}
%>

<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 lider-title">
        <i class="bi bi-person-badge me-2"></i> Panel de Líder Comunitario
      </h2>
      <p class="text-muted small mb-0 lider-subtitle">Gestiona las calles a tu cargo y da seguimiento a los reportes</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/reportes" class="btn btn-sm px-3 py-2 fw-semibold rounded-3 btn-lider-primary">
        <i class="bi bi-list-ul me-1"></i> Ver reportes
      </a>
      <a href="/voluntarios/gestionar" class="btn btn-sm btn-outline-secondary px-3 py-2 fw-semibold rounded-3 btn-lider-outline">
        <i class="bi bi-person-check me-1"></i> Voluntarios
      </a>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Información de calles a cargo -->
  <div class="alert alert-info border-0 rounded-3 py-3 mb-4 info-calles-lider">
    <div class="d-flex align-items-center gap-3 flex-wrap">
      <i class="bi bi-geo-alt-fill fs-3 info-calles-icon"></i>
      <div>
        <strong class="info-calles-title">📍 Calles a tu cargo:</strong>
        <% if (misCalles && misCalles.length > 0) { %>
          <span class="fw-semibold info-calles-nombre"><%= misCalles.map(c => c.nombre).join(', ') %></span>
        <% } else { %>
          <span class="text-muted info-calles-empty">No tienes calles asignadas</span>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Tarjetas de resumen -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-lider stat-card-total-lider">
        <i class="bi bi-file-text fs-2 stat-icon-lider"></i>
        <h3 class="fw-bold mb-0 stat-number-lider"><%= totales.total_reportes || 0 %></h3>
        <small class="text-muted stat-label-lider">Total reportes</small>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-lider stat-card-pendiente-lider">
        <i class="bi bi-clock-history fs-2 stat-icon-lider"></i>
        <h3 class="fw-bold mb-0 stat-number-lider-pendiente"><%= totales.pendientes || 0 %></h3>
        <small class="text-muted stat-label-lider-pendiente">Pendientes</small>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-lider stat-card-progreso-lider">
        <i class="bi bi-arrow-repeat fs-2 stat-icon-lider"></i>
        <h3 class="fw-bold mb-0 stat-number-lider-progreso"><%= totales.en_progreso || 0 %></h3>
        <small class="text-muted stat-label-lider-progreso">En Progreso</small>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-lider stat-card-resuelto-lider">
        <i class="bi bi-check-circle fs-2 stat-icon-lider"></i>
        <h3 class="fw-bold mb-0 stat-number-lider-resuelto"><%= totales.resueltos || 0 %></h3>
        <small class="text-muted stat-label-lider-resuelto">Resueltos</small>
      </div>
    </div>
  </div>

  <!-- Gráficas -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card-lider">
        <div class="px-4 py-3 chart-card-header-lider">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-pie-chart me-2"></i> Reportes por Categoría</h5>
        </div>
        <div class="card-body p-4 chart-card-body-lider">
          <canvas id="chartCategoria" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card-lider">
        <div class="px-4 py-3 chart-card-header-lider">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-donut me-2"></i> Reportes por Estado</h5>
        </div>
        <div class="card-body p-4 chart-card-body-lider">
          <canvas id="chartEstado" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Top Calles -->
  <div class="row g-4 mb-5">
    <div class="col-md-12">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-lider">
        <div class="px-4 py-3 chart-card-header-lider">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-bar-chart me-2"></i> Top Calles con más Reportes</h5>
        </div>
        <div class="card-body p-4 chart-card-body-lider">
          <canvas id="chartCalles" style="max-height: 300px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Reportes recientes -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden mb-5 table-card-lider">
    <div class="px-4 py-3 table-card-header-lider">
      <h5 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2"></i> Reportes Recientes en tus Calles</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 tabla-lider">
          <thead>
            <tr class="text-center">
              <th><i class="bi bi-card-heading"></i> Título</th>
              <th><i class="bi bi-tag"></i> Categoría</th>
              <th><i class="bi bi-geo-alt"></i> Calle</th>
              <th><i class="bi bi-person"></i> Reportado por</th>
              <th><i class="bi bi-calendar3"></i> Fecha</th>
              <th><i class="bi bi-info-circle"></i> Estado</th>
              <th><i class="bi bi-gear"></i> Acción</th>
            </tr>
          </thead>
          <tbody>
            <% if (reportesRecientes && reportesRecientes.length > 0) { %>
              <% reportesRecientes.forEach(r => { %>
                <tr class="text-center">
                  <td class="text-start"><strong><%= r.titulo %></strong></td>
                  <td><span class="badge px-2 py-1 rounded-pill categoria-badge-lider"><%= r.categoria %></span></td>
                  <td><%= r.calle %></td>
                  <td><%= r.reportado_por || 'Anónimo' %></td>
                  <td><%= new Date(r.fecha).toLocaleDateString() %></td>
                  <td>
                    <span class="badge rounded-pill px-2 py-1 estado-badge-lider 
                      <%= r.estado === 'Pendiente' ? 'bg-warning text-dark' : 
                          r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>">
                      <%= r.estado === 'Pendiente' ? '⏳ Pendiente' : 
                          r.estado === 'En Progreso' ? '🔄 Progreso' : '✅ Resuelto' %>
                    </span>
                  </td>
                  <td>
                    <a href="/reportes" class="btn btn-sm px-3 py-1 rounded-3 btn-ver-lider">
                      <i class="bi bi-eye me-1"></i> Ver
                    </a>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center py-5 empty-state-lider">
                  <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay reportes recientes en tus calles</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Acciones rápidas -->
  <div class="row g-4">
    <div class="col-12">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden acciones-card-lider">
        <div class="px-4 py-3 acciones-card-header-lider">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-lightning-charge me-2"></i> Acciones Rápidas</h5>
        </div>
        <div class="card-body p-3 acciones-card-body-lider">
          <div class="d-flex flex-wrap gap-2">
            <a href="/reportes" class="btn btn-sm px-3 py-2 fw-semibold rounded-3 btn-lider-primary">
              <i class="bi bi-list-ul me-1"></i> Ver todos los reportes
            </a>
            <a href="/voluntarios/gestionar" class="btn btn-sm btn-outline-secondary px-3 py-2 fw-semibold rounded-3 btn-lider-outline">
              <i class="bi bi-person-check me-1"></i> Gestionar voluntarios
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Datos desde el servidor
  const categoriasLabels = JSON.parse('<%- JSON.stringify(categoriasLabels) %>');
  const categoriasDatos = JSON.parse('<%- JSON.stringify(categoriasDatos) %>');
  const estadosLabels = JSON.parse('<%- JSON.stringify(estadosLabels) %>');
  const estadosDatos = JSON.parse('<%- JSON.stringify(estadosDatos) %>');
  const callesLabels = JSON.parse('<%- JSON.stringify(callesLabels) %>');
  const callesDatos = JSON.parse('<%- JSON.stringify(callesDatos) %>');

  // Gráfico de Categorías
  if (categoriasLabels.length > 0) {
    new Chart(document.getElementById('chartCategoria'), {
      type: 'pie',
      data: {
        labels: categoriasLabels,
        datasets: [{
          data: categoriasDatos,
          backgroundColor: [
            '#0d6efd',   // Agua - AZUL
            '#ffc107',   // Electricidad - AMARILLO
            '#dc3545',   // Salud - ROJO
            '#3bba89',   // Vialidad - VERDE
            '#6c757d',   // Otros - GRIS
            '#17a2b8',   // Extra - CELESTE
            '#fd7e14'    // Extra - NARANJA
          ],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
      }
    });
  }

  // Gráfico de Estados
  if (estadosLabels.length > 0) {
    new Chart(document.getElementById('chartEstado'), {
      type: 'doughnut',
      data: {
        labels: estadosLabels,
        datasets: [{
          data: estadosDatos,
          backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
      }
    });
  }

  // Gráfico de Calles
  if (callesLabels.length > 0) {
    new Chart(document.getElementById('chartCalles'), {
      type: 'bar',
      data: {
        labels: callesLabels,
        datasets: [{
          label: 'Reportes',
          data: callesDatos,
          backgroundColor: [
            '#fd6704bd',  // Naranja
            '#0d6efd',    // Azul
            '#28a745',    // Verde
            '#ffc107',    // Amarillo
            '#17a2b8'     // Celeste
          ],
          borderRadius: 8,
          barPercentage: 0.7
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          y: {
            beginAtZero: true,
            stepSize: 1,
            grid: { color: '#f0d5c0', lineWidth: 1 }
          },
          x: {
            ticks: { font: { size: 11, weight: 'bold' } },
            grid: { display: false }
          }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#fd6704bd',
            titleColor: 'white',
            bodyColor: 'white'
          }
        }
      }
    });
  }
</script>

<style>

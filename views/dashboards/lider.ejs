  }
  .stat-number-lider-resuelto {
    color: #155724;
  }
  .stat-label-lider {
    color: #8B6B5A;
  }
  .stat-label-lider-pendiente {
    color: #856404;
  }
  .stat-label-lider-progreso {
    color: #0c5460;
  }
  .stat-label-lider-resuelto {
    color: #155724;
  }
  
  /* Gráficos */
  .chart-card-header-lider {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
  }
  .chart-card-body-lider {
    background: white;
  }
  
  /* Tablas */
  .table-card-header-lider {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
  }
  .tabla-lider {
    background: white;
  }
  .tabla-lider thead th {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
    border-bottom: 2px solid #fd6704bd;
  }
  .tabla-lider tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  .categoria-badge-lider {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  .btn-ver-lider {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }

                <% if (ultimosUsuarios && ultimosUsuarios.length > 0) { %>
                  <% ultimosUsuarios.forEach(u => { %>
                    <tr class="text-center">
                      <td class="text-start"><strong><%= u.nombre %></strong></td>
                      <td><small><%= u.email %></small></td>
                      <td><span class="badge rounded-pill px-2 py-1 rol-badge-sa"><%= u.rol %></span></td>
                      <td><small><%= new Date(u.fecha_registro).toLocaleDateString() %></small></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-3 text-muted">No hay usuarios registrados</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent text-center table-footer-sa">
          <a href="/usuarios" class="btn btn-sm btn-outline-primary rounded-3">Ver todos los usuarios</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 5: AUDITORÍA Y ACCIONES RÁPIDAS ========== -->

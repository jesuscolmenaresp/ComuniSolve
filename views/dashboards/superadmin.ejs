<%
// Preparar datos para Chart.js
let estadosLabels = [];
let estadosDatos = [];
let habilidadesLabels = [];
let habilidadesDatos = [];

if (reportesPorEstado && reportesPorEstado.length > 0) {
  estadosLabels = reportesPorEstado.map(item => item.estado);
  estadosDatos = reportesPorEstado.map(item => item.total);
}

if (voluntariosPorHabilidad && voluntariosPorHabilidad.length > 0) {
  habilidadesLabels = voluntariosPorHabilidad.map(item => item.habilidad);
  habilidadesDatos = voluntariosPorHabilidad.map(item => item.total);
}
%>

<div class="container-fluid py-4 px-4">
  
  <!-- ========== ENCABEZADO ========== -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h1 class="display-5 fw-bold mb-1 superadmin-title" style="background: linear-gradient(135deg, #5D4037 0%, #8B6B5A 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            <i class="bi bi-shield-lock-fill me-2" style="background: none; -webkit-text-fill-color: #ffc107;"></i> 
            Panel SuperAdministrador
          </h1>
          <p class="text-muted superadmin-subtitle mt-2">
            <i class="bi bi-graph-up me-1"></i> Gestión global del sistema | Estadísticas en tiempo real | Control total
          </p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <button onclick="window.location.reload()" class="btn btn-actualizar-sa px-4 py-2 rounded-3">
            <i class="bi bi-arrow-repeat me-2"></i> Actualizar
          </button>
          <a href="/auditoria" class="btn btn-auditoria-sa px-4 py-2 rounded-3">
            <i class="bi bi-clock-history me-2"></i> Auditoría Completa
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== ACCIONES RÁPIDAS ========== -->
  <div class="row g-3 mb-5">
    <div class="col-12">
      <div class="card border-0 rounded-4 shadow-sm acciones-rapidas-card">
        <div class="card-body p-3">
          <div class="row g-2 align-items-center">
            <div class="col-md-2">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-lightning-charge-fill fs-3" style="color: #ffc107;"></i>
                <h5 class="mb-0 fw-bold">Acciones Rápidas</h5>
              </div>
            </div>
            <div class="col-md-10">
              <div class="d-flex flex-wrap gap-2 justify-content-md-end">
                <a href="/usuarios" class="btn btn-rapido"><i class="bi bi-people-fill me-1"></i> Usuarios</a>
                <a href="/reportes" class="btn btn-rapido"><i class="bi bi-file-text-fill me-1"></i> Reportes</a>
                <a href="/voluntarios/gestionar" class="btn btn-rapido"><i class="bi bi-person-badge-fill me-1"></i> Voluntarios</a>
                <a href="/calles" class="btn btn-rapido"><i class="bi bi-geo-alt-fill me-1"></i> Calles</a>
                <a href="/comunidades" class="btn btn-rapido"><i class="bi bi-building me-1"></i> Comunidades</a>
                <a href="/categorias" class="btn btn-rapido"><i class="bi bi-tags-fill me-1"></i> Categorías</a>
                <a href="/empresas" class="btn btn-rapido"><i class="bi bi-building me-1"></i> Empresas</a>
                <button class="btn btn-backup-rapido" data-bs-toggle="modal" data-bs-target="#modalBackup">
                  <i class="bi bi-database me-1"></i> Backup
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 1: TARJETAS PRINCIPALES (4 grandes) ========== -->
  <div class="row g-4 mb-4">
    <div class="col-lg-3 col-md-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa stat-card-sa-usuarios h-100">
        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <span class="stat-label-sa">Usuarios Totales</span>
              <h2 class="fw-bold mb-0 stat-number-sa mt-2"><%= totales.usuarios || 0 %></h2>
            </div>
            <div class="stat-icon-sa"><i class="bi bi-people-fill fs-4 text-white"></i></div>
          </div>
          <div class="stat-footer-sa"><small><i class="bi bi-arrow-up-short"></i> +12% este mes</small></div>
        </div>
      </div>
    </div>
    <div class="col-lg-3 col-md-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa stat-card-sa-reportes h-100">
        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <span class="stat-label-sa">Reportes Totales</span>
              <h2 class="fw-bold mb-0 stat-number-sa mt-2"><%= totales.reportes || 0 %></h2>
            </div>
            <div class="stat-icon-sa"><i class="bi bi-file-text-fill fs-4 text-white"></i></div>
          </div>
          <div class="stat-footer-sa"><small><i class="bi bi-calendar-check"></i> <%= totales.reportesHoy || 0 %> hoy</small></div>
        </div>
      </div>
    </div>
    <div class="col-lg-3 col-md-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa stat-card-sa-voluntarios h-100">
        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <span class="stat-label-sa">Voluntarios</span>
              <h2 class="fw-bold mb-0 stat-number-sa mt-2"><%= totales.voluntarios || 0 %></h2>
            </div>
            <div class="stat-icon-sa"><i class="bi bi-person-badge-fill fs-4 text-white"></i></div>
          </div>
          <div class="d-flex justify-content-between mt-2">
            <small class="text-success"><i class="bi bi-check-circle"></i> Aprob: <%= totales.voluntariosAprobados || 0 %></small>
            <small class="text-warning"><i class="bi bi-clock"></i> Pend: <%= totales.voluntariosPendientes || 0 %></small>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-3 col-md-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa stat-card-sa-actividad h-100">
        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <span class="stat-label-sa">Actividad Hoy</span>
              <h2 class="fw-bold mb-0 stat-number-sa mt-2"><%= totales.usuariosActivosHoy || 0 %></h2>
            </div>
            <div class="stat-icon-sa"><i class="bi bi-activity fs-4 text-white"></i></div>
          </div>
          <div class="stat-footer-sa"><small><i class="bi bi-people"></i> usuarios activos</small></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 2: TARJETAS SECUNDARIAS ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa-sm">
        <div class="card-body p-3 text-center">
          <i class="bi bi-geo-alt-fill fs-2" style="color: #17a2b8;"></i>
          <h3 class="fw-bold mb-0 mt-2"><%= totales.calles || 0 %></h3>
          <small class="text-muted">Calles</small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa-sm">
        <div class="card-body p-3 text-center">
          <i class="bi bi-building fs-2" style="color: #28a745;"></i>
          <h3 class="fw-bold mb-0 mt-2"><%= totales.comunidades || 0 %></h3>
          <small class="text-muted">Comunidades</small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa-sm">
        <div class="card-body p-3 text-center">
          <i class="bi bi-building fs-2" style="color: #fd7e14;"></i>
          <h3 class="fw-bold mb-0 mt-2"><%= totales.empresas || 0 %></h3>
          <small class="text-muted">Empresas</small>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm stat-card-sa-sm">
        <div class="card-body p-3 text-center">
          <i class="bi bi-tags-fill fs-2" style="color: #6f42c1;"></i>
          <h3 class="fw-bold mb-0 mt-2"><%= totales.categorias || 0 %></h3>
          <small class="text-muted">Categorías</small>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 3: REPORTES POR ESTADO + MONITOREO ========== -->
  <div class="row g-4 mb-5">
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm chart-card-sa h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-pie-chart-fill me-2" style="color: #ffc107;"></i> Reportes por Estado</h5>
        </div>
        <div class="card-body p-4 pt-0">
          <canvas id="chartEstado" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm monitoreo-card-sa h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-bar-chart-steps me-2" style="color: #28a745;"></i> Monitoreo del Sistema</h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3">
            <div class="col-6">
              <div class="monitoreo-item-sa p-3 rounded-3 text-center">
                <i class="bi bi-database fs-2" style="color: #17a2b8;"></i>
                <h6 class="mt-2 mb-0 fw-bold">Base de Datos</h6>
                <small class="text-muted">MySQL Local</small>
                <div><span class="badge bg-success mt-2">✅ Conectada</span></div>
              </div>
            </div>
            <div class="col-6">
              <div class="monitoreo-item-sa p-3 rounded-3 text-center">
                <i class="bi bi-people fs-2" style="color: #ffc107;"></i>
                <h6 class="mt-2 mb-0 fw-bold">Usuarios Hoy</h6>
                <h3 class="mb-0 fw-bold mt-1"><%= totales.usuariosActivosHoy || 0 %></h3>
                <small class="text-muted">activos</small>
              </div>
            </div>
            <div class="col-6">
              <div class="monitoreo-item-sa p-3 rounded-3 text-center">
                <i class="bi bi-file-text fs-2" style="color: #fd7e14;"></i>
                <h6 class="mt-2 mb-0 fw-bold">Reportes Hoy</h6>
                <h3 class="mb-0 fw-bold mt-1"><%= totales.reportesHoy || 0 %></h3>
                <small class="text-muted">nuevos</small>
              </div>
            </div>
            <div class="col-6">
              <div class="monitoreo-item-sa p-3 rounded-3 text-center">
                <i class="bi bi-hdd-stack fs-2" style="color: #6f42c1;"></i>
                <h6 class="mt-2 mb-0 fw-bold">Almacenamiento</h6>
                <small class="text-muted">Base de datos</small>
                <div><span class="badge bg-primary mt-2">~ 50 MB</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 4: TABLAS ========== -->
  <div class="row g-4 mb-5">
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm table-card-sa h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-person-badge me-2" style="color: #28a745;"></i> Voluntarios Pendientes</h5>
          <span class="badge bg-warning rounded-pill px-3 py-2"><i class="bi bi-clock me-1"></i> <%= totales.voluntariosPendientes || 0 %> pendientes</span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 tabla-sa">
              <thead>
                <tr><th><i class="bi bi-person"></i> Nombre</th><th><i class="bi bi-tools"></i> Habilidad</th><th><i class="bi bi-calendar3"></i> Fecha</th><th class="text-center"><i class="bi bi-gear"></i> Acción</th></tr>
              </thead>
              <tbody>
                <% if (ultimosVoluntarios && ultimosVoluntarios.filter(v => v.estado === 'pendiente').length > 0) { %>
                  <% ultimosVoluntarios.filter(v => v.estado === 'pendiente').slice(0, 5).forEach(v => { %>
                    <tr>
                      <td><strong><%= v.nombre %></strong></td>
                      <td><%= v.habilidad || '—' %></td>
                      <td><small><%= new Date(v.fecha_solicitud).toLocaleDateString() %></small></td>
                      <td class="text-center"><a href="/voluntarios/gestionar" class="btn btn-sm btn-success px-3"><i class="bi bi-check-lg me-1"></i> Revisar</a></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4" class="text-center py-4"><i class="bi bi-check-circle-fill fs-3 text-success"></i><p class="mt-2 text-muted mb-0">No hay voluntarios pendientes</p></td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent border-0 text-center pt-3 pb-4">
          <a href="/voluntarios/gestionar" class="btn btn-outline-primary rounded-3 px-4">Ver todos los voluntarios <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm chart-card-sa h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-bar-chart-steps me-2" style="color: #fd7e14;"></i> Voluntarios por Habilidad</h5>
        </div>
        <div class="card-body p-4 pt-0">
          <canvas id="chartHabilidades" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 5: AUDITORÍA + ÚLTIMOS USUARIOS ========== -->
  <div class="row g-4 mb-5">
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm table-card-sa h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-shield-check me-2" style="color: #fd7e14;"></i> Últimas Acciones de Auditoría</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 tabla-sa">
              <thead>
                <tr><th><i class="bi bi-person"></i> Usuario</th><th><i class="bi bi-lightning-charge"></i> Acción</th><th><i class="bi bi-table"></i> Tabla</th><th><i class="bi bi-calendar3"></i> Fecha</th></tr>
              </thead>
              <tbody>
                <% if (ultimasAuditorias && ultimasAuditorias.length > 0) { %>
                  <% ultimasAuditorias.slice(0, 5).forEach(a => { %>
                    <tr>
                      <td><%= a.usuario_nombre || 'Sistema' %></td>
                      <td><span class="badge rounded-pill px-2 py-1 <%= a.accion === 'CREAR' ? 'bg-success' : a.accion === 'EDITAR' ? 'bg-warning' : a.accion === 'ELIMINAR' ? 'bg-danger' : 'bg-info' %>"><%= a.accion %></span></td>
                      <td><%= a.tabla %></td>
                      <td><small><%= new Date(a.fecha).toLocaleString() %></small></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4" class="text-center py-4"><i class="bi bi-info-circle fs-3 text-muted"></i><p class="mt-2 text-muted mb-0">No hay registros de auditoría</p></td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent border-0 text-center pt-3 pb-4">
          <a href="/auditoria" class="btn btn-outline-primary rounded-3 px-4">Ver auditoría completa <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm table-card-sa h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-person-plus me-2" style="color: #17a2b8;"></i> Últimos Usuarios Registrados</h5>
          <span class="badge bg-info rounded-pill px-3 py-2"><i class="bi bi-people me-1"></i> últimos 5</span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 tabla-sa">
              <thead>
                <tr><th><i class="bi bi-person"></i> Nombre</th><th><i class="bi bi-envelope"></i> Email</th><th><i class="bi bi-tag"></i> Rol</th><th><i class="bi bi-calendar3"></i> Registro</th></tr>
              </thead>
              <tbody>
                <% if (ultimosUsuarios && ultimosUsuarios.length > 0) { %>
                  <% ultimosUsuarios.slice(0, 5).forEach(u => { %>
                    <tr>
                      <td><strong><%= u.nombre %></strong></td>
                      <td><small><%= u.email %></small></td>
                      <td><span class="badge rounded-pill rol-badge-sa"><%= u.rol %></span></td>
                      <td><small><%= new Date(u.fecha_registro).toLocaleDateString() %></small></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4" class="text-center py-4"><i class="bi bi-person-x fs-3 text-muted"></i><p class="mt-2 text-muted mb-0">No hay usuarios registrados</p></td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent border-0 text-center pt-3 pb-4">
          <a href="/usuarios" class="btn btn-outline-primary rounded-3 px-4">Ver todos los usuarios <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== CONFIGURACIÓN DISCRETA (AL FINAL) ========== -->
  <div class="row g-4 mt-2">
    <div class="col-12">
      <div class="card border-0 rounded-4 shadow-sm config-boton-card">
        <div class="card-header bg-transparent border-0 py-2 px-4 d-flex justify-content-between align-items-center">
          <h6 class="mb-0 fw-semibold">
            <i class="bi bi-toggle2-on me-2" style="color: #fd7e14;"></i> 
            Configuración del Modo Nocturno
          </h6>
          <div class="d-flex align-items-center gap-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="toggleMostrarBoton" 
                     <%= mostrarBoton ? 'checked' : '' %> 
                     style="width: 45px; height: 22px; cursor: pointer;">
              <label class="form-check-label small fw-semibold ms-1" for="toggleMostrarBoton">
                <%= mostrarBoton ? '🟢 Activado' : '🔴 Desactivado' %>
              </label>
            </div>
            <span id="estadoBoton" class="badge <%= mostrarBoton ? 'bg-success' : 'bg-secondary' %> px-2 py-1">
              <%= mostrarBoton ? '✅ Visible para todos' : '❌ Solo SuperAdmin' %>
            </span>
          </div>
        </div>
        <div class="card-body py-2 px-4">
          <p class="small text-muted mb-0">
            <i class="bi bi-info-circle me-1"></i>
            <%= mostrarBoton ? 'Los usuarios verán el botón 🌙 en el menú para cambiar el modo' : 'El botón solo estará visible para el SuperAdmin en este panel' %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== BADGE INFORMATIVO ========== -->
  <div class="text-center mt-4">
    <small class="text-muted badge-info-sa">
      <i class="bi bi-shield-lock-fill me-1" style="color: #ffc107;"></i> 
      Panel exclusivo para SuperAdministradores - Acceso total al sistema
    </small>
  </div>
</div>

<!-- ========== MODAL PARA RESPALDOS ========== -->
<div class="modal fade" id="modalBackup" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-backup-sa">
      <div class="modal-header modal-backup-header-sa border-0">
        <h5 class="modal-title text-white"><i class="bi bi-database me-2"></i> Respaldo de Base de Datos</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4 modal-backup-body-sa">
        <p class="mb-4">Seleccione el tipo de respaldo que desea generar:</p>
        <div class="d-grid gap-3">
          <a href="/superadmin/backup/completo" class="btn btn-primary rounded-3 py-2"><i class="bi bi-database-fill me-2"></i> Respaldo completo (SQL)</a>
          <a href="/superadmin/backup/estructura" class="btn btn-outline-secondary rounded-3 py-2"><i class="bi bi-diagram-3 me-2"></i> Solo estructura</a>
          <a href="/superadmin/backup/datos" class="btn btn-outline-secondary rounded-3 py-2"><i class="bi bi-table me-2"></i> Solo datos</a>
        </div>
        <hr class="my-4">
        <div class="alert alert-info small mb-0"><i class="bi bi-info-circle me-2"></i> Los respaldos se generan en formato SQL y se descargan automáticamente.</div>
      </div>
      <div class="modal-footer modal-backup-footer-sa border-0">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- ========== SCRIPTS (gráficos) ========== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Gráfico de Estados
  const estadosLabels = JSON.parse('<%- JSON.stringify(estadosLabels) %>');
  const estadosDatos = JSON.parse('<%- JSON.stringify(estadosDatos) %>');

  if (estadosLabels.length > 0) {
    new Chart(document.getElementById('chartEstado'), {
      type: 'doughnut',
      data: {
        labels: estadosLabels,
        datasets: [{ data: estadosDatos, backgroundColor: ['#ffc107', '#17a2b8', '#28a745'], borderWidth: 0, hoverOffset: 10 }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '60%',
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 15 } },
          tooltip: {
            callbacks: {
              label: function(context) {
                const label = context.label || '';
                const value = context.raw || 0;
                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                const percentage = ((value / total) * 100).toFixed(1);
                return `${label}: ${value} (${percentage}%)`;
              }
            }
          }
        }
      }
    });
  }

  // Gráfico de Habilidades
  const habilidadesLabels = JSON.parse('<%- JSON.stringify(habilidadesLabels) %>');
  const habilidadesDatos = JSON.parse('<%- JSON.stringify(habilidadesDatos) %>');

  if (habilidadesLabels.length > 0) {
    new Chart(document.getElementById('chartHabilidades'), {
      type: 'bar',
      data: {
        labels: habilidadesLabels,
        datasets: [{
          label: 'Cantidad de voluntarios',
          data: habilidadesDatos,
          backgroundColor: 'rgba(253, 103, 4, 0.7)',
          borderRadius: 8,
          barPercentage: 0.7,
          hoverBackgroundColor: 'rgba(253, 103, 4, 0.9)'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          y: { beginAtZero: true, stepSize: 1, grid: { color: '#e0e0e0' }, title: { display: true, text: 'Cantidad', font: { size: 12 } } },
          x: { ticks: { font: { size: 11 } }, grid: { display: false }, title: { display: true, text: 'Habilidades', font: { size: 12 } } }
        },
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(context) { return `Voluntarios: ${context.raw}`; } } } }
      }
    });
  }
</script>

<script>
  // ========== TOGGLE PARA MOSTRAR BOTÓN A TODOS LOS USUARIOS ==========
  document.addEventListener('DOMContentLoaded', function() {
    const toggle = document.getElementById('toggleMostrarBoton');
    if (toggle) {
      toggle.addEventListener('change', async function() {
        const mostrarBoton = this.checked;
        const estadoSpan = document.getElementById('estadoBoton');
        const label = document.querySelector('label[for="toggleMostrarBoton"]');
        const descripcion = document.querySelector('.config-boton-card .card-body p');
        
        // Actualizar estado visual inmediatamente
        if (mostrarBoton) {
          estadoSpan.className = 'badge bg-success px-2 py-1';
          estadoSpan.textContent = '✅ Visible para todos';
          label.textContent = '🟢 Activado';
          descripcion.innerHTML = '<i class="bi bi-info-circle me-1"></i> Los usuarios verán el botón 🌙 en el menú para cambiar el modo';
        } else {
          estadoSpan.className = 'badge bg-secondary px-2 py-1';
          estadoSpan.textContent = '❌ Solo SuperAdmin';
          label.textContent = '🔴 Desactivado';
          descripcion.innerHTML = '<i class="bi bi-info-circle me-1"></i> El botón solo estará visible para el SuperAdmin en este panel';
        }
        
        try {
          const response = await fetch('/config/mostrar-boton', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ mostrarBoton })
          });
          
          const data = await response.json();
          
          if (data.success) {
            setTimeout(() => window.location.reload(), 800);
          } else {
            alert('Error: ' + (data.error || 'Error desconocido'));
            this.checked = !mostrarBoton;
          }
        } catch (error) {
          console.error('Error:', error);
          alert('Error al cambiar la configuración');
          this.checked = !mostrarBoton;
        }
      });
    }
  });
</script>


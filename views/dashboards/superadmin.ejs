<%
// Preparar datos para Chart.js
let estadosLabels = [];
let estadosDatos = [];
let habilidadesLabels = [];
let habilidadesDatos = [];

if (reportesPorEstado && reportesPorEstado.length > 0) {
  estadosLabels = reportesPorEstado.map(item => item.estado);
  estadosDatos = reportesPorEstado.map(item => item.total);
}

if (voluntariosPorHabilidad && voluntariosPorHabilidad.length > 0) {
  habilidadesLabels = voluntariosPorHabilidad.map(item => item.habilidad);
  habilidadesDatos = voluntariosPorHabilidad.map(item => item.total);
}
%>

<div class="container py-4">
  
  <!-- ========== ENCABEZADO ========== -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1" style="color: #5D4037;">
        <i class="bi bi-shield-lock-fill me-2" style="color: #ffc107;"></i> Panel SuperAdministrador
      </h2>
      <p class="text-muted small mb-0" style="color: #8B6B5A;">Gestión global del sistema - Estadísticas completas - Control total</p>
    </div>
    <div class="d-flex gap-2">
      <button onclick="window.location.reload()" class="btn btn-sm px-3 py-2 rounded-3"
              style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;">
        <i class="bi bi-arrow-repeat me-1"></i> Actualizar
      </button>
      <button id="btnModoOscuro" class="btn btn-sm px-3 py-2 rounded-3"
              style="background: #6c757d; color: white; border: none;">
        <i class="bi bi-moon-stars-fill me-1"></i> Modo Oscuro
      </button>
      <a href="/auditoria" class="btn btn-sm px-3 py-2 rounded-3"
         style="background: #17a2b8; color: white; border: none;">
        <i class="bi bi-clock-history me-1"></i> Auditoría completa
      </a>
    </div>
  </div>

  <!-- ========== FILA 1: TARJETAS PRINCIPALES ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-usuarios">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-people-fill fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0"><%= totales.usuarios || 0 %></h2>
          <p class="small mb-0">Usuarios totales</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-reportes">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: #ffc107; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-file-text-fill fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0"><%= totales.reportes || 0 %></h2>
          <p class="small mb-0">Reportes totales</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-calles">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: #17a2b8; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-geo-alt-fill fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0"><%= totales.calles || 0 %></h2>
          <p class="small mb-0">Calles registradas</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-voluntarios">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: #28a745; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-person-badge-fill fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0"><%= totales.voluntarios || 0 %></h2>
          <p class="small mb-0">Voluntarios totales</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 2: TARJETAS SECUNDARIAS + ACTIVIDAD ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-comunidades">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-building fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0"><%= totales.comunidades || 0 %></h2>
          <p class="small mb-0">Comunidades</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-empresas">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: #6c757d; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-building fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0"><%= totales.empresas || 0 %></h2>
          <p class="small mb-0">Empresas</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-categorias">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: #6c757d; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-tags-fill fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0"><%= totales.categorias || 0 %></h2>
          <p class="small mb-0">Categorías</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="card-body p-3 text-center tarjeta-actividad">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div style="width: 50px; height: 50px; background: #0d6efd; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
              <i class="bi bi-activity fs-3 text-white"></i>
            </div>
          </div>
          <h5 class="fw-bold mb-0"><%= totales.reportesHoy || 0 %></h5>
          <p class="small mb-0">Reportes hoy</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 3: GRÁFICOS ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100">
        <div class="px-4 py-3 card-header-custom">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-pie-chart me-2"></i> Reportes por Estado</h5>
        </div>
        <div class="card-body p-4">
          <canvas id="chartEstado" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100">
        <div class="px-4 py-3 card-header-custom">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-bar-chart me-2"></i> Voluntarios por Habilidad</h5>
        </div>
        <div class="card-body p-4">
          <canvas id="chartHabilidades" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 4: VOLUNTARIOS ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="px-4 py-3 card-header-custom">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-person-badge me-2"></i> Voluntarios Pendientes de Aprobación</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr class="text-center">
                  <th><i class="bi bi-person"></i> Nombre</th>
                  <th><i class="bi bi-tools"></i> Habilidad</th>
                  <th><i class="bi bi-calendar3"></i> Fecha</th>
                  <th><i class="bi bi-gear"></i> Acción</th>
                </tr>
              </thead>
              <tbody>
                <% if (ultimosVoluntarios && ultimosVoluntarios.length > 0) { %>
                  <% ultimosVoluntarios.forEach(v => { %>
                    <tr class="text-center">
                      <td class="text-start"><strong><%= v.nombre %></strong></td>
                      <td><%= v.habilidad || '—' %></td>
                      <td><small><%= new Date(v.fecha_solicitud).toLocaleDateString() %></small></td>
                      <td>
                        <% if (v.estado === 'pendiente') { %>
                          <a href="/voluntarios/gestionar" class="btn btn-sm btn-success px-2 py-1 rounded-3">
                            <i class="bi bi-check-lg"></i> Revisar
                          </a>
                        <% } else { %>
                          <span class="badge bg-success rounded-pill px-2 py-1"><%= v.estado %></span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-3 text-muted">No hay voluntarios registrados</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent text-center">
          <a href="/voluntarios/gestionar" class="btn btn-sm btn-outline-primary rounded-3">Ver todos los voluntarios</a>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="px-4 py-3 card-header-custom">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2"></i> Últimos Usuarios Registrados</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr class="text-center">
                  <th><i class="bi bi-person"></i> Nombre</th>
                  <th><i class="bi bi-envelope"></i> Email</th>
                  <th><i class="bi bi-tag"></i> Rol</th>
                  <th><i class="bi bi-calendar3"></i> Registro</th>
                </tr>
              </thead>
              <tbody>
                <% if (ultimosUsuarios && ultimosUsuarios.length > 0) { %>
                  <% ultimosUsuarios.forEach(u => { %>
                    <tr class="text-center">
                      <td class="text-start"><strong><%= u.nombre %></strong></td>
                      <td><small><%= u.email %></small></td>
                      <td><span class="badge rounded-pill px-2 py-1" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;"><%= u.rol %></span></td>
                      <td><small><%= new Date(u.fecha_registro).toLocaleDateString() %></small></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-3 text-muted">No hay usuarios registrados</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent text-center">
          <a href="/usuarios" class="btn btn-sm btn-outline-primary rounded-3">Ver todos los usuarios</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== FILA 5: AUDITORÍA Y ACCIONES RÁPIDAS ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-7">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="px-4 py-3 card-header-custom">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-shield-check me-2"></i> Últimas Acciones de Auditoría</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr class="text-center">
                  <th><i class="bi bi-person"></i> Usuario</th>
                  <th><i class="bi bi-lightning-charge"></i> Acción</th>
                  <th><i class="bi bi-table"></i> Tabla</th>
                  <th><i class="bi bi-calendar3"></i> Fecha</th>
                </tr>
              </thead>
              <tbody>
                <% if (ultimasAuditorias && ultimasAuditorias.length > 0) { %>
                  <% ultimasAuditorias.forEach(a => { %>
                    <tr class="text-center">
                      <td><%= a.usuario_nombre || 'Sistema' %></td>
                      <td>
                        <span class="badge rounded-pill px-2 py-1 
                          <%= a.accion === 'CREAR' ? 'bg-success' : 
                              a.accion === 'EDITAR' ? 'bg-warning' : 
                              a.accion === 'ELIMINAR' ? 'bg-danger' : 'bg-info' %>" 
                          style="<%= a.accion === 'EDITAR' ? 'color: #333;' : 'color: white;' %>">
                          <%= a.accion %>
                        </span>
                      </td>
                      <td><%= a.tabla %></td>
                      <td><small><%= new Date(a.fecha).toLocaleString() %></small></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-3 text-muted">No hay registros de auditoría</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-transparent text-center">
          <a href="/auditoria" class="btn btn-sm btn-outline-primary rounded-3">Ver auditoría completa</a>
        </div>
      </div>
    </div>
    <div class="col-md-5">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="px-4 py-3 card-header-custom">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-lightning-charge me-2"></i> Acciones Rápidas</h5>
        </div>
        <div class="card-body p-4">
          <div class="d-grid gap-2">
            <a href="/usuarios" class="btn btn-outline-primary rounded-3 py-2">
              <i class="bi bi-people-fill me-2"></i> Gestionar usuarios
            </a>
            <a href="/reportes" class="btn btn-outline-primary rounded-3 py-2">
              <i class="bi bi-file-text-fill me-2"></i> Ver todos los reportes
            </a>
            <a href="/auditoria" class="btn btn-outline-primary rounded-3 py-2">
              <i class="bi bi-clock-history me-2"></i> Auditoría completa
            </a>
            <a href="/voluntarios/gestionar" class="btn btn-outline-primary rounded-3 py-2">
              <i class="bi bi-person-badge me-2"></i> Gestionar voluntarios
            </a>
            <a href="/calles" class="btn btn-outline-primary rounded-3 py-2">
              <i class="bi bi-geo-alt-fill me-2"></i> Gestionar calles
            </a>
            <a href="/comunidades" class="btn btn-outline-primary rounded-3 py-2">
              <i class="bi bi-building me-2"></i> Gestionar comunidades
            </a>
            <hr>
            <button class="btn btn-warning rounded-3 py-2" data-bs-toggle="modal" data-bs-target="#modalBackup">
              <i class="bi bi-database me-2"></i> Respaldo de base de datos
            </button>
            <a href="/dashboard/admin" class="btn btn-secondary rounded-3 py-2">
              <i class="bi bi-speedometer2 me-2"></i> Ir a panel UBCH
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== MONITOREO DEL SISTEMA ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-12">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
        <div class="px-4 py-3 card-header-custom">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-bar-chart-steps me-2"></i> Monitoreo del Sistema</h5>
        </div>
        <div class="card-body p-4">
          <div class="row text-center">
            <div class="col-md-3">
              <div class="p-3 rounded-3 bg-light">
                <i class="bi bi-database fs-2" style="color: #28a745;"></i>
                <h6 class="mt-2 mb-0">Base de Datos</h6>
                <small class="text-muted">MySQL Local</small>
                <div><span class="badge bg-success mt-2">✅ Conectada</span></div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="p-3 rounded-3 bg-light">
                <i class="bi bi-hdd-stack fs-2" style="color: #fd6704bd;"></i>
                <h6 class="mt-2 mb-0">Almacenamiento</h6>
                <small class="text-muted">Base de datos</small>
                <div><span class="badge bg-primary mt-2">~ 50 MB</span></div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="p-3 rounded-3 bg-light">
                <i class="bi bi-people fs-2" style="color: #17a2b8;"></i>
                <h6 class="mt-2 mb-0">Usuarios activos hoy</h6>
                <h3 class="mb-0 fw-bold" style="color: #17a2b8;"><%= totales.usuariosActivosHoy || 0 %></h3>
              </div>
            </div>
            <div class="col-md-3">
              <div class="p-3 rounded-3 bg-light">
                <i class="bi bi-file-text fs-2" style="color: #ffc107;"></i>
                <h6 class="mt-2 mb-0">Reportes hoy</h6>
                <h3 class="mb-0 fw-bold" style="color: #ffc107;"><%= totales.reportesHoy || 0 %></h3>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== BADGE INFORMATIVO ========== -->
  <div class="text-center mt-2">
    <small class="text-muted">
      <i class="bi bi-shield-lock-fill me-1" style="color: #ffc107;"></i> 
      Panel exclusivo para SuperAdministradores - Acceso total al sistema
    </small>
  </div>
</div>

<!-- ========== MODAL PARA RESPALDOS ========== -->
<div class="modal fade" id="modalBackup" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg">
      <div class="modal-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
        <h5 class="modal-title text-white">
          <i class="bi bi-database me-2"></i> Respaldo de Base de Datos
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <p class="mb-3">Seleccione el tipo de respaldo que desea generar:</p>
        <div class="d-grid gap-2">
          <a href="/superadmin/backup/completo" class="btn btn-primary rounded-3 py-2">
            <i class="bi bi-database me-2"></i> Respaldo completo (SQL)
          </a>
          <a href="/superadmin/backup/estructura" class="btn btn-outline-secondary rounded-3 py-2">
            <i class="bi bi-diagram-3 me-2"></i> Solo estructura
          </a>
          <a href="/superadmin/backup/datos" class="btn btn-outline-secondary rounded-3 py-2">
            <i class="bi bi-file-spreadsheet me-2"></i> Solo datos
          </a>
        </div>
        <hr>
        <p class="small text-muted mb-0 mt-3">
          <i class="bi bi-info-circle me-1"></i> Los respaldos se generan en formato SQL y se descargan automáticamente.
        </p>
      </div>
      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- ========== SCRIPTS ========== -->
<script>
  // Modo oscuro/claro mejorado
  let modoOscuro = localStorage.getItem('superadminDarkMode') === 'true';
  const btnModoOscuro = document.getElementById('btnModoOscuro');
  
  function aplicarModoOscuro(activar) {
    if (activar) {
      document.body.classList.add('dark-mode');
      btnModoOscuro.innerHTML = '<i class="bi bi-sun-fill me-1"></i> Modo Claro';
      localStorage.setItem('superadminDarkMode', 'true');
    } else {
      document.body.classList.remove('dark-mode');
      btnModoOscuro.innerHTML = '<i class="bi bi-moon-stars-fill me-1"></i> Modo Oscuro';
      localStorage.setItem('superadminDarkMode', 'false');
    }
    modoOscuro = activar;
  }
  
  // Aplicar modo guardado al cargar
  if (modoOscuro) {
    aplicarModoOscuro(true);
  }
  
  if (btnModoOscuro) {
    btnModoOscuro.addEventListener('click', function() {
      aplicarModoOscuro(!modoOscuro);
    });
  }
</script>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Gráfico de Estados
  const estadosLabels = JSON.parse('<%- JSON.stringify(estadosLabels) %>');
  const estadosDatos = JSON.parse('<%- JSON.stringify(estadosDatos) %>');

  if (estadosLabels.length > 0) {
    new Chart(document.getElementById('chartEstado'), {
      type: 'doughnut',
      data: {
        labels: estadosLabels,
        datasets: [{
          data: estadosDatos,
          backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
      }
    });
  }

  // Gráfico de Habilidades
  const habilidadesLabels = JSON.parse('<%- JSON.stringify(habilidadesLabels) %>');
  const habilidadesDatos = JSON.parse('<%- JSON.stringify(habilidadesDatos) %>');

  if (habilidadesLabels.length > 0) {
    new Chart(document.getElementById('chartHabilidades'), {
      type: 'bar',
      data: {
        labels: habilidadesLabels,
        datasets: [{
          label: 'Cantidad de voluntarios',
          data: habilidadesDatos,
          backgroundColor: '#fd6704bd',
          borderRadius: 8,
          barPercentage: 0.7
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          y: { beginAtZero: true, stepSize: 1, grid: { color: '#e0e0e0' } },
          x: { ticks: { font: { size: 11 } }, grid: { display: false } }

  <!-- ========== FILA 3: GRÁFICOS ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card-sa">
        <div class="px-4 py-3 chart-card-header-sa">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-pie-chart me-2"></i> Reportes por Estado</h5>
        </div>
        <div class="card-body p-4 chart-card-body-sa">
          <canvas id="chartEstado" style="max-height: 280px; width: 100%;"></canvas>

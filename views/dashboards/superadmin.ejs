<%
// Preparar datos para Chart.js
let estadosLabels = [];
let estadosDatos = [];
let habilidadesLabels = [];
let habilidadesDatos = [];

if (reportesPorEstado && reportesPorEstado.length > 0) {
  estadosLabels = reportesPorEstado.map(item => item.estado);
  estadosDatos = reportesPorEstado.map(item => item.total);
}

if (voluntariosPorHabilidad && voluntariosPorHabilidad.length > 0) {
  habilidadesLabels = voluntariosPorHabilidad.map(item => item.habilidad);
  habilidadesDatos = voluntariosPorHabilidad.map(item => item.total);
}
%>

<div class="container py-4">
  
  <!-- ========== ENCABEZADO ========== -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 superadmin-title">
        <i class="bi bi-shield-lock-fill me-2"></i> Panel SuperAdministrador
      </h2>
      <p class="text-muted small mb-0 superadmin-subtitle">Gestión global del sistema - Estadísticas completas - Control total</p>
    </div>
    <div class="d-flex gap-2">
      <button onclick="window.location.reload()" class="btn btn-sm px-3 py-2 rounded-3 btn-actualizar-sa">
        <i class="bi bi-arrow-repeat me-1"></i> Actualizar
      </button>
      <button id="btnDarkModeGlobal" class="btn btn-sm px-3 py-2 rounded-3 btn-darkmode-toggle">
        <i class="bi bi-moon-stars-fill me-1"></i> 
        <span id="darkModeText">Modo Nocturno</span>
      </button>
      <a href="/auditoria" class="btn btn-sm px-3 py-2 rounded-3 btn-auditoria-sa">
        <i class="bi bi-clock-history me-1"></i> Auditoría completa
      </a>
    </div>
  </div>

  <!-- ========== FILA 1: TARJETAS PRINCIPALES ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-sa">

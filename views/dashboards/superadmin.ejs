            </div>
          </div>
          <h2 class="fw-bold mb-0 fs-4 stat-number-sa"><%= totales.empresas || 0 %></h2>
          <p class="small mb-0 stat-label-sa">Empresas</p>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-sa">
        <div class="card-body p-3 text-center stat-card-sa-categorias">

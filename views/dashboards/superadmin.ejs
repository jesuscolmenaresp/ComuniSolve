  <!-- ========== BADGE INFORMATIVO ========== -->
  <div class="text-center mt-2">
    <small class="text-muted badge-info-sa">
      <i class="bi bi-shield-lock-fill me-1"></i> 
      Panel exclusivo para SuperAdministradores - Acceso total al sistema
    </small>

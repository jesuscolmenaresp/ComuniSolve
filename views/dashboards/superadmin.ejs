        </div>
        <div class="card-footer bg-transparent text-center table-footer-sa">
          <a href="/voluntarios/gestionar" class="btn btn-sm btn-outline-primary rounded-3">Ver todos los voluntarios</a>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden table-card-sa">
        <div class="px-4 py-3 table-card-header-sa">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2"></i> Últimos Usuarios Registrados</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 tabla-sa">
              <thead>
                <tr class="text-center">
                  <th><i class="bi bi-person"></i> Nombre</th>
                  <th><i class="bi bi-envelope"></i> Email</th>
                  <th><i class="bi bi-tag"></i> Rol</th>
                  <th><i class="bi bi-calendar3"></i> Registro</th>
                </tr>
              </thead>

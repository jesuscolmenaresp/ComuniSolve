        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 tabla-sa">
              <thead>
                <tr class="text-center">
                  <th><i class="bi bi-person"></i> Nombre</th>
                  <th><i class="bi bi-tools"></i> Habilidad</th>
                  <th><i class="bi bi-calendar3"></i> Fecha</th>
                  <th><i class="bi bi-gear"></i> Acción</th>
                </tr>
              </thead>
              <tbody>
                <% if (ultimosVoluntarios && ultimosVoluntarios.length > 0) { %>
                  <% ultimosVoluntarios.forEach(v => { %>
                    <tr class="text-center">
                      <td class="text-start"><strong><%= v.nombre %></strong></td>
                      <td><%= v.habilidad || '—' %></td>
                      <td><small><%= new Date(v.fecha_solicitud).toLocaleDateString() %></small></td>
                      <td>
                        <% if (v.estado === 'pendiente') { %>
                          <a href="/voluntarios/gestionar" class="btn btn-sm btn-success px-2 py-1 rounded-3 btn-revisar">
                            <i class="bi bi-check-lg"></i> Revisar
                          </a>
                        <% } else { %>
                          <span class="badge bg-success rounded-pill px-2 py-1"><%= v.estado %></span>
                        <% } %>

<!-- ========== MODAL PARA RESPALDOS ========== -->
<div class="modal fade" id="modalBackup" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-backup-sa">
      <div class="modal-header modal-backup-header-sa">
        <h5 class="modal-title text-white">
          <i class="bi bi-database me-2"></i> Respaldo de Base de Datos
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4 modal-backup-body-sa">
        <p class="mb-3">Seleccione el tipo de respaldo que desea generar:</p>
        <div class="d-grid gap-2">
          <a href="/superadmin/backup/completo" class="btn btn-primary rounded-3 py-2">📚 Respaldo completo (SQL)</a>
          <a href="/superadmin/backup/estructura" class="btn btn-outline-secondary rounded-3 py-2">🏗️ Solo estructura</a>
          <a href="/superadmin/backup/datos" class="btn btn-outline-secondary rounded-3 py-2">📊 Solo datos</a>
        </div>
        <hr>
        <p class="small text-muted mb-0 mt-3">
          <i class="bi bi-info-circle me-1"></i> Los respaldos se generan en formato SQL y se descargan automáticamente.
        </p>
      </div>
      <div class="modal-footer bg-light modal-backup-footer-sa">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- ========== SCRIPTS ========== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Gráfico de Estados
  const estadosLabels = JSON.parse('<%- JSON.stringify(estadosLabels) %>');
  const estadosDatos = JSON.parse('<%- JSON.stringify(estadosDatos) %>');

  if (estadosLabels.length > 0) {
    new Chart(document.getElementById('chartEstado'), {
      type: 'doughnut',
      data: {
        labels: estadosLabels,
        datasets: [{
          data: estadosDatos,
          backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
      }
    });
  }

  // Gráfico de Habilidades
  const habilidadesLabels = JSON.parse('<%- JSON.stringify(habilidadesLabels) %>');
  const habilidadesDatos = JSON.parse('<%- JSON.stringify(habilidadesDatos) %>');

  if (habilidadesLabels.length > 0) {
    new Chart(document.getElementById('chartHabilidades'), {
      type: 'bar',
      data: {
        labels: habilidadesLabels,
        datasets: [{
          label: 'Cantidad de voluntarios',
          data: habilidadesDatos,
          backgroundColor: '#fd6704bd',
          borderRadius: 8,
          barPercentage: 0.7
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        scales: {
          y: { beginAtZero: true, stepSize: 1, grid: { color: '#e0e0e0' } },
          x: { ticks: { font: { size: 11 } }, grid: { display: false } }
        },
        plugins: {
          legend: { display: false }
        }
      }
    });
  }
</script>

<script>
  // ========== MODO NOCTURNO GLOBAL (Controlado por SuperAdmin) ==========
  
  async function toggleDarkModeGlobal() {
    console.log('🖱️ Botón clickeado');
    const btn = document.getElementById('btnDarkModeGlobal');
    if (!btn) {
      console.error('❌ Botón no encontrado');
      return;
    }
    
    const span = document.getElementById('darkModeText');
    const icon = btn.querySelector('i');
    
    const isDark = icon.classList.contains('bi-sun-fill');
    const newMode = !isDark;
    
    console.log('Cambiando a modo:', newMode ? 'oscuro' : 'claro');
    
    try {
      const response = await fetch('/superadmin/config/dark-mode', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ darkMode: newMode })
      });
      
      const data = await response.json();
      console.log('Respuesta:', data);
      
      if (data.success) {
        window.location.reload();
      } else {
        alert('Error al cambiar el modo: ' + (data.error || 'Error desconocido'));
      }
    } catch (error) {
      console.error('Error en la petición:', error);
      alert('Error al cambiar el modo');
    }
  }

  async function cargarEstadoDarkMode() {
    try {
      const response = await fetch('/superadmin/config/dark-mode');
      const data = await response.json();
      
      const btn = document.getElementById('btnDarkModeGlobal');
      if (!btn) return;
      
      const span = document.getElementById('darkModeText');
      const icon = btn.querySelector('i');
      
      if (data.darkMode) {
        icon.className = 'bi bi-sun-fill me-1';
        span.textContent = 'Modo Claro';
        btn.style.background = '#fd6704bd';
      } else {
        icon.className = 'bi bi-moon-stars-fill me-1';
        span.textContent = 'Modo Nocturno';
        btn.style.background = '#6c757d';
      }
    } catch (error) {
      console.error('Error al cargar estado:', error);
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    const btn = document.getElementById('btnDarkModeGlobal');
    if (btn) {
      btn.removeEventListener('click', toggleDarkModeGlobal);
      btn.addEventListener('click', toggleDarkModeGlobal);
    }
    cargarEstadoDarkMode();
  });
</script>


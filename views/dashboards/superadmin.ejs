            </div>
          </div>
          <h2 class="fw-bold mb-0 fs-4 stat-number-sa"><%= totales.categorias || 0 %></h2>
          <p class="small mb-0 stat-label-sa">Categorías</p>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-sa">
        <div class="card-body p-3 text-center stat-card-sa-actividad">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="stat-icon-sa-sm">
              <i class="bi bi-activity fs-4 text-white"></i>
            </div>
          </div>
          <h5 class="fw-bold mb-0 fs-4 stat-number-sa"><%= totales.reportesHoy || 0 %></h5>
          <p class="small mb-0 stat-label-sa">Reportes hoy</p>
        </div>

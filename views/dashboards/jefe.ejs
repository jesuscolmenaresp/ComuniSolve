<%
// Preparar datos para Chart.js
let categoriasLabels = [];
let categoriasDatos = [];
let estadosLabels = [];
let estadosDatos = [];

if (porCategoria && porCategoria.length > 0) {
  categoriasLabels = porCategoria.map(item => item.nombre);
  categoriasDatos = porCategoria.map(item => item.total);
}

if (porEstado && porEstado.length > 0) {
  estadosLabels = porEstado.map(item => item.estado);
  estadosDatos = porEstado.map(item => item.total);
}
%>

<div class="container py-4">
  
  <!-- ========== ENCABEZADO MEJORADO ========== -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h2 class="fw-bold mb-1 jefe-title">
            <i class="bi bi-person-badge me-2" style="color: #fd6704;"></i> 
            Panel de Jefe de Calle
          </h2>
          <p class="text-muted small mb-0 jefe-subtitle">
            <i class="bi bi-house-heart me-1"></i> Gestiona y da seguimiento a los reportes de tu calle
          </p>
        </div>
        <div class="d-flex gap-2">
          <button onclick="window.location.reload()" class="btn btn-actualizar-jefe px-4 py-2 rounded-3">
            <i class="bi bi-arrow-repeat me-2"></i> Actualizar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== MENSAJES FLASH ========== -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- ========== INFO CALLE A CARGO ========== -->
  <% if (tieneCalle && miCalle) { %>
    <div class="alert info-calle-jefe info-calle-success border-0 rounded-3 py-3 mb-4">
      <div class="d-flex align-items-center gap-3 flex-wrap">
        <i class="bi bi-geo-alt-fill fs-3 info-calle-icon-success"></i>
        <div>
          <strong class="info-calle-title-success">📍 Calle a tu cargo:</strong>
          <span class="fw-semibold info-calle-nombre-success"><%= miCalle %></span>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="alert info-calle-jefe info-calle-warning border-0 rounded-3 py-3 mb-4">
      <div class="d-flex align-items-center gap-3 flex-wrap">
        <i class="bi bi-exclamation-triangle-fill fs-3 info-calle-icon-warning"></i>
        <div>
          <strong class="info-calle-title-warning">⚠️ No tienes una calle asignada.</strong>
          <br><small class="info-calle-text-warning">Contacta al administrador para asignarte una calle.</small>
        </div>
      </div>
    </div>
  <% } %>

  <!-- ========== TARJETAS DE RESUMEN (solo si tiene calle) ========== -->
  <% if (tieneCalle && miCalle) { %>
    <div class="row g-4 mb-5">
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm stat-card-jefe stat-card-total-jefe">
          <div class="card-body p-3 text-center">
            <div class="stat-icon-wrapper-jefe">
              <i class="bi bi-file-text-fill fs-3 text-white"></i>
            </div>
            <h3 class="fw-bold mb-0 stat-number-jefe mt-2"><%= totales.total_reportes || 0 %></h3>
            <small class="stat-label-jefe">Total reportes</small>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm stat-card-jefe stat-card-pendiente-jefe">
          <div class="card-body p-3 text-center">
            <div class="stat-icon-wrapper-jefe">
              <i class="bi bi-clock-history fs-3 text-white"></i>
            </div>
            <h3 class="fw-bold mb-0 stat-number-jefe-pendiente mt-2"><%= totales.pendientes || 0 %></h3>
            <small class="stat-label-jefe-pendiente">Pendientes</small>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm stat-card-jefe stat-card-progreso-jefe">
          <div class="card-body p-3 text-center">
            <div class="stat-icon-wrapper-jefe">
              <i class="bi bi-arrow-repeat fs-3 text-white"></i>
            </div>
            <h3 class="fw-bold mb-0 stat-number-jefe-progreso mt-2"><%= totales.en_progreso || 0 %></h3>
            <small class="stat-label-jefe-progreso">En Progreso</small>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm stat-card-jefe stat-card-resuelto-jefe">
          <div class="card-body p-3 text-center">
            <div class="stat-icon-wrapper-jefe">
              <i class="bi bi-check-circle-fill fs-3 text-white"></i>
            </div>
            <h3 class="fw-bold mb-0 stat-number-jefe-resuelto mt-2"><%= totales.resueltos || 0 %></h3>
            <small class="stat-label-jefe-resuelto">Resueltos</small>
          </div>
        </div>
      </div>
    </div>

    <!-- ========== GRÁFICOS (2 columnas) ========== -->
    <div class="row g-4 mb-5">
      <div class="col-lg-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-jefe h-100">
          <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h5 class="mb-0 fw-semibold">
              <i class="bi bi-pie-chart-fill me-2" style="color: #fd7e14;"></i> 
              Reportes por Categoría
            </h5>
          </div>
          <div class="card-body p-4 pt-0 chart-body-jefe">
            <canvas id="chartCategoria" style="max-height: 260px; width: 100%;"></canvas>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-jefe h-100">
          <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h5 class="mb-0 fw-semibold">
              <i class="bi bi-donut-fill me-2" style="color: #28a745;"></i> 
              Reportes por Estado
            </h5>
          </div>
          <div class="card-body p-4 pt-0 chart-body-jefe">
            <canvas id="chartEstado" style="max-height: 260px; width: 100%;"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- ========== REPORTES RECIENTES ========== -->
    <div class="row g-4 mb-5">
      <div class="col-12">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden table-card-jefe">
          <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0 fw-semibold">
              <i class="bi bi-clock-history me-2" style="color: #ffc107;"></i> 
              Reportes Recientes en tu Calle
            </h5>
            <span class="badge bg-info rounded-pill px-3 py-2">
              <i class="bi bi-file-text me-1"></i> últimos 5
            </span>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover mb-0 tabla-jefe tabla-reportes-jefe">
                <thead>
                  <tr>
                    <th><i class="bi bi-card-heading me-1"></i> Título</th>
                    <th><i class="bi bi-tag me-1"></i> Categoría</th>
                    <th><i class="bi bi-info-circle me-1"></i> Estado</th>
                    <th><i class="bi bi-calendar3 me-1"></i> Fecha</th>
                    <th class="text-center"><i class="bi bi-eye me-1"></i> Ver</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (reportesRecientes && reportesRecientes.length > 0) { %>
                    <% reportesRecientes.slice(0, 5).forEach(r => { %>
                      <tr>
                        <td><strong><%= r.titulo %></strong></td>
                        <td><span class="badge rounded-pill px-2 py-1 categoria-badge-jefe"><%= r.categoria %></span></td>
                        <td>
                          <span class="badge rounded-pill px-2 py-1 estado-badge-jefe 
                            <%= r.estado === 'Pendiente' ? 'bg-warning text-dark' : 
                                r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>">
                            <%= r.estado === 'Pendiente' ? '⏳' : 
                                r.estado === 'En Progreso' ? '🔄' : '✅' %>
                            <%= r.estado %>
                          </span>
                        </td>
                        <td><small><%= new Date(r.fecha).toLocaleDateString() %></small></td>
                        <td class="text-center">
                          <a href="/reportes" class="btn btn-sm btn-ver-jefe px-3">
                            <i class="bi bi-eye me-1"></i> Ver
                          </a>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="5" class="text-center py-4 empty-state-jefe">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        <p class="mb-0 small">No hay reportes en tu calle</p>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
          <div class="card-footer bg-transparent border-0 text-center pt-3 pb-4">
            <a href="/reportes" class="btn btn-sm btn-outline-primary rounded-3 px-4">
              Ver todos los reportes <i class="bi bi-arrow-right ms-1"></i>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ========== ESTADÍSTICAS ADICIONALES (2 columnas) ========== -->
    <div class="row g-4">
      <div class="col-md-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-jefe-adicional h-100">
          <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h5 class="mb-0 fw-semibold">
              <i class="bi bi-star-fill me-2" style="color: #ffc107;"></i> 
              Reporte más votado
            </h5>
          </div>
          <div class="card-body p-4 text-center stat-card-body-jefe">
            <% if (reporteMasVotado) { %>
              <div class="d-flex flex-column align-items-center">
                <i class="bi bi-trophy-fill fs-1 icon-trophy mb-2"></i>
                <h6 class="fw-bold reporte-titulo"><%= reporteMasVotado.titulo %></h6>
                <p class="small reporte-descripcion mb-2"><%= reporteMasVotado.descripcion ? (reporteMasVotado.descripcion.substring(0, 80) + '...') : 'Sin descripción' %></p>
                <span class="badge bg-warning rounded-pill px-3 py-1 badge-votos">👍 <%= reporteMasVotado.votos || 0 %> votos</span>
              </div>
            <% } else { %>
              <div class="d-flex flex-column align-items-center">
                <i class="bi bi-emoji-frown fs-1 text-muted mb-2"></i>
                <p class="text-muted mb-0">No hay reportes votados aún</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-jefe-adicional h-100">
          <div class="card-header bg-transparent border-0 pt-4 px-4">
            <h5 class="mb-0 fw-semibold">
              <i class="bi bi-calendar-week me-2" style="color: #fd7e14;"></i> 
              Reporte más antiguo
            </h5>
          </div>
          <div class="card-body p-4 text-center stat-card-body-jefe">
            <% if (reporteMasAntiguo) { %>
              <div class="d-flex flex-column align-items-center">
                <i class="bi bi-calendar-fill fs-1 icon-calendario mb-2"></i>
                <h6 class="fw-bold reporte-titulo"><%= reporteMasAntiguo.titulo %></h6>
                <p class="small reporte-descripcion mb-2">Desde: <%= new Date(reporteMasAntiguo.fecha).toLocaleDateString() %></p>
                <span class="badge rounded-pill px-3 py-1 estado-antiguo-badge" style="background: <%= reporteMasAntiguo.estado === 'Pendiente' ? '#ffc107' : (reporteMasAntiguo.estado === 'En Progreso' ? '#17a2b8' : '#28a745') %>; color: white;"><%= reporteMasAntiguo.estado %></span>
              </div>
            <% } else { %>
              <div class="d-flex flex-column align-items-center">
                <i class="bi bi-calendar-x fs-1 text-muted mb-2"></i>
                <p class="text-muted mb-0">No hay reportes registrados</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- ========== CHART.JS ========== -->
<% if (tieneCalle && miCalle && porCategoria && porCategoria.length > 0) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Datos desde el servidor
  const categoriasLabels = JSON.parse('<%- JSON.stringify(categoriasLabels) %>');
  const categoriasDatos = JSON.parse('<%- JSON.stringify(categoriasDatos) %>');
  const estadosLabels = JSON.parse('<%- JSON.stringify(estadosLabels) %>');
  const estadosDatos = JSON.parse('<%- JSON.stringify(estadosDatos) %>');

  // Gráfico de Categorías
  if (categoriasLabels.length > 0) {
    new Chart(document.getElementById('chartCategoria'), {
      type: 'pie',
      data: {
        labels: categoriasLabels,
        datasets: [{
          data: categoriasDatos,
          backgroundColor: [
            '#0d6efd',   // Agua - AZUL
            '#ffc107',   // Electricidad - AMARILLO
            '#dc3545',   // Salud - ROJO
            '#3bba89',   // Vialidad - VERDE
            '#6c757d',   // Otros - GRIS
            '#17a2b8',   // Extra - CELESTE
            '#fd7e14'    // Extra - NARANJA
          ],
          borderWidth: 0,
          hoverOffset: 10
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { 
            position: 'bottom', 
            labels: { 
              font: { size: 11 },
              padding: 15,
              usePointStyle: true,
              pointStyle: 'circle'
            }
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                const label = context.label || '';
                const value = context.raw || 0;
                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                const percentage = ((value / total) * 100).toFixed(1);
                return `${label}: ${value} (${percentage}%)`;
              }
            }
          }
        }
      }
    });
  }

  // Gráfico de Estados
  if (estadosLabels.length > 0) {
    new Chart(document.getElementById('chartEstado'), {
      type: 'doughnut',
      data: {
        labels: estadosLabels,
        datasets: [{
          data: estadosDatos,
          backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
          borderWidth: 0,
          hoverOffset: 10
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '60%',
        plugins: {
          legend: { 
            position: 'bottom', 
            labels: { 
              font: { size: 11 },
              padding: 15,
              usePointStyle: true,
              pointStyle: 'circle'
            }
          },
          tooltip: {
            callbacks: {
              label: function(context) {
                const label = context.label || '';
                const value = context.raw || 0;
                const total = context.dataset.data.reduce((a, b) => a + b, 0);
                const percentage = ((value / total) * 100).toFixed(1);
                return `${label}: ${value} (${percentage}%)`;
              }
            }
          }
        }
      }
    });
  }
</script>
<% } %>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .jefe-title {
    color: #5D4037;
  }
  .jefe-title i {
    color: #fd6704bd;
  }
  .jefe-subtitle {
    color: #8B6B5A;
  }
  
  /* Botón actualizar */
  .btn-actualizar-jefe {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-actualizar-jefe:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Info calle */
  .info-calle-jefe {
    border: none;
  }
  .info-calle-success {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
  }
  .info-calle-icon-success {
    color: #28a745;
  }
  .info-calle-title-success {
    color: #155724;
  }
  .info-calle-nombre-success {
    color: #155724;
  }
  .info-calle-warning {
    background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
  }
  .info-calle-icon-warning {
    color: #856404;
  }
  .info-calle-title-warning {
    color: #856404;
  }
  .info-calle-text-warning {
    color: #856404;
  }
  
  /* Tarjetas de estadísticas */
  .stat-card-jefe {
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .stat-card-jefe:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  }
  
  .stat-icon-wrapper-jefe {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
  }
  
  .stat-card-total-jefe {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  .stat-card-pendiente-jefe {
    background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
  }
  .stat-card-progreso-jefe {
    background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
  }
  .stat-card-resuelto-jefe {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
  }
  
  .stat-number-jefe {
    color: #5D4037;
  }
  .stat-number-jefe-pendiente {
    color: #856404;
  }
  .stat-number-jefe-progreso {
    color: #0c5460;
  }
  .stat-number-jefe-resuelto {
    color: #155724;
  }
  
  .stat-label-jefe {
    color: #8B6B5A;
  }
  .stat-label-jefe-pendiente {
    color: #856404;
  }
  .stat-label-jefe-progreso {
    color: #0c5460;
  }
  .stat-label-jefe-resuelto {
    color: #155724;
  }
  
  /* Gráficos */
  .chart-card-jefe {
    transition: all 0.2s ease;
  }
  .chart-card-jefe .card-header h5 {
    color: #5D4037;
  }
  .chart-body-jefe {
    background: white;
  }
  
  /* Tablas */
  .table-card-jefe {
    transition: all 0.2s ease;
  }
  
  .tabla-jefe {
    font-size: 14px;
  }
  .tabla-jefe thead th {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
    font-weight: 600;
    padding: 12px;
    border-bottom: 2px solid #fd6704bd;
  }
  .tabla-jefe tbody td {
    padding: 10px 12px;
    vertical-align: middle;
  }
  .tabla-jefe tbody tr {
    border-bottom: 1px solid #f0d5c0;
  }
  .tabla-jefe tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  
  .categoria-badge-jefe {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    font-size: 11px;
  }
  
  .estado-badge-jefe {
    font-size: 11px;
    padding: 4px 10px;
  }
  
  .btn-ver-jefe {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-ver-jefe:hover {
    transform: translateY(-2px);
  }
  
  .empty-state-jefe i {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-state-jefe p {
    color: #6c757d;
  }
  
  /* Tarjetas de estadísticas adicionales */
  .stat-card-jefe-adicional {
    transition: all 0.2s ease;
  }
  .stat-card-jefe-adicional .card-header h5 {
    color: #5D4037;
  }
  .stat-card-body-jefe {
    background: white;
  }
  .icon-trophy {
    color: #ffc107;
  }
  .icon-calendario {
    color: #fd6704bd;
  }
  .reporte-titulo {
    color: #5D4037;
  }
  .reporte-descripcion {
    color: #6c757d;
  }
  .badge-votos {
    color: #333;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .jefe-title {
    color: #e4e4e7;
  }
  body.dark-mode .jefe-subtitle {
    color: #a1a1aa;
  }
  
  body.dark-mode .info-calle-success {
    background: linear-gradient(135deg, #0d3b1f 0%, #0a2a16 100%);
  }
  body.dark-mode .info-calle-icon-success {
    color: #a3e4b7;
  }
  body.dark-mode .info-calle-title-success,
  body.dark-mode .info-calle-nombre-success {
    color: #a3e4b7;
  }
  body.dark-mode .info-calle-warning {
    background: linear-gradient(135deg, #3d2e1a 0%, #2d1f0a 100%);
  }
  body.dark-mode .info-calle-icon-warning {
    color: #f5dba3;
  }
  body.dark-mode .info-calle-title-warning,
  body.dark-mode .info-calle-text-warning {
    color: #f5dba3;
  }
  
  body.dark-mode .stat-card-total-jefe {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  body.dark-mode .stat-card-pendiente-jefe {
    background: linear-gradient(135deg, #3d2e1a 0%, #2d1f0a 100%);
  }
  body.dark-mode .stat-card-progreso-jefe {
    background: linear-gradient(135deg, #1a3d3d 0%, #0f2a2a 100%);

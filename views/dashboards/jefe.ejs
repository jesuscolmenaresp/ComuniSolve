<%
// Preparar datos para Chart.js
let categoriasLabels = [];
let categoriasDatos = [];
let estadosLabels = [];
let estadosDatos = [];

if (porCategoria && porCategoria.length > 0) {
  categoriasLabels = porCategoria.map(item => item.nombre);
  categoriasDatos = porCategoria.map(item => item.total);
}

if (porEstado && porEstado.length > 0) {
  estadosLabels = porEstado.map(item => item.estado);
  estadosDatos = porEstado.map(item => item.total);
}
%>

<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 jefe-title">
        <i class="bi bi-person-badge me-2"></i> Panel de Jefe de Calle
      </h2>
      <p class="text-muted small mb-0 jefe-subtitle">Gestiona y da seguimiento a los reportes de tu calle</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/reportes" class="btn btn-sm px-3 py-2 fw-semibold rounded-3 btn-jefe-primary">
        <i class="bi bi-list-ul me-1"></i> Ver reportes
      </a>
      <a href="/reportar" class="btn btn-sm btn-outline-secondary px-3 py-2 fw-semibold rounded-3 btn-jefe-outline">
        <i class="bi bi-plus-circle me-1"></i> Crear reporte
      </a>
    </div>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Información de la calle a cargo -->
  <% if (tieneCalle && miCalle) { %>
    <div class="alert alert-success border-0 rounded-3 py-3 mb-4 info-calle-jefe info-calle-success">
      <div class="d-flex align-items-center gap-3 flex-wrap">
        <i class="bi bi-geo-alt-fill fs-3 info-calle-icon-success"></i>
        <div>
          <strong class="info-calle-title-success">📍 Calle a tu cargo:</strong>
          <span class="fw-semibold info-calle-nombre-success"><%= miCalle %></span>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="alert alert-warning border-0 rounded-3 py-3 mb-4 info-calle-jefe info-calle-warning">
      <div class="d-flex align-items-center gap-3 flex-wrap">
        <i class="bi bi-exclamation-triangle-fill fs-3 info-calle-icon-warning"></i>
        <div>
          <strong class="info-calle-title-warning">⚠️ No tienes una calle asignada.</strong>
          <br><small class="info-calle-text-warning">Contacta al administrador para asignarte una calle.</small>
        </div>
      </div>
    </div>
  <% } %>

  <!-- Tarjetas de resumen (solo si tiene calle) -->
  <% if (tieneCalle && miCalle) { %>
    <div class="row g-4 mb-5">
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-jefe stat-card-total-jefe">
          <i class="bi bi-file-text fs-2 stat-icon-jefe"></i>
          <h3 class="fw-bold mb-0 stat-number-jefe"><%= totales.total_reportes || 0 %></h3>
          <small class="text-muted stat-label-jefe">Total reportes</small>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-jefe stat-card-pendiente-jefe">
          <i class="bi bi-clock-history fs-2 stat-icon-jefe-pendiente"></i>
          <h3 class="fw-bold mb-0 stat-number-jefe-pendiente"><%= totales.pendientes || 0 %></h3>
          <small class="text-muted stat-label-jefe-pendiente">Pendientes</small>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-jefe stat-card-progreso-jefe">
          <i class="bi bi-arrow-repeat fs-2 stat-icon-jefe-progreso"></i>
          <h3 class="fw-bold mb-0 stat-number-jefe-progreso"><%= totales.en_progreso || 0 %></h3>
          <small class="text-muted stat-label-jefe-progreso">En Progreso</small>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-jefe stat-card-resuelto-jefe">
          <i class="bi bi-check-circle fs-2 stat-icon-jefe-resuelto"></i>
          <h3 class="fw-bold mb-0 stat-number-jefe-resuelto"><%= totales.resueltos || 0 %></h3>
          <small class="text-muted stat-label-jefe-resuelto">Resueltos</small>
        </div>
      </div>
    </div>

    <!-- Gráficas -->
    <div class="row g-4 mb-5">
      <div class="col-md-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card-jefe">
          <div class="px-4 py-3 chart-card-header-jefe">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-pie-chart me-2"></i> Reportes por Categoría</h5>
          </div>
          <div class="card-body p-4 chart-card-body-jefe">
            <canvas id="chartCategoria" style="max-height: 280px; width: 100%;"></canvas>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card-jefe">
          <div class="px-4 py-3 chart-card-header-jefe">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-donut me-2"></i> Reportes por Estado</h5>
          </div>
          <div class="card-body p-4 chart-card-body-jefe">
            <canvas id="chartEstado" style="max-height: 280px; width: 100%;"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Reportes recientes -->
    <div class="card border-0 rounded-4 shadow-sm overflow-hidden mb-5 table-card-jefe">
      <div class="px-4 py-3 table-card-header-jefe">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2"></i> Reportes Recientes en tu Calle</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 tabla-jefe">
            <thead>
              <tr class="text-center">
                <th><i class="bi bi-card-heading"></i> Título</th>
                <th><i class="bi bi-tag"></i> Categoría</th>
                <th><i class="bi bi-person"></i> Reportado por</th>
                <th><i class="bi bi-calendar3"></i> Fecha</th>
                <th><i class="bi bi-info-circle"></i> Estado</th>
                <th><i class="bi bi-gear"></i> Acción</th>
              </tr>
            </thead>
            <tbody>
              <% if (reportesRecientes && reportesRecientes.length > 0) { %>
                <% reportesRecientes.forEach(r => { %>
                  <tr class="text-center">
                    <td class="text-start"><strong><%= r.titulo %></strong></td>
                    <td><span class="badge px-2 py-1 rounded-pill categoria-badge-jefe"><%= r.categoria %></span></td>
                    <td><%= r.reportado_por || 'Anónimo' %></td>
                    <td><%= new Date(r.fecha).toLocaleDateString() %></td>
                    <td>
                      <span class="badge rounded-pill px-2 py-1 estado-badge-jefe 
                        <%= r.estado === 'Pendiente' ? 'bg-warning text-dark' : 
                            r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>">
                        <%= r.estado === 'Pendiente' ? '⏳ Pendiente' : 
                            r.estado === 'En Progreso' ? '🔄 Progreso' : '✅ Resuelto' %>
                      </span>
                    </td>
                    <td>
                      <a href="/reportes" class="btn btn-sm px-3 py-1 rounded-3 btn-ver-jefe">
                        <i class="bi bi-eye me-1"></i> Ver
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-5 empty-state-jefe">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <p class="mb-0">No hay reportes en tu calle</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Estadísticas adicionales -->
    <div class="row g-4">
      <div class="col-md-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-jefe">
          <div class="px-4 py-3 stat-card-header-jefe">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-star-fill me-2"></i> Reporte más votado</h5>
          </div>
          <div class="card-body p-4 stat-card-body-jefe">
            <% if (reporteMasVotado) { %>
              <div class="d-flex align-items-center gap-3">
                <i class="bi bi-trophy-fill fs-1 icon-trophy"></i>
                <div>
                  <h6 class="mb-1 fw-bold reporte-titulo"><%= reporteMasVotado.titulo %></h6>
                  <p class="small reporte-descripcion mb-0"><%= reporteMasVotado.descripcion ? (reporteMasVotado.descripcion.substring(0, 100) + '...') : 'Sin descripción' %></p>
                  <span class="badge bg-warning mt-2 rounded-pill px-3 py-1 badge-votos">👍 <%= reporteMasVotado.votos || 0 %> votos</span>
                </div>
              </div>
            <% } else { %>
              <p class="text-muted text-center mb-0">No hay reportes votados aún</p>
            <% } %>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-jefe">
          <div class="px-4 py-3 stat-card-header-jefe">
            <h5 class="mb-0 fw-semibold"><i class="bi bi-calendar-week me-2"></i> Reporte más antiguo</h5>
          </div>
          <div class="card-body p-4 stat-card-body-jefe">
            <% if (reporteMasAntiguo) { %>
              <div class="d-flex align-items-center gap-3">
                <i class="bi bi-calendar-fill fs-1 icon-calendario"></i>
                <div>
                  <h6 class="mb-1 fw-bold reporte-titulo"><%= reporteMasAntiguo.titulo %></h6>
                  <p class="small reporte-descripcion mb-0">Desde: <%= new Date(reporteMasAntiguo.fecha).toLocaleDateString() %></p>
                  <span class="badge rounded-pill px-3 py-1 mt-2 estado-antiguo-badge" style="background: <%= reporteMasAntiguo.estado === 'Pendiente' ? '#ffc107' : (reporteMasAntiguo.estado === 'En Progreso' ? '#17a2b8' : '#28a745') %>; color: white;"><%= reporteMasAntiguo.estado %></span>
                </div>
              </div>
            <% } else { %>
              <p class="text-muted text-center mb-0">No hay reportes registrados</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>

<!-- Chart.js -->
<% if (tieneCalle && miCalle && porCategoria && porCategoria.length > 0) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Datos desde el servidor
  const categoriasLabels = JSON.parse('<%- JSON.stringify(categoriasLabels) %>');
  const categoriasDatos = JSON.parse('<%- JSON.stringify(categoriasDatos) %>');
  const estadosLabels = JSON.parse('<%- JSON.stringify(estadosLabels) %>');
  const estadosDatos = JSON.parse('<%- JSON.stringify(estadosDatos) %>');

  // Gráfico de Categorías
  if (categoriasLabels.length > 0) {
    new Chart(document.getElementById('chartCategoria'), {
      type: 'pie',
      data: {
        labels: categoriasLabels,
        datasets: [{
          data: categoriasDatos,
          backgroundColor: [
            '#0d6efd',   // Agua - AZUL
            '#ffc107',   // Electricidad - AMARILLO
            '#dc3545',   // Salud - ROJO
            '#3bba89',   // Vialidad - VERDE
            '#6c757d',   // Otros - GRIS
            '#17a2b8',   // Extra - CELESTE
            '#fd7e14'    // Extra - NARANJA
          ],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
      }
    });
  }

  // Gráfico de Estados
  if (estadosLabels.length > 0) {
    new Chart(document.getElementById('chartEstado'), {
      type: 'doughnut',
      data: {
        labels: estadosLabels,
        datasets: [{
          data: estadosDatos,
          backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
      }
    });
  }
</script>
<% } %>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .jefe-title {
    color: #5D4037;
  }
  .jefe-title i {
    color: #fd6704bd;
  }
  .jefe-subtitle {
    color: #8B6B5A;
  }
  
  /* Botones */

<%
// Preparar datos para Chart.js
const categorias = {
    labels: porCategoria.map(item => item.nombre),
    datos: porCategoria.map(item => item.total)
};

const estados = {
    labels: porEstado.map(item => item.estado),
    datos: porEstado.map(item => item.total)
};

const calles = {
    labels: porCalle.map(item => item.nombre),
    datos: porCalle.map(item => item.total)
};
%>

<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 admin-title">
        <i class="bi bi-graph-up me-2"></i> Panel de Administración
      </h2>
      <p class="text-muted small mb-0 admin-subtitle">Estadísticas y métricas de la comunidad</p>
    </div>
    <div class="d-flex gap-2">
      <button onclick="window.location.reload()" class="btn btn-sm px-3 py-2 rounded-3 btn-actualizar">
        <i class="bi bi-arrow-repeat me-1"></i> Actualizar
      </button>
    </div>
  </div>

  <!-- Tarjetas de resumen -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card">
        <div class="card-body p-3 text-center stat-card-total">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="stat-icon-wrapper">
              <i class="bi bi-file-text fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0 stat-number"><%= totales.total_reportes || 0 %></h2>
          <p class="small mb-0 stat-label">Total Reportes</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card">
        <div class="card-body p-3 text-center stat-card-pendiente">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="stat-icon-wrapper">
              <i class="bi bi-clock-history fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0 stat-number"><%= totales.pendientes || 0 %></h2>
          <p class="small mb-0 stat-label">Pendientes</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card">
        <div class="card-body p-3 text-center stat-card-progreso">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="stat-icon-wrapper">
              <i class="bi bi-arrow-repeat fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0 stat-number"><%= totales.en_progreso || 0 %></h2>
          <p class="small mb-0 stat-label">En Progreso</p>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card">
        <div class="card-body p-3 text-center stat-card-resuelto">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="stat-icon-wrapper">
              <i class="bi bi-check-circle fs-3 text-white"></i>
            </div>
          </div>
          <h2 class="fw-bold mb-0 stat-number"><%= totales.resueltos || 0 %></h2>
          <p class="small mb-0 stat-label">Resueltos</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Gráficas -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card">
        <div class="px-4 py-3 chart-card-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-pie-chart me-2"></i> Reportes por Categoría</h5>
        </div>
        <div class="card-body p-4 chart-card-body">
          <canvas id="chartCategoria" style="max-height: 300px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card">
        <div class="px-4 py-3 chart-card-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-donut me-2"></i> Reportes por Estado</h5>
        </div>
        <div class="card-body p-4 chart-card-body">
          <canvas id="chartEstado" style="max-height: 300px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Top calles y más votados -->
  <div class="row g-4 mb-5">
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card">
        <div class="px-4 py-3 chart-card-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-bar-chart me-2"></i> Top 5 Calles con más Reportes</h5>
        </div>
        <div class="card-body p-4 chart-card-body">
          <canvas id="chartCalles" style="max-height: 300px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden h-100 chart-card">
        <div class="px-4 py-3 chart-card-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-star-fill me-2"></i> Reportes más Votados</h5>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 votos-table">
              <thead>
                <tr class="text-center">
                  <th><i class="bi bi-card-heading"></i> Título</th>
                  <th><i class="bi bi-tag"></i> Categoría</th>
                  <th><i class="bi bi-geo-alt"></i> Calle</th>
                  <th><i class="bi bi-hand-thumbs-up"></i> Votos</th>
                </tr>
              </thead>
              <tbody>
                <% if (masVotados && masVotados.length > 0) { %>
                  <% masVotados.forEach(r => { %>
                    <tr class="text-center">
                      <td class="text-start"><strong><%= r.titulo %></strong></td>
                      <td><span class="badge px-2 py-1 rounded-pill categoria-badge-voto"><%= r.categoria %></span></td>
                      <td><i class="bi bi-pin-map-fill me-1 location-icon"></i> <%= r.calle %></td>
                      <td class="text-center"><span class="badge bg-warning rounded-pill px-3 py-1 votos-badge">👍 <%= r.votos || 0 %></span></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center py-5 empty-state-votos">
                      <i class="bi bi-hand-thumbs-up fs-1 d-block mb-2"></i>
                      <p class="mb-0">Sin votos registrados</p>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Participación ciudadana -->
  <div class="row g-4">
    <div class="col-md-6 mx-auto">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden participation-card">
        <div class="px-4 py-3 participation-card-header">
          <h5 class="mb-0 fw-semibold"><i class="bi bi-people-fill me-2"></i> Participación Ciudadana</h5>
        </div>
        <div class="card-body p-0">
          <div class="list-group list-group-flush">
            <div class="list-group-item d-flex justify-content-between align-items-center px-4 py-3 participation-item">
              <div>
                <i class="bi bi-person-fill me-2 participation-icon"></i>
                <strong>Ciudadanos registrados</strong>
              </div>
              <span class="badge rounded-pill px-3 py-2 ciudadanos-badge"><%= totales.total_ciudadanos || 0 %></span>
            </div>
            <div class="list-group-item d-flex justify-content-between align-items-center px-4 py-3 participation-item">
              <div>
                <i class="bi bi-person-badge me-2 participation-icon"></i>
                <strong>Voluntarios</strong>
              </div>
              <span class="badge rounded-pill px-3 py-2 voluntarios-badge"><%= totales.total_voluntarios || 0 %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  // Gráfico de Categorías
  new Chart(document.getElementById('chartCategoria'), {
    type: 'pie',
    data: {
      labels: JSON.parse('<%- JSON.stringify(categorias.labels) %>'),
      datasets: [{
        data: JSON.parse('<%- JSON.stringify(categorias.datos) %>'),
        backgroundColor: [
          '#0d6efd',   // Agua - AZUL
          '#ffc107',   // Electricidad - AMARILLO
          '#dc3545',   // Salud - ROJO
          '#3bba89',   // Vialidad - VERDE
          '#6c757d',   // Otros - GRIS
          '#17a2b8',   // Extra - CELESTE
          '#fd7e14'    // Extra - NARANJA
        ],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { font: { size: 11 } }
        }
      }
    }
  });

  // Gráfico de Estados
  new Chart(document.getElementById('chartEstado'), {
    type: 'doughnut',
    data: {
      labels: JSON.parse('<%- JSON.stringify(estados.labels) %>'),
      datasets: [{
        data: JSON.parse('<%- JSON.stringify(estados.datos) %>'),
        backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { font: { size: 11 } }
        }
      }
    }
  });

  // Gráfico de Calles
  new Chart(document.getElementById('chartCalles'), {
    type: 'bar',
    data: {
      labels: JSON.parse('<%- JSON.stringify(calles.labels) %>'),
      datasets: [{
        label: 'Reportes',
        data: JSON.parse('<%- JSON.stringify(calles.datos) %>'),
        backgroundColor: [
          '#fd6704bd',  // Naranja
          '#0d6efd',    // Azul
          '#28a745',    // Verde
          '#ffc107',    // Amarillo
          '#17a2b8'     // Celeste
        ],
        borderRadius: 8,
        barPercentage: 0.7
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        y: {
          beginAtZero: true,
          stepSize: 1,
          grid: { color: '#f0d5c0', lineWidth: 1 }
        },
        x: {
          ticks: { font: { size: 11, weight: 'bold' } },
          grid: { display: false }
        }
      },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#fd6704bd',
          titleColor: 'white',
          bodyColor: 'white'
        }
      }
    }
  });
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .admin-title {
    color: #5D4037;
  }
  
  .admin-title i {
    color: #fd6704bd;
  }
  
  .admin-subtitle {
    color: #8B6B5A;
  }
  
  /* Botón actualizar */
  .btn-actualizar {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  
  .btn-actualizar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Tarjetas de estadísticas */
  .stat-card {
    transition: all 0.2s ease;
  }
  
  .stat-card:hover {
    transform: translateY(-4px);
  }
  
  .stat-card-total {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .stat-card-pendiente {
    background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
  }
  
  .stat-card-progreso {
    background: linear-gradient(135deg, #d1ecf1 0%, #bee5eb 100%);
  }
  
  .stat-card-resuelto {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
  }
  
  .stat-icon-wrapper {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .stat-number {
    color: #5D4037;
  }
  
  .stat-label {
    color: #8B6B5A;
  }
  
  .stat-card-pendiente .stat-number {
    color: #856404;
  }
  
  .stat-card-progreso .stat-number {
    color: #0c5460;
  }
  
  .stat-card-resuelto .stat-number {
    color: #155724;
  }
  
  .stat-card-pendiente .stat-label {
    color: #856404;
  }
  
  .stat-card-progreso .stat-label {
    color: #0c5460;
  }
  
  .stat-card-resuelto .stat-label {
    color: #155724;
  }
  
  /* Tarjetas de gráficos */
  .chart-card-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .chart-card-header h5 {
    color: #5D4037;
  }
  
  .chart-card-header i {
    color: #fd6704bd;
  }
  
  .chart-card-body {
    background: white;
  }
  
  /* Tabla de votos */
  .votos-table {
    background: white;
  }
  
  .votos-table thead th {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
    font-weight: 600;
    border-bottom: 2px solid #fd6704bd;
  }
  
  .votos-table tbody tr {
    border-bottom-color: #f0d5c0;
  }
  
  .votos-table tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  
  .categoria-badge-voto {
    background: #fce5d4;
    color: #fd6704bd;
  }
  
  .location-icon {
    color: #6c757d;
  }
  
  .votos-badge {
    background: #ffc107;
    color: #333;
  }
  
  .empty-state-votos i {
    color: #6c757d;
    opacity: 0.5;
  }
  
  .empty-state-votos p {
    color: #6c757d;
  }
  
  /* Tarjeta de participación */
  .participation-card-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .participation-card-header h5 {
    color: #5D4037;
  }
  
  .participation-card-header i {
    color: #fd6704bd;
  }
  
  .participation-item {
    background: white;
    border-color: #f0d5c0;
  }
  
  .participation-icon {
    color: #fd6704bd;
  }
  
  .ciudadanos-badge {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  .voluntarios-badge {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .admin-title {
    color: #e4e4e7;
  }
  
  body.dark-mode .admin-subtitle {
    color: #a1a1aa;
  }
  
  body.dark-mode .stat-card-total {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  
  body.dark-mode .stat-card-pendiente {
    background: linear-gradient(135deg, #3d2e1a 0%, #2d1f0a 100%);
  }
  
  body.dark-mode .stat-card-progreso {
    background: linear-gradient(135deg, #1a3d3d 0%, #0f2a2a 100%);
  }
  
  body.dark-mode .stat-card-resuelto {
    background: linear-gradient(135deg, #0d3b1f 0%, #0a2a16 100%);
  }
  
  body.dark-mode .stat-number {
    color: #e4e4e7;
  }
  
  body.dark-mode .stat-label {
    color: #a1a1aa;
  }
  
  body.dark-mode .stat-card-pendiente .stat-number {
    color: #f5dba3;
  }
  
  body.dark-mode .stat-card-progreso .stat-number {
    color: #a3e4e4;
  }
  
  body.dark-mode .stat-card-resuelto .stat-number {
    color: #a3e4b7;
  }
  
  body.dark-mode .chart-card-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  
  body.dark-mode .chart-card-header h5 {
    color: #e4e4e7;
  }
  
  body.dark-mode .chart-card-body {
    background: #27272a;
  }
  
  body.dark-mode .votos-table {
    background: #27272a;
  }
  
  body.dark-mode .votos-table thead th {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
    color: #e4e4e7;
  }
  
  body.dark-mode .votos-table tbody tr {
    border-bottom-color: #3f3f46;
  }
  
  body.dark-mode .votos-table tbody tr:hover {
    background-color: #3d3d5c !important;
  }
  
  body.dark-mode .votos-table td,
  body.dark-mode .votos-table th {
    color: #e4e4e7;
  }
  
  body.dark-mode .categoria-badge-voto {
    background: #3d3d5c;
    color: #f7931e;
  }
  
  body.dark-mode .location-icon {
    color: #a1a1aa;
  }
  
  body.dark-mode .empty-state-votos i {
    color: #a1a1aa;
  }
  
  body.dark-mode .empty-state-votos p {
    color: #a1a1aa;
  }
  
  body.dark-mode .participation-card-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
  }
  
  body.dark-mode .participation-card-header h5 {
    color: #e4e4e7;
  }
  
  body.dark-mode .participation-item {
    background: #27272a;
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  
  body.dark-mode .participation-item strong {
    color: #e4e4e7;
  }
  
  body.dark-mode .participation-icon {
    color: #f7931e;
  }
  
  /* Chart.js en modo nocturno */
  body.dark-mode canvas {
    filter: brightness(0.9);
  }
  
  /* Escala de gráficos en modo nocturno */
  body.dark-mode .chartjs-grid {
    color: #a1a1aa;
  }
</style>
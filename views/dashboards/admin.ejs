<%
// Preparar datos para Chart.js
const categorias = {
    labels: porCategoria.map(item => item.nombre),
    datos: porCategoria.map(item => item.total)
};

const estados = {
    labels: porEstado.map(item => item.estado),
    datos: porEstado.map(item => item.total)
};

const calles = {
    labels: porCalle.map(item => item.nombre),
    datos: porCalle.map(item => item.total)
};
%>

<div class="container py-4">
  
  <!-- ========== ENCABEZADO MEJORADO ========== -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h2 class="fw-bold mb-1 admin-title">
            <i class="bi bi-graph-up-arrow me-2" style="color: #fd6704;"></i> 
            Panel de Administración
          </h2>
          <p class="text-muted small mb-0 admin-subtitle">
            <i class="bi bi-bar-chart me-1"></i> Estadísticas y métricas de la comunidad
          </p>
        </div>
        <div class="d-flex gap-2">
          <button onclick="window.location.reload()" class="btn btn-actualizar-admin px-4 py-2 rounded-3">
            <i class="bi bi-arrow-repeat me-2"></i> Actualizar
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== TARJETAS DE RESUMEN (4) ========== -->
  <div class="row g-4 mb-5">
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-admin stat-card-total">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <span class="stat-label-admin">Total Reportes</span>
              <h2 class="fw-bold mb-0 stat-number-admin mt-1"><%= totales.total_reportes || 0 %></h2>
            </div>
            <div class="stat-icon-admin">
              <i class="bi bi-file-text-fill fs-3 text-white"></i>
            </div>
          </div>
          <div class="stat-footer-admin mt-3">
            <small><i class="bi bi-arrow-up-short"></i> General</small>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-admin stat-card-pendiente">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <span class="stat-label-admin">Pendientes</span>
              <h2 class="fw-bold mb-0 stat-number-admin mt-1"><%= totales.pendientes || 0 %></h2>
            </div>
            <div class="stat-icon-admin">
              <i class="bi bi-clock-history fs-3 text-white"></i>
            </div>
          </div>
          <div class="stat-footer-admin mt-3">
            <small><i class="bi bi-hourglass-split"></i> Por atender</small>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-admin stat-card-progreso">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <span class="stat-label-admin">En Progreso</span>
              <h2 class="fw-bold mb-0 stat-number-admin mt-1"><%= totales.en_progreso || 0 %></h2>
            </div>
            <div class="stat-icon-admin">
              <i class="bi bi-arrow-repeat fs-3 text-white"></i>
            </div>
          </div>
          <div class="stat-footer-admin mt-3">
            <small><i class="bi bi-arrow-right"></i> En proceso</small>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden stat-card-admin stat-card-resuelto">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <span class="stat-label-admin">Resueltos</span>
              <h2 class="fw-bold mb-0 stat-number-admin mt-1"><%= totales.resueltos || 0 %></h2>
            </div>
            <div class="stat-icon-admin">
              <i class="bi bi-check-circle-fill fs-3 text-white"></i>
            </div>
          </div>
          <div class="stat-footer-admin mt-3">
            <small><i class="bi bi-check2-all"></i> Completados</small>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== GRÁFICOS (2 columnas) ========== -->
  <div class="row g-4 mb-5">
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-admin h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-pie-chart-fill me-2" style="color: #fd7e14;"></i> 
            Reportes por Categoría
          </h5>
        </div>
        <div class="card-body p-4 pt-0 chart-body-admin">
          <canvas id="chartCategoria" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-admin h-100">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-donut-fill me-2" style="color: #28a745;"></i> 
            Reportes por Estado
          </h5>
        </div>
        <div class="card-body p-4 pt-0 chart-body-admin">
          <canvas id="chartEstado" style="max-height: 280px; width: 100%;"></canvas>
        </div>
      </div>
    </div>
  </div>

 <!-- ========== TOP CALLES + MÁS VOTADOS ========== -->
<div class="row g-4 mb-5">
  <div class="col-lg-6">
    <div class="card border-0 rounded-4 shadow-sm overflow-hidden chart-card-admin h-100">
      <div class="card-header bg-transparent border-0 pt-4 px-4">
        <h5 class="mb-0 fw-semibold">
          <i class="bi bi-bar-chart-steps me-2" style="color: #17a2b8;"></i> 
          Top 5 Calles con más Reportes
        </h5>
      </div>
      <div class="card-body p-4 pt-0 chart-body-admin">
        <canvas id="chartCalles" style="max-height: 280px; width: 100%;"></canvas>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card border-0 rounded-4 shadow-sm overflow-hidden table-card-admin h-100">
      <div class="card-header bg-transparent border-0 pt-4 px-4">
        <h5 class="mb-0 fw-semibold">
          <i class="bi bi-star-fill me-2" style="color: #ffc107;"></i> 
          Reportes más Votados
        </h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0 tabla-admin tabla-votos">
            <thead>
              <tr>
                <th><i class="bi bi-card-heading me-1"></i> Título</th>
                <th><i class="bi bi-tag me-1"></i> Categoría</th>
                <th><i class="bi bi-geo-alt me-1"></i> Calle</th>
                <th class="text-center"><i class="bi bi-hand-thumbs-up me-1"></i> Votos</th>
              </tr>
            </thead>
            <tbody>
              <% if (masVotados && masVotados.length > 0) { %>
                <% masVotados.forEach(r => { %>
                  <tr>
                    <td><strong><%= r.titulo %></strong></td>
                    <td><span class="badge rounded-pill px-2 py-1 categoria-badge-voto"><%= r.categoria %></span></td>
                    <td><i class="bi bi-pin-map-fill me-1 location-icon"></i> <%= r.calle %></td>
                    <td class="text-center"><span class="badge rounded-pill px-3 py-1 votos-badge">👍 <%= r.votos || 0 %></span></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="text-center py-5 empty-state-admin">
                    <i class="bi bi-hand-thumbs-up fs-1 d-block mb-2"></i>
                    <p class="mb-0">Sin votos registrados</p>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer bg-transparent border-0 text-center pt-3 pb-4">
        <small class="text-muted">
          <i class="bi bi-info-circle me-1"></i> 
          Los reportes más votados por la comunidad
        </small>
      </div>
    </div>
  </div>
</div>

  <!-- ========== PARTICIPACIÓN CIUDADANA ========== -->
  <div class="row g-4">
    <div class="col-md-8 mx-auto">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden participation-card-admin">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
          <h5 class="mb-0 fw-semibold">
            <i class="bi bi-people-fill me-2" style="color: #fd7e14;"></i> 
            Participación Ciudadana
          </h5>
        </div>
        <div class="card-body p-4">
          <div class="row g-3">
            <div class="col-md-6">
              <div class="participation-item-admin p-3 rounded-3 text-center">
                <div class="d-flex align-items-center justify-content-center gap-3">
                  <i class="bi bi-person-fill fs-2 participation-icon-admin"></i>
                  <div>
                    <h5 class="mb-0 fw-bold"><%= totales.total_ciudadanos || 0 %></h5>
                    <small class="text-muted">Ciudadanos registrados</small>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="participation-item-admin p-3 rounded-3 text-center">
                <div class="d-flex align-items-center justify-content-center gap-3">
                  <i class="bi bi-person-badge fs-2 participation-icon-admin-vol"></i>
                  <div>
                    <h5 class="mb-0 fw-bold"><%= totales.total_voluntarios || 0 %></h5>
                    <small class="text-muted">Voluntarios activos</small>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
</div>

<!-- ========== CHART.JS ========== -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  // Gráfico de Categorías
  new Chart(document.getElementById('chartCategoria'), {
    type: 'pie',
    data: {
      labels: JSON.parse('<%- JSON.stringify(categorias.labels) %>'),
      datasets: [{
        data: JSON.parse('<%- JSON.stringify(categorias.datos) %>'),
        backgroundColor: [
          '#0d6efd',   // Agua - AZUL
          '#ffc107',   // Electricidad - AMARILLO
          '#dc3545',   // Salud - ROJO
          '#3bba89',   // Vialidad - VERDE
          '#6c757d',   // Otros - GRIS
          '#17a2b8',   // Extra - CELESTE
          '#fd7e14'    // Extra - NARANJA
        ],
        borderWidth: 0,
        hoverOffset: 10
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { 
            font: { size: 11 },
            padding: 15,
            usePointStyle: true,
            pointStyle: 'circle'
          }
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const label = context.label || '';
              const value = context.raw || 0;
              const total = context.dataset.data.reduce((a, b) => a + b, 0);
              const percentage = ((value / total) * 100).toFixed(1);
              return `${label}: ${value} (${percentage}%)`;
            }
          }
        }
      }
    }
  });

  // Gráfico de Estados
  new Chart(document.getElementById('chartEstado'), {
    type: 'doughnut',
    data: {
      labels: JSON.parse('<%- JSON.stringify(estados.labels) %>'),
      datasets: [{
        data: JSON.parse('<%- JSON.stringify(estados.datos) %>'),
        backgroundColor: ['#ffc107', '#17a2b8', '#28a745'],
        borderWidth: 0,
        hoverOffset: 10
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      cutout: '60%',
      plugins: {
        legend: {
          position: 'bottom',
          labels: { 
            font: { size: 11 },
            padding: 15,
            usePointStyle: true,
            pointStyle: 'circle'
          }
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const label = context.label || '';
              const value = context.raw || 0;
              const total = context.dataset.data.reduce((a, b) => a + b, 0);
              const percentage = ((value / total) * 100).toFixed(1);
              return `${label}: ${value} (${percentage}%)`;
            }
          }
        }
      }
    }
  });

  // Gráfico de Calles
  new Chart(document.getElementById('chartCalles'), {
    type: 'bar',
    data: {
      labels: JSON.parse('<%- JSON.stringify(calles.labels) %>'),
      datasets: [{
        label: 'Reportes',
        data: JSON.parse('<%- JSON.stringify(calles.datos) %>'),
        backgroundColor: [
          'rgba(253, 103, 4, 0.8)',
          'rgba(13, 110, 253, 0.8)',
          'rgba(40, 167, 69, 0.8)',
          'rgba(255, 193, 7, 0.8)',
          'rgba(23, 162, 184, 0.8)'
        ],
        borderRadius: 8,
        barPercentage: 0.7,
        hoverBackgroundColor: [
          'rgba(253, 103, 4, 1)',
          'rgba(13, 110, 253, 1)',
          'rgba(40, 167, 69, 1)',
          'rgba(255, 193, 7, 1)',
          'rgba(23, 162, 184, 1)'
        ]
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      scales: {
        y: {
          beginAtZero: true,
          stepSize: 1,
          grid: { color: 'rgba(0,0,0,0.05)' },
          ticks: { font: { size: 11 } }
        },
        x: {
          ticks: { font: { size: 11, weight: 'bold' } },
          grid: { display: false }
        }
      },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(0,0,0,0.8)',
          titleColor: 'white',
          bodyColor: 'white',
          cornerRadius: 8,
          padding: 10
        }
      }
    }
  });
</script>


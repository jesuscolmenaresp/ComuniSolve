<!-- 🗺️ Mapa -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="mb-0">🗺️ Reportes en el Mapa</h2>
  <a href="/reportar" class="btn btn-primary">➕ Reportar un problema</a>
</div>
<div id="map"></div>

<!-- 📌 Sección ¿Qué es ComuniSolve? -->
<section class="mt-5 p-4 bg-light rounded shadow-sm">
  <h2 class="text-center mb-3">¿Qué es <span class="text-primary">ComuniSolve</span>?</h2>
  <p class="text-center">
    ComuniSolve es un software de gestión comunitaria diseñado para facilitar la participación ciudadana 
    en la <strong>Comuna Socialista Nuestra Señora de las Mercedes</strong>. 
    Permite reportar problemas, ver incidencias geolocalizadas en un mapa, 
    votar por prioridades y fortalecer la organización local mediante herramientas tecnológicas accesibles y eficientes.
  </p>
</section>

<!-- 📌 Sección ¿Cómo funciona? -->
<section class="mt-5">
  <h2 class="text-center mb-4">¿Cómo funciona ComuniSolve?</h2>
  <div class="row text-center">
    <div class="col-md-3">
      <div class="p-3 bg-white shadow-sm rounded">
        <h3>📢</h3>
        <h5>Reporta</h5>
        <p>Informa cualquier problema en tu comunidad con una descripción, imagen y ubicación.</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="p-3 bg-white shadow-sm rounded">
        <h3>🗺️</h3>
        <h5>Visualiza</h5>
        <p>Todos los reportes se muestran en un mapa interactivo accesible a la comunidad.</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="p-3 bg-white shadow-sm rounded">
        <h3>👍</h3>
        <h5>Prioriza</h5>
        <p>Los vecinos pueden votar y comentar los reportes, ayudando a decidir qué atender primero.</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="p-3 bg-white shadow-sm rounded">
        <h3>🤝</h3>
        <h5>Actúa</h5>
        <p>Líderes y voluntarios coordinan acciones para resolver los problemas priorizados.</p>
      </div>
    </div>
  </div>
</section>

<!-- 📌 Sectores que atiende -->
<section class="mt-5">
  <h2 class="text-center mb-4">🏘️ Sectores que atiende ComuniSolve</h2>
  <div class="row text-center">
    <div class="col-md-3"><div class="p-3 bg-white shadow-sm rounded sector-card"><h5>Virgen de Lourdes</h5></div></div>
    <div class="col-md-3"><div class="p-3 bg-white shadow-sm rounded sector-card"><h5>Nuestra Señora de Las Mercedes</h5></div></div>
    <div class="col-md-3"><div class="p-3 bg-white shadow-sm rounded sector-card"><h5>Brisas de las Mercedes</h5></div></div>
    <div class="col-md-3"><div class="p-3 bg-white shadow-sm rounded sector-card"><h5>Las Mercedes</h5></div></div>
  </div>
  <div class="row text-center mt-3">
    <div class="col-md-4"><div class="p-3 bg-white shadow-sm rounded sector-card"><h5>Asentamiento campesino</h5></div></div>
    <div class="col-md-4"><div class="p-3 bg-white shadow-sm rounded sector-card"><h5>Urbanización La Providencia</h5></div></div>
    <div class="col-md-4"><div class="p-3 bg-white shadow-sm rounded sector-card"><h5>Santa Eduviges</h5></div></div>
  </div>
</section>

<!-- 📢 Últimos reportes -->
<h3 class="mt-5 mb-3">📢 Últimos reportes</h3>
<div class="row">
  <% if (reportes && reportes.length > 0) { %>
    <% reportes.slice(0,3).forEach(r => { %>
      <div class="col-md-4">
        <div class="report-card">
          <h5><%= r.titulo %></h5>
          <p class="text-muted"><%= r.descripcion.substring(0, 80) %>...</p>
          <p><strong>Categoría:</strong> 
            <span class="badge bg-<%= r.categoria_color || 'primary' %>">
              <%= r.categoria_icono ? r.categoria_icono + ' ' : '' %><%= r.categoria_nombre %>
            </span>
          </p>
          <p><strong>Calle:</strong> <%= r.nombre_calle %></p>
          <p><span class="badge <%= r.estado === 'Pendiente' ? 'bg-warning' : r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>"><%= r.estado %></span></p>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p class="text-muted">No hay reportes registrados aún.</p>
  <% } %>
</div>

<!-- 🔘 Botones de acción -->
<div class="text-center mt-4 d-flex justify-content-center gap-3 flex-wrap">
  <a href="/reportes" class="btn btn-outline-primary">📄 Ver todos los reportes</a>
  <a href="/voluntarios" class="btn btn-success">🤝 Únete como voluntario</a>
  <a href="#" class="btn btn-warning text-white">⭐ Votar / priorizar</a>
</div>

<!-- Script del mapa -->
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
  const map = L.map('map').setView([10.042, -67.489], 14);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

    const reportes = JSON.parse('<%- JSON.stringify(reportes || []) %>');
      reportes.forEach(r => {
    if (r.ubicacion_lat && r.ubicacion_lng) {
      L.marker([r.ubicacion_lat, r.ubicacion_lng])
        .addTo(map)
        .bindPopup(`<strong>${r.titulo}</strong><br>${r.descripcion}`);
    }
  });
</script>
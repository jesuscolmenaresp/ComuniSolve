<!-- 📢 Últimos reportes -->
<section class="mt-4 py-5 reports-section">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
      <div>
        <div class="reports-badge d-inline-block mb-2">ACTIVIDAD RECIENTE</div>
        <h3 class="reports-title mb-0"><i class="bi bi-newspaper me-2"></i> Últimos reportes</h3>
      </div>
      <img src="/images/logotipo.png" alt="ComuniSolve" style="height: 60px;" class="reports-logo">
    </div>
    
    <div class="row g-4">
      <% if (reportes && reportes.length > 0) { %>
        <% reportes.slice(0,3).forEach(r => { %>
          <div class="col-md-4">
            <div class="report-card h-100">
              <div class="report-card-header mb-3">
                <span class="badge categoria-badge" style="background: <%= r.categoria_color === 'primary' ? '#fd6704bd' : r.categoria_color === 'success' ? '#28a745' : r.categoria_color === 'warning' ? '#ffc107' : '#17a2b8' %>;">
                  <%= r.categoria_icono ? r.categoria_icono + ' ' : '' %><%= r.categoria_nombre %>
                </span>
                <span class="badge estado-badge ms-2 <%= r.estado === 'Pendiente' ? 'bg-warning text-dark' : r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>">
                  <%= r.estado === 'Pendiente' ? '⏳ Pendiente' : r.estado === 'En Progreso' ? '🔄 En Progreso' : '✅ Resuelto' %>
                </span>
              </div>
              <h5 class="report-card-title"><%= r.titulo %></h5>
              <p class="report-description"><%= r.descripcion.substring(0, 100) %>...</p>
              <div class="report-card-footer mt-auto">
                <p class="mb-1"><i class="bi bi-geo-alt"></i> <%= r.nombre_calle %></p>
                <small class="text-muted"><i class="bi bi-calendar3"></i> <%= new Date(r.fecha).toLocaleDateString() %></small>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12">
          <div class="empty-state text-center py-5 rounded-4">
            <i class="bi bi-inbox fs-1 mb-3 d-block"></i>
            <h5>No hay reportes registrados aún</h5>
            <p class="mb-0">¡Sé el primero en reportar un problema en tu comunidad!</p>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Botones de acción -->
    <div class="text-center mt-5 d-flex justify-content-center gap-3 flex-wrap">
      <a href="/reportes" class="btn btn-primary-custom px-4 py-2 rounded-3">
        <i class="bi bi-list-ul me-2"></i> Ver todos los reportes
      </a>
      <a href="/voluntarios" class="btn btn-success-custom px-4 py-2 rounded-3">
        <i class="bi bi-person-heart me-2"></i> Únete como voluntario
      </a>
      <% if (usuario && usuario.rol_id === 4) { %>
        <a href="/reportes" class="btn btn-warning-custom px-4 py-2 rounded-3">
          <i class="bi bi-star me-2"></i> Votar / priorizar
        </a>
      <% } else if (!usuario) { %>
        <a href="/login" class="btn btn-warning-custom px-4 py-2 rounded-3">
          <i class="bi bi-box-arrow-in-right me-2"></i> Inicia sesión para votar
        </a>
      <% } else { %>
        <a href="/reportes" class="btn btn-secondary-custom px-4 py-2 rounded-3">
          <i class="bi bi-gear me-2"></i> Gestionar reportes
        </a>
      <% } %>
    </div>
  </div>
</section>

<!-- Script del mapa -->
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
  const map = L.map('map').setView([10.042, -67.489], 14);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  const reportes = JSON.parse('<%- JSON.stringify(reportes || []) %>');
  reportes.forEach(r => {
    if (r.ubicacion_lat && r.ubicacion_lng) {
      L.marker([r.ubicacion_lat, r.ubicacion_lng])
        .addTo(map)
        .bindPopup(`
          <strong>${r.titulo}</strong><br>
          ${r.descripcion.substring(0, 100)}<br>
          <small>Estado: ${r.estado}</small>
        `);
    }
  });
</script>


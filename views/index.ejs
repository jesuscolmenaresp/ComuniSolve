<!-- Hero Section - Compacta y moderna -->
<section class="hero-section py-5 mx-3">
  <div class="container">
    <div class="text-center">
      <div class="hero-badge mb-3 d-inline-block">BIENVENIDO A</div>
      <h1 class="hero-title mb-3">
        <span class="hero-title-dark">COMUNI</span><span class="hero-title-primary">SOLVE</span>
      </h1>
      <p class="hero-description mx-auto">La plataforma de gestión comunitaria que transforma tu comunidad</p>
    </div>
  </div>
</section>

<!-- 🗺️ Mapa -->
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="section-title"><i class="bi bi-map me-2"></i> Reportes en el Mapa</h2>
    <a href="/reportar" class="btn btn-primary btn-lg px-4">
      <i class="bi bi-plus-circle me-2"></i> Reportar problema
    </a>
  </div>
  <div id="map" class="shadow-lg rounded-4"></div>
</div>

<!-- 📌 Sección ¿Qué es ComuniSolve? -->
<section class="mt-5 py-5 info-section">
  <div class="container">
    <div class="text-center">
      <div class="info-badge d-inline-block mb-3">¿QUÉ ES?</div>
      <h2 class="display-5 fw-bold mb-4">Comuni<span class="text-gradient">Solve</span></h2>
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="info-card p-4 rounded-4">
            <p class="info-text mb-0">
              ComuniSolve es un software de gestión comunitaria diseñado para facilitar la participación ciudadana 
              en la <strong class="text-highlight">Comuna Socialista Nuestra Señora de las Mercedes</strong>. 
              Permite reportar problemas, ver incidencias geolocalizadas en un mapa, 
              votar por prioridades y fortalecer la organización local mediante herramientas tecnológicas accesibles y eficientes.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 📌 Sección ¿Cómo funciona? -->

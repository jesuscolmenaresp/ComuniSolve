<div class="container py-4">
  
  <!-- ========== ENCABEZADO MEJORADO ========== -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
          <h2 class="fw-bold mb-1 micalle-title">
            <i class="bi bi-house-heart me-2" style="color: #fd6704;"></i> 
            Reportes de mi calle
          </h2>
          <p class="text-muted small mb-0 micalle-subtitle">
            <i class="bi bi-pin-map-fill me-1" style="color: #fd6704;"></i> 
            <span class="fw-semibold"><%= usuario.calle_nombre || 'No asignada' %></span>
            <span class="badge bg-info rounded-pill ms-2 px-2 py-1" style="font-size: 0.65rem;">
              <i class="bi bi-file-text me-1"></i> <%= reportes.length %> reportes
            </span>
          </p>
        </div>
        <div class="d-flex gap-2">
          <a href="/reportar" class="btn btn-crear-reporte-micalle px-4 py-2 rounded-3">
            <i class="bi bi-plus-circle me-2"></i> Crear reporte
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== MENSAJES FLASH ========== -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- ========== FILTROS ========== -->
  <div class="card border-0 rounded-4 shadow-sm mb-4 overflow-hidden filtros-card-micalle">
    <div class="card-body p-4 filtros-body-micalle">
      <div class="row g-3 align-items-center">
        <div class="col-md-8">
          <ul class="nav nav-pills gap-2 flex-wrap" id="filtroTipo">
            <li class="nav-item">
              <a class="nav-link active rounded-pill px-4" data-tipo="todos" href="#">
                <i class="bi bi-grid-3x3-gap-fill me-1"></i> Todos
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link rounded-pill px-4" data-tipo="con_votos" href="#">
                <i class="bi bi-hand-thumbs-up-fill me-1"></i> Más votados
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link rounded-pill px-4" data-tipo="pendientes" href="#">
                <i class="bi bi-clock-history me-1"></i> Pendientes
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link rounded-pill px-4" data-tipo="resueltos" href="#">
                <i class="bi bi-check-circle-fill me-1"></i> Resueltos
              </a>
            </li>
          </ul>
        </div>
        <div class="col-md-4">
          <div class="input-group">
            <span class="input-group-text buscador-icon-micalle">
              <i class="bi bi-search"></i>
            </span>
            <input type="text" id="buscarReporte" class="form-control border-start-0 buscador-input-micalle" 
                   placeholder="Buscar reporte...">
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== VISTA DE TARJETAS CON WRAPPER ========== -->
  <div id="vistaTarjetas">
    <% if (reportes.length === 0) { %>
      <div class="col-12">
        <div class="card border-0 rounded-4 shadow-sm empty-card-micalle">
          <div class="card-body text-center py-5">
            <i class="bi bi-inbox fs-1 d-block mb-3 empty-icon-micalle"></i>
            <h5 class="empty-title-micalle">No hay reportes en tu calle aún</h5>
            <p class="empty-text-micalle mb-3">¡Sé el primero en reportar un problema en tu comunidad!</p>
            <a href="/reportar" class="btn btn-crear-reporte-micalle px-4 py-2 rounded-3">
              <i class="bi bi-plus-circle me-2"></i> Crear reporte
            </a>
          </div>
        </div>
      </div>
    <% } else { %>
      <% for(var i = 0; i < reportes.length; i++) { 
           var r = reportes[i];
           var anchoVotos = (r.total_votos || 0) * 10;
           if (anchoVotos > 100) anchoVotos = 100;
      %>
        <div class="reporte-tarjeta-micalle-wrapper" 
             data-estado="<%= r.estado %>" 
             data-votos="<%= r.total_votos || 0 %>"
             data-titulo="<%= r.titulo %>"
             data-descripcion="<%= r.descripcion %>">
          <div class="card border-0 rounded-4 shadow-sm h-100 reporte-tarjeta-micalle">
            
            <div class="card-body p-4">
              <!-- Encabezado -->
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h6 class="card-title mb-0 fw-bold tarjeta-titulo-micalle">
                  <%= r.titulo %>
                </h6>
                <span class="badge rounded-pill px-2 py-1 estado-badge-micalle 
                  <% if (r.estado === 'Pendiente') { %>estado-pendiente-micalle<% } 
                  else if (r.estado === 'En Progreso') { %>estado-progreso-micalle<% } 
                  else { %>estado-resuelto-micalle<% } %>">
                  <% if (r.estado === 'Pendiente') { %>
                    ⏳
                  <% } else if (r.estado === 'En Progreso') { %>
                    🔄
                  <% } else { %>
                    ✅
                  <% } %>
                </span>
              </div>
              
              <!-- Categoría -->
              <div class="mb-2">
                <span class="badge rounded-pill px-2 py-1 badge-categoria-micalle" style="font-size: 0.65rem;">
                  <%= r.categoria_icono ? r.categoria_icono + ' ' : '' %><%= r.categoria_nombre %>
                </span>
                <span class="badge bg-light text-muted rounded-pill px-2 py-1 ms-1" style="font-size: 0.6rem;">
                  <i class="bi bi-calendar3 me-1"></i> <%= new Date(r.fecha).toLocaleDateString() %>
                </span>
              </div>
              
              <!-- Descripción -->
              <p class="card-text descripcion-micalle mb-3" style="font-size: 0.85rem;">
                <% if (r.descripcion && r.descripcion.length > 80) { %>
                  <%= r.descripcion.substring(0, 80) + '...' %>
                <% } else { %>
                  <%= r.descripcion || 'Sin descripción' %>
                <% } %>
              </p>
              
              <!-- Votos y acciones -->
              <div class="d-flex justify-content-between align-items-center mt-2 flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                  <span class="badge bg-secondary rounded-pill px-2 py-1 badge-votos-micalle" style="font-size: 0.7rem;">
                    <i class="bi bi-hand-thumbs-up me-1"></i>
                    <span class="votos-count"><%= r.total_votos || 0 %></span>
                  </span>
                  <% if (r.imagen) { %>
                    <button type="button" class="btn btn-sm btn-outline-info rounded-3 px-2 py-0 btn-imagen-micalle" 
                            style="font-size: 0.7rem;"
                            onclick="verImagenGrande('<%= r.imagen %>')">
                      <i class="bi bi-image me-1"></i> Ver
                    </button>
                  <% } %>
                </div>
                
                <% if (!votosUsuario[r.id]) { %>
                  <form action="/reportes/<%= r.id %>/votar" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm rounded-3 px-2 py-1 btn-votar-micalle" 
                            style="font-size: 0.7rem;"
                            onclick="return confirm('¿Votar por este reporte?')">
                      <i class="bi bi-hand-thumbs-up me-1"></i> Votar
                    </button>
                  </form>
                <% } else { %>
                  <span class="badge bg-success rounded-pill px-2 py-1 badge-ya-votaste-micalle" style="font-size: 0.65rem;">
                    <i class="bi bi-check-circle me-1"></i> Votaste
                  </span>
                <% } %>
              </div>
            </div>
            
            <!-- Barra de apoyo -->
            <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-4">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-people-fill text-secondary small progreso-icon-micalle" style="font-size: 0.7rem;"></i>
                <div class="flex-grow-1">
                  <div class="progress progreso-bar-micalle" style="height: 4px;">
                    <div class="progress-bar progreso-barra-micalle" style="width: <%= anchoVotos %>%;">
                    </div>
                  </div>
                </div>
                <small class="progreso-texto-micalle" style="font-size: 0.6rem;"><%= r.total_votos || 0 %> apoyos</small>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>

  <!-- ========== BOTÓN VOLVER ========== -->
  <div class="text-center mt-4">
    <a href="/reportes" class="btn btn-volver-micalle px-4 py-2 rounded-3">
      <i class="bi bi-arrow-left me-2"></i> Volver a todos los reportes
    </a>
  </div>
</div>

<!-- ========== MODAL PARA VER IMAGEN ========== -->
<div class="modal fade" id="modalImagen" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-imagen-micalle">
      <div class="modal-header modal-imagen-header-micalle">
        <h5 class="modal-title text-white"><i class="bi bi-image me-2"></i> Imagen del reporte</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-4 modal-imagen-body-micalle">
        <img id="imagenGrande" src="" class="img-fluid rounded shadow-sm" style="max-height: 500px;">
      </div>
      <div class="modal-footer modal-imagen-footer-micalle">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<script>
  function verImagenGrande(src) {
    document.getElementById('imagenGrande').src = src;
    new bootstrap.Modal(document.getElementById('modalImagen')).show();
  }

  // Filtro por tipo - Corregido para usar wrappers
  document.querySelectorAll('#filtroTipo .nav-link').forEach(function(tab) {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      var tabs = document.querySelectorAll('#filtroTipo .nav-link');
      for (var i = 0; i < tabs.length; i++) {
        tabs[i].classList.remove('active');
      }
      this.classList.add('active');
      
      var tipo = this.dataset.tipo;
      var wrappers = document.querySelectorAll('.reporte-tarjeta-micalle-wrapper');
      
      for (var i = 0; i < wrappers.length; i++) {
        var wrapper = wrappers[i];
        var votos = parseInt(wrapper.dataset.votos || '0');
        var estado = wrapper.dataset.estado;
        
        // Mostrar todos primero
        wrapper.style.display = '';
        
        // Ocultar según filtro
        if (tipo === 'con_votos' && votos === 0) {
          wrapper.style.display = 'none';
        } else if (tipo === 'pendientes' && estado !== 'Pendiente') {
          wrapper.style.display = 'none';
        } else if (tipo === 'resueltos' && estado !== 'Resuelto') {
          wrapper.style.display = 'none';
        }
      }
    });
  });

  // Buscador - Corregido para usar wrappers
  var buscarInput = document.getElementById('buscarReporte');
  if (buscarInput) {
    buscarInput.addEventListener('keyup', function() {
      var texto = this.value.toLowerCase();
      var wrappers = document.querySelectorAll('.reporte-tarjeta-micalle-wrapper');
      for (var i = 0; i < wrappers.length; i++) {
        var wrapper = wrappers[i];
        var titulo = (wrapper.dataset.titulo || '').toLowerCase();
        var descripcion = (wrapper.dataset.descripcion || '').toLowerCase();
        if (titulo.indexOf(texto) === -1 && descripcion.indexOf(texto) === -1) {
          wrapper.style.display = 'none';
        } else {
          wrapper.style.display = '';
        }
      }
    });
  }
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .micalle-title {
    color: #5D4037;
  }
  .micalle-title i {
    color: #fd6704bd;
  }
  .micalle-subtitle {
    color: #8B6B5A;
  }
  
  /* Botón crear reporte */
  .btn-crear-reporte-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-crear-reporte-micalle:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Filtros */
  .filtros-card-micalle {
    background: white;
  }
  .filtros-body-micalle {
    background: white;
  }
  
  .buscador-icon-micalle {
    background-color: #fefaf7;
    border-color: #f0d5c0;
    color: #fd6704bd;
  }
  .buscador-input-micalle {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
  }
  .buscador-input-micalle:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  
  /* Nav pills */
  .nav-pills .nav-link {
    border-radius: 30px;
    padding: 6px 18px;
    transition: all 0.2s ease;
    color: #5D4037;
    font-size: 0.85rem;
  }
  .nav-pills .nav-link:hover {
    transform: translateY(-2px);
  }
  .nav-pills .nav-link.active {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  /* ========== CORRECCIÓN PARA FILTROS ========== */
  /* Contenedor de tarjetas con flex-wrap */
  #vistaTarjetas {
    display: flex !important;
    flex-wrap: wrap !important;
    gap: 1.5rem;
  }
  
  /* Cada wrapper ocupa su espacio */
  .reporte-tarjeta-micalle-wrapper {
    flex: 0 0 auto;
    width: calc(33.333% - 1rem);
    transition: all 0.3s ease;
  }
  
  /* Cuando se oculta, desaparece sin dejar hueco */
  .reporte-tarjeta-micalle-wrapper[style*="display: none"] {
    display: none !important;
  }
  
  /* Tarjetas dentro del wrapper */
  .reporte-tarjeta-micalle {
    background: white;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    height: 100%;
  }
  .reporte-tarjeta-micalle:hover {
    transform: translateY(-4px);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important;
  }
  
  /* Responsive */
  @media (max-width: 992px) {
    .reporte-tarjeta-micalle-wrapper {
      width: calc(50% - 1rem);
    }
  }
  
  @media (max-width: 768px) {
    .reporte-tarjeta-micalle-wrapper {
      width: 100%;
    }
    .nav-pills .nav-link {
      font-size: 0.75rem;
      padding: 4px 12px;
    }
  }
  
  .tarjeta-titulo-micalle {
    color: #5D4037;
    font-size: 0.95rem;
  }
  
  .estado-badge-micalle {
    font-size: 0.75rem;
    padding: 2px 8px;
  }
  .estado-pendiente-micalle {
    background-color: #ffc107;
    color: #333;
  }
  .estado-progreso-micalle {
    background-color: #17a2b8;
    color: white;
  }
  .estado-resuelto-micalle {
    background-color: #28a745;
    color: white;
  }
  
  .badge-categoria-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  .descripcion-micalle {
    color: #6c757d;
    font-size: 0.85rem;
  }
  
  .badge-votos-micalle {
    background: #6c757d;
  }
  
  .btn-imagen-micalle {
    border-color: #f0d5c0;
    color: #17a2b8;
    transition: all 0.2s ease;
  }
  .btn-imagen-micalle:hover {
    background: #17a2b8;
    color: white;
    transform: translateY(-2px);
  }
  
  .btn-votar-micalle {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    color: #333;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-votar-micalle:hover {
    transform: translateY(-2px);
  }
  
  .badge-ya-votaste-micalle {
    background: #28a745;
    color: white;
  }
  
  .progreso-icon-micalle {
    color: #fd6704bd;
  }
  .progreso-bar-micalle {
    background-color: #f0d5c0;
    border-radius: 10px;
  }
  .progreso-barra-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border-radius: 10px;
    transition: width 0.3s ease;
  }
  .progreso-texto-micalle {
    color: #8B6B5A;
  }
  
  .btn-volver-micalle {
    border: 2px solid #f0d5c0;
    color: #5D4037;
    background: transparent;
    transition: all 0.2s ease;
  }
  .btn-volver-micalle:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  .empty-card-micalle {
    background: #f8f9fa;
  }
  .empty-icon-micalle {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-title-micalle {
    color: #6c757d;
  }
  .empty-text-micalle {
    color: #6c757d;
  }
  
  .modal-imagen-micalle {
    background: white;
  }
  .modal-imagen-header-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
  }
  .modal-imagen-body-micalle {
    background: #fefaf7;
  }
  .modal-imagen-footer-micalle {
    background: #f8f9fa;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .micalle-title {
    color: #e4e4e7;
  }
  body.dark-mode .micalle-subtitle {
    color: #a1a1aa;
  }
  
  body.dark-mode .filtros-card-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .filtros-body-micalle {
    background: #1a1a2e;
  }
  
  body.dark-mode .buscador-icon-micalle {
    background-color: #3f3f46;
    border-color: #3f3f46;
    color: #f7931e;
  }
  body.dark-mode .buscador-input-micalle {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .buscador-input-micalle:focus {
    border-color: #f7931e;
  }
  body.dark-mode .buscador-input-micalle::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .reporte-tarjeta-micalle {
    background: #27272a;
  }
  body.dark-mode .tarjeta-titulo-micalle {
    color: #e4e4e7;
  }
  
  body.dark-mode .descripcion-micalle {
    color: #a1a1aa;
  }
  
  body.dark-mode .badge-votos-micalle {
    background: #3f3f46;
  }
  
  body.dark-mode .btn-imagen-micalle {
    border-color: #3f3f46;
    color: #138496;
  }
  body.dark-mode .btn-imagen-micalle:hover {
    background: #138496;
    color: white;
  }
  
  body.dark-mode .progreso-bar-micalle {
    background-color: #3f3f46;
  }
  body.dark-mode .progreso-texto-micalle {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-volver-micalle {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-micalle:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .empty-card-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .empty-icon-micalle {
    color: #a1a1aa;
  }
  body.dark-mode .empty-title-micalle {
    color: #a1a1aa;
  }
  body.dark-mode .empty-text-micalle {
    color: #a1a1aa;
  }
  
  body.dark-mode .nav-pills .nav-link {
    color: #e4e4e7;
  }
  body.dark-mode .nav-pills .nav-link.active {
    background: linear-gradient(135deg, #f7931e 0%, #e08515 100%);
  }
  
  body.dark-mode .modal-imagen-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .modal-imagen-body-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .modal-imagen-footer-micalle {
    background: #1a1a2e;
  }
  
  body.dark-mode .progress {
    background-color: #3f3f46;
  }
  
  body.dark-mode .badge.bg-light {
    background: #2d2d44 !important;
    color: #a1a1aa !important;
  }
  
  .btn-sm {
    transition: all 0.2s ease;
  }
  .badge {
    font-weight: normal;
  }
</style>
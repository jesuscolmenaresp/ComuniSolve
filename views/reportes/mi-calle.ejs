<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 micalle-title">
        <i class="bi bi-house-heart me-2"></i> Reportes de mi calle
      </h2>
      <p class="text-muted small mb-0 micalle-subtitle">
        <i class="bi bi-pin-map-fill me-1"></i> 
        <span class="fw-semibold"><%= usuario.calle_nombre || 'No asignada' %></span>
      </p>
    </div>
    <a href="/reportar" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-crear-reporte-micalle">
      <i class="bi bi-plus-circle me-1"></i> Crear nuevo reporte
    </a>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Pestañas de filtro -->
  <div class="card border-0 rounded-4 shadow-sm mb-4 overflow-hidden filtros-card-micalle">
    <div class="px-4 py-3 filtros-header-micalle">
      <h5 class="mb-0 fw-semibold">
        <i class="bi bi-funnel me-2"></i> Filtros
      </h5>
    </div>
    <div class="card-body p-4 filtros-body-micalle">
      <ul class="nav nav-pills justify-content-center gap-2 mb-4" id="filtroTipo">
        <li class="nav-item">
          <a class="nav-link active rounded-pill px-4" data-tipo="todos" href="#">
            <i class="bi bi-grid-3x3-gap-fill me-1"></i> Todos
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link rounded-pill px-4" data-tipo="con_votos" href="#">
            <i class="bi bi-hand-thumbs-up-fill me-1"></i> Más votados
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link rounded-pill px-4" data-tipo="pendientes" href="#">
            <i class="bi bi-clock-history me-1"></i> Pendientes
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link rounded-pill px-4" data-tipo="resueltos" href="#">
            <i class="bi bi-check-circle-fill me-1"></i> Resueltos
          </a>
        </li>
      </ul>
      
      <!-- Buscador -->
      <div class="row justify-content-center">
        <div class="col-md-6">
          <div class="input-group">
            <span class="input-group-text buscador-icon-micalle">
              <i class="bi bi-search"></i>
            </span>
            <input type="text" id="buscarReporte" class="form-control border-start-0 rounded-3 buscador-input-micalle" 
                   placeholder="Buscar por título o descripción...">
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Vista de tarjetas -->
  <div class="row g-4" id="vistaTarjetas">
    <% if (reportes.length === 0) { %>
      <div class="col-12">
        <div class="card border-0 rounded-4 shadow-sm empty-card-micalle">
          <div class="card-body text-center py-5">
            <i class="bi bi-inbox fs-1 d-block mb-3 empty-icon-micalle"></i>
            <h5 class="empty-title-micalle">No hay reportes en tu calle aún</h5>
            <p class="empty-text-micalle mb-3">¡Sé el primero en reportar un problema en tu comunidad!</p>
            <a href="/reportar" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-crear-reporte-micalle">
              <i class="bi bi-plus-circle me-1"></i> Crear nuevo reporte
            </a>
          </div>
        </div>
      </div>
    <% } else { %>
      <% for(var i = 0; i < reportes.length; i++) { 
           var r = reportes[i];
           var anchoVotos = (r.total_votos || 0) * 10;
           if (anchoVotos > 100) anchoVotos = 100;
      %>
        <div class="col-md-6 col-lg-6">
          <div class="card border-0 rounded-4 shadow-sm h-100 reporte-tarjeta-micalle" 
               data-estado="<%= r.estado %>" 
               data-votos="<%= r.total_votos || 0 %>"
               data-titulo="<%= r.titulo %>"
               data-descripcion="<%= r.descripcion %>">
            
            <div class="card-body p-4">
              <!-- Encabezado -->
              <div class="d-flex justify-content-between align-items-start mb-3">
                <h5 class="card-title mb-0 fw-bold tarjeta-titulo-micalle">
                  <i class="bi bi-chat-square-text me-2 tarjeta-icon-micalle"></i>
                  <%= r.titulo %>
                </h5>
                <span class="badge rounded-pill px-3 py-1 
                  <% if (r.estado === 'Pendiente') { %>estado-pendiente-micalle<% } 
                  else if (r.estado === 'En Progreso') { %>estado-progreso-micalle<% } 
                  else { %>estado-resuelto-micalle<% } %>">
                  <% if (r.estado === 'Pendiente') { %>
                    <i class="bi bi-clock-history me-1"></i> Pendiente
                  <% } else if (r.estado === 'En Progreso') { %>
                    <i class="bi bi-arrow-repeat me-1"></i> Progreso
                  <% } else { %>
                    <i class="bi bi-check-circle me-1"></i> Resuelto
                  <% } %>
                </span>
              </div>
              
              <!-- Categoría y fecha -->
              <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="badge rounded-pill px-3 py-1 badge-categoria-micalle">
                  <%= r.categoria_icono ? r.categoria_icono + ' ' : '' %><%= r.categoria_nombre %>
                </span>
                <small class="fecha-micalle">
                  <i class="bi bi-calendar3 me-1 fecha-icon-micalle"></i> <%= new Date(r.fecha).toLocaleDateString() %>
                </small>
              </div>
              
              <!-- Descripción -->
              <p class="card-text descripcion-micalle mb-3">
                <% if (r.descripcion && r.descripcion.length > 100) { %>
                  <%= r.descripcion.substring(0, 100) + '...' %>
                <% } else { %>
                  <%= r.descripcion || 'Sin descripción' %>
                <% } %>
              </p>
              
              <!-- Votos y acciones -->
              <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                  <div class="badge bg-secondary rounded-pill px-3 py-1 badge-votos-micalle">
                    <i class="bi bi-hand-thumbs-up me-1"></i>
                    <span class="votos-count"><%= r.total_votos || 0 %></span> votos
                  </div>
                  <% if (r.imagen) { %>
                    <button type="button" class="btn btn-sm btn-outline-info rounded-3 px-3 py-1 btn-imagen-micalle" 
                            onclick="verImagenGrande('<%= r.imagen %>')">
                      <i class="bi bi-image me-1"></i> Ver imagen
                    </button>
                  <% } %>
                </div>
                
                <% if (!votosUsuario[r.id]) { %>
                  <form action="/reportes/<%= r.id %>/votar" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-sm rounded-3 px-3 py-1 btn-votar-micalle" 
                            onclick="return confirm('¿Votar por este reporte?')">
                      <i class="bi bi-hand-thumbs-up me-1"></i> Votar
                    </button>
                  </form>
                <% } else { %>
                  <span class="badge bg-success rounded-pill px-3 py-1 badge-ya-votaste-micalle">
                    <i class="bi bi-check-circle me-1"></i> Ya votaste
                  </span>
                <% } %>
              </div>
            </div>
            
            <!-- Barra de progreso -->
            <div class="card-footer bg-transparent border-0 pt-0 pb-4 px-4">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-people-fill text-secondary small progreso-icon-micalle"></i>
                <div class="flex-grow-1">
                  <div class="progress progreso-bar-micalle" style="height: 6px;">
                    <div class="progress-bar progreso-barra-micalle" style="width: <%= anchoVotos %>%;">
                    </div>
                  </div>
                </div>
                <small class="progreso-texto-micalle"><%= r.total_votos || 0 %> apoyos</small>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    <% } %>
  </div>

  <!-- Botón para volver -->
  <div class="text-center mt-4">
    <a href="/reportes" class="btn btn-outline-secondary rounded-3 px-4 py-2 fw-semibold btn-volver-micalle">
      <i class="bi bi-arrow-left me-1"></i> Volver a todos los reportes
    </a>
  </div>
</div>

<!-- Modal para ver imagen -->
<div class="modal fade" id="modalImagen" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg modal-imagen-micalle">
      <div class="modal-header modal-imagen-header-micalle">
        <h5 class="modal-title text-white"><i class="bi bi-image me-2"></i> Imagen del reporte</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center p-4 modal-imagen-body-micalle">
        <img id="imagenGrande" src="" class="img-fluid rounded shadow-sm" style="max-height: 500px;">
      </div>
      <div class="modal-footer modal-imagen-footer-micalle">
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<script>
  function verImagenGrande(src) {
    document.getElementById('imagenGrande').src = src;
    new bootstrap.Modal(document.getElementById('modalImagen')).show();
  }

  // Filtro por tipo (con clases CSS)
  document.querySelectorAll('#filtroTipo .nav-link').forEach(function(tab) {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      var tabs = document.querySelectorAll('#filtroTipo .nav-link');
      for (var i = 0; i < tabs.length; i++) {
        tabs[i].classList.remove('active');
      }
      this.classList.add('active');
      
      var tipo = this.dataset.tipo;
      var tarjetas = document.querySelectorAll('.reporte-tarjeta-micalle');
      
      for (var i = 0; i < tarjetas.length; i++) {
        var tarjeta = tarjetas[i];
        var votos = parseInt(tarjeta.dataset.votos || '0');
        var estado = tarjeta.dataset.estado;
        
        tarjeta.classList.remove('filtro-oculto');
        
        if (tipo === 'con_votos' && votos === 0) {
          tarjeta.classList.add('filtro-oculto');
        } else if (tipo === 'pendientes' && estado !== 'Pendiente') {
          tarjeta.classList.add('filtro-oculto');
        } else if (tipo === 'resueltos' && estado !== 'Resuelto') {
          tarjeta.classList.add('filtro-oculto');
        }
      }
    });
  });

  // Buscador
  var buscarInput = document.getElementById('buscarReporte');
  if (buscarInput) {
    buscarInput.addEventListener('keyup', function() {
      var texto = this.value.toLowerCase();
      var tarjetas = document.querySelectorAll('.reporte-tarjeta-micalle');
      for (var i = 0; i < tarjetas.length; i++) {
        var tarjeta = tarjetas[i];
        var titulo = (tarjeta.dataset.titulo || '').toLowerCase();
        var descripcion = (tarjeta.dataset.descripcion || '').toLowerCase();
        if (titulo.indexOf(texto) === -1 && descripcion.indexOf(texto) === -1) {
          tarjeta.classList.add('filtro-oculto');
        } else {
          tarjeta.classList.remove('filtro-oculto');
        }
      }
    });
  }
</script>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .micalle-title {
    color: #5D4037;
  }
  .micalle-title i {
    color: #fd6704bd;
  }
  .micalle-subtitle {
    color: #8B6B5A;
  }
  
  /* Botón crear reporte */
  .btn-crear-reporte-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-crear-reporte-micalle:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Filtros card */
  .filtros-card-micalle {
    background: white;
  }
  .filtros-header-micalle {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
    color: #5D4037;
  }
  .filtros-body-micalle {
    background: white;
  }
  
  /* Buscador */
  .buscador-icon-micalle {
    background-color: #fefaf7;
    border-color: #f0d5c0;
    color: #fd6704bd;
  }
  .buscador-input-micalle {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
  }
  .buscador-input-micalle:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  
  /* Tarjetas de reportes */
  .reporte-tarjeta-micalle {
    background: white;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    height: 100%;
  }
  .reporte-tarjeta-micalle:hover {
    transform: translateY(-4px);
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important;
  }
  
  .tarjeta-titulo-micalle {
    color: #5D4037;
  }
  .tarjeta-icon-micalle {
    color: #fd6704bd;
  }
  
  /* Badge de estado */
  .estado-pendiente-micalle {
    background-color: #ffc107;
    color: #333;
  }
  .estado-progreso-micalle {
    background-color: #17a2b8;
    color: white;
  }
  .estado-resuelto-micalle {
    background-color: #28a745;
    color: white;
  }
  
  /* Badge de categoría */
  .badge-categoria-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  /* Fecha */
  .fecha-micalle {
    color: #8B6B5A;
  }
  .fecha-icon-micalle {
    color: #fd6704bd;
  }
  
  /* Descripción */
  .descripcion-micalle {
    color: #6c757d;
  }
  
  /* Badge de votos */
  .badge-votos-micalle {
    background: #6c757d;
  }
  
  /* Botón imagen */
  .btn-imagen-micalle {
    border-color: #f0d5c0;
    color: #17a2b8;
    transition: all 0.2s ease;
  }
  .btn-imagen-micalle:hover {
    background: #17a2b8;
    color: white;
    transform: translateY(-2px);
  }
  
  /* Botón votar */
  .btn-votar-micalle {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    color: #333;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-votar-micalle:hover {
    transform: translateY(-2px);
  }
  
  /* Badge ya votaste */
  .badge-ya-votaste-micalle {
    background: #28a745;
    color: white;
  }
  
  /* Barra de progreso */
  .progreso-icon-micalle {
    color: #fd6704bd;
  }
  .progreso-bar-micalle {
    background-color: #f0d5c0;
    border-radius: 10px;
  }
  .progreso-barra-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border-radius: 10px;
    transition: width 0.3s ease;
  }
  .progreso-texto-micalle {
    color: #8B6B5A;
  }
  
  /* Botón volver */
  .btn-volver-micalle {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-micalle:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Estado vacío */
  .empty-card-micalle {
    background: #f8f9fa;
  }
  .empty-icon-micalle {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-title-micalle {
    color: #6c757d;
  }
  .empty-text-micalle {
    color: #6c757d;
  }
  
  /* Nav pills */
  .nav-pills .nav-link {
    border-radius: 30px;
    padding: 8px 20px;
    transition: all 0.2s ease;
    color: #5D4037;
  }
  .nav-pills .nav-link:hover {
    transform: translateY(-2px);
  }
  .nav-pills .nav-link.active {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  /* Modal de imagen */
  .modal-imagen-micalle {
    background: white;
  }
  .modal-imagen-header-micalle {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
  }
  .modal-imagen-body-micalle {
    background: #fefaf7;
  }
  .modal-imagen-footer-micalle {
    background: #f8f9fa;
  }
  
  /* Ocultar tarjetas en los filtros */
  .filtro-oculto {
    display: none !important;
  }
  
  /* Responsive para móviles */
  @media (max-width: 768px) {
    #vistaTarjetas > div {
      width: 100% !important;
    }
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .micalle-title {
    color: #e4e4e7;
  }
  body.dark-mode .micalle-subtitle {
    color: #a1a1aa;
  }
  
  body.dark-mode .filtros-card-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .filtros-header-micalle {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%);
    color: #e4e4e7;
  }
  body.dark-mode .filtros-body-micalle {
    background: #1a1a2e;
  }
  
  body.dark-mode .buscador-icon-micalle {
    background-color: #3f3f46;
    border-color: #3f3f46;
    color: #f7931e;
  }
  body.dark-mode .buscador-input-micalle {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .buscador-input-micalle:focus {
    border-color: #f7931e;
  }
  body.dark-mode .buscador-input-micalle::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .reporte-tarjeta-micalle {
    background: #27272a;
  }
  body.dark-mode .tarjeta-titulo-micalle {
    color: #e4e4e7;
  }
  
  body.dark-mode .descripcion-micalle {
    color: #a1a1aa;
  }
  
  body.dark-mode .fecha-micalle {
    color: #a1a1aa;
  }
  
  body.dark-mode .badge-votos-micalle {
    background: #3f3f46;
  }
  
  body.dark-mode .btn-imagen-micalle {
    border-color: #3f3f46;
    color: #138496;
  }
  body.dark-mode .btn-imagen-micalle:hover {
    background: #138496;
    color: white;
  }
  
  body.dark-mode .progreso-bar-micalle {
    background-color: #3f3f46;
  }
  body.dark-mode .progreso-texto-micalle {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-volver-micalle {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-micalle:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .empty-card-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .empty-icon-micalle {
    color: #a1a1aa;
  }
  body.dark-mode .empty-title-micalle {
    color: #a1a1aa;
  }
  body.dark-mode .empty-text-micalle {
    color: #a1a1aa;
  }
  
  body.dark-mode .nav-pills .nav-link {
    color: #e4e4e7;
  }
  body.dark-mode .nav-pills .nav-link.active {
    background: linear-gradient(135deg, #f7931e 0%, #e08515 100%);
  }
  
  body.dark-mode .modal-imagen-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .modal-imagen-body-micalle {
    background: #1a1a2e;
  }
  body.dark-mode .modal-imagen-footer-micalle {
    background: #1a1a2e;
  }
  
  body.dark-mode .progress {
    background-color: #3f3f46;
  }
  
  .btn-sm {
    transition: all 0.2s ease;
  }
  .badge {
    font-weight: normal;
  }
</style>
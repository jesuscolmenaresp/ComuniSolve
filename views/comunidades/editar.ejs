<div class="container mt-4">
  <h2>✏️ Editar Comunidad</h2>

  <% if (session && session.error) { %>
    <div class="alert alert-danger">
      <%= session.error %>
    </div>
    <% session.error = null; %>
  <% } %>

  <form action="/comunidades/<%= comunidad.id %>/editar" method="POST" class="card p-4 shadow-sm">
    <div class="row">
      <div class="col-md-12 mb-3">
        <label class="form-label">Nombre de la comunidad *</label>
        <input type="text" name="nombre" class="form-control" 
               value="<%= comunidad.nombre %>" required>
      </div>

      <div class="col-md-12 mb-3">
        <label class="form-label">Descripción</label>
        <textarea name="descripcion" class="form-control" rows="3"><%= comunidad.descripcion || '' %></textarea>
      </div>
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-success">Actualizar</button>
      <a href="/comunidades" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>
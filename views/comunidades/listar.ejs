<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1" style="color: #5D4037;">
        <i class="bi bi-building me-2" style="color: #fd6704bd;"></i> Gestión de Comunidades
      </h2>
      <p class="text-muted small mb-0" style="color: #8B6B5A;">Administra las comunidades y sectores de la comuna</p>
    </div>
    <a href="/comunidades/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
      <i class="bi bi-plus-circle me-1"></i> Nueva Comunidad
    </a>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Tabla de comunidades -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr class="text-center">
              <th><i class="bi bi-building"></i> Nombre</th>
              <th><i class="bi bi-file-text"></i> Descripción</th>
              <th><i class="bi bi-geo-alt"></i> Calles</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (comunidades && comunidades.length > 0) { %>
              <% comunidades.forEach(c => { %>
                <tr class="align-middle text-center">
                  <td class="fw-semibold text-start" style="color: #5D4037;"><%= c.nombre %></td>
                  <td class="text-muted text-start"><%= c.descripcion || '—' %></td>
                  <td>
                    <span class="badge rounded-pill px-3 py-1" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                      <i class="bi bi-geo-alt me-1"></i> <%= c.total_calles || 0 %> calles
                    </span>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/comunidades/<%= c.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); color: #333; border: none;">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/comunidades/<%= c.id %>/eliminar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Eliminar esta comunidad? Se eliminarán también sus relaciones.')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3" 
                                style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none;">
                          <i class="bi bi-trash me-1"></i> Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center py-5">
                  <i class="bi bi-building fs-1 text-muted d-block mb-2"></i>
                  <p class="text-muted mb-0">No hay comunidades registradas</p>
                  <a href="/comunidades/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera comunidad
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted" style="color: #8B6B5A;">
      <i class="bi bi-info-circle me-1" style="color: #fd6704bd;"></i> 
      Las comunidades agrupan las calles del territorio
    </small>
  </div>
</div>

<style>
  .table-hover tbody tr:hover {
    background-color: #fff8f0 !important;
  }
  .btn-sm {
    transition: all 0.2s ease;
  }
  .btn-sm:hover {
    transform: translateY(-2px);
  }
  .badge {
    font-weight: normal;
  }
</style>
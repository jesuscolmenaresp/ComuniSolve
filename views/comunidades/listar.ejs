<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 comunidades-title">
        <i class="bi bi-building me-2"></i> Gestión de Comunidades
      </h2>
      <p class="text-muted small mb-0 comunidades-subtitle">Administra las comunidades y sectores de la comuna</p>
    </div>
    <a href="/comunidades/nueva" class="btn btn-sm px-4 py-2 fw-semibold rounded-3 btn-nueva-comunidad">
      <i class="bi bi-plus-circle me-1"></i> Nueva Comunidad
    </a>
  </div>

  <!-- Mensajes flash -->
  <% if (typeof session !== 'undefined' && session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (typeof session !== 'undefined' && session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- Tabla de comunidades -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden comunidades-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 comunidades-tabla">
          <thead class="comunidades-tabla-header">
            <tr class="text-center">
              <th><i class="bi bi-building"></i> Nombre</th>
              <th><i class="bi bi-file-text"></i> Descripción</th>
              <th><i class="bi bi-geo-alt"></i> Calles</th>
              <th><i class="bi bi-gear"></i> Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (comunidades && comunidades.length > 0) { %>
              <% comunidades.forEach(c => { %>
                <tr class="align-middle text-center comunidad-fila">
                  <td class="fw-semibold text-start comunidad-nombre"><%= c.nombre %></td>
                  <td class="comunidad-descripcion text-start"><%= c.descripcion || '—' %></td>
                  <td>
                    <span class="badge rounded-pill px-3 py-1 badge-calles">
                      <i class="bi bi-geo-alt me-1"></i> <%= c.total_calles || 0 %> calles
                    </span>
                  </td>
                  <td>
                    <div class="d-flex gap-1 justify-content-center">
                      <a href="/comunidades/<%= c.id %>/editar" class="btn btn-sm px-3 py-1 rounded-3 btn-editar-comunidad">
                        <i class="bi bi-pencil me-1"></i> Editar
                      </a>
                      <form action="/comunidades/<%= c.id %>/eliminar" method="POST" class="d-inline"
                            onsubmit="return confirm('¿Eliminar esta comunidad? Se eliminarán también sus relaciones.')">
                        <button type="submit" class="btn btn-sm px-3 py-1 rounded-3 btn-eliminar-comunidad">
                          <i class="bi bi-trash me-1"></i> Eliminar
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center py-5 empty-state-comunidades">
                  <i class="bi bi-building fs-1 d-block mb-2"></i>
                  <p class="mb-0">No hay comunidades registradas</p>
                  <a href="/comunidades/nueva" class="btn btn-sm mt-3 px-3 py-1 rounded-3 btn-crear-comunidad">
                    <i class="bi bi-plus-circle me-1"></i> Crear primera comunidad
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Badge de información -->
  <div class="text-center mt-4">
    <small class="text-muted comunidades-info">
      <i class="bi bi-info-circle me-1"></i> 
      Las comunidades agrupan las calles del territorio
    </small>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Títulos */
  .comunidades-title {
    color: #5D4037;
  }
  .comunidades-title i {
    color: #fd6704bd;
  }
  .comunidades-subtitle {
    color: #8B6B5A;
  }
  
  /* Botón nueva comunidad */
  .btn-nueva-comunidad {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-nueva-comunidad:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Tarjeta de tabla */
  .comunidades-card {
    background: white;
  }
  
  /* Tabla */
  .comunidades-tabla {
    background: white;
  }
  
  .comunidades-tabla-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);
  }
  
  .comunidades-tabla-header th {
    color: #5D4037;
    font-weight: 600;
    border-bottom: 2px solid #fd6704bd;
  }
  
  .comunidad-fila {
    border-bottom-color: #f0d5c0;
  }
  
  .comunidad-fila:hover {
    background-color: #fff8f0 !important;
  }
  
  .comunidad-nombre {
    color: #5D4037;
  }
  
  .comunidad-descripcion {
    color: #6c757d;
  }
  
  /* Badge de calles */
  .badge-calles {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
  }
  
  /* Botones de acción */
  .btn-editar-comunidad {
    background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);
    color: #333;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-editar-comunidad:hover {
    transform: translateY(-2px);
  }
  
  .btn-eliminar-comunidad {
    background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
    color: white;
    border: none;
    transition: all 0.2s ease;
  }
  .btn-eliminar-comunidad:hover {
    transform: translateY(-2px);
  }
  
  /* Estado vacío */
  .empty-state-comunidades i {
    color: #6c757d;
    opacity: 0.5;
  }
  .empty-state-comunidades p {
    color: #6c757d;
  }
  
  .btn-crear-comunidad {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    color: white;
    transition: all 0.2s ease;
  }
  .btn-crear-comunidad:hover {
    transform: translateY(-2px);
  }
  
  /* Información */
  .comunidades-info {
    color: #8B6B5A;
  }
  .comunidades-info i {
    color: #fd6704bd;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .comunidades-title {
    color: #e4e4e7;
  }
  body.dark-mode .comunidades-subtitle {
    color: #a1a1aa;
  }
  
  /* Corrección de la tabla en modo nocturno */
  body.dark-mode .comunidades-card {
    background: #1a1a2e !important;
  }
  
  body.dark-mode .comunidades-tabla {
    background-color: #1a1a2e !important;
  }
  
  body.dark-mode .comunidades-tabla tbody tr {
    background-color: #1a1a2e !important;
  }
  
  body.dark-mode .comunidades-tabla tbody tr:hover {
    background-color: #2d2d44 !important;
  }
  
  body.dark-mode .comunidades-tabla td {
    color: #e4e4e7 !important;
    background-color: transparent !important;
  }
  
  body.dark-mode .comunidades-tabla .comunidad-nombre {
    color: #e4e4e7 !important;
  }
  
  body.dark-mode .comunidades-tabla .comunidad-descripcion {
    color: #a1a1aa !important;
  }
  
  body.dark-mode .comunidades-tabla-header {
    background: linear-gradient(135deg, #2d2d44 0%, #1f1f35 100%) !important;
  }
  
  body.dark-mode .comunidades-tabla-header th {
    color: #e4e4e7 !important;
    border-bottom-color: #f7931e !important;
    background: transparent !important;
  }
  
  body.dark-mode .badge-calles {
    background: linear-gradient(135deg, #f7931e 0%, #e08515 100%);
  }
  
  body.dark-mode .btn-editar-comunidad {
    background: linear-gradient(135deg, #e0a800 0%, #c69500 100%);
    color: #333;
  }
  
  body.dark-mode .btn-eliminar-comunidad {
    background: linear-gradient(135deg, #c82333 0%, #a71d2a 100%);
  }
  
  body.dark-mode .empty-state-comunidades i {
    color: #a1a1aa;
  }
  body.dark-mode .empty-state-comunidades p {
    color: #a1a1aa;
  }
  
  body.dark-mode .comunidades-info {
    color: #a1a1aa;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .badge {
    font-weight: normal;
  }
</style>
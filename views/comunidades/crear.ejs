<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden comunidad-card">
        
        <!-- Header con gradiente dual -->
        <div class="text-center py-4 px-3 comunidad-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="comunidad-icon-wrapper">
              <i class="bi bi-building fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold comunidad-title">Nueva Comunidad</h3>
          <p class="small mb-0 mt-1 comunidad-subtitle">Registra un nuevo sector o comunidad en la comuna</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 comunidad-body">
          
          <!-- Botón volver -->
          <div class="d-flex justify-content-end mb-3">
            <a href="/comunidades" class="btn btn-sm px-3 py-1 rounded-3 btn-volver-comunidad">
              <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
          </div>

          <!-- Mensajes de error -->
          <% if (typeof session !== 'undefined' && session && session.error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> 
              <small><%= session.error %></small>
              <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
            </div>
            <% session.error = null; %>
          <% } %>

          <!-- Formulario -->
          <form action="/comunidades" method="POST">
            
            <!-- Nombre -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 comunidad-label">
                <i class="bi bi-building me-1"></i> Nombre de la comunidad *
              </label>
              <input type="text" name="nombre" class="form-control rounded-3 comunidad-input" required
                     placeholder="Ej: Virgen de Lourdes, Las Mercedes, Brisas de las Mercedes">
              <small class="text-muted comunidad-help">Nombre del sector o comunidad dentro de la comuna</small>
            </div>

            <!-- Descripción -->
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 comunidad-label">
                <i class="bi bi-file-text me-1"></i> Descripción (opcional)
              </label>
              <textarea name="descripcion" class="form-control rounded-3 comunidad-textarea" rows="3"
                        placeholder="Breve descripción de la comunidad..."></textarea>
            </div>

            <!-- Botones -->
            <div class="d-flex gap-3 mt-4 pt-2">
              <button type="submit" class="btn px-4 py-2 fw-semibold rounded-3 btn-guardar-comunidad">
                <i class="bi bi-save me-2"></i> Guardar comunidad
              </button>
              <a href="/comunidades" class="btn btn-outline-secondary px-4 py-2 fw-semibold rounded-3 btn-cancelar-comunidad">
                <i class="bi bi-x-circle me-2"></i> Cancelar
              </a>
            </div>

          </form>

          <!-- Badges de información -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 comunidad-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 comunidad-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  /* Tarjeta principal */
  .comunidad-card {
    background: #ffffff;
  }
  
  /* Header con gradiente dual */
  .comunidad-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .comunidad-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .comunidad-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .comunidad-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  /* Body */
  .comunidad-body {
    background: #ffffff;
  }
  
  /* Botón volver */
  .btn-volver-comunidad {
    border: 1px solid #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-volver-comunidad:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Labels */
  .comunidad-label {
    color: #5D4037;
  }
  .comunidad-label i {
    color: #fd6704bd;
  }
  
  /* Inputs y textarea */
  .comunidad-input, .comunidad-textarea {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .comunidad-input:focus, .comunidad-textarea:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  /* Ayuda */
  .comunidad-help {
    color: #8B6B5A;
  }
  
  /* Botón guardar */
  .btn-guardar-comunidad {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-guardar-comunidad:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  /* Botón cancelar */
  .btn-cancelar-comunidad {
    border-color: #f0d5c0;
    color: #5D4037;
    transition: all 0.2s ease;
  }
  .btn-cancelar-comunidad:hover {
    background: #f0d5c0;
    transform: translateY(-2px);
  }
  
  /* Badges */
  .comunidad-badge {
    color: #8B6B5A !important;
  }
  .comunidad-badge i {
    color: #17a2b8;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .comunidad-card {
    background: #27272a;
  }
  
  body.dark-mode .comunidad-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .comunidad-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .comunidad-body {
    background: #27272a;
  }
  
  body.dark-mode .btn-volver-comunidad {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-volver-comunidad:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .comunidad-label {
    color: #e4e4e7;
  }
  body.dark-mode .comunidad-label i {
    color: #f7931e;
  }
  
  body.dark-mode .comunidad-input,
  body.dark-mode .comunidad-textarea {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .comunidad-input:focus,
  body.dark-mode .comunidad-textarea:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .comunidad-input::placeholder,
  body.dark-mode .comunidad-textarea::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .comunidad-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .btn-cancelar-comunidad {
    border-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .btn-cancelar-comunidad:hover {
    background: #3f3f46;
  }
  
  body.dark-mode .comunidad-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .comunidad-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
  }
  
  /* Transiciones */
  .btn-sm, .btn {
    transition: all 0.2s ease;
  }
  
  .form-control:focus, .form-select:focus, .form-textarea:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
  }
  body.dark-mode .form-control:focus, 
  body.dark-mode .form-select:focus, 
  body.dark-mode .form-textarea:focus {
    border-color: #f7931e;
  }
</style>
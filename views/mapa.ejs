<div class="container py-4">
  
  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h2 class="fw-bold mb-1 mapa-title">
        <i class="bi bi-map me-2"></i> Mapa de Reportes Ciudadanos
      </h2>
      <p class="text-muted small mb-0 mapa-subtitle">Visualiza geográficamente las incidencias reportadas en tu comunidad</p>
    </div>
    <a href="/reportar" class="btn px-4 py-2 fw-semibold rounded-3 btn-mapa-primary">
      <i class="bi bi-plus-circle me-2"></i> Reportar problema
    </a>
  </div>

  <!-- Tarjetas de estadísticas -->
  <div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-mapa stat-card-total-mapa">
        <i class="bi bi-file-text fs-2 stat-icon-mapa-total"></i>
        <h3 class="fw-bold mb-0 stat-number-mapa-total" id="totalReportes">0</h3>
        <small class="text-muted stat-label-mapa-total">Total reportes</small>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-mapa stat-card-pendiente-mapa">
        <i class="bi bi-clock-history fs-2 stat-icon-mapa-pendiente"></i>
        <h3 class="fw-bold mb-0 stat-number-mapa-pendiente" id="pendientesReportes">0</h3>
        <small class="text-muted stat-label-mapa-pendiente">Pendientes</small>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-mapa stat-card-progreso-mapa">
        <i class="bi bi-arrow-repeat fs-2 stat-icon-mapa-progreso"></i>
        <h3 class="fw-bold mb-0 stat-number-mapa-progreso" id="progresoReportes">0</h3>
        <small class="text-muted stat-label-mapa-progreso">En Progreso</small>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 rounded-4 shadow-sm text-center p-2 stat-card-mapa stat-card-resuelto-mapa">
        <i class="bi bi-check-circle fs-2 stat-icon-mapa-resuelto"></i>
        <h3 class="fw-bold mb-0 stat-number-mapa-resuelto" id="resueltosReportes">0</h3>
        <small class="text-muted stat-label-mapa-resuelto">Resueltos</small>
      </div>
    </div>
  </div>

  <!-- Mapa -->
  <div class="card border-0 rounded-4 shadow-sm overflow-hidden mb-4 mapa-card">
    <div id="map" style="height: 500px; width: 100%;"></div>
  </div>

  <!-- Filtros y leyenda -->
  <div class="row g-3">
    <div class="col-md-8">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden filtros-card-mapa">
        <div class="px-4 py-2 filtros-header-mapa">
          <h6 class="mb-0 fw-semibold"><i class="bi bi-funnel me-2"></i> Filtrar por categoría</h6>
        </div>
        <div class="card-body p-3 filtros-body-mapa">
          <div class="d-flex flex-wrap gap-2" id="filtrosCategorias">
            <button class="btn btn-sm rounded-pill px-3 filtro-categoria active" data-categoria="todos" style="--cat-color: #fd6704bd;">
              <i class="bi bi-globe me-1"></i> Todos
            </button>
            <!-- Los botones se generarán dinámicamente con JavaScript -->
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 rounded-4 shadow-sm overflow-hidden leyenda-card-mapa">
        <div class="px-4 py-2 leyenda-header-mapa">
          <h6 class="mb-0 fw-semibold"><i class="bi bi-info-circle me-2"></i> Estado de reportes</h6>
        </div>
        <div class="card-body p-3 leyenda-body-mapa">
          <div class="d-flex flex-wrap gap-3 align-items-center">
            <span class="d-flex align-items-center gap-1"><span style="display: inline-block; width: 12px; height: 12px; background-color: #ffc107; border-radius: 50%;"></span> <small>Pendiente</small></span>
            <span class="d-flex align-items-center gap-1"><span style="display: inline-block; width: 12px; height: 12px; background-color: #17a2b8; border-radius: 50%;"></span> <small>En Progreso</small></span>
            <span class="d-flex align-items-center gap-1"><span style="display: inline-block; width: 12px; height: 12px; background-color: #28a745; border-radius: 50%;"></span> <small>Resuelto</small></span>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Leaflet CSS y JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  // ========================================
  // 1. DATOS DE REPORTES
  // ========================================
  const reportes = <%- JSON.stringify(reportes) %>;
  
  // ========================================
  // 2. MAPA DE COLORES PARA CATEGORÍAS
  // ========================================
  const coloresCategorias = [
    '#0d6efd', '#dc3545', '#28a745', '#ffc107', '#17a2b8',
    '#6f42c1', '#fd7e14', '#20c997', '#d63384', '#0dcaf0',
    '#198754', '#3b82f6', '#8b5cf6', '#f59e0b', '#10b981'
  ];

  let colorIndex = 0;
  const categoriaColores = {};

  function getColorCategoria(categoria) {
    if (!categoria) return '#6c757d';
    if (categoriaColores[categoria]) return categoriaColores[categoria];
    const color = coloresCategorias[colorIndex % coloresCategorias.length];
    categoriaColores[categoria] = color;
    colorIndex++;
    return color;
  }

  // ========================================
  // 3. INICIALIZAR MAPA
  // ========================================
  const map = L.map('map').setView([10.042, -67.489], 14);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
  }).addTo(map);

  // ========================================
  // 4. FUNCIONES AUXILIARES
  // ========================================
  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function getColorEstado(estado) {
    switch(estado) {
      case 'Pendiente': return '#ffc107';
      case 'En Progreso': return '#17a2b8';
      case 'Resuelto': return '#28a745';
      default: return '#6c757d';
    }
  }

  // ========================================
  // 5. OBTENER CATEGORÍAS ÚNICAS
  // ========================================
  const categoriasUnicas = [];
  reportes.forEach(r => {
    if (r.categoria_nombre && !categoriasUnicas.includes(r.categoria_nombre)) {
      categoriasUnicas.push(r.categoria_nombre);
    }
  });

  // Si no hay categorías, usar algunas por defecto
  if (categoriasUnicas.length === 0) {
    categoriasUnicas.push('Agua', 'Electricidad', 'Vialidad', 'Salud', 'Ambiente');
  }

  // ========================================
  // 6. ACTUALIZAR ESTADÍSTICAS
  // ========================================
  document.getElementById('totalReportes').textContent = reportes.length;
  document.getElementById('pendientesReportes').textContent = reportes.filter(r => r.estado === 'Pendiente').length;
  document.getElementById('progresoReportes').textContent = reportes.filter(r => r.estado === 'En Progreso').length;
  document.getElementById('resueltosReportes').textContent = reportes.filter(r => r.estado === 'Resuelto').length;

  // ========================================
  // 7. CREAR BOTONES DE FILTRO DINÁMICAMENTE
  // ========================================
  const contenedorBotones = document.getElementById('filtrosCategorias');

  categoriasUnicas.forEach(cat => {
    const btn = document.createElement('button');
    btn.className = 'btn btn-sm rounded-pill px-3 filtro-categoria';
    btn.dataset.categoria = cat;
    const color = getColorCategoria(cat);
    btn.style.setProperty('--cat-color', color);
    btn.innerHTML = `<span class="cat-dot" style="background-color: ${color};"></span> ${cat}`;
    contenedorBotones.appendChild(btn);
  });

  // ========================================
  // 8. CREAR MARCADORES POR CATEGORÍA
  // ========================================
  const markers = {};
  let todosLosMarcadores = L.layerGroup().addTo(map);

  // Inicializar grupos por categoría
  categoriasUnicas.forEach(cat => {
    markers[cat] = L.layerGroup();
  });

  // Agregar marcadores
  reportes.forEach(r => {
    if (r.ubicacion_lat && r.ubicacion_lng) {
      const categoria = r.categoria_nombre || 'Sin categoría';
      const catColor = getColorCategoria(categoria);
      const estadoColor = getColorEstado(r.estado);

      const marker = L.circleMarker([r.ubicacion_lat, r.ubicacion_lng], {
        radius: 10,
        fillColor: estadoColor,
        color: catColor,
        weight: 3,
        opacity: 1,
        fillOpacity: 0.8
      });

      // Popup
      let popupContent = `
        <div style="min-width: 220px; max-width: 280px;">
          <h6 class="mb-1 fw-bold" style="color: #5D4037;">${escapeHtml(r.titulo || 'Sin título')}</h6>
          <p class="small text-muted mb-2">${escapeHtml(r.descripcion ? r.descripcion.substring(0, 100) + (r.descripcion.length > 100 ? '...' : '') : 'Sin descripción')}</p>
          <div class="mb-2">
            <span class="badge px-2 py-1 rounded-pill me-1" style="background-color: ${catColor}; color: white;">
              ${r.categoria_nombre || 'Sin categoría'}
            </span>
            <span class="badge px-2 py-1 rounded-pill" style="background-color: ${estadoColor}; color: ${r.estado === 'Pendiente' ? '#333' : 'white'};">
              ${r.estado || 'Pendiente'}
            </span>
          </div>
          <div class="small">
            <div><i class="bi bi-geo-alt me-1"></i> ${escapeHtml(r.nombre_calle || 'Sin calle')}</div>
            <div><i class="bi bi-calendar me-1"></i> ${r.fecha ? new Date(r.fecha).toLocaleDateString() : 'Sin fecha'}</div>
          </div>
      `;
      
      if (r.imagen) {
        popupContent += `<div class="mt-2"><img src="${r.imagen}" style="max-width: 100%; max-height: 100px; border-radius: 8px; object-fit: cover; cursor: pointer;" onclick="window.open('${r.imagen}', '_blank')"></div>`;
      }
      
      popupContent += `</div>`;
      
      marker.bindPopup(popupContent);
      
      // Agregar al grupo correspondiente
      if (markers[categoria]) {
        markers[categoria].addLayer(marker);
      } else {
        markers['Sin categoría'] = L.layerGroup();
        markers['Sin categoría'].addLayer(marker);
      }
      todosLosMarcadores.addLayer(marker);
    }
  });

  // ========================================
  // 9. FUNCIÓN DE FILTRADO
  // ========================================
  function filtrarPorCategoria(categoria) {
    map.removeLayer(todosLosMarcadores);
    Object.keys(markers).forEach(cat => {
      map.removeLayer(markers[cat]);
    });
    
    if (categoria === 'todos') {
      map.addLayer(todosLosMarcadores);
    } else {
      if (markers[categoria]) {
        map.addLayer(markers[categoria]);
      }
    }
  }

  // ========================================
  // 10. EVENTOS DE FILTRO
  // ========================================
  contenedorBotones.addEventListener('click', function(e) {
    const btn = e.target.closest('.filtro-categoria');
    if (!btn) return;

    const categoria = btn.dataset.categoria;
      
    document.querySelectorAll('.filtro-categoria').forEach(b => {
      b.classList.remove('active');
    });
      
    btn.classList.add('active');
    filtrarPorCategoria(categoria);
  });

  // ========================================
  // 11. AJUSTAR MAPA A LOS MARCADORES
  // ========================================
  const puntos = reportes.filter(r => r.ubicacion_lat && r.ubicacion_lng);
  if (puntos.length > 0) {
    const group = L.featureGroup(puntos.map(r => L.marker([r.ubicacion_lat, r.ubicacion_lng])));
    if (group.getLayers().length > 0) {
      map.fitBounds(group.getBounds().pad(0.1));
    }
  } else {
    map.setView([10.042, -67.489], 14);
  }
</script>


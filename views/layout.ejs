<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ComuniSolve - <%- typeof title !== 'undefined' ? title : 'Gestión Comunitaria' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- 🔹 Header -->
  <header>
    <nav class="navbar navbar-expand-lg navbar-light px-4 shadow-sm">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">
          <img src="/images/isotipo.png" alt="ComuniSolve" style="height: 60px;">
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <!-- Módulos públicos (visibles para todos) -->
            <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house-door"></i> Inicio</a></li>
            <li class="nav-item"><a class="nav-link" href="/mapas"><i class="bi bi-map"></i> Mapas</a></li>
            
            <!-- Voluntarios para no logueados -->
            <% if (!usuario) { %>
              <li class="nav-item"><a class="nav-link" href="/voluntarios/publico"><i class="bi bi-people"></i> Voluntarios</a></li>
            <% } %>
            
            <!-- Módulos para Ciudadano (rol 4) -->
            <% if (usuario && usuario.rol_id === 4) { %>
              <li class="nav-item"><a class="nav-link" href="/reportes"><i class="bi bi-file-text"></i> Mis Reportes</a></li>
              <li class="nav-item"><a class="nav-link" href="/reportes/mi-calle"><i class="bi bi-house-heart"></i> Reportes de mi calle</a></li>
              <% if (esVoluntario) { %>
                <li class="nav-item"><a class="nav-link" href="/voluntarios/mi-perfil"><i class="bi bi-person-badge"></i> Mi Perfil Voluntario</a></li>
              <% } else { %>
                <li class="nav-item"><a class="nav-link" href="/voluntarios"><i class="bi bi-person-plus"></i> Ser Voluntario</a></li>
              <% } %>
            <% } %>
            
            <!-- Módulos para Líder (rol 2) -->
            <% if (usuario && usuario.rol_id === 2) { %>
              <li class="nav-item"><a class="nav-link" href="/reportes"><i class="bi bi-file-text"></i> Mis Reportes</a></li>
              <li class="nav-item"><a class="nav-link" href="/voluntarios/gestionar"><i class="bi bi-person-check"></i> Gestionar Voluntarios</a></li>
            <% } %>
            
            <!-- Módulos para Jefe de Calle (rol 3) -->
            <% if (usuario && usuario.rol_id === 3) { %>
              <li class="nav-item"><a class="nav-link" href="/reportes"><i class="bi bi-file-text"></i> Mis Reportes</a></li>
            <% } %>
            
            <!-- Módulos de gestión (solo para UBCH) -->
            <% if (usuario && usuario.rol_id === 1) { %>
              <li class="nav-item"><a class="nav-link" href="/reportes"><i class="bi bi-file-text"></i> Reportes</a></li>
              
              <!-- Dropdown Gestión -->
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="bi bi-gear"></i> Gestión
                </a>
                <ul class="dropdown-menu">
                  <li><a class="dropdown-item" href="/categorias"><i class="bi bi-tags"></i> Categorías</a></li>
                  <li><a class="dropdown-item" href="/empresas"><i class="bi bi-building"></i> Empresas</a></li>
                  <li><a class="dropdown-item" href="/comunidades"><i class="bi bi-people-fill"></i> Comunidades</a></li>
                  <li><a class="dropdown-item" href="/calles"><i class="bi bi-geo-alt"></i> Calles</a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="dropdown-item" href="/voluntarios/gestionar"><i class="bi bi-person-check"></i> Gestionar Voluntarios</a></li>
                  <li><a class="dropdown-item" href="/auditoria"><i class="bi bi-clock-history"></i> Auditoría</a></li>
                </ul>
              </li>
              
              <!-- Dropdown Usuarios -->
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                  <i class="bi bi-people"></i> Usuarios
                </a>
                <ul class="dropdown-menu">
                  <li><a class="dropdown-item" href="/usuarios"><i class="bi bi-list-ul"></i> Listar usuarios</a></li>
                  <li><a class="dropdown-item" href="/usuarios/nuevo"><i class="bi bi-person-plus"></i> Crear usuario</a></li>
                </ul>
              </li>
            <% } %>
            
            <!-- Login / Registro / Logout -->
            <% if (!usuario) { %>
              <li class="nav-item">
                <a class="btn btn-outline-success ms-2" href="/registro"><i class="bi bi-person-plus"></i> Registrarse</a>
              </li>
              <li class="nav-item">
                <a class="btn btn-primary ms-2" href="/login"><i class="bi bi-box-arrow-in-right"></i> Iniciar sesión</a>
              </li>
            <% } else { %>
              <li class="nav-item">
                <span class="navbar-text me-2"><i class="bi bi-person-circle"></i> Hola, <strong><%= usuario.nombre %></strong></span>
              </li>
              <li class="nav-item">
                <a class="btn btn-outline-danger ms-2" href="/logout"><i class="bi bi-box-arrow-right"></i> Salir</a>
              </li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>
  </header>

  <!-- 🔹 Contenido principal -->
  <main class="container mt-4">
    <%- body %>
  </main>

  <!-- 🔹 Footer con fondo de iglesia -->
  <footer class="mt-5 py-4 text-center" style="background: linear-gradient(rgba(252, 233, 216, 0.85), rgba(252, 233, 216, 0.85)), url('/images/iglesia-mercedes.jpg'); background-size: cover; background-position: center;">
    <div class="container">
      <div class="row">
        <div class="col-md-4 mb-3">
          <img src="/images/logotipo.png" alt="ComuniSolve" style="height: 80px;">
        </div>
        <div class="col-md-4 mb-3">
          <p class="mb-0">© <%= new Date().getFullYear() %> ComuniSolve</p>
          <p class="small">Todos los derechos reservados</p>
        </div>
        <div class="col-md-4 mb-3">
          <p class="small mb-0">Villa de Cura, Estado Aragua</p>
          <p class="small">Comuna Socialista Nuestra Señora de las Mercedes</p>
        </div>
      </div>
    </div>
  </footer>

  <!-- Scripts comunes -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2>📋 Lista de Reportes</h2>
    <a href="/reportar" class="btn btn-primary">
      ➕ Crear nuevo reporte
    </a>
  </div>

  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= session.mensaje %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <%= session.error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- FILTROS AVANZADOS (visible para todos los roles) -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header bg-light">
      <h5 class="mb-0">
        <i class="bi bi-funnel"></i> Filtros avanzados
        <button class="btn btn-sm btn-link float-end" type="button" data-bs-toggle="collapse" data-bs-target="#filtrosCollapse">
          <i class="bi bi-chevron-down"></i>
        </button>
      </h5>
    </div>
    <div class="collapse show" id="filtrosCollapse">
      <div class="card-body">
        <form id="formFiltros" method="GET" action="/reportes" class="row g-3">
          <!-- Búsqueda por texto -->
          <div class="col-md-4">
            <label class="form-label">🔍 Buscar</label>
            <div class="input-group">
              <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
              <input type="text" name="search" id="searchInput" class="form-control" 
                     placeholder="Título o descripción..." value="<%= search || '' %>">
            </div>
          </div>
          
          <!-- Estado -->
          <div class="col-md-2">
            <label class="form-label">📌 Estado</label>
            <select name="estado" id="estadoSelect" class="form-select">
              <option value="todos">Todos</option>
              <option value="Pendiente">⏳ Pendiente</option>
              <option value="En Progreso">🔄 En Progreso</option>
              <option value="Resuelto">✅ Resuelto</option>
            </select>
          </div>
          
          <!-- Categoría (solo para roles 1,2,3) -->
          <div class="col-md-3">
            <label class="form-label">🏷️ Categoría</label>
            <select name="categoria_id" id="categoriaSelect" class="form-select">
              <option value="todos">Todas</option>
              <% if (categorias && categorias.length > 0) { %>
                <% categorias.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.nombre %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          
          <!-- Calle (solo para roles 1,2,3) -->
          <div class="col-md-3">
            <label class="form-label">📍 Calle</label>
            <select name="calle_id" id="calleSelect" class="form-select">
              <option value="todos">Todas</option>
              <% if (calles && calles.length > 0) { %>
                <% calles.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.nombre %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          
          <!-- Fecha desde -->
          <div class="col-md-3">
            <label class="form-label">📅 Desde</label>
            <input type="date" name="fecha_desde" id="fechaDesde" class="form-control" value="<%= fecha_desde || '' %>">
          </div>
          
          <!-- Fecha hasta -->
          <div class="col-md-3">
            <label class="form-label">📅 Hasta</label>
            <input type="date" name="fecha_hasta" id="fechaHasta" class="form-control" value="<%= fecha_hasta || '' %>">
          </div>
          
          <!-- Botones -->
          <div class="col-12 d-flex gap-2 justify-content-end">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-search"></i> Filtrar
            </button>
            <button type="button" id="btnLimpiarFiltros" class="btn btn-secondary">
              <i class="bi bi-x-circle"></i> Limpiar
            </button>
            
            <!-- EXPORTACIÓN (solo para roles 1,2,3) -->
            <% if (usuario && [1,2,3].includes(usuario.rol_id)) { %>
              <div class="btn-group">
                <button type="button" class="btn btn-success dropdown-toggle" data-bs-toggle="dropdown">
                  <i class="bi bi-download"></i> Exportar
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a href="#" id="btnExportarExcel" class="dropdown-item"><i class="bi bi-file-excel text-success"></i> Excel</a></li>
                  <li><a href="#" id="btnExportarPDF" class="dropdown-item"><i class="bi bi-file-pdf text-danger"></i> PDF</a></li>
                </ul>
              </div>
            <% } %>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- TABLA DE REPORTES -->
  <div class="table-responsive">
    <table class="table table-striped table-hover table-sm align-middle" id="tablaReportes">
      <thead class="table-dark">
        <tr>
          <th>Título</th>
          <th>Descripción</th>
          <th>Categoría</th>
          <th>Calle</th>
          <th>Fecha</th>
          <th>Votos</th>
          <th>Estado</th>
          <% if (usuario && [1,2,3].includes(usuario.rol_id)) { %>
            <th>Acciones</th>
          <% } %>
          <% if (usuario && usuario.rol_id === 4) { %>
            <th>Votar</th>
          <% } %>
          <th>Detalles</th>
        </tr>
      </thead>
      <tbody>
        <% if (reportes.length === 0) { %>
          <tr>
            <td colspan="9" class="text-center text-muted">No hay reportes registrados.</td>
          </tr>
        <% } else { %>
          <% reportes.forEach(r => { %>
            <tr class="reporte-fila" data-estado="<%= r.estado %>" data-id="<%= r.id %>" style="cursor: pointer;">
              <td><strong><%= r.titulo %></strong></td>
              <td><%= r.descripcion.length > 50 ? r.descripcion.substring(0,50) + '...' : r.descripcion %></td>
              <td><span class="badge bg-<%= r.categoria_color || 'primary' %>"><%= r.categoria_icono ? r.categoria_icono + ' ' : '' %><%= r.categoria_nombre %></span></td>
              <td><%= r.nombre_calle %></td>
              <td><%= new Date(r.fecha).toLocaleDateString() %></td>
              <td class="text-center"><span class="badge bg-secondary">👍 <%= r.total_votos || 0 %></span></td>
              <td><span class="badge <%= r.estado === 'Pendiente' ? 'bg-warning' : r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>"><%= r.estado %></span></td>
              
              <!-- Acciones -->
              <% if (usuario && [1,2,3].includes(usuario.rol_id)) { %>
                <td>
                  <form action="/reportes/<%= r.id %>/estado" method="POST" class="d-flex gap-1">
                    <select name="estado" class="form-select form-select-sm" style="width: 100px;">
                      <option value="Pendiente" <%= r.estado === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
                      <option value="En Progreso" <%= r.estado === 'En Progreso' ? 'selected' : '' %>>Progreso</option>
                      <option value="Resuelto" <%= r.estado === 'Resuelto' ? 'selected' : '' %>>Resuelto</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-success">✔️</button>
                  </form>
                </td>
              <% } %>

              <!-- Votar -->
              <% if (usuario && usuario.rol_id === 4) { %>
                <td class="text-center">
                  <% if (!votosUsuario[r.id]) { %>
                    <form action="/reportes/<%= r.id %>/votar" method="POST">
                      <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('¿Votar por este reporte?')">👍 Votar</button>
                    </form>
                  <% } else { %>
                    <span class="badge bg-success">✓ Ya votaste</span>
                  <% } %>
                </td>
              <% } %>

              <!-- Botón detalles -->
              <td class="text-center">
                <button class="btn btn-sm btn-outline-info ver-detalle" data-id="<%= r.id %>">
                  🔍 Ver
                </button>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- MODALES (igual que antes) -->
<div class="modal fade" id="modalReporteDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">📋 Detalles del Reporte</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="detalleReporteContent">
        <div class="text-center">Cargando...</div>
      </div>
      <div class="modal-footer d-flex flex-wrap gap-2 justify-content-between">
        <% if (usuario && [1,2].includes(usuario.rol_id) && empresas && empresas.length > 0) { %>
          <div id="asignarEmpresaSection" style="display: none;" class="me-auto">
            <form id="formAsignarEmpresa" method="POST" class="d-flex gap-2 align-items-center">
              <select name="empresa_id" class="form-select form-select-sm" style="width: 220px;">
                <option value="">-- Seleccionar empresa --</option>
                <% empresas.forEach(e => { %>
                  <option value="<%= e.id %>"><%= e.nombre %></option>
                <% }) %>
              </select>
              <button type="submit" class="btn btn-sm btn-primary">🏢 Asignar empresa</button>
            </form>
          </div>
        <% } %>
        
        <% if (usuario && [1,2].includes(usuario.rol_id)) { %>
          <div id="asignarVoluntarioSection" style="display: none;" class="me-auto">
            <form id="formAsignarVoluntario" method="POST" class="d-flex gap-2 align-items-center">
              <input type="hidden" name="reporte_id" id="reporte_id_voluntario">
              <select name="voluntario_id" class="form-select form-select-sm" style="width: 220px;" required>
                <option value="">-- Seleccionar voluntario --</option>
              </select>
              <button type="submit" class="btn btn-sm btn-success">👥 Asignar voluntario</button>
            </form>
          </div>
        <% } %>
        
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalImagen" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">📸 Imagen del reporte</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center">
        <img id="imagenGrande" src="" class="img-fluid rounded" style="max-height: 500px;">
      </div>
    </div>
  </div>
</div>

<script>
  // Preseleccionar valores de los filtros
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('estado')) document.getElementById('estadoSelect').value = urlParams.get('estado');
  if (urlParams.get('categoria_id')) document.getElementById('categoriaSelect').value = urlParams.get('categoria_id');
  if (urlParams.get('calle_id')) document.getElementById('calleSelect').value = urlParams.get('calle_id');
  if (urlParams.get('search')) document.getElementById('searchInput').value = urlParams.get('search');
  if (urlParams.get('fecha_desde')) document.getElementById('fechaDesde').value = urlParams.get('fecha_desde');
  if (urlParams.get('fecha_hasta')) document.getElementById('fechaHasta').value = urlParams.get('fecha_hasta');
  
  // Limpiar filtros
  document.getElementById('btnLimpiarFiltros').addEventListener('click', function() {
    window.location.href = '/reportes';
  });
  
  // Actualizar enlaces de exportación (solo si existen los botones)
  function actualizarEnlacesExportacion() {
    const params = new URLSearchParams();
    const estado = document.getElementById('estadoSelect')?.value;
    const categoriaId = document.getElementById('categoriaSelect')?.value;
    const calleId = document.getElementById('calleSelect')?.value;
    const search = document.getElementById('searchInput')?.value;
    const fechaDesde = document.getElementById('fechaDesde')?.value;
    const fechaHasta = document.getElementById('fechaHasta')?.value;
    
    if (estado && estado !== 'todos') params.append('estado', estado);
    if (categoriaId && categoriaId !== 'todos') params.append('categoria_id', categoriaId);
    if (calleId && calleId !== 'todos') params.append('calle_id', calleId);
    if (search) params.append('search', search);
    if (fechaDesde) params.append('fecha_desde', fechaDesde);
    if (fechaHasta) params.append('fecha_hasta', fechaHasta);
    
    const queryString = params.toString();
    const excelBtn = document.getElementById('btnExportarExcel');
    const pdfBtn = document.getElementById('btnExportarPDF');
    
    if (excelBtn) excelBtn.href = `/reportes/exportar/excel${queryString ? '?' + queryString : ''}`;
    if (pdfBtn) pdfBtn.href = `/reportes/exportar/pdf${queryString ? '?' + queryString : ''}`;
  }
  
  // Escuchar cambios en los filtros
  const filtros = ['estadoSelect', 'categoriaSelect', 'calleSelect', 'searchInput', 'fechaDesde', 'fechaHasta'];
  filtros.forEach(id => {
    const element = document.getElementById(id);
    if (element) {
      element.addEventListener('change', actualizarEnlacesExportacion);
      element.addEventListener('keyup', actualizarEnlacesExportacion);
    }
  });
  
  function verImagenGrande(src) {
    document.getElementById('imagenGrande').src = src;
    new bootstrap.Modal(document.getElementById('modalImagen')).show();
  }
  
  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
  
  actualizarEnlacesExportacion();
</script>

<style>
  .table-sm td, .table-sm th { padding: 0.5rem; vertical-align: middle; }
  .badge { font-weight: normal; }
  .reporte-fila { cursor: pointer; }
  .reporte-fila:hover { background-color: #fff8f0 !important; }
  .ver-detalle:hover { transform: scale(1.05); transition: transform 0.2s; }
  .btn-sm { transition: all 0.2s ease; }
  .card-header .btn-link { text-decoration: none; }
</style>
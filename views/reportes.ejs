<div class="container mt-4">
  <h2 class="mb-4 text-center">📋 Lista de Reportes</h2>

  <div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
      <thead class="table-dark">
        <tr>
          <th>Título</th>
          <th>Descripción</th>
          <th>Categoría</th>
          <th>Calle</th>
          <th>Reportado por</th>
          <th>Fecha</th>
          <th>Imagen</th> <!-- 👈 nueva columna -->
          <th>Estado</th>
          <% if (usuario && [1,2,3].includes(usuario.rol_id)) { %>
            <th>Acciones</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (reportes.length === 0) { %>
          <tr>
            <td colspan="9" class="text-center text-muted">
              No hay reportes registrados.
            </td>
          </tr>
        <% } else { %>
          <% reportes.forEach(r => { %>
            <tr>
              <td><strong><%= r.titulo %></strong></td>
              <td><%= r.descripcion %></td>
              <td>
                <span class="badge bg-primary"><%= r.categoria %></span>
              </td>
              <td><%= r.nombre_calle %></td>
              <td>
                <% if (r.mostrar_nombre && r.nombre_usuario) { %>
                  <span class="text-success"><%= r.nombre_usuario %></span>
                <% } else { %>
                  <span class="text-danger">Anónimo</span>
                  <% if (r.nombre_jefe) { %>
                    <small>(Jefe: <%= r.nombre_jefe %>)</small>
                  <% } %>
                <% } %>
              </td>
              <td><%= new Date(r.fecha).toLocaleString() %></td>

              <!-- 📸 Imagen -->
<td>
  <% if (r.imagen) { %>
    <img src="<%= r.imagen %>" class="img-thumbnail" style="max-width: 120px;">
  <% } else { %>
    <span class="text-muted">Sin imagen</span>
  <% } %>
</td>
              <td>
                <span class="badge 
                  <%= r.estado === 'Pendiente' ? 'bg-warning' : 
                      r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>">
                  <%= r.estado %>
                </span>
              </td>

              <% if (usuario && [1,2,3].includes(usuario.rol_id)) { %>
                <td>
                  <form action="/reportes/<%= r.id %>/estado" method="POST" class="d-flex gap-2">
                    <select name="estado" class="form-select form-select-sm">
                      <option value="Pendiente" <%= r.estado === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
                      <option value="En Progreso" <%= r.estado === 'En Progreso' ? 'selected' : '' %>>En Progreso</option>
                      <option value="Resuelto" <%= r.estado === 'Resuelto' ? 'selected' : '' %>>Resuelto</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-success">✔️</button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="text-center mt-3">
    <a href="/reportar" class="btn btn-primary">
      ➕ Crear nuevo reporte
    </a>
  </div>
</div>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h2 class="fw-bold" style="color: #5D4037;"><i class="bi bi-list-ul me-2" style="color: #fd6704bd;"></i> Lista de Reportes</h2>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/reportar" class="btn px-4 py-2 fw-semibold rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
        <i class="bi bi-plus-circle me-2"></i> Crear nuevo reporte
      </a>
      <!-- Botón Reportes Inactivos (solo UBCH y SuperAdmin) -->
      <% if (usuario && (usuario.rol_id === 1 || usuario.rol_id === 5)) { %>
        <a href="/reportes/inactivos" class="btn px-4 py-2 fw-semibold rounded-3" style="background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%); color: white; border: none;">
          <i class="bi bi-eye-slash me-2"></i> Reportes inactivos
        </a>
      <% } %>
    </div>
  </div>

  <% if (session && session.mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i> 
      <small><%= session.mensaje %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.mensaje = null; %>
  <% } %>

  <% if (session && session.error) { %>
    <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i> 
      <small><%= session.error %></small>
      <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
    <% session.error = null; %>
  <% } %>

  <!-- FILTROS AVANZADOS -->
  <div class="card mb-4 shadow-sm border-0 rounded-4">
    <div class="card-header bg-light rounded-top-4" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
      <h5 class="mb-0 fw-semibold" style="color: #5D4037;">
        <i class="bi bi-funnel me-2" style="color: #fd6704bd;"></i> Filtros avanzados
        <button class="btn btn-sm btn-link float-end text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#filtrosCollapse">
          <i class="bi bi-chevron-down"></i>
        </button>
      </h5>
    </div>
    <div class="collapse show" id="filtrosCollapse">
      <div class="card-body">
        <form id="formFiltros" method="GET" action="/reportes" class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-semibold small" style="color: #5D4037;"><i class="bi bi-search me-1" style="color: #fd6704bd;"></i> Buscar</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0"><i class="bi bi-search" style="color: #fd6704bd;"></i></span>
              <input type="text" name="search" id="searchInput" class="form-control border-start-0" 
                     placeholder="Título o descripción..." value="<%= search || '' %>"
                     style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
            </div>
          </div>
          
          <div class="col-md-2">
            <label class="form-label fw-semibold small" style="color: #5D4037;"><i class="bi bi-info-circle me-1" style="color: #fd6704bd;"></i> Estado</label>
            <select name="estado" id="estadoSelect" class="form-select" style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
              <option value="todos">Todos</option>
              <option value="Pendiente">⏳ Pendiente</option>
              <option value="En Progreso">🔄 En Progreso</option>
              <option value="Resuelto">✅ Resuelto</option>
            </select>
          </div>
          
          <div class="col-md-3">
            <label class="form-label fw-semibold small" style="color: #5D4037;"><i class="bi bi-tag me-1" style="color: #fd6704bd;"></i> Categoría</label>
            <select name="categoria_id" id="categoriaSelect" class="form-select" style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
              <option value="todos">Todas</option>
              <% if (categorias && categorias.length > 0) { %>
                <% categorias.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.nombre %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          
          <div class="col-md-3">
            <label class="form-label fw-semibold small" style="color: #5D4037;"><i class="bi bi-geo-alt me-1" style="color: #fd6704bd;"></i> Calle</label>
            <select name="calle_id" id="calleSelect" class="form-select" style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
              <option value="todos">Todas</option>
              <% if (calles && calles.length > 0) { %>
                <% calles.forEach(c => { %>
                  <option value="<%= c.id %>"><%= c.nombre %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          
          <div class="col-md-3">
            <label class="form-label fw-semibold small" style="color: #5D4037;"><i class="bi bi-calendar3 me-1" style="color: #fd6704bd;"></i> Desde</label>
            <input type="date" name="fecha_desde" id="fechaDesde" class="form-control" value="<%= fecha_desde || '' %>"
                   style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
          </div>
          
          <div class="col-md-3">
            <label class="form-label fw-semibold small" style="color: #5D4037;"><i class="bi bi-calendar3 me-1" style="color: #fd6704bd;"></i> Hasta</label>
            <input type="date" name="fecha_hasta" id="fechaHasta" class="form-control" value="<%= fecha_hasta || '' %>"
                   style="border: 1px solid #f0d5c0; background-color: #fefaf7;">
          </div>
          
          <div class="col-12 d-flex gap-2 justify-content-end">
            <button type="submit" class="btn btn-sm px-4 py-2 fw-semibold rounded-3" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;">
              <i class="bi bi-search me-1"></i> Filtrar
            </button>
            <button type="button" id="btnLimpiarFiltros" class="btn btn-sm btn-outline-secondary px-4 py-2 fw-semibold rounded-3" style="border-color: #f0d5c0; color: #5D4037;">
              <i class="bi bi-x-circle me-1"></i> Limpiar
            </button>
            
            <% if (usuario && ([1,2,3,5].includes(usuario.rol_id))) { %>
              <div class="btn-group">
                <button type="button" class="btn btn-sm btn-success dropdown-toggle px-4 py-2 fw-semibold rounded-3" 
                        style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white; border: none;"
                        data-bs-toggle="dropdown">
                  <i class="bi bi-download me-1"></i> Exportar
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a href="/reportes/exportar/excel" id="btnExportarExcel" class="dropdown-item"><i class="bi bi-file-excel text-success me-2"></i> Excel</a></li>
                  <li><a href="/reportes/exportar/pdf" id="btnExportarPDF" class="dropdown-item"><i class="bi bi-file-pdf text-danger me-2"></i> PDF</a></li>
                </ul>
              </div>
            <% } %>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- TABLA DE REPORTES -->
  <div class="table-responsive">
    <table class="table table-striped table-hover table-sm align-middle" id="tablaReportes">
      <thead class="table-dark">
        <tr class="text-center">
          <th><i class="bi bi-card-heading"></i> Título</th>
          <th><i class="bi bi-file-text"></i> Descripción</th>
          <th><i class="bi bi-tag"></i> Categoría</th>
          <th><i class="bi bi-geo-alt"></i> Calle</th>
          <th><i class="bi bi-calendar3"></i> Fecha</th>
          <th><i class="bi bi-hand-thumbs-up"></i> Votos</th>
          <th><i class="bi bi-info-circle"></i> Estado</th>
          <% if (usuario && [1,2,3].includes(usuario.rol_id)) { %>
            <th><i class="bi bi-tools"></i> Acciones</th>
          <% } %>
          <% if (usuario && usuario.rol_id === 4) { %>
            <th><i class="bi bi-star"></i> Votar</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (reportes.length === 0) { %>
          <tr>
            <td colspan="8" class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-1 d-block mb-2"></i>No hay reportes registrados
            </td>
          </tr>
        <% } else { %>
          <% reportes.forEach(r => { %>
            <tr class="reporte-fila align-middle" data-estado="<%= r.estado %>" data-id="<%= r.id %>" style="cursor: pointer;">
              <td><i class="bi bi-chat-square-text me-1 text-primary"></i> <%= r.titulo %></td>
              <td><%= r.descripcion.length > 50 ? r.descripcion.substring(0,50) + '...' : r.descripcion %></td>
              <!-- ========== ICONO CORREGIDO EN LA TABLA ========== -->
              <td class="text-center"><span class="badge px-2 py-1 rounded-pill" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;"><%= r.categoria_icono ? r.categoria_icono + ' ' : '' %><%= r.categoria_nombre %></span></td>
              <td><i class="bi bi-pin-map-fill text-secondary me-1"></i> <%= r.nombre_calle %></td>
              <td><i class="bi bi-calendar-week"></i> <%= new Date(r.fecha).toLocaleDateString() %></td>
              <td class="text-center"><span class="badge bg-secondary rounded-pill px-2 py-1"><i class="bi bi-hand-thumbs-up me-1"></i> <%= r.total_votos || 0 %></span></td>
              <td class="text-center"><span class="badge rounded-pill px-2 py-1 <%= r.estado === 'Pendiente' ? 'bg-warning' : r.estado === 'En Progreso' ? 'bg-info' : 'bg-success' %>" style="color: white;"><%= r.estado %></span></td>
              
              <% if (usuario && [1,2,3].includes(usuario.rol_id)) { %>
                <td>
                  <form action="/reportes/<%= r.id %>/estado" method="POST" class="d-flex gap-1">
                    <select name="estado" class="form-select form-select-sm" style="width: 70px; border: 1px solid #f0d5c0;">
                      <option value="Pendiente" <%= r.estado === 'Pendiente' ? 'selected' : '' %>>⏳</option>
                      <option value="En Progreso" <%= r.estado === 'En Progreso' ? 'selected' : '' %>>🔄</option>
                      <option value="Resuelto" <%= r.estado === 'Resuelto' ? 'selected' : '' %>>✅</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-success" title="Actualizar estado" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); border: none;">
                      <i class="bi bi-check-lg"></i>
                    </button>
                  </form>
                </td>
              <% } %>

              <% if (usuario && usuario.rol_id === 4) { %>
                <td class="text-center">
                  <% if (!votosUsuario[r.id]) { %>
                    <form action="/reportes/<%= r.id %>/votar" method="POST">
                      <button type="submit" class="btn btn-sm btn-warning px-3 py-1 rounded-3" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%); border: none; color: #333;" onclick="return confirm('¿Votar por este reporte?')">
                        <i class="bi bi-hand-thumbs-up me-1"></i> Votar
                      </button>
                    </form>
                  <% } else { %>
                    <span class="badge bg-success rounded-pill px-3 py-1"><i class="bi bi-check-circle me-1"></i> Votaste</span>
                  <% } %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- ========== MENSAJE INFORMATIVO FUERA DE LA TABLA ========== -->
<div class="text-center mt-3">
  <span class="badge bg-light text-muted px-3 py-2 rounded-pill" style="font-weight: normal; font-size: 0.75rem; border: 1px solid #e0e0e0;">
    <i class="bi bi-hand-index-thumb me-1"></i> 
    Doble clic en cualquier fila para ver detalles
  </span>
</div>

<!-- MODAL DE DETALLES MEJORADO - CON TEXTO LEGIBLE -->
<div class="modal fade" id="modalReporteDetalle" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 rounded-4 shadow-lg">
      <div class="modal-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
        <h5 class="modal-title text-white">
          <i class="bi bi-chat-right-text-fill me-2"></i>Detalle del Reporte
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4" style="background: #ffffff;" id="detalleReporteContent">
        <div class="text-center py-5">
          <div class="spinner-border text-primary" role="status"></div>
          <p class="mt-2 text-muted">Cargando información del reporte...</p>
        </div>
      </div>
      <div class="modal-footer bg-light d-flex flex-wrap gap-3 justify-content-between">
        
        <!-- APARTADO UNIFICADO: RESPONSABLES ASIGNADOS -->
        <div class="w-100 mb-2" id="responsablesContainer">
          <div class="card border-0 shadow-sm rounded-3">
            <div class="card-header" style="background: linear-gradient(135deg, #5D4037 0%, #6B4C3B 100%);">
              <small class="fw-bold text-white"><i class="bi bi-people-fill me-2"></i>RESPONSABLES ASIGNADOS</small>
            </div>
            <div class="card-body p-3" style="background: #fefaf7;" id="responsablesContent">
              <div class="text-center py-2">
                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Cargando responsables...</small>
              </div>
            </div>
          </div>
        </div>

        <!-- SOLO PARA UBCH (1) y LÍDERES (2) - Mostrar secciones de asignación -->
        <% if (usuario && (usuario.rol_id === 1 || usuario.rol_id === 2 || usuario.rol_id === 5)) { %>
          <div id="asignarEmpresaSection" style="display: none;" class="flex-grow-1"></div>
          <div id="asignarVoluntarioSection" style="display: none;" class="flex-grow-1"></div>
        <% } %>
        
        <!-- Botón Desactivar (solo UBCH y SuperAdmin) -->
        <% if (usuario && (usuario.rol_id === 1 || usuario.rol_id === 5)) { %>
          <button type="button" class="btn btn-warning rounded-3 px-4" id="btnDesactivarReporte">
            <i class="bi bi-eye-slash me-1"></i> Desactivar
          </button>
        <% } %>
        
        <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">
          <i class="bi bi-x-circle me-1"></i> Cerrar
        </button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL DE IMAGEN -->
<div class="modal fade" id="modalImagen" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4">
      <div class="modal-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
        <h5 class="modal-title text-white"><i class="bi bi-image me-2"></i> Imagen del reporte</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body text-center">
        <img id="imagenGrande" src="" class="img-fluid rounded" style="max-height: 500px;">
      </div>
    </div>
  </div>
</div>

<!-- ========== MODAL DESACTIVAR REPORTE ========== -->
<div class="modal fade" id="modalDesactivarReporte" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 rounded-4 shadow-lg">
      <div class="modal-header" style="background: linear-gradient(135deg, #ffc107 0%, #e0a800 100%);">
        <h5 class="modal-title text-dark">
          <i class="bi bi-eye-slash me-2"></i> Desactivar Reporte
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="formDesactivarReporte" method="POST">
        <div class="modal-body p-4">
          <div class="alert alert-warning mb-3">
            <i class="bi bi-info-circle me-1"></i>
            <strong>¿Por qué desactivar este reporte?</strong>
          </div>
          <p class="mb-2">Estás a punto de desactivar el reporte:</p>
          <div class="bg-light p-2 rounded-3 mb-3 text-center" id="reporteADesactivarInfo">
            <!-- Se llena con JavaScript -->
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">
              <i class="bi bi-chat-text me-1"></i> Motivo de desactivación:
            </label>
            <textarea name="motivo" id="motivoDesactivacion" class="form-control rounded-3" rows="3" 
                      placeholder="Ej: Reporte duplicado, información incorrecta, etc."
                      required></textarea>
            <small class="text-muted">Este motivo quedará registrado en la auditoría.</small>
          </div>
        </div>
        <div class="modal-footer bg-light">
          <button type="button" class="btn btn-secondary rounded-3 px-4" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-warning rounded-3 px-4">
            <i class="bi bi-eye-slash me-1"></i> Desactivar
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // ========================
  // VARIABLES GLOBALES
  // ========================
  let currentReporteId = null;
  let currentReporteData = null;
  const usuarioRol = <%- usuario ? usuario.rol_id : 0 %>;
  const esAdmin = (usuarioRol === 1 || usuarioRol === 2 || usuarioRol === 5);

  // ========================
  // FUNCIONES AUXILIARES
  // ========================
  function verImagenGrande(src) {
    document.getElementById('imagenGrande').src = src;
    new bootstrap.Modal(document.getElementById('modalImagen')).show();
  }

  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ========================
  // FUNCIONES PARA GESTIÓN DE EMPRESA
  // ========================
  function mostrarFormAsignarEmpresa(id) {
      const section = document.getElementById('asignarEmpresaSection');
      if (!section) return;
      
      // Obtener las empresas del reporte actual
      const reporte = currentReporteData;
      const empresas = reporte?.empresas_disponibles || [];
      
      let options = '<option value="">-- Seleccionar empresa --</option>';
      empresas.forEach(e => {
          // Mostrar: "Alcaldia del Municipio Zamora - Director Leonardo Vivas"
          const nombreMostrar = e.contacto 
              ? `${e.nombre} - ${e.contacto}` 
              : e.nombre;
          options += `<option value="${e.id}">${escapeHtml(nombreMostrar)}</option>`;
      });
      
      if (empresas.length === 0) {
          options = '<option value="">No hay empresas disponibles para esta categoría</option>';
      }
      
      section.innerHTML = `
        <div class="card border-primary rounded-3 h-100">
          <div class="card-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
            <small class="fw-bold text-white"><i class="bi bi-building me-2"></i>ASIGNAR EMPRESA</small>
          </div>
          <div class="card-body p-2" style="background: #fefaf7;">
            <form id="formAsignarEmpresa" method="POST" class="d-flex gap-2 align-items-center flex-wrap">
              <select name="empresa_id" class="form-select form-select-sm" style="border: 1px solid #f0d5c0; background-color: #fefaf7;" ${empresas.length === 0 ? 'disabled' : ''}>
                ${options}
              </select>
              <button type="submit" class="btn btn-sm" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;" ${empresas.length === 0 ? 'disabled' : ''}>
                <i class="bi bi-check-lg"></i> Asignar
              </button>
            </form>
            ${empresas.length === 0 ? `<small class="text-muted">No hay empresas que atiendan esta categoría</small>` : ''}
          </div>
        </div>
      `;
      section.style.display = 'block';
      
      const form = document.getElementById('formAsignarEmpresa');
      if (form) {
        form.action = `/reportes/${id}/asignar-empresa`;
      }
  }

  function mostrarEmpresaAsignada(reporte) {
    const section = document.getElementById('asignarEmpresaSection');
    if (!section) return;
    
    section.innerHTML = `
      <div class="card border-primary rounded-3 h-100">
        <div class="card-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
          <small class="fw-bold text-white"><i class="bi bi-building me-2"></i>EMPRESA ASIGNADA</small>
        </div>
        <div class="card-body p-2" style="background: #fefaf7;">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <strong style="color: #28a745;">${escapeHtml(reporte.empresa_nombre)}</strong>
              ${reporte.empresa_contacto ? `<div class="small text-muted">Contacto: ${escapeHtml(reporte.empresa_contacto)}</div>` : ''}
            </div>
            ${esAdmin ? `
              <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-sm btn-outline-primary rounded-3" onclick="mostrarFormCambiarEmpresa(${reporte.id})">
                  <i class="bi bi-pencil"></i> Cambiar
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-3" onclick="confirmarEliminarEmpresa(${reporte.id})">
                  <i class="bi bi-trash"></i> Eliminar
                </button>
              </div>
            ` : ''}
          </div>
        </div>
      </div>
    `;
    section.style.display = 'block';
  }

  function mostrarFormCambiarEmpresa(id) {
    const section = document.getElementById('asignarEmpresaSection');
    if (!section) return;
    
    const reporte = currentReporteData;
    const empresas = reporte?.empresas_disponibles || [];
    
    let options = '<option value="">-- Seleccionar nueva empresa --</option>';
    empresas.forEach(e => {
        const nombreMostrar = e.contacto 
            ? `${e.nombre} - ${e.contacto}` 
            : e.nombre;
        options += `<option value="${e.id}">${escapeHtml(nombreMostrar)}</option>`;
    });
    
    if (empresas.length === 0) {
        options = '<option value="">No hay empresas disponibles para esta categoría</option>';
    }
    
    section.innerHTML = `
      <div class="card border-primary rounded-3 h-100">
        <div class="card-header" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);">
          <small class="fw-bold text-white"><i class="bi bi-building me-2"></i>CAMBIAR EMPRESA</small>
        </div>
        <div class="card-body p-2" style="background: #fefaf7;">
          <form id="formCambiarEmpresa" method="POST" class="d-flex gap-2 align-items-center flex-wrap">
            <select name="empresa_id" class="form-select form-select-sm" style="border: 1px solid #f0d5c0;" ${empresas.length === 0 ? 'disabled' : ''}>
              ${options}
            </select>
            <button type="submit" class="btn btn-sm" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white; border: none;" ${empresas.length === 0 ? 'disabled' : ''}>Actualizar</button>
            <button type="button" class="btn btn-sm btn-secondary" onclick="location.reload()">Cancelar</button>
          </form>
          ${empresas.length === 0 ? `<small class="text-muted">No hay empresas que atiendan esta categoría</small>` : ''}
        </div>
      </div>
    `;
    section.style.display = 'block';
    
    const form = document.getElementById('formCambiarEmpresa');
    if (form) {
      form.action = `/reportes/${id}/asignar-empresa`;
    }
}

  function confirmarEliminarEmpresa(id) {
    if (confirm('¿Estás seguro de eliminar la empresa asignada a este reporte?')) {
      fetch(`/reportes/${id}/eliminar-empresa`, { method: 'POST' })
        .then(response => {
          if (response.ok) {
            location.reload();
          } else {
            alert('Error al eliminar la empresa');
          }
        })
        .catch(err => console.error('Error:', err));
    }
  }

  // ========================
  // FUNCIONES PARA GESTIÓN DE VOLUNTARIO
  // ========================
  async function cargarListaVoluntarios() {
    try {
      const volResponse = await fetch('/api/voluntarios/aprobados');
      const voluntarios = await volResponse.json();
      return voluntarios;
    } catch (err) {
      console.error('Error cargando voluntarios:', err);
      return [];
    }
  }

  async function mostrarFormAsignarVoluntario(id) {
    const section = document.getElementById('asignarVoluntarioSection');
    if (!section) return;
    
    const voluntarios = await cargarListaVoluntarios();
    let options = '<option value="">-- Seleccionar voluntario --</option>';
    voluntarios.forEach(v => {
      options += `<option value="${v.id}">${escapeHtml(v.nombre)} - ${escapeHtml(v.habilidad)}</option>`;
    });
    
    section.innerHTML = `
      <div class="card border-success rounded-3 h-100">
        <div class="card-header" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
          <small class="fw-bold text-white"><i class="bi bi-person-badge me-2"></i>ASIGNAR VOLUNTARIO</small>
        </div>
        <div class="card-body p-2" style="background: #fefaf7;">
          <form id="formAsignarVoluntario" method="POST" class="d-flex gap-2 align-items-center flex-wrap">
            <select name="voluntario_id" class="form-select form-select-sm" style="border: 1px solid #f0d5c0;" required>
              ${options}
            </select>
            <button type="submit" class="btn btn-sm" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white; border: none;">
              <i class="bi bi-person-plus-fill"></i> Asignar
            </button>
          </form>
        </div>
      </div>
    `;
    section.style.display = 'block';
    
    const form = document.getElementById('formAsignarVoluntario');
    if (form) {
      form.action = `/voluntarios/asignar-reporte`;
      let hiddenInput = form.querySelector('input[name="reporte_id"]');
      if (!hiddenInput) {
        hiddenInput = document.createElement('input');
        hiddenInput.type = 'hidden';
        hiddenInput.name = 'reporte_id';
        form.appendChild(hiddenInput);
      }
      hiddenInput.value = id;
    }
  }

  async function mostrarVoluntarioAsignado(reporte) {
    const section = document.getElementById('asignarVoluntarioSection');
    if (!section) return;
    
    section.innerHTML = `
      <div class="card border-success rounded-3 h-100">
        <div class="card-header" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
          <small class="fw-bold text-white"><i class="bi bi-person-badge me-2"></i>VOLUNTARIO ASIGNADO</small>
        </div>
        <div class="card-body p-2" style="background: #fefaf7;">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
              <strong style="color: #28a745;">${escapeHtml(reporte.voluntario_nombre)}</strong>
              ${reporte.voluntario_habilidad ? `<div class="small text-muted">Habilidad: ${escapeHtml(reporte.voluntario_habilidad)}</div>` : ''}
              ${reporte.voluntario_telefono ? `<div class="small text-muted"><i class="bi bi-telephone"></i> ${escapeHtml(reporte.voluntario_telefono)}</div>` : ''}
            </div>
            ${esAdmin ? `
              <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-sm btn-outline-success rounded-3" onclick="mostrarFormCambiarVoluntario(${reporte.id})">
                  <i class="bi bi-pencil"></i> Cambiar
                </button>
                <button type="button" class="btn btn-sm btn-outline-danger rounded-3" onclick="confirmarEliminarVoluntario(${reporte.id})">
                  <i class="bi bi-trash"></i> Eliminar
                </button>
              </div>
            ` : ''}
          </div>
        </div>
      </div>
    `;
    section.style.display = 'block';
  }

  async function mostrarFormCambiarVoluntario(id) {
    const section = document.getElementById('asignarVoluntarioSection');
    if (!section) return;
    
    const voluntarios = await cargarListaVoluntarios();
    let options = '<option value="">-- Seleccionar nuevo voluntario --</option>';
    voluntarios.forEach(v => {
      options += `<option value="${v.id}">${escapeHtml(v.nombre)} - ${escapeHtml(v.habilidad)}</option>`;
    });
    
    section.innerHTML = `
      <div class="card border-success rounded-3 h-100">
        <div class="card-header" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%);">
          <small class="fw-bold text-white"><i class="bi bi-person-badge me-2"></i>CAMBIAR VOLUNTARIO</small>
        </div>
        <div class="card-body p-2" style="background: #fefaf7;">
          <form id="formCambiarVoluntario" method="POST" class="d-flex gap-2 align-items-center flex-wrap">
            <select name="voluntario_id" class="form-select form-select-sm" style="border: 1px solid #f0d5c0;" required>
              ${options}
            </select>
            <button type="submit" class="btn btn-sm" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); color: white; border: none;">Actualizar</button>
            <button type="button" class="btn btn-sm btn-secondary" onclick="location.reload()">Cancelar</button>
          </form>
        </div>
      </div>
    `;
    section.style.display = 'block';
    
    const form = document.getElementById('formCambiarVoluntario');
    if (form) {
      form.action = `/voluntarios/asignar-reporte`;
      let hiddenInput = form.querySelector('input[name="reporte_id"]');
      if (!hiddenInput) {
        hiddenInput = document.createElement('input');
        hiddenInput.type = 'hidden';
        hiddenInput.name = 'reporte_id';
        form.appendChild(hiddenInput);
      }
      hiddenInput.value = id;
    }
  }

  function confirmarEliminarVoluntario(id) {
    if (confirm('¿Estás seguro de eliminar el voluntario asignado a este reporte?')) {
      fetch(`/reportes/${id}/eliminar-voluntario`, { method: 'POST' })
        .then(response => {
          if (response.ok) {
            location.reload();
          } else {
            alert('Error al eliminar el voluntario');
          }
        })
        .catch(err => console.error('Error:', err));
    }
  }

  // ========================
  // FUNCIONES DE FILTROS Y EXPORTACIÓN
  // ========================
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('estado')) document.getElementById('estadoSelect').value = urlParams.get('estado');
  if (urlParams.get('categoria_id')) document.getElementById('categoriaSelect').value = urlParams.get('categoria_id');
  if (urlParams.get('calle_id')) document.getElementById('calleSelect').value = urlParams.get('calle_id');
  if (urlParams.get('search')) document.getElementById('searchInput').value = urlParams.get('search');
  if (urlParams.get('fecha_desde')) document.getElementById('fechaDesde').value = urlParams.get('fecha_desde');
  if (urlParams.get('fecha_hasta')) document.getElementById('fechaHasta').value = urlParams.get('fecha_hasta');
  
  document.getElementById('btnLimpiarFiltros').addEventListener('click', function() {
    window.location.href = '/reportes';
  });
  
  function actualizarEnlacesExportacion() {
    const params = new URLSearchParams();
    const estado = document.getElementById('estadoSelect')?.value;
    const categoriaId = document.getElementById('categoriaSelect')?.value;
    const calleId = document.getElementById('calleSelect')?.value;
    const search = document.getElementById('searchInput')?.value;
    const fechaDesde = document.getElementById('fechaDesde')?.value;
    const fechaHasta = document.getElementById('fechaHasta')?.value;
    
    if (estado && estado !== 'todos') params.append('estado', estado);
    if (categoriaId && categoriaId !== 'todos') params.append('categoria_id', categoriaId);
    if (calleId && calleId !== 'todos') params.append('calle_id', calleId);
    if (search) params.append('search', search);
    if (fechaDesde) params.append('fecha_desde', fechaDesde);
    if (fechaHasta) params.append('fecha_hasta', fechaHasta);
    
    const queryString = params.toString();
    const excelBtn = document.getElementById('btnExportarExcel');
    const pdfBtn = document.getElementById('btnExportarPDF');
    
    if (excelBtn) {
      excelBtn.href = `/reportes/exportar/excel${queryString ? '?' + queryString : ''}`;
    }
    if (pdfBtn) {
      pdfBtn.href = `/reportes/exportar/pdf${queryString ? '?' + queryString : ''}`;
    }
  }
  
  document.addEventListener('DOMContentLoaded', function() {
    actualizarEnlacesExportacion();
  });
  
  const filtrosExport = ['estadoSelect', 'categoriaSelect', 'calleSelect', 'searchInput', 'fechaDesde', 'fechaHasta'];
  filtrosExport.forEach(id => {
    const element = document.getElementById(id);
    if (element) {
      element.addEventListener('change', actualizarEnlacesExportacion);
      element.addEventListener('keyup', actualizarEnlacesExportacion);
    }
  });

  // ========================
  // DOBLE CLIC PARA VER DETALLES
  // ========================
  document.querySelectorAll('.reporte-fila').forEach(fila => {
    fila.addEventListener('dblclick', async function(e) {
      if (e.target.tagName === 'BUTTON' || e.target.tagName === 'SELECT' || e.target.tagName === 'FORM') return;
      
      const id = this.dataset.id;
      currentReporteId = id;
      const modalContent = document.getElementById('detalleReporteContent');
      const responsablesContent = document.getElementById('responsablesContent');
      
      modalContent.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Cargando información...</p></div>';
      if (responsablesContent) responsablesContent.innerHTML = '<div class="text-center py-2"><small class="text-muted">Cargando responsables...</small></div>';
      
      try {
        const response = await fetch(`/reportes/${id}/detalle`);
        const reporte = await response.json();
        currentReporteData = reporte;
        
        // Generar HTML de responsables
        let responsablesHtml = '';
        const tieneEmpresa = reporte.empresa_nombre && reporte.empresa_nombre !== '' && reporte.empresa_nombre !== null;
        const tieneVoluntario = reporte.voluntario_nombre && reporte.voluntario_nombre !== '' && reporte.voluntario_nombre !== null;
        
        if (tieneEmpresa || tieneVoluntario) {
          responsablesHtml = `<div class="row g-2">`;
          if (tieneEmpresa) {
            responsablesHtml += `
              <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 p-2 bg-success bg-opacity-10 border-start border-3 border-success rounded-3">
                  <i class="bi bi-building fs-4 text-success"></i>
                  <div>
                    <div class="small text-muted">Empresa responsable</div>
                    <strong class="text-success">${escapeHtml(reporte.empresa_nombre)}</strong>
                    ${reporte.empresa_contacto ? `<div class="small text-muted">Contacto: ${escapeHtml(reporte.empresa_contacto)}</div>` : ''}
                  </div>
                </div>
              </div>
            `;
          }
          if (tieneVoluntario) {
            responsablesHtml += `
              <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 p-2 bg-success bg-opacity-10 border-start border-3 border-success rounded-3">
                  <i class="bi bi-person-badge fs-4 text-success"></i>
                  <div>
                    <div class="small text-muted">Voluntario asignado</div>
                    <strong class="text-success">${escapeHtml(reporte.voluntario_nombre)}</strong>
                    ${reporte.voluntario_habilidad ? `<div class="small text-muted">Habilidad: ${escapeHtml(reporte.voluntario_habilidad)}</div>` : ''}
                    ${reporte.voluntario_telefono ? `<div class="small text-muted"><i class="bi bi-telephone"></i> ${escapeHtml(reporte.voluntario_telefono)}</div>` : ''}
                  </div>
                </div>
              </div>
            `;
          }
          responsablesHtml += `</div>`;
        } else {
          responsablesHtml = `
            <div class="text-center py-2">
              <i class="bi bi-exclamation-circle me-1 text-muted"></i>
              <small class="text-muted">No hay responsables asignados aún</small>
              ${esAdmin ? `<div class="mt-1"><small class="text-muted">Puedes asignar una empresa y/o un voluntario usando los formularios de abajo</small></div>` : ''}
            </div>
          `;
        }
        if (responsablesContent) responsablesContent.innerHTML = responsablesHtml;
        
        // Configurar sección de empresa (solo para admin)
        const asignarEmpresaSection = document.getElementById('asignarEmpresaSection');
        if (asignarEmpresaSection && esAdmin) {
          if (!tieneEmpresa) {
            mostrarFormAsignarEmpresa(id);
          } else {
            mostrarEmpresaAsignada(reporte);
          }
        } else if (asignarEmpresaSection && !esAdmin) {
          asignarEmpresaSection.style.display = 'none';
        }
        
        // Configurar sección de voluntario (solo para admin)
        const asignarVoluntarioSection = document.getElementById('asignarVoluntarioSection');
        if (asignarVoluntarioSection && esAdmin) {
          if (!tieneVoluntario) {
            await mostrarFormAsignarVoluntario(id);
          } else {
            await mostrarVoluntarioAsignado(reporte);
          }
        } else if (asignarVoluntarioSection && !esAdmin) {
          asignarVoluntarioSection.style.display = 'none';
        }
        
        // Configurar botón desactivar
        const btnDesactivar = document.getElementById('btnDesactivarReporte');
        if (btnDesactivar) {
          btnDesactivar.onclick = function() {
            document.getElementById('reporteADesactivarInfo').innerHTML = '<strong>' + escapeHtml(reporte.titulo) + '</strong>';
            document.getElementById('motivoDesactivacion').value = '';
            document.getElementById('formDesactivarReporte').action = '/reportes/' + id + '/desactivar';
            new bootstrap.Modal(document.getElementById('modalDesactivarReporte')).show();
          };
        }
        
        let imagenHtml = '';
        if (reporte.imagen) {
          imagenHtml = `<div class="text-center mt-4 pt-3 border-top">
                          <img src="${reporte.imagen}" class="img-fluid rounded shadow-sm" style="max-height: 300px; cursor: pointer;" 
                               onclick="verImagenGrande('${reporte.imagen}')">
                          <div class="mt-2"><small class="text-muted"><i class="bi bi-eye"></i> Haz clic para ampliar</small></div>
                        </div>`;
        }
        
        modalContent.innerHTML = `
          <div class="card border-0">
            <div class="card-body p-0">
              <h4 class="mb-3 border-start border-4 border-primary ps-3" style="color: #5D4037;">
                <i class="bi bi-megaphone-fill text-primary me-2"></i>${escapeHtml(reporte.titulo)}
              </h4>
              <p class="text-muted mb-4">${escapeHtml(reporte.descripcion)}</p>
              
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3">
                    <i class="bi bi-calendar-event text-primary fs-5"></i>
                    <div><strong class="small text-secondary">Fecha y hora</strong><br><span class="small">${new Date(reporte.fecha).toLocaleString()}</span></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3">
                    <i class="bi bi-tag text-info fs-5"></i>
                    <div><strong class="small text-secondary">Categoría</strong><br>
                    <span class="badge px-2 py-1 rounded-pill" style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); color: white;">
                      ${reporte.categoria_icono ? reporte.categoria_icono + ' ' : ''}${reporte.categoria_nombre}
                    </span>
                    </div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3">
                    <i class="bi bi-geo-alt text-danger fs-5"></i>
                    <div><strong class="small text-secondary">Calle</strong><br><span class="small fw-semibold" style="color: #5D4037;">${escapeHtml(reporte.nombre_calle)}</span></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3">
                    <i class="bi bi-person-badge text-secondary fs-5"></i>
                    <div><strong class="small text-secondary">Reportado por</strong><br><span class="small">${reporte.mostrar_nombre && reporte.nombre_usuario ? escapeHtml(reporte.nombre_usuario) : '<span class="text-muted">Anónimo</span>'}</span></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3">
                    <i class="bi bi-hand-thumbs-up text-warning fs-5"></i>
                    <div><strong class="small text-secondary">Votos</strong><br><span class="badge bg-secondary rounded-pill px-2 py-1">👍 ${reporte.total_votos || 0}</span></div>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3">
                    <i class="bi bi-info-circle fs-5 ${reporte.estado === 'Pendiente' ? 'text-warning' : (reporte.estado === 'En Progreso' ? 'text-primary' : 'text-success')}"></i>
                    <div><strong class="small text-secondary">Estado</strong><br><span class="badge rounded-pill px-2 py-1 ${reporte.estado === 'Pendiente' ? 'bg-warning' : (reporte.estado === 'En Progreso' ? 'bg-info' : 'bg-success')}" style="color: white;">${reporte.estado}</span></div>
                  </div>
                </div>
                ${reporte.ubicacion_lat && reporte.ubicacion_lng ? `
                <div class="col-12">
                  <div class="d-flex align-items-center gap-2 p-2 bg-light rounded-3">
                    <i class="bi bi-map text-dark fs-5"></i>
                    <div><strong class="small text-secondary">Ubicación exacta</strong><br><span class="small text-muted">Lat: ${reporte.ubicacion_lat}, Lng: ${reporte.ubicacion_lng}</span></div>
                  </div>
                </div>` : ''}
              </div>
              
              ${imagenHtml}
            </div>
          </div>
        `;
        
        new bootstrap.Modal(document.getElementById('modalReporteDetalle')).show();
      } catch (error) {
        console.error('Error:', error);
        modalContent.innerHTML = '<div class="alert alert-danger m-3"><i class="bi bi-exclamation-triangle-fill me-2"></i>Error al cargar los detalles del reporte</div>';
        if (responsablesContent) responsablesContent.innerHTML = '<div class="text-center py-2"><small class="text-danger">Error al cargar responsables</small></div>';
      }
    });
  });
</script>


<div class="container-fluid p-0 min-vh-100 d-flex align-items-center">
  <div class="row g-0 w-100">
    
    <!-- COLUMNA IZQUIERDA: Branding / Bienvenida -->
    <div class="col-lg-5 d-flex align-items-center justify-content-center p-5 login-left-col" style="min-height: 100vh;">
      <div class="text-center px-3" style="max-width: 400px;">
        
        <!-- Logo -->
        <div class="mb-4">
          <img src="/images/isotipo.png" alt="ComuniSolve" style="height: 90px;">
        </div>
        
        <!-- Título con colores personalizados -->
        <h3 class="fw-bold mb-2" style="font-size: 2rem;">
          <span class="login-title-dark">COMUNI</span><span class="login-title-primary">SOLVE</span>
        </h3>
        <p class="mb-4 login-subtitle">Software de Gestión Comunitaria</p>
        
        <!-- Línea decorativa -->
        <div class="d-flex justify-content-center align-items-center gap-3 mb-4">
          <div class="flex-grow-1 login-divider"></div>
          <i class="bi bi-heart-fill login-heart"></i>
          <div class="flex-grow-1 login-divider"></div>
        </div>
        
        <!-- Texto de la comuna -->
        <p class="mb-0 login-community-text">
          Transformando la Comuna Socialista<br>
          <strong class="login-community-highlight">Nuestra Señora de las Mercedes</strong>
        </p>
        
        <!-- Villa de Cura -->
        <p class="mt-3 small mb-0 login-location">
          <i class="bi bi-geo-alt-fill"></i> Villa de Cura, Estado Aragua
        </p>
        
      </div>
    </div>

    <!-- COLUMNA DERECHA: Formulario de Login -->
    <div class="col-lg-7 d-flex align-items-center justify-content-center p-4 p-lg-5 login-right-col" style="min-height: 100vh;">
      <div class="w-100" style="max-width: 450px;">
        
        <!-- Card del formulario -->
        <div class="card border-0 rounded-4 shadow-lg overflow-hidden login-card">
          
          <!-- Header del card -->
          <div class="text-center py-4 px-3 login-card-header">
            <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
              <div class="login-icon-wrapper">
                <i class="bi bi-box-arrow-in-right fs-3 text-white"></i>
              </div>
            </div>
            <h3 class="mb-0 fw-semibold login-card-title">Iniciar Sesión</h3>
            <p class="small mb-0 mt-1 login-card-subtitle">Ingresa tus credenciales para continuar</p>
          </div>
          
          <!-- Body del card -->
          <div class="card-body p-4 p-lg-5 login-card-body">
            
            <!-- Mensajes flash -->
            <% if (typeof registroExitoso !== 'undefined' && registroExitoso) { %>
              <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> 
                <small><strong>¡Registro exitoso!</strong> Ya puedes iniciar sesión.</small>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> 
                <small><strong>Error:</strong> <%= error %></small>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <!-- Formulario -->
            <form method="POST" action="/login">
              
              <!-- Campo Email -->
              <div class="mb-4">
                <label class="form-label fw-semibold small mb-2 login-label">
                  <i class="bi bi-envelope-fill me-1"></i> Correo electrónico
                </label>
                <input type="email" name="email" class="form-control form-control-lg rounded-3 login-input" 
                       placeholder="tucorreo@ejemplo.com" required>
              </div>

              <!-- Campo Contraseña -->
              <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <label class="form-label fw-semibold small mb-0 login-label">
                    <i class="bi bi-lock-fill me-1"></i> Contraseña
                  </label>
                  <a href="/olvide-password" class="text-decoration-none small login-forgot-link">
                    ¿Olvidaste tu contraseña?
                  </a>
                </div>
                <input type="password" name="password" class="form-control form-control-lg rounded-3 login-input" 
                       placeholder="••••••••" required>
              </div>

              <!-- Botón -->
              <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-lg py-3 fw-semibold rounded-3 login-btn">
                  <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar sesión
                </button>
              </div>

              <!-- Registro -->
              <div class="text-center mt-4">
                <p class="mb-0 small login-footer-text">
                  ¿No tienes cuenta? 
                  <a href="/registro" class="fw-bold text-decoration-none login-register-link">
                    Regístrate aquí <i class="bi bi-arrow-right"></i>
                  </a>
                </p>
              </div>

            </form>

            <!-- Badges -->
            <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
              <small class="text-muted d-flex align-items-center gap-1 login-badge">
                <i class="bi bi-shield-check"></i> Datos seguros
              </small>
              <small class="text-muted d-flex align-items-center gap-1 login-badge">
                <i class="bi bi-lock-fill"></i> Conexión SSL
              </small>
            </div>

          </div>
        </div>

      </div>
    </div>

  </div>
</div>


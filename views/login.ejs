<div class="container-fluid p-0 min-vh-100 d-flex align-items-center">
  <div class="row g-0 w-100">
    
    <!-- COLUMNA IZQUIERDA: Branding / Bienvenida -->
    <div class="col-lg-5 d-flex align-items-center justify-content-center p-5" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%); min-height: 100vh;">
      <div class="text-center px-3" style="max-width: 400px;">
        
        <!-- Logo -->
        <div class="mb-4">
          <img src="/images/isotipo.png" alt="ComuniSolve" style="height: 90px;">
        </div>
        
        <!-- Título con colores personalizados -->
        <h3 class="fw-bold mb-2" style="font-size: 2rem;">
          <span style="color: #5D4037;">COMUNI</span><span style="color: #fd6704bd;">SOLVE</span>
        </h3>
        <p class="mb-4" style="font-size: 0.9rem; color: #5D4037;">Software de Gestión Comunitaria</p>
        
        <!-- Línea decorativa -->
        <div class="d-flex justify-content-center align-items-center gap-3 mb-4">
          <div class="flex-grow-1" style="height: 2px; background: #fd6704bd; opacity: 0.2; border-radius: 2px;"></div>
          <i class="bi bi-heart-fill" style="color: #fd6704bd; opacity: 0.6; font-size: 0.9rem;"></i>
          <div class="flex-grow-1" style="height: 2px; background: #fd6704bd; opacity: 0.2; border-radius: 2px;"></div>
        </div>
        
        <!-- Texto de la comuna -->
        <p class="mb-0" style="font-size: 0.85rem; color: #6B4C3B;">
          Transformando la Comuna Socialista<br>
          <strong style="color: #fd6704bd;">Nuestra Señora de las Mercedes</strong>
        </p>
        
        <!-- Villa de Cura -->
        <p class="mt-3 small mb-0" style="color: #8B6B5A;">
          <i class="bi bi-geo-alt-fill"></i> Villa de Cura, Estado Aragua
        </p>
        
      </div>
    </div>

    <!-- COLUMNA DERECHA: Formulario de Login -->
    <div class="col-lg-7 d-flex align-items-center justify-content-center p-4 p-lg-5" style="background: #ffffff; min-height: 100vh;">
      <div class="w-100" style="max-width: 450px;">
        
        <!-- Card del formulario -->
        <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
          
          <!-- Header del card -->
          <div class="text-center py-4 px-3" style="background: linear-gradient(135deg, #fce5d4 0%, #fdf1e7 100%);">
            <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
              <div style="width: 55px; height: 55px; background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); border-radius: 15px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(253, 103, 4, 0.3);">
                <i class="bi bi-box-arrow-in-right fs-3 text-white"></i>
              </div>
            </div>
            <h3 class="mb-0 fw-semibold" style="color: #fd6704bd;">Iniciar Sesión</h3>
            <p class="small mb-0 mt-1" style="color: #8B6B5A;">Ingresa tus credenciales para continuar</p>
          </div>
          
          <!-- Body del card -->
          <div class="card-body p-4 p-lg-5">
            
            <!-- Mensajes flash -->
            <% if (typeof registroExitoso !== 'undefined' && registroExitoso) { %>
              <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> 
                <small><strong>¡Registro exitoso!</strong> Ya puedes iniciar sesión.</small>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> 
                <small><strong>Error:</strong> <%= error %></small>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <!-- Formulario -->
            <form method="POST" action="/login">
              
              <!-- Campo Email -->
              <div class="mb-4">
                <label class="form-label fw-semibold small mb-2" style="color: #5D4037;">
                  <i class="bi bi-envelope-fill me-1" style="color: #fd6704bd;"></i> Correo electrónico
                </label>
                <input type="email" name="email" class="form-control form-control-lg rounded-3" 
                       placeholder="tucorreo@ejemplo.com" required 
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; transition: all 0.3s ease;">
              </div>

              <!-- Campo Contraseña -->
              <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <label class="form-label fw-semibold small mb-0" style="color: #5D4037;">
                    <i class="bi bi-lock-fill me-1" style="color: #fd6704bd;"></i> Contraseña
                  </label>
                  <a href="/olvide-password" class="text-decoration-none small" style="color: #fd6704bd;">
                    ¿Olvidaste tu contraseña?
                  </a>
                </div>
                <input type="password" name="password" class="form-control form-control-lg rounded-3" 
                       placeholder="••••••••" required 
                       style="border: 1px solid #f0d5c0; background-color: #fefaf7; transition: all 0.3s ease;">
              </div>

              <!-- Botón -->
              <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-lg py-3 fw-semibold rounded-3" 
                        style="background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%); 
                               border: none; color: white; box-shadow: 0 4px 12px rgba(253, 103, 4, 0.3);
                               transition: transform 0.2s ease, box-shadow 0.2s ease;">
                  <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar sesión
                </button>
              </div>

              <!-- Registro -->
              <div class="text-center mt-4">
                <p class="mb-0 small" style="color: #8B6B5A;">
                  ¿No tienes cuenta? 
                  <a href="/registro" class="fw-bold text-decoration-none" style="color: #fd6704bd;">
                    Regístrate aquí <i class="bi bi-arrow-right"></i>
                  </a>
                </p>
              </div>

            </form>

            <!-- Badges -->
            <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
              <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
                <i class="bi bi-shield-check" style="color: #fd6704bd;"></i> Datos seguros
              </small>
              <small class="text-muted d-flex align-items-center gap-1" style="color: #8B6B5A !important;">
                <i class="bi bi-lock-fill" style="color: #fd6704bd;"></i> Conexión SSL
              </small>
            </div>

          </div>
        </div>

      </div>
    </div>

  </div>
</div>
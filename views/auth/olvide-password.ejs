<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden password-card">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3 password-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="password-icon-wrapper">
              <i class="bi bi-key fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold password-title">¿Olvidaste tu contraseña?</h3>
          <p class="small mb-0 mt-1 password-subtitle">Te enviaremos un enlace para recuperarla</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 password-body">
          
          <!-- Mensajes de error -->
          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <div>
                  <strong>Error</strong>
                  <small class="d-block"><%= error %></small>
                </div>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
              </div>
            </div>
          <% } %>

          <!-- Mensaje de éxito -->
          <% if (mensaje) { %>
            <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <div>
                  <strong>¡Éxito!</strong>
                  <small class="d-block"><%= mensaje %></small>
                </div>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
              </div>
            </div>
          <% } %>

          <p class="text-muted mb-4" style="font-size: 0.9rem;">
            <i class="bi bi-info-circle me-1"></i> 
            Ingresa tu correo electrónico y te enviaremos un enlace para restablecer tu contraseña.
          </p>

          <form method="POST" action="/olvide-password">
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 password-label">
                <i class="bi bi-envelope-fill me-1"></i> Correo electrónico
              </label>
              <div class="input-group">
                <span class="input-group-text password-input-icon">
                  <i class="bi bi-envelope"></i>
                </span>
                <input type="email" name="email" class="form-control rounded-end-3 password-input" 
                       placeholder="tu-correo@ejemplo.com" required>
              </div>
              <small class="text-muted password-help">Te enviaremos el enlace a este correo</small>
            </div>

            <div class="d-grid gap-2">
              <button type="submit" class="btn py-2 fw-semibold rounded-3 btn-recuperar">
                <i class="bi bi-envelope-paper me-2"></i> Enviar enlace de recuperación
              </button>
            </div>

            <div class="text-center mt-3">
              <a href="/login" class="text-decoration-none password-link">
                <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
              </a>
            </div>
          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 password-badge">
              <i class="bi bi-shield-check"></i> Datos seguros
            </small>
            <small class="text-muted d-flex align-items-center gap-1 password-badge">
              <i class="bi bi-lock-fill"></i> Conexión SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  .password-card {
    background: #ffffff;
  }
  
  .password-header {
    background: linear-gradient(135deg, #fce5d4 0%, #fd6704bd 60%, #17a2b8 100%);
  }
  
  .password-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(23, 162, 184, 0.4);
  }
  
  .password-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .password-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  .password-body {
    background: #ffffff;
  }
  
  .password-label {
    color: #5D4037;
  }
  .password-label i {
    color: #fd6704bd;
  }
  
  .password-input {
    border: 1px solid #f0d5c0;
    background-color: #fefaf7;
    padding: 0.6rem 1rem;
    transition: all 0.3s ease;
  }
  .password-input:focus {
    border-color: #fd6704bd;
    box-shadow: 0 0 0 3px rgba(253, 103, 4, 0.15);
    background-color: #fefaf7;
    outline: none;
  }
  
  .password-input-icon {
    background-color: #fefaf7;
    border: 1px solid #f0d5c0;
    border-right: none;
    color: #fd6704bd;
  }
  
  .password-help {
    color: #8B6B5A;
  }
  
  .btn-recuperar {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-recuperar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  .password-link {
    color: #8B6B5A;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }
  .password-link:hover {
    color: #fd6704bd;
  }
  
  .password-badge {
    color: #8B6B5A !important;
  }
  .password-badge i {
    color: #17a2b8;
  }
  
  .alert-success {
    background: #d4edda;
    color: #155724;
    border-left: 4px solid #28a745;
  }
  
  .alert-danger {
    background: #f8d7da;
    color: #721c24;
    border-left: 4px solid #dc3545;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .password-card {
    background: #27272a;
  }
  
  body.dark-mode .password-header {
    background: linear-gradient(135deg, #2d2d44 0%, #f7931e 60%, #138496 100%);
  }
  
  body.dark-mode .password-icon-wrapper {
    background: linear-gradient(135deg, #138496 0%, #0e5c6b 100%);
    box-shadow: 0 4px 10px rgba(19, 132, 150, 0.4);
  }
  
  body.dark-mode .password-title {
    color: white;
  }
  
  body.dark-mode .password-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  body.dark-mode .password-body {
    background: #27272a;
  }
  
  body.dark-mode .password-label {
    color: #e4e4e7;
  }
  body.dark-mode .password-label i {
    color: #f7931e;
  }
  
  body.dark-mode .password-input {
    border: 1px solid #3f3f46;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .password-input:focus {
    border-color: #f7931e;
    background-color: #3f3f46;
    color: #e4e4e7;
  }
  body.dark-mode .password-input::placeholder {
    color: #a1a1aa;
  }
  
  body.dark-mode .password-input-icon {
    background-color: #3f3f46;
    border-color: #3f3f46;
    color: #f7931e;
  }
  
  body.dark-mode .password-help {
    color: #a1a1aa;
  }
  
  body.dark-mode .password-link {
    color: #a1a1aa;
  }
  body.dark-mode .password-link:hover {
    color: #f7931e;
  }
  
  body.dark-mode .password-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .password-badge i {
    color: #138496;
  }
  
  body.dark-mode .alert-success {
    background: #0d3b1f;
    color: #a3e4b7;
    border-left-color: #28a745;
  }
  
  body.dark-mode .alert-danger {
    background: #3d1a1f;
    color: #f5a3a3;
    border-left-color: #dc3545;
  }
</style>
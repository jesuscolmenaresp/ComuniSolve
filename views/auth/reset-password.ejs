<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden password-card">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3 password-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="password-icon-wrapper">
              <i class="bi bi-key fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold password-title">Restablecer Contraseña</h3>
          <p class="small mb-0 mt-1 password-subtitle">Crea una nueva contraseña para tu cuenta</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 password-body">
          
          <!-- Mensaje de error -->
          <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 py-2 mb-4" role="alert">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <div>
                  <strong>Error</strong>
                  <small class="d-block"><%= error %></small>
                </div>
                <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
              </div>
            </div>
          <% } %>

          <p class="text-muted mb-4" style="font-size: 0.9rem;">
            <i class="bi bi-info-circle me-1"></i> 
            Ingresa tu nueva contraseña. Debe tener al menos 6 caracteres.
          </p>

          <form method="POST" action="/reset-password/<%= token %>">
            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 password-label">
                <i class="bi bi-lock-fill me-1"></i> Nueva contraseña
              </label>
              <div class="input-group">
                <span class="input-group-text password-input-icon">
                  <i class="bi bi-key"></i>
                </span>
                <input type="password" name="password" id="password" class="form-control rounded-end-3 password-input" 
                       placeholder="Mínimo 6 caracteres" required minlength="6">
              </div>
              <small class="text-muted password-help" id="passwordHelp">Mínimo 6 caracteres</small>
            </div>

            <div class="mb-4">
              <label class="form-label fw-semibold small mb-2 password-label">
                <i class="bi bi-check-circle-fill me-1"></i> Confirmar contraseña
              </label>
              <div class="input-group">
                <span class="input-group-text password-input-icon">
                  <i class="bi bi-key"></i>
                </span>
                <input type="password" name="confirm_password" id="confirm_password" class="form-control rounded-end-3 password-input" 
                       placeholder="Repite tu contraseña" required>
              </div>
              <small class="text-muted password-help" id="confirmPasswordHelp"></small>
            </div>

            <div class="d-grid gap-2">
              <button type="submit" class="btn py-2 fw-semibold rounded-3 btn-recuperar">
                <i class="bi bi-check-circle me-2"></i> Restablecer contraseña
              </button>
            </div>

            <div class="text-center mt-3">
              <a href="/login" class="text-decoration-none password-link">
                <i class="bi bi-arrow-left me-1"></i> Volver al inicio de sesión
              </a>
            </div>
          </form>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 password-badge">
              <i class="bi bi-shield-check"></i> Contraseña segura
            </small>
            <small class="text-muted d-flex align-items-center gap-1 password-badge">
              <i class="bi bi-lock-fill"></i> Encriptación SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<script>
  // Validar contraseñas en tiempo real
  document.getElementById('confirm_password').addEventListener('keyup', function() {
    const password = document.getElementById('password').value;
    const confirm = this.value;
    const help = document.getElementById('confirmPasswordHelp');
    
    if (password === confirm && password !== '') {
      help.innerHTML = '<span class="text-success">✅ Las contraseñas coinciden</span>';
      this.style.borderColor = '#28a745';
    } else if (password !== confirm && confirm !== '') {
      help.innerHTML = '<span class="text-danger">❌ Las contraseñas no coinciden</span>';
      this.style.borderColor = '#dc3545';
    } else {
      help.innerHTML = '';
      this.style.borderColor = '';
    }
  });

  // Validar longitud de contraseña
  document.getElementById('password').addEventListener('keyup', function() {
    const help = document.getElementById('passwordHelp');
    if (this.value.length > 0 && this.value.length < 6) {
      help.innerHTML = '<span class="text-warning">⚠️ Mínimo 6 caracteres (' + this.value.length + '/6)</span>';
      this.style.borderColor = '#ffc107';
    } else if (this.value.length >= 6) {
      help.innerHTML = '<span class="text-success">✅ Contraseña válida</span>';
      this.style.borderColor = '#28a745';
    } else {
      help.innerHTML = 'Mínimo 6 caracteres';
      this.style.borderColor = '';
    }
  });
</script>


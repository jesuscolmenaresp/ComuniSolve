<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">
      
      <!-- Tarjeta principal -->
      <div class="card border-0 rounded-4 shadow-lg overflow-hidden success-card">
        
        <!-- Header con gradiente -->
        <div class="text-center py-4 px-3 success-header">
          <div class="mx-auto d-flex align-items-center justify-content-center mb-2">
            <div class="success-icon-wrapper">
              <i class="bi bi-check-lg fs-2 text-white"></i>
            </div>
          </div>
          <h3 class="mb-0 fw-bold success-title">¡Contraseña Actualizada!</h3>
          <p class="small mb-0 mt-1 success-subtitle">Tu contraseña ha sido restablecida exitosamente</p>
        </div>
        
        <!-- Body del card -->
        <div class="card-body p-4 p-lg-5 success-body text-center">
          
          <div class="mb-4">
            <i class="bi bi-check-circle-fill" style="font-size: 5rem; color: #28a745;"></i>
          </div>

          <h5 class="mb-3 fw-bold" style="color: #5D4037;">¡Restablecimiento exitoso!</h5>

          <p class="text-muted mb-4" style="font-size: 0.95rem;">
            <i class="bi bi-info-circle me-1"></i> 
            <%= mensaje || 'Tu contraseña ha sido cambiada correctamente. Ahora puedes iniciar sesión con tu nueva contraseña.' %>
          </p>

          <div class="d-grid gap-2">
            <a href="/login" class="btn py-2 fw-semibold rounded-3 btn-iniciar">
              <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar sesión
            </a>
          </div>

          <!-- Badges de seguridad -->
          <div class="d-flex justify-content-center gap-4 mt-4 pt-2">
            <small class="text-muted d-flex align-items-center gap-1 success-badge">
              <i class="bi bi-shield-check"></i> Contraseña segura
            </small>
            <small class="text-muted d-flex align-items-center gap-1 success-badge">
              <i class="bi bi-lock-fill"></i> Encriptación SSL
            </small>
          </div>

        </div>
      </div>
      
    </div>
  </div>
</div>

<style>
  /* ========== ESTILOS BASE (MODO CLARO) ========== */
  
  .success-card {
    background: #ffffff;
  }
  
  .success-header {
    background: linear-gradient(135deg, #d4edda 0%, #28a745 100%);
  }
  
  .success-icon-wrapper {
    width: 55px;
    height: 55px;
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(40, 167, 69, 0.4);
  }
  
  .success-title {
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
  }
  
  .success-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  .success-body {
    background: #ffffff;
  }
  
  .btn-iniciar {
    background: linear-gradient(135deg, #fd6704bd 0%, #f7931e 100%);
    border: none;
    color: white;
    transition: all 0.2s ease;
  }
  .btn-iniciar:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(253, 103, 4, 0.3);
  }
  
  .success-badge {
    color: #8B6B5A !important;
  }
  .success-badge i {
    color: #28a745;
  }
  
  /* ========== MODO NOCTURNO ========== */
  body.dark-mode .success-card {
    background: #27272a;
  }
  
  body.dark-mode .success-header {
    background: linear-gradient(135deg, #0d3b1f 0%, #28a745 100%);
  }
  
  body.dark-mode .success-icon-wrapper {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
  }
  
  body.dark-mode .success-title {
    color: white;
  }
  
  body.dark-mode .success-subtitle {
    color: rgba(255,255,255,0.9);
  }
  
  body.dark-mode .success-body {
    background: #27272a;
  }
  
  body.dark-mode .success-body h5 {
    color: #e4e4e7 !important;
  }
  
  body.dark-mode .success-body .text-muted {
    color: #a1a1aa !important;
  }
  
  body.dark-mode .success-badge {
    color: #a1a1aa !important;
  }
  body.dark-mode .success-badge i {
    color: #28a745;
  }
</style>